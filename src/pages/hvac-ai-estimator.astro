---
import LandingPageAds from '../components/LandingPageAds.astro';
import '../styles/global.css';

export const prerender = true;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HVAC Estimating Software | TradesQuote</title>
    <meta
      name="description"
      content="Stop doing HVAC estimates at 11pm. TradesQuote generates complete, line-item HVAC estimates in seconds — built on your price book. Push straight to Simpro or Jobber. Get started - Free 14 days Trial."
    />
    <link rel="canonical" href="https://www.tradesquote.ai/hvac-ai-estimator" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.tradesquote.ai/hvac-ai-estimator" />
    <meta property="og:title" content="HVAC Estimating Software | TradesQuote" />
    <meta
      property="og:description"
      content="Stop doing HVAC estimates at 11pm. Generate complete line-item estimates in seconds — then push to Simpro or Jobber with one click."
    />
    <meta property="og:image" content="https://www.tradesquote.ai/og-hvac.png" />
    <meta property="og:site_name" content="TradesQuote" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="HVAC Estimating Software | TradesQuote" />
    <meta
      name="twitter:description"
      content="Stop doing HVAC estimates at 11pm. Generate complete estimates in seconds — push to Simpro or Jobber."
    />
    <meta name="twitter:image" content="https://www.tradesquote.ai/og-hvac.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data: SoftwareApplication -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "TradesQuote",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web, iOS, Android",
        "description": "AI-powered HVAC estimating software. Generate complete, line-item estimates in seconds based on your price book, then push to Simpro or Jobber with one click.",
        "url": "https://tradesquote.ai",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "AUD",
          "description": "14-day free trial, no credit card required"
        },
        "featureList": [
          "AI-generated line-item HVAC estimates",
          "Custom price book integration",
          "Simpro integration",
          "Jobber integration",
          "Mobile-friendly"
        ]
      }
    </script>

    <!-- Structured Data: FAQPage -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Do I need to change my price book format?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No. We accept most common formats — Excel, CSV, or PDF exports from your existing system. Our team helps you set it up during onboarding at no extra cost."
            }
          },
          {
            "@type": "Question",
            "name": "Does TradesQuote work for service repairs, not just new installs?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. TradesQuote handles service repairs, maintenance agreements, and full installation quotes. Just describe the scope and the AI selects the right line items."
            }
          },
          {
            "@type": "Question",
            "name": "What if the estimate isn't quite right?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "You can edit any line before sending. The AI is your starting point — you're always in control of the final numbers before they leave your desk."
            }
          },
          {
            "@type": "Question",
            "name": "Is my pricing data secure?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Your price book and job data are encrypted at rest and in transit. We never share your pricing with other contractors or third parties."
            }
          }
        ]
      }
    </script>
  </head>

  <body class="antialiased bg-white text-gray-900 overflow-x-hidden" style="font-family: 'Inter', sans-serif;">
    <LandingPageAds />
  </body>
</html>
