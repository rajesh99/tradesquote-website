---
import Base from "../../layouts/Base.astro";
import { getSinglePage } from "../../lib/contentParser.astro";
import PostSingle from "../../layouts/partials/PostSingle.astro";

export async function getStaticPaths() {
  const BLOG_FOLDER = "posts";
  const posts = await getSinglePage(BLOG_FOLDER);

  const paths = posts.map((post) => ({
    params: {
      single: post.id,
    },
    props: { post },
  }));
  return paths;
}

const BLOG_FOLDER = "posts";
const slug = Astro.params.single;

let post = Astro.props?.post;
if (!post && slug) {
  const posts = await getSinglePage(BLOG_FOLDER);
  post = posts.find((p) => p.id === slug);
}

if (!post) {
  return new Response("Not found", { status: 404 });
}

const { title, meta_title, image, description } = post.data;
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  <PostSingle post={post} />
</Base>
