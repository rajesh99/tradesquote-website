---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const missionParagraphs = [
  "Ask any contractor how estimates actually get built, and the honest answer is rarely \"a system\" — it's memory, a gut-feel markup, and whatever pricing sheet is still open in a browser tab. The same person who wires a panel to code or gets a furnace running in freezing weather ends up handwriting a quote on a clipboard, or copy-pasting an old estimate and hoping the numbers still hold up. The work is expert. The paperwork often isn't — and the customer sees the paperwork first.",
  "TradesQuote exists to close that gap. Describe the job in plain language — the scope, the materials, the site conditions — and our AI turns it into a clean, professional, line-item estimate, so quotes go out fast and consistent instead of slow and improvised. It's not about replacing the expertise trades bring to a job; it's about making sure that expertise shows up in the quote as clearly as it shows up in the work.",
  "We build around how trades actually work, not how software companies think business should work — from HVAC-specific calculators and glossary tools that speak the industry's language, to estimates that plug straight into the accounting and job-management systems contractors already run on. Nobody should have to rip out their workflow just to get a faster quote out the door.",
];

const values = [
  {
    title: "Built for the trades, not adapted from generic software",
    description: "We're not repurposing generic small-business software and calling it trade-ready. Estimating for HVAC, plumbing, electrical, and similar trades has its own vocabulary, its own line items, and its own pace — TradesQuote is built around that from the ground up.",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94z"/></svg>`,
  },
  {
    title: "Speed shouldn't cost you accuracy",
    description: "A fast quote that's missing line items just creates a headache later. The goal isn't the fastest estimate — it's a fast estimate you'd still stand behind if the customer read it line by line.",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  },
  {
    title: "Fits into your business, not around it",
    description: "Nobody wants to learn a new system mid-job. TradesQuote connects with the tools you already use — Simpro, Jobber, QuickBooks, Xero, and Zapier — so estimating gets faster without adding another app to babysit.",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
  },
  {
    title: "Every quote is a first impression",
    description: "A clean, professional, line-item estimate tells a customer you run a tight operation before you've ever picked up a tool. We treat the quote itself as part of the craftsmanship.",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  },
];

const integrations = [
  { label: "Simpro", href: "/simpro-integration" },
  { label: "Jobber", href: "/getjobber-integration" },
  { label: "QuickBooks", href: "/quickbooks-integration" },
  { label: "Xero", href: "/xero-integration" },
  { label: "Zapier", href: "/zapier-integration" },
];
---

<Layout
  title="About — TradesQuote"
  description="TradesQuote uses AI to produce professional, line-item estimates for trades. Just describe the job — our AI handles the rest."
>
  <Header />

  <main>

    <!-- Hero -->
    <section class="w-full pt-20 pb-16 px-6 bg-white relative overflow-hidden">
      <div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-[radial-gradient(ellipse_at_center,rgba(99,102,241,0.07),transparent)] -z-10"></div>
      <div class="max-w-6xl mx-auto flex flex-col items-center text-center gap-4">
        <span class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-600 text-sm font-semibold tracking-wide uppercase">
          About TradesQuote
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 leading-tight tracking-tight max-w-2xl">
          Your work already looks professional. Your quotes should too.
        </h1>
        <p class="text-gray-500 text-lg leading-relaxed max-w-2xl">
          TradesQuote turns a plain description of the job into a clean, line-item estimate — so what lands in your customer's inbox looks as sharp as the work you do on site. No napkin math, no dusty spreadsheet, just a fast, professional quote.
        </p>
      </div>
    </section>

    <!-- Mission -->
    <section class="w-full py-16 sm:py-20 px-6 bg-gray-50">
      <div class="max-w-3xl mx-auto flex flex-col gap-6">
        {missionParagraphs.map((paragraph) => (
          <p class="text-gray-600 text-base sm:text-lg leading-relaxed">
            {paragraph}
          </p>
        ))}
      </div>
    </section>

    <!-- Values -->
    <section class="w-full py-16 sm:py-20 px-6 bg-white">
      <div class="max-w-6xl mx-auto flex flex-col gap-10">
        <div class="flex flex-col items-center gap-3 text-center max-w-2xl mx-auto">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight tracking-tight">
            What we believe
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {values.map((value) => (
            <div class="flex flex-col gap-4 p-6 rounded-2xl border border-gray-100 bg-gray-50 hover:bg-white hover:shadow-sm transition-all duration-150">
              <div class="shrink-0 w-10 h-10 rounded-xl bg-indigo-50 border border-indigo-100 flex items-center justify-center text-indigo-500">
                <Fragment set:html={value.icon} />
              </div>
              <div class="flex flex-col gap-1.5">
                <p class="text-sm font-bold text-gray-900">{value.title}</p>
                <p class="text-sm text-gray-500 leading-relaxed">{value.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Integrations -->
    <section class="w-full py-16 sm:py-20 px-6 bg-white border-t border-gray-100">
      <div class="max-w-6xl mx-auto flex flex-col items-center gap-8 text-center">
        <p class="text-gray-500 text-lg leading-relaxed max-w-2xl">
          TradesQuote is built to slot into your workflow, not replace it — it already connects with the software running your back office: Simpro, Jobber, QuickBooks, Xero, and Zapier.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          {integrations.map((integration) => (
            <a
              href={integration.href}
              class="inline-flex items-center px-4 py-2 rounded-full border border-gray-100 bg-gray-50 text-sm font-semibold text-gray-700 hover:text-indigo-600 hover:border-indigo-100 transition-colors duration-150"
            >
              {integration.label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="w-full py-20 sm:py-24 px-6 bg-gray-50 border-t border-gray-100">
      <div class="max-w-6xl mx-auto flex flex-col items-center gap-6 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight tracking-tight max-w-2xl">
          Give your next estimate the respect it deserves
        </h2>
        <p class="text-gray-500 text-lg leading-relaxed max-w-xl">
          Describe the job in plain language and let TradesQuote turn it into a professional, line-item estimate — line by line, no spreadsheet required.
        </p>
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <a
            href="https://app.tradesquote.ai/auth/sign-up"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-indigo-600 text-white text-sm font-semibold rounded-xl hover:bg-indigo-700 active:scale-[0.99] transition-all duration-150 shadow-lg shadow-indigo-500/20"
          >
            Get started
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/contact" class="text-sm font-semibold text-gray-600 hover:text-indigo-600 transition-colors duration-150">
            Talk to us
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />

</Layout>
