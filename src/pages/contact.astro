---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Part13 from '../components/Part13.astro';

export const prerender = false;

const env = (Astro.locals as App.Locals).runtime?.env;
// Use Cloudflare test site key as fallback for local dev without wrangler bindings
const turnstileSiteKey = env?.TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA';
---

<Layout
  title="Contact Us — TradesQuote"
  description="Get in touch with the TradesQuote team. We typically respond within 24 hours."
>
  <Header />

  <main>

    <!-- Hero -->
    <section class="w-full pt-20 pb-12 px-6 bg-white relative overflow-hidden">
      <div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-[radial-gradient(ellipse_at_center,rgba(99,102,241,0.07),transparent)] -z-10"></div>
      <div class="max-w-6xl mx-auto flex flex-col items-center text-center gap-4">
        <span class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-600 text-sm font-semibold tracking-wide uppercase">
          Contact us
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 leading-tight tracking-tight max-w-2xl">
          We'd love to hear from you
        </h1>
        <p class="text-gray-500 text-lg leading-relaxed max-w-lg">
          Have a question, idea, or just want to say hi? Fill in the form and
          we'll get back to you within 24 hours.
        </p>
      </div>
    </section>

    <!-- Main content: info cards + form -->
    <section class="w-full py-12 px-6 bg-white">
      <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">

        <!-- Left: info cards -->
        <aside class="lg:col-span-2 flex flex-col gap-6">

          <!-- Email -->
          <div class="flex items-start gap-4 p-6 rounded-2xl border border-gray-100 bg-gray-50 hover:bg-white hover:shadow-sm transition-all duration-200">
            <div class="shrink-0 w-10 h-10 rounded-xl bg-indigo-50 border border-indigo-100 flex items-center justify-center text-indigo-500">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div class="flex flex-col gap-1">
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Email us</p>
              <a href="mailto:sales@veersoftsolutions.com" class="text-sm font-semibold text-gray-900 hover:text-indigo-600 transition-colors duration-150">
                sales@veersoftsolutions.com
              </a>
              <p class="text-xs text-gray-400 leading-relaxed">We reply within 24 hours on business days.</p>
            </div>
          </div>

          <!-- Response time -->
          <div class="flex items-start gap-4 p-6 rounded-2xl border border-gray-100 bg-gray-50 hover:bg-white hover:shadow-sm transition-all duration-200">
            <div class="shrink-0 w-10 h-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-500">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div class="flex flex-col gap-1">
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Response time</p>
              <p class="text-sm font-semibold text-gray-900">Under 24 hours</p>
              <p class="text-xs text-gray-400 leading-relaxed">Monday – Friday, 9am – 6pm GMT.</p>
            </div>
          </div>

          <!-- Support -->
          <div class="flex items-start gap-4 p-6 rounded-2xl border border-gray-100 bg-gray-50 hover:bg-white hover:shadow-sm transition-all duration-200">
            <div class="shrink-0 w-10 h-10 rounded-xl bg-violet-50 border border-violet-100 flex items-center justify-center text-violet-500">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <div class="flex flex-col gap-1">
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">What to expect</p>
              <p class="text-sm font-semibold text-gray-900">Friendly, human support</p>
              <p class="text-xs text-gray-400 leading-relaxed">No bots. A real person from our team will read your message.</p>
            </div>
          </div>

          <!-- Divider -->
          <div class="h-px bg-gray-100"></div>

          <!-- What we can help with -->
          <div class="flex flex-col gap-4">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">We can help with</p>
            <ul class="flex flex-col gap-3">
              {[
                "General questions about TradesQuote",
                "Setting up Simpro integrations",
                "Billing and subscription queries",
                "Feature requests and feedback",
                "Partnership or agency enquiries",
              ].map((item) => (
                <li class="flex items-center gap-2.5 text-sm text-gray-600">
                  <span class="shrink-0 w-4 h-4 rounded-full bg-indigo-100 flex items-center justify-center">
                    <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

        </aside>

        <!-- Right: form -->
        <div class="lg:col-span-3">
          <div class="rounded-2xl border border-gray-100 bg-white shadow-sm overflow-hidden">

            <!-- Form header -->
            <div class="px-8 py-6 border-b border-gray-100 bg-gray-50/50 flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center shrink-0">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-bold text-gray-900">Send us a message</p>
                <p class="text-xs text-gray-400">All fields marked <span class="text-red-400">*</span> are required.</p>
              </div>
            </div>

            <!-- The form -->
            <form
              id="contact-form"
              class="px-8 py-8 flex flex-col gap-6"
              novalidate
            >
              <!-- Name + Email row -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

                <!-- Name -->
                <div class="flex flex-col gap-1.5">
                  <label for="name" class="text-sm font-semibold text-gray-700">
                    Full name <span class="text-red-400">*</span>
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    placeholder="Jane Smith"
                    autocomplete="name"
                    required
                    maxlength="100"
                    class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-white text-sm text-gray-900 placeholder-gray-400 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all duration-150"
                  />
                  <p class="field-error hidden text-xs text-red-500 mt-0.5" id="name-error"></p>
                </div>

                <!-- Email -->
                <div class="flex flex-col gap-1.5">
                  <label for="email" class="text-sm font-semibold text-gray-700">
                    Email address <span class="text-red-400">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="jane@company.com"
                    autocomplete="email"
                    required
                    maxlength="254"
                    class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-white text-sm text-gray-900 placeholder-gray-400 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all duration-150"
                  />
                  <p class="field-error hidden text-xs text-red-500 mt-0.5" id="email-error"></p>
                </div>

              </div>

              <!-- Phone -->
              <div class="flex flex-col gap-1.5">
                <label for="phone" class="text-sm font-semibold text-gray-700">
                  Phone number
                  <span class="ml-1 text-xs font-normal text-gray-400">(optional)</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="+1 (555) 000-0000"
                  autocomplete="tel"
                  maxlength="30"
                  class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-white text-sm text-gray-900 placeholder-gray-400 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all duration-150"
                />
              </div>

              <!-- Message -->
              <div class="flex flex-col gap-1.5">
                <div class="flex items-center justify-between">
                  <label for="message" class="text-sm font-semibold text-gray-700">
                    Message <span class="text-red-400">*</span>
                  </label>
                  <span id="char-count" class="text-xs text-gray-400">0 / 5000</span>
                </div>
                <textarea
                  id="message"
                  name="message"
                  placeholder="Tell us what's on your mind..."
                  required
                  maxlength="5000"
                  rows="5"
                  class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-white text-sm text-gray-900 placeholder-gray-400 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all duration-150 resize-none"
                ></textarea>
                <p class="field-error hidden text-xs text-red-500 mt-0.5" id="message-error"></p>
              </div>

              <!-- Turnstile widget -->
              <div class="flex flex-col gap-1.5">
                <div
                  class="cf-turnstile"
                  data-sitekey={turnstileSiteKey}
                  data-theme="light"
                  data-size="normal"
                ></div>
                <p id="turnstile-error" class="hidden text-xs text-red-500"></p>
              </div>

              <!-- Global error banner -->
              <div
                id="form-error"
                class="hidden items-center gap-3 px-4 py-3 rounded-xl bg-red-50 border border-red-100 text-sm text-red-600"
              >
                <svg class="shrink-0 w-4 h-4 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="12" y1="8" x2="12" y2="12"/>
                  <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span id="form-error-msg"></span>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                id="submit-btn"
                class="w-full inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-indigo-600 text-white text-sm font-semibold rounded-xl hover:bg-indigo-700 active:scale-[0.99] transition-all duration-150 shadow-lg shadow-indigo-500/20 disabled:opacity-60 disabled:cursor-not-allowed disabled:active:scale-100"
              >
                <!-- Default state -->
                <span id="btn-default" style="display:inline-flex;" class="items-center gap-2">
                  Send message
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="22" y1="2" x2="11" y2="13"/>
                    <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                  </svg>
                </span>
                <!-- Loading state -->
                <span id="btn-loading" style="display:none;" class="items-center gap-2">
                  <svg class="animate-spin w-4 h-4" viewBox="0 0 24 24" fill="none">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                  </svg>
                  Sending...
                </span>
              </button>


            </form>

          </div>
        </div>

      </div>
    </section>

    <!-- Success overlay (hidden by default) -->
    <div
      id="success-screen"
      class="hidden fixed inset-0 z-50 bg-white/95 backdrop-blur-sm flex items-center justify-center px-6"
    >
      <div class="flex flex-col items-center gap-6 text-center max-w-md">
        <!-- Animated check -->
        <div class="w-20 h-20 rounded-full bg-emerald-50 border-2 border-emerald-200 flex items-center justify-center">
          <svg class="w-10 h-10 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <div class="flex flex-col gap-2">
          <h2 class="text-2xl font-bold text-gray-900 tracking-tight">Message sent!</h2>
          <p class="text-gray-500 text-base leading-relaxed">
            Thanks for reaching out. We've received your message and will get
            back to you within 24 hours.
          </p>
        </div>
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-indigo-600 text-white text-sm font-semibold rounded-xl hover:bg-indigo-700 transition-colors duration-150"
        >
          Back to home
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

  </main>

  <Part13 />

  <!-- Cloudflare Turnstile script -->
  <script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>

  <!-- Form logic -->
  <script>
    const form       = document.getElementById('contact-form')    as HTMLFormElement;
    const submitBtn  = document.getElementById('submit-btn')      as HTMLButtonElement;
    const btnDefault = document.getElementById('btn-default')     as HTMLElement;
    const btnLoading = document.getElementById('btn-loading')     as HTMLElement;
    const formError  = document.getElementById('form-error')      as HTMLElement;
    const formErrMsg = document.getElementById('form-error-msg')  as HTMLElement;
    const successScreen = document.getElementById('success-screen') as HTMLElement;
    const charCount  = document.getElementById('char-count')      as HTMLElement;
    const messageEl  = document.getElementById('message')        as HTMLTextAreaElement;

    // ── Character counter ─────────────────────────────────────────────────
    messageEl?.addEventListener('input', () => {
      const len = messageEl.value.length;
      charCount.textContent = `${len} / 5000`;
      charCount.classList.toggle('text-red-500', len >= 4800);
      charCount.classList.toggle('text-gray-400', len < 4800);
    });

    // ── Inline field error helpers ────────────────────────────────────────
    function showFieldError(id: string, msg: string) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.classList.remove('hidden');
    }
    function clearFieldError(id: string) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }
    function clearAllErrors() {
      ['name-error', 'email-error', 'message-error', 'turnstile-error'].forEach(clearFieldError);
      formError.classList.add('hidden');
      formErrMsg.textContent = '';
    }

    // Clear errors on input
    document.getElementById('name')?.addEventListener('input', () => clearFieldError('name-error'));
    document.getElementById('email')?.addEventListener('input', () => clearFieldError('email-error'));
    messageEl?.addEventListener('input', () => clearFieldError('message-error'));

    // ── Set loading state ─────────────────────────────────────────────────
    function setLoading(loading: boolean) {
      submitBtn.disabled = loading;
      btnDefault.style.display = loading ? 'none' : 'inline-flex';
      btnLoading.style.display = loading ? 'inline-flex' : 'none';
    }

    // ── Show global error ─────────────────────────────────────────────────
    function showGlobalError(msg: string) {
      formErrMsg.textContent = msg;
      formError.classList.remove('hidden');
      formError.classList.add('flex');
      formError.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // ── Submit ────────────────────────────────────────────────────────────
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearAllErrors();

      const data = new FormData(form);
      const name    = (data.get('name')    as string)?.trim();
      const email   = (data.get('email')   as string)?.trim();
      const message = (data.get('message') as string)?.trim();
      const token   = data.get('cf-turnstile-response') as string;

      // Client-side validation
      let hasError = false;
      if (!name) {
        showFieldError('name-error', 'Please enter your name.');
        hasError = true;
      }
      if (!email) {
        showFieldError('email-error', 'Please enter your email address.');
        hasError = true;
      } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showFieldError('email-error', 'Please enter a valid email address.');
        hasError = true;
      }
      if (!message) {
        showFieldError('message-error', 'Please enter a message.');
        hasError = true;
      }
      // Only enforce Turnstile on the client if the widget actually loaded
      const turnstileWidget = document.querySelector('.cf-turnstile iframe');
      if (turnstileWidget && !token) {
        showFieldError('turnstile-error', 'Please complete the security check.');
        hasError = true;
      }
      if (hasError) return;

      setLoading(true);

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          body: data,
        });

        const json = await res.json() as { success: boolean; error?: string };

        if (!res.ok || !json.success) {
          showGlobalError(json.error ?? 'Something went wrong. Please try again.');
          // Reset Turnstile so user can retry
          if (typeof (window as any).turnstile !== 'undefined') {
            (window as any).turnstile.reset();
          }
          return;
        }

        // Show success overlay
        successScreen.classList.remove('hidden');
        successScreen.classList.add('flex');
        document.body.style.overflow = 'hidden';

      } catch {
        showGlobalError('Network error. Please check your connection and try again.');
        if (typeof (window as any).turnstile !== 'undefined') {
          (window as any).turnstile.reset();
        }
      } finally {
        setLoading(false);
      }
    });
  </script>

</Layout>
