---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import HvacRelatedCalculators from "@/components/HvacRelatedCalculators.astro";
import CalculatorBreadcrumb from "@/components/CalculatorBreadcrumb.astro";
import CalculatorFaqSection from "@/components/CalculatorFaqSection.astro";
import CalculatorTradesQuoteCta from "@/components/CalculatorTradesQuoteCta.astro";
import { buildFaqPageSchema, type CalculatorFaq } from "@/lib/calculatorFaq";

const title = "Target Superheat Calculator — Fixed-Orifice Charging Chart | TradesQuote";
const description =
  "Free target superheat calculator for fixed-orifice (piston) AC systems. Enter indoor wet-bulb and outdoor dry-bulb temperatures to get the chart target superheat for charging. Instant, no sign-up.";

const pageUrl = "https://tradesquote.ai/calculators/hvac/hvac-target-superheat-calculator";

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://tradesquote.ai/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://tradesquote.ai/calculators" },
    { "@type": "ListItem", position: 3, name: "HVAC", item: "https://tradesquote.ai/calculators/hvac" },
    { "@type": "ListItem", position: 4, name: "Target Superheat Calculator", item: pageUrl },
  ],
};

const webAppData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Target Superheat Calculator",
  url: pageUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (web-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description:
    "Free online target superheat calculator that finds the correct superheat target for a fixed-orifice (piston) air conditioner from indoor wet-bulb and outdoor dry-bulb temperatures, using the standard industry charging chart approximation.",
};

const faqs: CalculatorFaq[] = [
  {
    question: "What is target superheat?",
    answer:
      "Target superheat is the <strong>superheat you should charge a fixed-orifice (piston) system to</strong> at a given set of indoor and outdoor conditions. It comes from the manufacturer's charging chart — a table keyed to indoor wet-bulb and outdoor dry-bulb temperatures.",
  },
  {
    question: "What is the target superheat formula?",
    answer:
      "This calculator uses the common chart approximation: <strong>target superheat = ((3 × indoor wet-bulb °F) − 80 − outdoor dry-bulb °F) ÷ 2</strong>, clamped to 5–25°F. At 62°F WB and 85°F DB that gives 10.5°F.",
  },
  {
    question: "When do I use target superheat vs. subcooling?",
    answer:
      "Use <strong>target superheat for fixed-orifice (piston) metering devices</strong>. TXV systems are charged by subcooling at the condenser, not superheat at the evaporator. If you're not sure which device you have, check the indoor coil — a TXV has an external sensing bulb on the suction line.",
  },
  {
    question: "What wet-bulb and dry-bulb should I enter?",
    answer:
      "Enter the <strong>indoor wet-bulb</strong> (return-air moisture level — use a psychrometer or digital hygrometer with wet-bulb mode) and the <strong>outdoor dry-bulb</strong> (ambient air temperature at the condenser). Both readings should be stable with the system running.",
  },
  {
    question: "Why is the result clamped to 5–25°F?",
    answer:
      "Manufacturer charging charts typically cap targets between <strong>5°F and 25°F</strong>. Values outside that range usually mean the outdoor temperature is extreme or a probe reading is off — re-check before adding or removing refrigerant.",
  },
  {
    question: "Does target superheat work for heat pumps?",
    answer:
      "The same piston-metering logic applies in <strong>cooling mode</strong> on a heat pump with a fixed orifice. In heating mode, charge verification follows the heat-mode manufacturer chart — use the <a href=\"/calculators/hvac/hvac-heat-pump-calculator\" class=\"font-semibold text-amber-700 underline decoration-amber-300 hover:decoration-amber-600\">Heat Pump Sizing Calculator</a> to confirm system capacity first.",
  },
  {
    question: "How do I measure actual superheat?",
    answer:
      "Actual superheat = <strong>suction line temperature minus saturation temperature</strong> at the same pressure. Use the <a href=\"/calculators/hvac/hvac-superheat-calculator\" class=\"font-semibold text-amber-700 underline decoration-amber-300 hover:decoration-amber-600\">Superheat Calculator</a> to compare your measured value against this target.",
  },
];
const faqData = buildFaqPageSchema(faqs);

const ctaHeading = "Charge verified? Quote the service call in seconds.";
const ctaDescription =
  "A correct superheat reading proves the job is done right — TradesQuote turns the full service visit into a line-item quote: refrigerant, labor, materials, and any coil or line repairs, with quantities, unit prices, and totals validated by a built-in quality control agent.";

const relatedCalculators = [
  {
    href: "/calculators/hvac/hvac-superheat-calculator",
    title: "Superheat Calculator",
    description: "Measured superheat from suction line and saturation temps.",
  },
  {
    href: "/calculators/hvac/hvac-subcooling-calculator",
    title: "Subcooling Calculator",
    description: "TXV charging targets from liquid line readings.",
  },
  {
    href: "/calculators/hvac/hvac-delta-t-calculator",
    title: "Delta T Calculator",
    description: "Screen airflow and charge with temperature split.",
  },
  {
    href: "/calculators/hvac/hvac-btu-calculator",
    title: "BTU Calculator",
    description: "Right-size the cooling load.",
  },
];
---

<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Target Superheat Calculator — Fixed-Orifice Charging Chart" />
    <meta
      property="og:description"
      content="Find the target superheat for a piston-metered AC from indoor wet-bulb and outdoor dry-bulb temperatures. Free and instant."
    />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="TradesQuote" />
    <meta property="og:image" content="https://tradesquote.ai/logo.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Target Superheat Calculator — Fixed-Orifice Charging Chart" />
    <meta
      name="twitter:description"
      content="Target superheat for fixed-orifice AC from wet-bulb and dry-bulb temps. Free, no sign-up."
    />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  </Fragment>

  <div class="bg-white min-h-screen text-slate-700">
    <Header />

    <main>
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-6">
          <CalculatorBreadcrumb
            category="HVAC"
            categoryHref="/calculators/hvac"
            current="Target Superheat Calculator"
          />

          <div class="max-w-3xl">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"
                ></path>
              </svg>
              HVAC Tools · Charging · Free
            </span>

            <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
              Target Superheat Calculator <span class="text-amber-600">— Free Online Calculator</span>
            </h1>

            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              Fixed-orifice (piston) air conditioners are charged to a target superheat that changes with indoor
              humidity and outdoor temperature. Enter the indoor wet-bulb and outdoor dry-bulb readings and this
              tool returns the chart target — so you know exactly what superheat to aim for before adding or
              removing refrigerant.
            </p>

            <div class="mt-6 flex items-start gap-3 rounded-xl border border-amber-100 bg-amber-50 p-4">
              <svg
                class="h-5 w-5 shrink-0 text-amber-600 mt-0.5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
              <p class="text-sm text-slate-600">
                <span class="font-semibold text-slate-900">Have measured superheat already?</span>
                Compare it with the
                <a
                  href="/calculators/hvac/hvac-superheat-calculator"
                  class="font-semibold text-amber-700 underline decoration-amber-300 hover:decoration-amber-600"
                  >Superheat Calculator</a
                >
                — or screen airflow first with the
                <a
                  href="/calculators/hvac/hvac-delta-t-calculator"
                  class="font-semibold text-amber-700 underline decoration-amber-300 hover:decoration-amber-600"
                  >Delta T Calculator</a
                >.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="calculator" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12 pt-4">
        <div class="mx-auto max-w-5xl rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
              <svg
                class="h-5 w-5 text-amber-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M12 17h.01M9 14h.01M12 14h.01M15 14h.01M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"
                ></path>
              </svg>
              Enter wet-bulb and dry-bulb temperatures
            </h2>

          <div class="mt-6 lg:grid lg:grid-cols-2 lg:gap-8 lg:items-start">
          <div class="space-y-6">
<div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="tsh-wb" class="text-sm font-semibold text-slate-800"
                    >Indoor wet-bulb (°F)</label
                  >
                  <input
                    id="tsh-wb"
                    type="number"
                    min="50"
                    max="75"
                    step="0.5"
                    value="62"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">Return-air wet-bulb with system running</p>
                </div>

                <div>
                  <label for="tsh-db" class="text-sm font-semibold text-slate-800"
                    >Outdoor dry-bulb (°F)</label
                  >
                  <input
                    id="tsh-db"
                    type="number"
                    min="55"
                    max="115"
                    step="1"
                    value="85"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">Ambient at the condenser</p>
                </div>
              </div>

              <button
                id="resetBtn"
                type="button"
                class="text-sm font-medium text-slate-500 hover:text-amber-600 transition flex items-center gap-1.5"
              >
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                  ></path>
                </svg>
                Reset to defaults
              </button>
          </div>

          <!-- Results -->
          <div class="mt-6 lg:mt-0 rounded-xl border border-amber-100 bg-amber-50 p-5 sm:p-6">

              <p class="text-sm font-medium text-slate-600">Target superheat</p>
              <div class="mt-2 flex items-baseline gap-2">
                <span id="tsh-result" class="text-5xl font-extrabold tracking-tight text-amber-600">10.5°F</span>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-xl border border-amber-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Chart range</p>
                  <p id="tsh-range" class="mt-1 text-2xl font-bold text-slate-900">5–25°F</p>
                </div>
                <div class="rounded-xl border border-amber-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Metering type</p>
                  <p class="mt-1 text-2xl font-bold text-slate-900">Fixed orifice</p>
                </div>
              </div>

              <div class="mt-3 rounded-xl border border-amber-100 bg-white p-4">
                <p class="text-xs text-slate-500">Charging note</p>
                <p id="tsh-note" class="mt-1 text-sm font-medium leading-snug">
                  Charge a fixed-orifice (piston) system to this target superheat at the outdoor conditions
                  shown.
                </p>
              </div>

              <details class="group mt-5 rounded-xl border border-amber-100 bg-white">
                <summary
                  class="flex items-center justify-between cursor-pointer px-4 py-3 text-sm font-semibold text-slate-800"
                >
                  See the breakdown
                  <svg
                    class="h-4 w-4 text-slate-500 transition-transform group-open:rotate-180"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="px-4 pb-4 text-sm space-y-1.5 text-slate-600">
                  <div class="flex justify-between">
                    <span>Indoor wet-bulb</span><span id="tsh-bd-wb" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Outdoor dry-bulb</span><span id="tsh-bd-db" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div
                    class="flex justify-between border-t border-slate-200 pt-1.5 mt-1.5 text-slate-900"
                  >
                    <span class="font-bold text-slate-900">Formula</span><span id="tsh-bd-formula" class="font-bold text-right">—</span>
                  </div>
                </div>
              </details>

              <p class="mt-4 text-xs text-slate-500 leading-relaxed">
                Chart approximation only — always follow the manufacturer's charging chart for your refrigerant
                type and verify airflow before adjusting charge.
              </p>
            
          </div>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">Target superheat quick reference</h2>
          <p class="mt-2 text-sm text-slate-500">
            Common outdoor dry-bulb (85°F) at varying indoor wet-bulb readings.
          </p>
          <div class="mt-5 overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-500">
                  <th class="py-2.5 pr-4 font-semibold">Indoor wet-bulb</th>
                  <th class="py-2.5 pr-4 font-semibold">Outdoor dry-bulb</th>
                  <th class="py-2.5 font-semibold">Target superheat</th>
                </tr>
              </thead>
              <tbody class="text-slate-700">
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">58°F</td>
                  <td class="py-2.5 pr-4">85°F</td>
                  <td class="py-2.5">5°F (chart min)</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">62°F</td>
                  <td class="py-2.5 pr-4">85°F</td>
                  <td class="py-2.5 text-amber-700 font-semibold">10.5°F</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">64°F</td>
                  <td class="py-2.5 pr-4">85°F</td>
                  <td class="py-2.5">13.5°F</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">62°F</td>
                  <td class="py-2.5 pr-4">95°F</td>
                  <td class="py-2.5">5.5°F</td>
                </tr>
                <tr>
                  <td class="py-2.5 pr-4 font-semibold">64°F</td>
                  <td class="py-2.5 pr-4">75°F</td>
                  <td class="py-2.5">18.5°F</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-xs text-slate-500">
            Sources &amp; standards: HVAC School — superheat charging procedures · EPA Section 608 refrigerant
            handling · Manufacturer fixed-orifice charging charts (R-410A / R-22) · ACCA Manual S equipment
            selection.
          </p>
        </div>
      </section>

      <section class="bg-slate-50 border-y border-slate-200">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">
            The formula, explained in plain English
          </h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Manufacturer charging charts map indoor wet-bulb and outdoor dry-bulb to a target superheat. This
            calculator uses the standard linear approximation those charts follow.
          </p>

          <div
            class="mt-8 rounded-2xl bg-slate-900 p-6 sm:p-8 text-slate-100 font-mono text-sm leading-relaxed overflow-x-auto"
          >
            <div class="text-amber-300"># Target superheat (fixed orifice):</div>
            <div>
              target&nbsp;=&nbsp;((<span class="text-amber-300">3</span> × indoor WB °F) − <span
                class="text-amber-300">80</span
              > − outdoor DB °F) ÷ <span class="text-amber-300">2</span>
            </div>
            <div class="mt-4 text-amber-300"># Clamp to chart limits:</div>
            <div>result&nbsp;=&nbsp;min(25, max(5, target))&nbsp;&nbsp;<span class="text-slate-400">// 62 WB, 85 DB → 10.5°F</span></div>
            <div class="mt-4 text-amber-300"># Compare to measured:</div>
            <div>measured superheat&nbsp;=&nbsp;suction line temp − saturation temp at suction pressure</div>
          </div>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Why wet-bulb, not dry-bulb indoors?</h3>
              <p class="mt-2 text-sm text-slate-600">
                Indoor moisture load changes how much refrigerant the evaporator needs. Wet-bulb captures both
                temperature and humidity in one number the chart can use.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Fixed orifice only</h3>
              <p class="mt-2 text-sm text-slate-600">
                TXV systems self-regulate flow — charge them by subcooling at the condenser, not superheat at
                the evaporator.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Confirm airflow first</h3>
              <p class="mt-2 text-sm text-slate-600">
                Wrong airflow makes any superheat target meaningless. Check filter, blower speed, and static
                pressure before adjusting refrigerant.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Let the system stabilize</h3>
              <p class="mt-2 text-sm text-slate-600">
                Take readings after 10–15 minutes of continuous run time with a clean filter and all supply
                registers open.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Worked examples</h2>
        <p class="mt-4 text-slate-600">Three common field scenarios for piston-metered systems.</p>

        <div class="mt-8 space-y-6">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-amber-100 text-amber-700 font-bold"
                >1</span
              >
              <h3 class="text-lg font-bold text-slate-900">Typical summer day — 62°F WB, 85°F DB</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              ((3 × 62) − 80 − 85) ÷ 2 = <span class="font-bold text-amber-700">10.5°F</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> charge to 10.5°F superheat — a common
              mid-summer target for moderate humidity.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-amber-100 text-amber-700 font-bold"
                >2</span
              >
              <h3 class="text-lg font-bold text-slate-900">Hot afternoon — 64°F WB, 95°F DB</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              ((3 × 64) − 80 − 95) ÷ 2 = <span class="font-bold text-amber-700">5.5°F</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> high outdoor temperature drives the
              target down — expect a lower superheat on very hot days.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-amber-100 text-amber-700 font-bold"
                >3</span
              >
              <h3 class="text-lg font-bold text-slate-900">Mild day — 64°F WB, 75°F DB</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              ((3 × 64) − 80 − 75) ÷ 2 = <span class="font-bold text-amber-700">18.5°F</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> cooler outdoor air raises the target —
              don't chase a low superheat number on a mild day.
            </p>
          </div>
        </div>
      </section>

      <CalculatorFaqSection
        faqs={faqs}
        accent="amber"
        subtitle="Common questions about target superheat and fixed-orifice charging."
      />

      <CalculatorTradesQuoteCta heading={ctaHeading} description={ctaDescription} />

      <HvacRelatedCalculators calculators={relatedCalculators} accent="amber" />
    </main>

