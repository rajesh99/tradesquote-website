---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import HvacRelatedCalculators from "@/components/HvacRelatedCalculators.astro";
import CalculatorBreadcrumb from "@/components/CalculatorBreadcrumb.astro";
import CalculatorFaqSection from "@/components/CalculatorFaqSection.astro";
import CalculatorTradesQuoteCta from "@/components/CalculatorTradesQuoteCta.astro";
import { buildFaqPageSchema, type CalculatorFaq } from "@/lib/calculatorFaq";

const title = "Delta T Calculator — HVAC Temperature Split (AC & Furnace) | TradesQuote";
const description =
  "Free HVAC Delta T calculator. Check your air conditioner's temperature split (return minus supply, normally 16–22°F) or furnace temperature rise, and what a high or low reading means. Instant, no sign-up.";

const pageUrl = "https://tradesquote.ai/calculators/hvac/hvac-delta-t-calculator";

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://tradesquote.ai/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://tradesquote.ai/calculators" },
    { "@type": "ListItem", position: 3, name: "HVAC", item: "https://tradesquote.ai/calculators/hvac" },
    { "@type": "ListItem", position: 4, name: "Delta T Calculator", item: pageUrl },
  ],
};

const webAppData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "HVAC Delta T Calculator",
  url: pageUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (web-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description:
    "Free online HVAC Delta T calculator that checks an air conditioner's temperature split (return minus supply air) or a furnace's temperature rise, shows whether the reading is in the healthy range, and explains the most likely causes when it isn't.",
};

const faqs: CalculatorFaq[] = [
  {
    question: "What is a good Delta T for an AC?",
    answer:
      "A healthy cooling temperature split is <strong>16–22°F</strong> between return and supply air, with ~18–20°F typical at average humidity. Outside that range points to an airflow or refrigerant problem.",
  },
  {
    question: "What does a high Delta T mean?",
    answer:
      "Above ~22°F in cooling almost always means <strong>restricted airflow</strong> — dirty filter, closed/blocked vents, undersized or leaky ducts, or blower speed set too low. Air moves too slowly and gets overcooled.",
  },
  {
    question: "What does a low Delta T mean?",
    answer:
      "Below ~16°F means the coil isn't removing enough heat: <strong>low refrigerant/leak</strong>, a dirty evaporator coil, or too much airflow. It can also be normal briefly right after start-up.",
  },
  {
    question: "Does humidity affect Delta T?",
    answer:
      "Yes. In humid air more of the system's capacity goes to removing moisture (latent heat), so the measured split runs lower — <strong>15–18°F can be perfectly normal at high indoor humidity</strong>.",
  },
  {
    question: "What is a normal furnace temperature rise?",
    answer:
      "Most furnaces specify a rise of <strong>40–70°F</strong> between return and supply, listed on the nameplate. Too high means airflow is restricted (overheating risk); too low means too much airflow or too little heat.",
  },
  {
    question: "Can I charge refrigerant using Delta T?",
    answer:
      "No. Delta T is a screening check. Set and verify charge with <strong>superheat (fixed-orifice) or subcooling (TXV)</strong> and confirm airflow per the manufacturer — split alone can't tell you the exact charge.",
  },
];
const faqData = buildFaqPageSchema(faqs);

const ctaHeading = "Diagnosed the system? Quote the fix in seconds.";
const ctaDescription =
  "A BTU number tells you the equipment size — TradesQuote turns the whole job into a detailed, line-item estimate in seconds. Describe the work or upload photos, and our AI builds quantities, unit prices, and totals, validated by a built-in quality control agent.";

const relatedCalculators = [
  {
    href: "/calculators/hvac/hvac-static-pressure-calculator",
    title: "Static Pressure Calculator",
    description: "Diagnose the airflow restriction behind a high split.",
  },
  {
    href: "/calculators/hvac/hvac-cfm-calculator",
    title: "CFM / Airflow Calculator",
    description: "Target airflow per room and per ton.",
  },
  {
    href: "/calculators/hvac/hvac-btu-calculator",
    title: "BTU Calculator",
    description: "Right-size the cooling load.",
  },
  {
    href: "/calculators/hvac/hvac-seer-savings-calculator",
    title: "SEER Savings Calculator",
    description: "Compare efficiency and running cost.",
  },
];
---

<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Delta T Calculator — HVAC Temperature Split (AC & Furnace)" />
    <meta
      property="og:description"
      content="Check your AC temperature split or furnace temperature rise and what a high or low reading means. Free and instant."
    />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="TradesQuote" />
    <meta property="og:image" content="https://tradesquote.ai/logo.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Delta T Calculator — HVAC Temperature Split (AC & Furnace)" />
    <meta
      name="twitter:description"
      content="Check your AC temperature split or furnace temperature rise. Free, instant, no sign-up."
    />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  </Fragment>

  <div class="bg-white min-h-screen text-slate-700">
    <Header />

    <main>
      <!-- ============================ HERO + H1 + INTRO ============================ -->
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-6">
          <CalculatorBreadcrumb category="HVAC" categoryHref="/calculators/hvac" current="Delta T Calculator" />

          <div class="max-w-3xl">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-purple-100 px-3 py-1 text-xs font-semibold text-purple-700"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"
                ></path>
              </svg>
              HVAC Tools · Diagnostics · Free
            </span>

            <!-- (1) H1 -->
            <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
              Delta T Calculator <span class="text-purple-600">— Free Online Calculator</span>
            </h1>

            <!-- (2) What this calculates — 2 sentences -->
            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              Delta T — the temperature split across the coil — is the fastest first check of whether an HVAC
              system is moving and conditioning air properly. Enter the return and supply air temperatures and
              this tool gives your split, whether it's in the healthy range, and the most likely causes when it
              isn't.
            </p>
          </div>
        </div>
      </section>

      <!-- ============================ (3) THE INTERACTIVE CALCULATOR ============================ -->
      <section id="calculator" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12">
        <div class="grid lg:grid-cols-5 gap-6">
          <!-- Inputs -->
          <div class="lg:col-span-3 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
            <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
              <svg
                class="h-5 w-5 text-purple-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M12 17h.01M9 14h.01M12 14h.01M15 14h.01M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"
                ></path>
              </svg>
              Enter your air temperatures
            </h2>

            <div class="mt-6 space-y-6">
              <div>
                <label for="dt-mode" class="text-sm font-semibold text-slate-800">Mode</label>
                <select
                  id="dt-mode"
                  class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 outline-none"
                >
                  <option value="cooling" selected>Cooling (AC) — temperature split</option>
                  <option value="heating">Heating (furnace) — temperature rise</option>
                </select>
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="dt-return" class="text-sm font-semibold text-slate-800">Return air temp (°F)</label>
                  <input
                    id="dt-return"
                    type="number"
                    min="0"
                    max="200"
                    value="75"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 outline-none"
                  />
                </div>

                <div>
                  <label for="dt-supply" class="text-sm font-semibold text-slate-800">Supply air temp (°F)</label>
                  <input
                    id="dt-supply"
                    type="number"
                    min="0"
                    max="250"
                    value="56"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 outline-none"
                  />
                </div>

                <div class="sm:col-span-2">
                  <label for="dt-rh" class="text-sm font-semibold text-slate-800"
                    >Indoor humidity (cooling only)</label
                  >
                  <select
                    id="dt-rh"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 outline-none"
                  >
                    <option value="low">Dry (under 40% RH)</option>
                    <option value="normal" selected>Average (40–50% RH)</option>
                    <option value="high">Humid (over 50% RH)</option>
                  </select>
                </div>
              </div>

              <button
                id="resetBtn"
                type="button"
                class="text-sm font-medium text-slate-500 hover:text-purple-600 transition flex items-center gap-1.5"
              >
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                  ></path>
                </svg>
                Reset to defaults
              </button>
            </div>
          </div>

          <!-- Results -->
          <div class="lg:col-span-2">
            <div
              class="lg:sticky lg:top-24 rounded-2xl bg-gradient-to-br from-purple-600 to-indigo-500 p-6 sm:p-8 text-white shadow-lg"
            >
              <p id="dt-label" class="text-sm font-medium text-purple-100">Temperature split</p>
              <div class="mt-2 flex items-baseline gap-2">
                <span id="dt-result" class="text-5xl font-extrabold tracking-tight">19°F</span>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-xl bg-white/15 p-4">
                  <p class="text-xs text-purple-100">Reading</p>
                  <p id="dt-status" class="mt-1 text-2xl font-bold">Healthy</p>
                </div>
                <div class="rounded-xl bg-white/15 p-4">
                  <p class="text-xs text-purple-100">Ideal target</p>
                  <p id="dt-target" class="mt-1 text-2xl font-bold">18–20°F</p>
                </div>
              </div>

              <div class="mt-3 rounded-xl bg-white/15 p-4">
                <p class="text-xs text-purple-100">Likely causes</p>
                <p id="dt-causes" class="mt-1 text-sm font-medium leading-snug">
                  A 16–22°F split with average humidity means good airflow and a proper refrigerant charge — no
                  action needed.
                </p>
              </div>

              <!-- Breakdown -->
              <details class="group mt-5 rounded-xl bg-white/10">
                <summary
                  class="flex items-center justify-between cursor-pointer px-4 py-3 text-sm font-semibold"
                >
                  See the breakdown
                  <svg
                    class="h-4 w-4 transition-transform group-open:rotate-180"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="px-4 pb-4 text-sm space-y-1.5 text-purple-50">
                  <div class="flex justify-between">
                    <span>Return air</span><span id="dt-bd-return" class="font-semibold">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Supply air</span><span id="dt-bd-supply" class="font-semibold">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Difference</span><span id="dt-bd-diff" class="font-semibold">—</span>
                  </div>
                  <div
                    class="flex justify-between border-t border-white/20 pt-1.5 mt-1.5 text-white"
                  >
                    <span class="font-bold">Healthy range</span><span id="dt-bd-range" class="font-bold">—</span>
                  </div>
                </div>
              </details>

              <p class="mt-4 text-xs text-purple-100 leading-relaxed">
                A split is a screening check, not a charging method. Verify charge by superheat/subcooling and
                airflow per manufacturer specs.
              </p>
            </div>
          </div>
        </div>

        <!-- Reference table -->
        <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">What your reading means</h2>
          <p class="mt-2 text-sm text-slate-500">
            Cooling mode, average indoor humidity. Targets shift with humidity and altitude.
          </p>
          <div class="mt-5 overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-500">
                  <th class="py-2.5 pr-4 font-semibold">Temperature split</th>
                  <th class="py-2.5 pr-4 font-semibold">Reading</th>
                  <th class="py-2.5 font-semibold">Most likely cause</th>
                </tr>
              </thead>
              <tbody class="text-slate-700">
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Under 14°F</td>
                  <td class="py-2.5 pr-4">Low</td>
                  <td class="py-2.5">Low refrigerant/leak, dirty coil, or too much airflow</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">14–16°F</td>
                  <td class="py-2.5 pr-4">Low-normal</td>
                  <td class="py-2.5">Often OK in humid conditions; verify charge</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">16–22°F</td>
                  <td class="py-2.5 pr-4 text-purple-700 font-semibold">Healthy</td>
                  <td class="py-2.5">Good airflow and charge</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">22–25°F</td>
                  <td class="py-2.5 pr-4">High</td>
                  <td class="py-2.5">Restricted airflow — filter, vents, ducts, low blower speed</td>
                </tr>
                <tr>
                  <td class="py-2.5 pr-4 font-semibold">Over 25°F</td>
                  <td class="py-2.5 pr-4">Very high</td>
                  <td class="py-2.5">Severe airflow restriction — do not ignore</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-xs text-slate-500">
            Sources &amp; standards: HVAC School —
            <a
              href="https://hvacrschool.com/20-delta-t-a-lazy-rule-of-thumb/"
              class="underline hover:text-purple-600"
              target="_blank"
              rel="noopener">"20° ΔT, A Lazy Rule of Thumb"</a
            > · ENERGY STAR — HVAC Quality Installation (airflow &amp; charge verification) · Furnace temperature
            rise per equipment nameplate / AHRI.
          </p>
        </div>
      </section>

      <!-- ============================ (4) FORMULA EXPLAINED ============================ -->
      <section class="bg-slate-50 border-y border-slate-200">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">
            The formula, explained in plain English
          </h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Delta T is just the temperature difference the system creates between the air going in and the air
            coming out. Which way you subtract depends on whether you're cooling or heating.
          </p>

          <div
            class="mt-8 rounded-2xl bg-slate-900 p-6 sm:p-8 text-slate-100 font-mono text-sm leading-relaxed overflow-x-auto"
          >
            <div class="text-purple-300"># Cooling (AC) split:</div>
            <div>ΔT&nbsp;=&nbsp;return air °F − supply air °F&nbsp;&nbsp;&nbsp;→ healthy <span class="text-amber-300">16–22°F</span></div>
            <div class="mt-4 text-purple-300"># Heating (furnace) rise:</div>
            <div>ΔT&nbsp;=&nbsp;supply air °F − return air °F&nbsp;&nbsp;&nbsp;→ healthy <span class="text-amber-300">40–70°F</span> (nameplate)</div>
            <div class="mt-4 text-purple-300"># Read it:</div>
            <div>too HIGH = restricted airflow · too LOW = charge/heat problem or too much airflow</div>
          </div>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">What Delta T tells you</h3>
              <p class="mt-2 text-sm text-slate-600">
                How much heat the coil is adding or removing as air passes through — a quick health check on
                airflow and capacity together.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Where to measure</h3>
              <p class="mt-2 text-sm text-slate-600">
                Return a few feet before the coil, supply a few feet after — away from line-of-sight to the coil
                so radiant heat doesn't skew the probe.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Humidity shifts the target</h3>
              <p class="mt-2 text-sm text-slate-600">
                In humid air more energy goes to removing moisture, so the cooling split runs lower — 15–18°F can
                be normal at high RH.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Not a charging method</h3>
              <p class="mt-2 text-sm text-slate-600">
                Confirm refrigerant charge with superheat or subcooling, not split alone — Delta T only flags
                that something is off.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================ (5) WORKED EXAMPLES ============================ -->
      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Worked examples</h2>
        <p class="mt-4 text-slate-600">
          Three readings showing a healthy split, a classic high-split fault, and a furnace in heating mode.
        </p>

        <div class="mt-8 space-y-6">
          <!-- Example 1 -->
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-purple-100 text-purple-700 font-bold"
                >1</span
              >
              <h3 class="text-lg font-bold text-slate-900">Healthy AC — 75°F return, 56°F supply</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              75 − 56 = <span class="font-bold text-purple-700">19°F → Healthy</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> a 19°F split sits right in the 16–22°F band — good airflow and a proper charge.
            </p>
          </div>

          <!-- Example 2 -->
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-purple-100 text-purple-700 font-bold"
                >2</span
              >
              <h3 class="text-lg font-bold text-slate-900">Dirty filter — 76°F return, 51°F supply</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              76 − 51 = <span class="font-bold text-purple-700">25°F → High split</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> restricted airflow is overcooling slow-moving air. Change the filter and re-check.
            </p>
          </div>

          <!-- Example 3 -->
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-purple-100 text-purple-700 font-bold"
                >3</span
              >
              <h3 class="text-lg font-bold text-slate-900">Furnace rise — 130°F supply, 68°F return (heating mode)</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              130 − 68 = <span class="font-bold text-purple-700">62°F → Healthy</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> a 62°F rise is within the typical 40–70°F nameplate range — airflow and firing are well matched.
            </p>
          </div>
        </div>
      </section>

      <CalculatorFaqSection
        faqs={faqs}
        accent="violet"
        subtitle="Common questions about HVAC temperature split and furnace rise."
      />

      <CalculatorTradesQuoteCta heading={ctaHeading} description={ctaDescription} />

      <HvacRelatedCalculators calculators={relatedCalculators} accent="violet" />
    </main>

    <Footer />
  </div>

  <script>
