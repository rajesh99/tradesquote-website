---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import HvacRelatedCalculators from "@/components/HvacRelatedCalculators.astro";
import CalculatorBreadcrumb from "@/components/CalculatorBreadcrumb.astro";
import CalculatorFaqSection from "@/components/CalculatorFaqSection.astro";
import CalculatorTradesQuoteCta from "@/components/CalculatorTradesQuoteCta.astro";
import { buildFaqPageSchema, type CalculatorFaq } from "@/lib/calculatorFaq";

const title = "Combustion Efficiency Calculator — Boiler Stack Loss & Siegert Formula | TradesQuote";
const description =
  "Free boiler combustion efficiency calculator using the Siegert formula. Enter flue gas temperature, combustion air temperature, and flue oxygen (O₂%) to get stack loss percentage, net efficiency, and excess air. Instant, no sign-up.";

const pageUrl = "https://www.tradesquote.ai/calculators/hvac/hvac-combustion-efficiency-calculator";

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://www.tradesquote.ai/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://www.tradesquote.ai/calculators" },
    { "@type": "ListItem", position: 3, name: "HVAC", item: "https://www.tradesquote.ai/calculators/hvac" },
    { "@type": "ListItem", position: 4, name: "Combustion Efficiency Calculator", item: pageUrl },
  ],
};

const webAppData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Combustion Efficiency Calculator",
  url: pageUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (web-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description:
    "Free online boiler combustion efficiency calculator using the Siegert formula. Calculates sensible stack heat loss, net combustion efficiency, and excess air percentage from flue gas temperature, air temperature, and flue oxygen readings.",
};

const faqs: CalculatorFaq[] = [
  {
    question: "What is boiler combustion efficiency?",
    answer:
      "Combustion efficiency measures how completely a boiler converts fuel into usable heat. It is the percentage of the fuel's heat content that ends up in the building's heating system, after subtracting sensible stack losses, latent water-vapour losses, and casing radiation. A well-tuned natural-gas boiler typically achieves <strong>80–92%</strong> combustion efficiency, with condensing boilers exceeding 90% when the flue temperature is below the dew point.",
  },
  {
    question: "What is the Siegert formula?",
    answer:
      "The Siegert formula calculates sensible stack heat loss — the heat wasted by hot flue gas escaping up the chimney — from three measurable field quantities: flue gas temperature, combustion air temperature, and flue oxygen percentage. Developed by Karl Siegert in the 1930s, it remains the basis for all portable flue-gas analyser efficiency readings.",
  },
  {
    question: "What is a good flue gas oxygen percentage?",
    answer:
      "For natural gas, <strong>3–5% O₂</strong> represents a well-adjusted burner with adequate excess air to prevent CO formation but low enough to limit stack losses. Below 1.5% O₂ there is a risk of carbon monoxide; above 8% O₂ there is excessive dilution air that carries heat up the flue.",
  },
  {
    question: "Why does stack temperature matter?",
    answer:
      "Stack gas temperature is the single biggest driver of stack heat loss. Every 10°C reduction in flue temperature saves roughly 0.4–0.5% in stack losses. Elevated stack temperatures above <strong>250°C</strong> typically indicate fouled heat-transfer surfaces, scale on waterside heat exchangers, or insufficient combustion gas baffling.",
  },
  {
    question: "What is excess air in combustion?",
    answer:
      "Excess air is the percentage of air supplied above the stoichiometric minimum needed for complete combustion. It is calculated from flue O₂ as: <em>excess air (%) = O₂ / (21 − O₂) × 100</em>. Typical targets are <strong>10–20% excess air</strong> (3–4% O₂) for gas boilers; higher excess air increases stack losses.",
  },
  {
    question: "How is combustion efficiency different from seasonal efficiency (AFUE)?",
    answer:
      "Combustion efficiency is a real-time, point-in-time measurement under steady operating conditions. AFUE (Annual Fuel Utilization Efficiency) is a laboratory-rated seasonal figure that also accounts for pilot losses, cyclic start/stop losses, and jacket losses over a whole heating season. A boiler can have <strong>82% combustion efficiency</strong> at steady state but a lower AFUE once cycling losses are included.",
  },
];
const faqData = buildFaqPageSchema(faqs);

const ctaHeading = "Measured efficiency. Now quote the upgrade.";
const ctaDescription =
  "A combustion efficiency reading tells you whether the boiler needs tuning or replacement — TradesQuote turns the scope of work into a detailed, line-item estimate in seconds. Describe the job or upload photos, and our AI builds quantities, unit prices, and totals, validated by a built-in quality control agent.";

const relatedCalculators = [
  {
    href: "/calculators/hvac/hvac-afue-savings-calculator",
    title: "AFUE Savings Calculator",
    description: "Compare furnace efficiency ratings and 15-year fuel savings.",
  },
  {
    href: "/calculators/hvac/hvac-operating-cost-calculator",
    title: "Operating Cost Calculator",
    description: "Annual fuel cost from efficiency, runtime, and energy price.",
  },
  {
    href: "/calculators/hvac/hvac-replacement-cost-calculator",
    title: "Replacement Cost Calculator",
    description: "Installed cost range for a new high-efficiency boiler or furnace.",
  },
  {
    href: "/calculators/hvac/hvac-duct-friction-rate-calculator",
    title: "Duct Friction Rate Calculator",
    description: "Manual D friction rate for correct duct sizing.",
  },
];
---

<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Combustion Efficiency Calculator — Boiler Stack Loss & Siegert Formula" />
    <meta
      property="og:description"
      content="Free boiler combustion efficiency calculator using the Siegert formula. Enter flue gas temp, air temp, and O₂% for instant stack loss and net efficiency."
    />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="TradesQuote" />
    <meta property="og:image" content="https://www.tradesquote.ai/logo.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Combustion Efficiency Calculator — Boiler Stack Loss & Siegert Formula" />
    <meta
      name="twitter:description"
      content="Instant boiler combustion efficiency from flue gas temperature, air temperature, and O₂%. Free, no sign-up."
    />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  </Fragment>

  <div class="bg-white min-h-screen text-slate-700">
    <Header />

    <main>
      <!-- ============================ HERO + H1 + INTRO ============================ -->
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-6">
          <CalculatorBreadcrumb category="HVAC" categoryHref="/calculators/hvac" current="Combustion Efficiency Calculator" />

          <div class="max-w-3xl">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-orange-100 px-3 py-1 text-xs font-semibold text-orange-600"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"
                ></path>
              </svg>
              HVAC Tools · Combustion · Free
            </span>

            <!-- H1 -->
            <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
              Combustion Efficiency Calculator <span class="text-orange-600">— Free Online Calculator</span>
            </h1>

            <!-- Intro paragraph -->
            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              The Siegert formula converts three field measurements — flue gas temperature, combustion air
              temperature, and flue oxygen — into the sensible stack heat loss percentage and net combustion
              efficiency of any gas, propane, or oil-fired boiler. Enter the readings below for an instant
              efficiency result with excess-air and safety flags.
            </p>
          </div>
        </div>
      </section>

      <!-- ============================ THE INTERACTIVE CALCULATOR ============================ -->
      <section id="calculator" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12">
        <div class="mx-auto max-w-5xl rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
              <svg
                class="h-5 w-5 text-orange-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M12 17h.01M9 14h.01M12 14h.01M15 14h.01M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"
                ></path>
              </svg>
              Enter flue gas readings
            </h2>

          <div class="mt-6 lg:grid lg:grid-cols-2 lg:gap-8 lg:items-start">
          <div class="space-y-6">
<div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="ce-fuel" class="text-sm font-semibold text-slate-800">Fuel type</label>
                  <select
                    id="ce-fuel"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none"
                  >
                    <option value="naturalGas" selected>Natural Gas (CH₄)</option>
                    <option value="propane">Propane (LPG / C₃H₈)</option>
                    <option value="fuelOil">No. 2 Fuel Oil</option>
                  </select>
                </div>

                <div>
                  <label for="ce-temp-unit" class="text-sm font-semibold text-slate-800">Temperature unit</label>
                  <select
                    id="ce-temp-unit"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none"
                  >
                    <option value="C" selected>Celsius (°C)</option>
                    <option value="F">Fahrenheit (°F)</option>
                  </select>
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="ce-flue-temp" class="text-sm font-semibold text-slate-800">Flue gas temperature</label>
                  <input
                    id="ce-flue-temp"
                    type="number"
                    value="180"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none"
                  />
                </div>

                <div>
                  <label for="ce-air-temp" class="text-sm font-semibold text-slate-800">Combustion air temperature</label>
                  <input
                    id="ce-air-temp"
                    type="number"
                    value="20"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none"
                  />
                </div>
              </div>

              <div>
                <label for="ce-o2" class="text-sm font-semibold text-slate-800">Flue O₂ (dry basis) (%)</label>
                <input
                  id="ce-o2"
                  type="number"
                  min="0"
                  max="20.9"
                  step="0.1"
                  value="4"
                  class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none"
                />
              </div>

              <button
                id="ce-reset"
                type="button"
                class="text-sm font-medium text-slate-500 hover:text-orange-600 transition flex items-center gap-1.5"
              >
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                  ></path>
                </svg>
                Reset to defaults
              </button>
          </div>

          <!-- Results -->
          <div class="mt-6 lg:mt-0 rounded-xl border border-orange-100 bg-orange-50 p-5 sm:p-6">

              <p class="text-sm font-medium text-slate-600">Net Efficiency</p>
              <div class="mt-2 flex items-baseline gap-2">
                <span id="ce-result-efficiency" class="text-5xl font-extrabold tracking-tight text-orange-600">—</span>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-xl border border-orange-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Stack Loss</p>
                  <p id="ce-result-qa" class="mt-1 text-2xl font-bold text-slate-900">—</p>
                </div>
                <div class="rounded-xl border border-orange-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Excess Air</p>
                  <p id="ce-result-excess-air" class="mt-1 text-2xl font-bold text-slate-900">—</p>
                </div>
              </div>

              <!-- Breakdown -->
              <details class="group mt-5 rounded-xl border border-orange-100 bg-white">
                <summary
                  class="flex items-center justify-between cursor-pointer px-4 py-3 text-sm font-semibold text-slate-800"
                >
                  See the breakdown
                  <svg
                    class="h-4 w-4 text-slate-500 transition-transform group-open:rotate-180"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="px-4 pb-4 text-sm space-y-1.5 text-slate-600">
                  <div class="flex justify-between">
                    <span>Flue gas temp</span><span id="ce-bd-flue" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Air temp</span><span id="ce-bd-air" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Stack loss qA</span><span id="ce-bd-qa" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Latent loss</span><span id="ce-bd-latent" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between border-t border-slate-200 pt-1.5 mt-1.5 text-slate-900">
                    <span class="font-bold text-slate-900">Radiation loss</span><span id="ce-bd-rad" class="font-bold text-slate-900">—</span>
                  </div>
                </div>
              </details>

              <!-- Warning box -->
              <div
                id="ce-warning"
                class="hidden mt-4 rounded-xl bg-yellow-400/20 border border-yellow-300/40 p-4"
              >
                <p class="text-xs font-bold text-yellow-200 uppercase tracking-wide mb-1">Warning</p>
                <p id="ce-warning-text" class="text-sm font-medium text-slate-600 leading-snug"></p>
              </div>

              <p class="mt-4 text-xs text-slate-500 leading-relaxed">
                Results use the simplified Siegert method. Radiation and convection losses are estimated at 1.5%.
                For certification, use a calibrated flue gas analyser per EN 15502.
              </p>
            
          </div>
          </div>
        </div>

        <!-- Reference table -->
        <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">Boiler efficiency benchmark</h2>
          <div class="mt-5 overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-500">
                  <th class="py-2.5 pr-4 font-semibold">Net Efficiency</th>
                  <th class="py-2.5 pr-4 font-semibold">Rating</th>
                  <th class="py-2.5 font-semibold">Typical system</th>
                </tr>
              </thead>
              <tbody class="text-slate-700">
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Under 75%</td>
                  <td class="py-2.5 pr-4">Poor</td>
                  <td class="py-2.5">Old cast-iron boiler, no maintenance</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">75–80%</td>
                  <td class="py-2.5 pr-4">Fair</td>
                  <td class="py-2.5">Standard-efficiency pre-1990s boiler</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">80–85%</td>
                  <td class="py-2.5 pr-4">Good</td>
                  <td class="py-2.5">Mid-efficiency gas boiler</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">85–90%</td>
                  <td class="py-2.5 pr-4">Very Good</td>
                  <td class="py-2.5">High-efficiency condensing boiler (non-condensing mode)</td>
                </tr>
                <tr>
                  <td class="py-2.5 pr-4 font-semibold">90%+</td>
                  <td class="py-2.5 pr-4 text-orange-600 font-semibold">Excellent</td>
                  <td class="py-2.5">Condensing boiler operating in condensing mode</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-xs text-slate-500">
            Sources &amp; standards: ASHRAE Handbook — Fundamentals; EN 304 / EN 14394 boiler efficiency test
            methods; BRE Domestic Heating Design Guide.
          </p>
        </div>
      </section>

      <!-- ============================ FORMULA EXPLAINED ============================ -->
      <section class="bg-slate-50 border-y border-slate-200">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">
            The Siegert formula, explained
          </h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            The Siegert method was developed by German engineer Karl Siegert and remains the basis for all
            portable flue-gas analyser efficiency readings. It splits boiler losses into three components:
            sensible stack heat carried out by hot flue gas, latent heat in uncondensed water vapour, and fixed
            radiation and convection losses from the boiler casing. The sensible stack loss dominates in
            non-condensing boilers and is directly measured using flue gas temperature and oxygen percentage.
          </p>

          <div
            class="mt-8 rounded-2xl bg-slate-900 p-6 sm:p-8 text-slate-100 font-mono text-sm leading-relaxed overflow-x-auto"
          >
            <div class="text-orange-300"># Siegert sensible stack loss:</div>
            <div>qA = (tFG &minus; tA) &times; (f &divide; (21 &minus; O&#x2082;,dry))&nbsp;&nbsp;&nbsp;[%]</div>
            <div class="mt-2 pl-4 text-slate-400">tFG = flue gas temperature (&deg;C)</div>
            <div class="pl-4 text-slate-400">tA&nbsp; = combustion air temperature (&deg;C)</div>
            <div class="pl-4 text-slate-400">O&#x2082;,dry = flue oxygen on dry basis (%)</div>
            <div class="pl-4 text-slate-400">f&nbsp; = fuel factor&nbsp;&nbsp;&rarr;&nbsp;&nbsp;<span class="text-amber-300">0.66</span> Natural Gas &middot; <span class="text-amber-300">0.63</span> Propane &middot; <span class="text-amber-300">0.68</span> Fuel Oil</div>
            <div class="mt-4 text-orange-300"># Net combustion efficiency:</div>
            <div>&eta; = 100% &minus; qA &minus; L_latent &minus; L_radiation</div>
            <div class="mt-2 pl-4 text-slate-400">L_latent&nbsp;&nbsp;&nbsp;&nbsp;= <span class="text-amber-300">11%</span> (Natural Gas) &middot; <span class="text-amber-300">8%</span> (Propane) &middot; <span class="text-amber-300">0%</span> (Fuel Oil)</div>
            <div class="pl-4 text-slate-400">L_radiation = <span class="text-amber-300">1.5%</span> (fixed &mdash; casing losses)</div>
          </div>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Why flue oxygen?</h3>
              <p class="mt-2 text-sm text-slate-600">
                Oxygen remaining in flue gas directly indicates excess air. Lower O₂ means less excess air and
                less sensible heat wasted — but below 1–2% O₂, the risk of incomplete combustion and CO
                formation increases sharply.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Fuel factor f</h3>
              <p class="mt-2 text-sm text-slate-600">
                The fuel factor accounts for the specific heat capacity and molecular weight of each fuel's
                combustion products. Natural gas (f=0.66) and propane (f=0.63) are close; fuel oil (f=0.68) has
                slightly heavier combustion products.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Condensing benefit</h3>
              <p class="mt-2 text-sm text-slate-600">
                When flue gas temperature drops below the dew point (~55°C for natural gas), the latent heat of
                water vapour is recovered, boosting efficiency above 100% on a gross calorific basis.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">O₂ vs CO₂</h3>
              <p class="mt-2 text-sm text-slate-600">
                Many older analysers measure CO₂ instead of O₂. The relationship is: CO₂,max − CO₂,measured =
                O₂ × (CO₂,max / (21 − O₂,stoich)). For natural gas, CO₂,max ≈ 11.7%.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================ WORKED EXAMPLES ============================ -->
      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Worked examples</h2>
        <p class="mt-4 text-slate-600">
          Three real-world readings — a condensing boiler at low stack temperature, a conventional gas boiler,
          and a neglected oil boiler with high flue losses.
        </p>

        <div class="mt-8 space-y-6">
          <!-- Example 1 -->
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-orange-100 text-orange-600 font-bold"
                >1</span
              >
              <h3 class="text-lg font-bold text-slate-900">
                Efficient condensing boiler — 60°C flue gas, 20°C air, 4% O₂, Natural Gas
              </h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              qA = (60 &minus; 20) &times; (0.66 / (21 &minus; 4)) = 40 &times; 0.039 = <span class="font-bold text-orange-600">1.55%</span><br />
              &eta; = 100 &minus; 1.55 &minus; 11 &minus; 1.5 = <span class="font-bold text-orange-600">85.95% &asymp; 86%</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> High efficiency — low stack temperature
              is the hallmark of condensing-mode operation.
            </p>
          </div>

          <!-- Example 2 -->
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-orange-100 text-orange-600 font-bold"
                >2</span
              >
              <h3 class="text-lg font-bold text-slate-900">
                Conventional gas boiler — 200°C flue gas, 20°C air, 5% O₂, Natural Gas
              </h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              qA = (200 &minus; 20) &times; (0.66 / (21 &minus; 5)) = 180 &times; 0.04125 = <span class="font-bold text-orange-600">7.4%</span><br />
              &eta; = 100 &minus; 7.4 &minus; 11 &minus; 1.5 = <span class="font-bold text-orange-600">80.1%</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> Typical for a well-tuned conventional
              boiler — acceptable but limited by the non-condensing flue design.
            </p>
          </div>

          <!-- Example 3 -->
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-orange-100 text-orange-600 font-bold"
                >3</span
              >
              <h3 class="text-lg font-bold text-slate-900">
                Neglected oil boiler — 300°C flue gas, 25°C air, 6% O₂, Fuel Oil
              </h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              qA = (300 &minus; 25) &times; (0.68 / (21 &minus; 6)) = 275 &times; 0.04533 = <span class="font-bold text-orange-600">12.5%</span><br />
              &eta; = 100 &minus; 12.5 &minus; 0 &minus; 1.5 = <span class="font-bold text-orange-600">86%</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> Note the high stack temperature flag —
              fouled heat exchange surfaces are wasting thermal energy.
            </p>
          </div>
        </div>
