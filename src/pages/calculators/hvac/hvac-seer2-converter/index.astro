---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import HvacRelatedCalculators from "@/components/HvacRelatedCalculators.astro";
import CalculatorBreadcrumb from "@/components/CalculatorBreadcrumb.astro";
import CalculatorFaqSection from "@/components/CalculatorFaqSection.astro";
import CalculatorTradesQuoteCta from "@/components/CalculatorTradesQuoteCta.astro";
import { buildFaqPageSchema, type CalculatorFaq } from "@/lib/calculatorFaq";

const title = "SEER to SEER2 Converter — 2023 Federal Minimums | TradesQuote";
const description =
  "Convert between SEER and SEER2 using the official DOE 0.9524 factor. See the 2023 federal minimum for your region (South: 14 SEER2, North: 13.4 SEER2) and check compliance instantly.";

const pageUrl = "https://tradesquote.ai/calculators/hvac/hvac-seer2-converter";

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://tradesquote.ai/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://tradesquote.ai/calculators" },
    { "@type": "ListItem", position: 3, name: "HVAC", item: "https://tradesquote.ai/calculators/hvac" },
    { "@type": "ListItem", position: 4, name: "SEER / SEER2 Converter", item: pageUrl },
  ],
};

const webAppData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "SEER / SEER2 Converter",
  url: pageUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (web-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description:
    "Free SEER to SEER2 converter using the official DOE M1→M2 conversion factor (0.9524). Checks compliance against 2023 federal minimums for South (14 SEER2) and North (13.4 SEER2) regions.",
};

const faqs: CalculatorFaq[] = [
  {
    question: "Why did SEER change to SEER2?",
    answer:
      "DOE updated the test procedure in 2023 to require testing at a higher external static pressure (0.5 in.w.c. vs. 0.1 in.w.c.). The new M2 test better reflects real-world duct resistance. A SEER2 14 unit performs identically to the old SEER 14.7 unit — it is the same equipment, tested differently.",
  },
  {
    question: "What is the exact SEER to SEER2 conversion factor?",
    answer:
      "DOE published a conversion factor of 0.9524 for split-system central air conditioners and heat pumps. So SEER2 = SEER ÷ 1.05. Some manufacturers round slightly. This calculator uses the official DOE factor.",
  },
  {
    question: "Does the new minimum mean new equipment is less efficient?",
    answer:
      "No. The SEER2 14 minimum represents the same physical efficiency as the old SEER 14.7 minimum. Consumers should compare SEER2 to SEER2 (both new standard) or SEER to SEER (both old standard) — never mix the two.",
  },
  {
    question: "Does this conversion apply to heat pumps?",
    answer:
      "Yes, with the same 0.9524 factor for the cooling SEER/SEER2 rating. Heat pump heating efficiency uses a separate conversion: HSPF2 = HSPF × 0.851. The heat pump federal minimum is 14.3 SEER2 (all regions) effective January 2023.",
  },
];
const faqData = buildFaqPageSchema(faqs);

const relatedCalculators = [
  {
    href: "/calculators/hvac/hvac-seer-savings-calculator",
    title: "SEER Savings Calculator",
    description: "Dollar savings from upgrading to a higher SEER2 unit.",
  },
  {
    href: "/calculators/hvac/hvac-operating-cost-calculator",
    title: "Operating Cost Calculator",
    description: "Annual electricity cost at any efficiency rating.",
  },
  {
    href: "/calculators/hvac/hvac-amp-draw-calculator",
    title: "Amp Draw Calculator",
    description: "Electrical service requirements by SEER2 and BTU.",
  },
];
---

<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="SEER to SEER2 Converter | TradesQuote" />
    <meta
      property="og:description"
      content="Convert SEER ↔ SEER2 with the official DOE factor. Check 2023 federal minimums for your region instantly. Free, no sign-up."
    />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="TradesQuote" />
    <meta property="og:image" content="https://tradesquote.ai/logo.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="SEER / SEER2 Converter | TradesQuote" />
    <meta
      name="twitter:description"
      content="Convert between SEER and SEER2 using DOE's official 0.9524 factor. Check compliance with 2023 regional minimums. Free, instant."
    />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  </Fragment>

  <div class="bg-white min-h-screen text-slate-700">
    <Header />

    <main>
      <!-- HERO -->
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-6">
          <CalculatorBreadcrumb category="HVAC" categoryHref="/calculators/hvac" current="SEER / SEER2 Converter" />

          <div class="max-w-3xl">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-600"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path>
              </svg>
              HVAC Tools · Efficiency · Free
            </span>

            <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
              SEER / SEER2 Converter <span class="text-emerald-600">— Free Online Calculator</span>
            </h1>

            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              Convert an efficiency rating between the old SEER test standard (M1) and the new SEER2
              standard (M2, effective January 2023), and compare it against the current federal minimum
              for your region. The equipment did not change — only the test conditions.
            </p>
          </div>
        </div>
      </section>

      <!-- CALCULATOR -->
      <section id="calculator" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12">
        <div class="mx-auto max-w-5xl rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
              <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M12 17h.01M9 14h.01M12 14h.01M15 14h.01M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
              Enter efficiency rating
            </h2>

          <div class="mt-6 lg:grid lg:grid-cols-2 lg:gap-8 lg:items-start">
          <div class="space-y-6">
<div>
                <label for="s2-mode" class="text-sm font-semibold text-slate-800">Convert from</label>
                <select
                  id="s2-mode"
                  class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 outline-none"
                >
                  <option value="seer-to-seer2" selected>SEER → SEER2 (old rating to new)</option>
                  <option value="seer2-to-seer">SEER2 → SEER (new rating to old)</option>
                </select>
              </div>

              <div>
                <label for="s2-value" class="text-sm font-semibold text-slate-800">Rating value</label>
                <input
                  id="s2-value"
                  type="number"
                  min="8"
                  max="40"
                  step="0.1"
                  value="16"
                  class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 outline-none"
                />
                <p class="mt-1 text-xs text-slate-400">SEER or SEER2 value from the equipment label</p>
              </div>

              <div>
                <label for="s2-region" class="text-sm font-semibold text-slate-800">Installation region</label>
                <select
                  id="s2-region"
                  class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 outline-none"
                >
                  <option value="south" selected>South / Southwest (FL, TX, AZ, LA, MS, AL, GA, SC) — 14 SEER2 minimum</option>
                  <option value="north">North / all other states — 13.4 SEER2 minimum</option>
                </select>
              </div>

              <button
                id="s2-reset"
                type="button"
                class="text-sm font-medium text-slate-500 hover:text-emerald-600 transition flex items-center gap-1.5"
              >
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
                Reset to defaults
              </button>
          </div>

          <!-- Results -->
          <div class="mt-6 lg:mt-0 rounded-xl border border-emerald-100 bg-emerald-50 p-5 sm:p-6">

              <p class="text-sm font-medium text-slate-600">Converted Rating</p>
              <div class="mt-2">
                <span id="s2-result-converted" class="text-4xl font-extrabold tracking-tight">—</span>
              </div>

              <div class="mt-6 space-y-3">
                <div class="rounded-xl border border-emerald-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Federal minimum for your region</p>
                  <p class="mt-1 text-2xl font-bold text-slate-900">
                    <span id="s2-result-min">—</span>
                  </p>
                </div>
                <div class="rounded-xl border border-emerald-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Compliance status</p>
                  <p class="mt-1 text-base font-bold">
                    <span id="s2-result-status">—</span>
                  </p>
                </div>
              </div>

              <p class="mt-4 text-xs text-slate-500 leading-relaxed">
                Conversion factor: SEER2 = SEER × 0.9524 (DOE official M1→M2 factor for split-system AC/heat pumps).
              </p>
            
          </div>
          </div>
        </div>
      </section>

      <!-- FORMULA -->
      <section class="bg-slate-50 border-y border-slate-200">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">
            How the SEER / SEER2 Converter Works
          </h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            DOE published a single conversion factor when it adopted the new M2 test procedure for the
            2023 efficiency standards. The physical performance of the equipment is unchanged — the
            SEER2 number is simply what the same equipment scores on the harder test.
          </p>

          <div class="mt-8 rounded-2xl bg-slate-900 p-6 sm:p-8 text-slate-100 font-mono text-sm leading-relaxed overflow-x-auto">
            <div class="text-emerald-300"># DOE official conversion factor (split-system AC and heat pump):</div>
            <div>SEER2 = SEER &times; 0.9524&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;(M1 &rarr; M2)</div>
            <div>SEER &nbsp;= SEER2 &divide; 0.9524&nbsp;&nbsp;&nbsp;(M2 &rarr; M1)</div>
            <div class="mt-4 text-emerald-300"># Federal minimums effective January 1, 2023:</div>
            <div>South / Southwest (DOE region IV): &nbsp;14.0 SEER2 &nbsp;(&asymp; 14.7 SEER old)</div>
            <div>North (all other states): &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;13.4 SEER2 (&asymp; 14.1 SEER old)</div>
            <div>Heat pumps (all regions): &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;14.3 SEER2 (&asymp; 15.0 SEER old)</div>
          </div>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">What changed in M2?</h3>
              <p class="mt-2 text-sm text-slate-600">
                The M2 test requires 0.5 in.w.c. external static pressure instead of 0.1 in.w.c.
                This extra duct resistance reduces measured airflow and cooling capacity, so the
                same equipment scores about 5% lower in SEER2 vs. SEER.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">When to compare SEER vs SEER2</h3>
              <p class="mt-2 text-sm text-slate-600">
                Only compare within the same standard — SEER to SEER, or SEER2 to SEER2. If
                one quote shows SEER 16 and another shows SEER2 15.2, convert both to the same
                standard before comparing. SEER 16 = SEER2 15.24, so they are equivalent.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- WORKED EXAMPLE -->
      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Worked example</h2>
        <p class="mt-4 text-slate-600">
          A contractor in Texas receives a quote for a 16 SEER unit from an old-stock proposal. Does it meet the 2023 South minimum?
        </p>

        <div class="mt-8">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span class="flex h-9 w-9 items-center justify-center rounded-full bg-emerald-100 text-emerald-600 font-bold">1</span>
              <h3 class="text-lg font-bold text-slate-900">16 SEER (old rating) → SEER2 → compare to South minimum</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700 leading-relaxed">
              <div>SEER2 = 16 &times; 0.9524 = <span class="font-bold text-emerald-600">15.24 SEER2</span></div>
              <div class="mt-1">South minimum = <span class="font-bold text-emerald-600">14.0 SEER2</span></div>
              <div class="mt-1">15.24 &ge; 14.0 &rarr; <span class="font-bold text-emerald-600">Compliant</span></div>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> A 16 SEER unit converts to 15.24 SEER2 and
              exceeds the 14 SEER2 minimum for Texas. However, if the equipment was manufactured under the old
              standard and marked "SEER 14" (= SEER2 13.33), it would not meet the South minimum of 14 SEER2.
            </p>
          </div>
        </div>
      </section>

      <CalculatorFaqSection
        faqs={faqs}
        accent="emerald"
        subtitle="Common questions about the SEER to SEER2 conversion and 2023 federal efficiency minimums."
      />

      <CalculatorTradesQuoteCta
        heading="Equipment selected. Now quote the installation."
        description="TradesQuote turns your equipment specs into a detailed, line-item estimate in seconds. Describe the job or upload photos, and our AI builds quantities, unit prices, and totals — validated by a built-in quality control agent."
      />

      <HvacRelatedCalculators calculators={relatedCalculators} accent="emerald" />
    </main>

    <Footer />
  </div>

  <script>
    import { initHvacSeer2Converter } from "@/scripts/calculators/hvac-seer2-converter";
    initHvacSeer2Converter();
  </script>
</Layout>
