        subheading="The CFM targets, air-change rates, and CFM-per-ton rules on this page trace back to widely adopted airflow and duct-design specifications. These organisations publish the standards contractors rely on when sizing blowers, registers, and duct runs."
        resources={CFM_CALCULATOR_EXTERNAL_RESOURCES}
      />
    </main>

    <Footer />
  </div>

