---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import HvacRelatedCalculators from "@/components/HvacRelatedCalculators.astro";
import CalculatorBreadcrumb from "@/components/CalculatorBreadcrumb.astro";
import CalculatorFaqSection from "@/components/CalculatorFaqSection.astro";
import CalculatorTradesQuoteCta from "@/components/CalculatorTradesQuoteCta.astro";
import { buildFaqPageSchema, type CalculatorFaq } from "@/lib/calculatorFaq";

const title = "HRV / ERV Effectiveness Calculator — Sensible & Total Heat Recovery | TradesQuote";
const description =
  "Free HRV and ERV effectiveness calculator. Enter supply and exhaust airflow and temperatures to get sensible heat recovery effectiveness (%), total energy recovery, and ASHRAE 84 compliance flags. Instant, no sign-up.";

const pageUrl = "https://www.tradesquote.ai/calculators/hvac/hvac-hrv-erv-effectiveness-calculator";

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://www.tradesquote.ai/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://www.tradesquote.ai/calculators" },
    { "@type": "ListItem", position: 3, name: "HVAC", item: "https://www.tradesquote.ai/calculators/hvac" },
    { "@type": "ListItem", position: 4, name: "HRV / ERV Effectiveness Calculator", item: pageUrl },
  ],
};

const webAppData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "HRV / ERV Effectiveness Calculator",
  url: pageUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (web-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description:
    "Free online HRV and ERV effectiveness calculator. Enter supply and exhaust airflow and temperatures to get sensible heat recovery effectiveness (%), total energy recovery, and ASHRAE 84 compliance flags.",
};

const faqs: CalculatorFaq[] = [
  {
    question: "What is HRV effectiveness?",
    answer:
      "HRV sensible effectiveness is the percentage of maximum possible sensible heat transfer that the unit actually achieves between supply and exhaust airstreams, measured per ASHRAE Standard 84. A unit with 80% effectiveness pre-conditions 80% of the temperature difference between indoor and outdoor air, reducing the heating or cooling load on the main HVAC system.",
  },
  {
    question: "What is the difference between HRV and ERV?",
    answer:
      "An HRV (Heat Recovery Ventilator) transfers sensible heat only — it pre-conditions the temperature of incoming air. An ERV (Energy Recovery Ventilator) transfers both sensible heat and moisture (latent energy), recovering humidity in winter and limiting humidity gain in summer. ERVs are generally preferred in climates with high latent loads; HRVs are preferred where moisture recovery could cause condensation problems.",
  },
  {
    question: "What is a good HRV effectiveness rating?",
    answer:
      "Most residential HRVs achieve <strong>70–85% sensible effectiveness</strong> at rated conditions. ENERGY STAR requires a minimum 55% for HRVs; premium counter-flow and rotary-wheel units exceed 90%. Higher effectiveness reduces ventilation-related heating and cooling costs but generally increases equipment cost.",
  },
  {
    question: "Why does flow balance matter for HRV/ERV?",
    answer:
      "ASHRAE Standard 84 requires balanced supply and exhaust flows for a valid effectiveness test. An imbalance above 10% distorts the measured effectiveness reading. Operationally, a persistently unbalanced HRV will either pressurise or depressurise the building, affecting infiltration rates, moisture drive through the envelope, and combustion appliance safety.",
  },
  {
    question: "What ASHRAE standard covers HRV/ERV testing?",
    answer:
      "ASHRAE Standard 84 — <em>Method of Testing Air-to-Air Heat/Energy Exchangers</em> — defines the effectiveness measurement method, test conditions, and minimum airflow balance requirements. ASHRAE 62.2 and 62.1 govern the ventilation rates that HRVs and ERVs are often sized to meet.",
  },
  {
    question: "Can effectiveness exceed 100%?",
    answer:
      "Under ASHRAE 84, sensible effectiveness above 95% is flagged as a thermodynamic anomaly under practical steady-state conditions. Apparent readings above 100% always indicate a measurement error, a condensation effect boosting the apparent reading, or sensor calibration problems.",
  },
];
const faqData = buildFaqPageSchema(faqs);

const ctaHeading = "Confirmed the effectiveness. Now build the ventilation quote.";
const ctaDescription =
  "Equipment performance data gives you the scope — TradesQuote converts it into a detailed, line-item estimate in seconds. Describe the ventilation job or upload photos, and the AI builds quantities, unit prices, and totals, validated by a built-in quality control agent.";

const relatedCalculators = [
  {
    href: "/calculators/hvac/hvac-ventilation-calculator",
    title: "Ventilation Calculator",
    description: "ASHRAE 62.2 residential and 62.1 commercial ventilation CFM.",
  },
  {
    href: "/calculators/hvac/hvac-cfm-calculator",
    title: "CFM / Airflow Calculator",
    description: "Room airflow and system total CFM targets.",
  },
  {
    href: "/calculators/hvac/hvac-humidity-control-calculator",
    title: "Humidity Control Calculator",
    description: "Humidifier and dehumidifier sizing from latent load.",
  },
  {
    href: "/calculators/hvac/hvac-sensible-latent-heat-calculator",
    title: "Sensible & Latent Heat Calculator",
    description: "Split total coil load into sensible and latent BTU/h.",
  },
];
---

<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="HRV / ERV Effectiveness Calculator — Sensible & Total Heat Recovery" />
    <meta
      property="og:description"
      content="Calculate HRV and ERV sensible effectiveness, total energy recovery, and ASHRAE 84 compliance. Free and instant."
    />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="TradesQuote" />
    <meta property="og:image" content="https://www.tradesquote.ai/logo.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="HRV / ERV Effectiveness Calculator — Sensible & Total Heat Recovery" />
    <meta
      name="twitter:description"
      content="Calculate HRV and ERV sensible effectiveness and ASHRAE 84 compliance. Free, instant, no sign-up."
    />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  </Fragment>

  <div class="bg-white min-h-screen text-slate-700">
    <Header />

    <main>
      <!-- ============================ HERO + H1 + INTRO ============================ -->
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-6">
          <CalculatorBreadcrumb category="HVAC" categoryHref="/calculators/hvac" current="HRV / ERV Effectiveness Calculator" />

          <div class="max-w-3xl">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-teal-100 px-3 py-1 text-xs font-semibold text-teal-600"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"
                ></path>
              </svg>
              HVAC Tools · Ventilation · Free
            </span>

            <!-- (1) H1 -->
            <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
              HRV / ERV Effectiveness Calculator <span class="text-teal-600">— Free Online Calculator</span>
            </h1>

            <!-- (2) What this calculates — intro -->
            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              Heat Recovery Ventilators (HRVs) and Energy Recovery Ventilators (ERVs) pre-condition incoming fresh
              air using energy from the exhaust stream. Effectiveness — the fraction of maximum possible heat
              transfer actually achieved — is the key performance metric under ASHRAE Standard 84. Enter supply and
              exhaust airflow rates and temperatures to calculate sensible effectiveness and detect
              flow-imbalance problems instantly.
            </p>
          </div>
        </div>
      </section>

      <!-- ============================ (3) THE INTERACTIVE CALCULATOR ============================ -->
      <section id="calculator" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12">
        <div class="mx-auto max-w-5xl rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
              <svg
                class="h-5 w-5 text-teal-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M12 17h.01M9 14h.01M12 14h.01M15 14h.01M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"
                ></path>
              </svg>
              Enter airflow and temperatures
            </h2>

          <div class="mt-6 lg:grid lg:grid-cols-2 lg:gap-8 lg:items-start">
          <div class="space-y-6">
<div>
                <label for="hrv-type" class="text-sm font-semibold text-slate-800">Device type</label>
                <select
                  id="hrv-type"
                  class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                >
                  <option value="hrv" selected>HRV — Sensible only</option>
                  <option value="erv">ERV — Sensible + Latent</option>
                </select>
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="hrv-vs" class="text-sm font-semibold text-slate-800">Supply airflow Vs (CFM)</label>
                  <input
                    id="hrv-vs"
                    type="number"
                    min="1"
                    max="10000"
                    value="150"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                  />
                </div>

                <div>
                  <label for="hrv-ve" class="text-sm font-semibold text-slate-800">Exhaust airflow Ve (CFM)</label>
                  <input
                    id="hrv-ve"
                    type="number"
                    min="1"
                    max="10000"
                    value="150"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                  />
                </div>

                <div>
                  <label for="hrv-t1" class="text-sm font-semibold text-slate-800">Outdoor supply inlet temp t&#x2081; (°F)</label>
                  <input
                    id="hrv-t1"
                    type="number"
                    min="-60"
                    max="130"
                    value="20"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                  />
                </div>

                <div>
                  <label for="hrv-t2" class="text-sm font-semibold text-slate-800">Supply air leaving temp t&#x2082; (°F)</label>
                  <input
                    id="hrv-t2"
                    type="number"
                    min="-60"
                    max="130"
                    value="60"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                  />
                </div>

                <div class="sm:col-span-2">
                  <label for="hrv-t3" class="text-sm font-semibold text-slate-800">Indoor exhaust inlet temp t&#x2083; (°F)</label>
                  <input
                    id="hrv-t3"
                    type="number"
                    min="-60"
                    max="130"
                    value="70"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                  />
                </div>
              </div>

              <button
                id="hrv-reset"
                type="button"
                class="text-sm font-medium text-slate-500 hover:text-teal-600 transition flex items-center gap-1.5"
              >
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                  ></path>
                </svg>
                Reset to defaults
              </button>
          </div>

          <!-- Results -->
          <div class="mt-6 lg:mt-0 rounded-xl border border-teal-100 bg-teal-50 p-5 sm:p-6">

              <p class="text-sm font-medium text-slate-600">Sensible Effectiveness</p>
              <div class="mt-2 flex items-baseline gap-2">
                <span id="hrv-result-effectiveness" class="text-5xl font-extrabold tracking-tight text-teal-600">—</span>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-xl border border-teal-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Vmin</p>
                  <p id="hrv-result-vmin" class="mt-1 text-2xl font-bold text-slate-900">—</p>
                </div>
                <div class="rounded-xl border border-teal-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Flow Balance</p>
                  <p id="hrv-result-balance" class="mt-1 text-2xl font-bold text-slate-900">—</p>
                </div>
              </div>

              <div class="mt-3 rounded-xl border border-teal-100 bg-white p-4">
                <p class="text-xs text-slate-500">Rating</p>
                <p id="hrv-status" class="mt-1 text-2xl font-bold text-slate-900">—</p>
              </div>

              <!-- Warning box -->
              <div id="hrv-warning" class="hidden mt-3 rounded-xl bg-amber-400/25 border border-amber-300/40 p-4">
                <p class="text-xs font-semibold text-amber-100 uppercase tracking-wide">Warning</p>
                <p id="hrv-warning-text" class="mt-1 text-sm font-medium text-white leading-snug"></p>
              </div>

              <!-- Breakdown -->
              <details class="group mt-5 rounded-xl border border-teal-100 bg-white">
                <summary
                  class="flex items-center justify-between cursor-pointer px-4 py-3 text-sm font-semibold text-slate-800"
                >
                  See the breakdown
                  <svg
                    class="h-4 w-4 text-slate-500 transition-transform group-open:rotate-180"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="px-4 pb-4 text-sm space-y-1.5 text-slate-600">
                  <div class="flex justify-between">
                    <span>Vs (supply CFM)</span><span id="hrv-bd-vs" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Ve (exhaust CFM)</span><span id="hrv-bd-ve" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Vmin</span><span id="hrv-bd-vmin" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between border-t border-white/20 pt-1.5 mt-1.5">
                    <span>t&#x2081; (supply inlet)</span><span id="hrv-bd-t1" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>t&#x2082; (supply leaving)</span><span id="hrv-bd-t2" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>t&#x2083; (exhaust inlet)</span><span id="hrv-bd-t3" class="font-semibold text-slate-900">—</span>
                  </div>
                </div>
              </details>

              <p class="mt-4 text-xs text-slate-500 leading-relaxed">
                Effectiveness calculated per ASHRAE Standard 84. Balanced flow (|Vs&#x2212;Ve|/max &#x2264; 10%) is required for a valid effectiveness reading.
              </p>
            
          </div>
          </div>
        </div>

        <!-- Reference table -->
        <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">HRV/ERV effectiveness benchmarks</h2>
          <p class="mt-2 text-sm text-slate-500">
            Sensible effectiveness at rated conditions (balanced flow, ASHRAE 84 test method).
          </p>
          <div class="mt-5 overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-500">
                  <th class="py-2.5 pr-4 font-semibold">Sensible Effectiveness</th>
                  <th class="py-2.5 pr-4 font-semibold">Rating</th>
                  <th class="py-2.5 font-semibold">Typical product type</th>
                </tr>
              </thead>
              <tbody class="text-slate-700">
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Under 65%</td>
                  <td class="py-2.5 pr-4">Basic</td>
                  <td class="py-2.5">Low-cost plate exchanger</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">65–75%</td>
                  <td class="py-2.5 pr-4">Standard</td>
                  <td class="py-2.5">Entry-level rotary wheel or plate</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">75–82%</td>
                  <td class="py-2.5 pr-4 text-teal-700 font-semibold">Good</td>
                  <td class="py-2.5">Mid-range cross-flow or counter-flow plate</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">82–90%</td>
                  <td class="py-2.5 pr-4 text-teal-700 font-semibold">Excellent</td>
                  <td class="py-2.5">High-efficiency counter-flow or rotary</td>
                </tr>
                <tr>
                  <td class="py-2.5 pr-4 font-semibold">90%+</td>
                  <td class="py-2.5 pr-4 text-emerald-700 font-semibold">Premium</td>
                  <td class="py-2.5">High-performance rotary wheel with purge sector</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- ============================ (4) FORMULA EXPLAINED ============================ -->
      <section class="bg-slate-50 border-y border-slate-200">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">
            The effectiveness formula, explained
          </h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            ASHRAE Standard 84 defines sensible heat recovery effectiveness as the ratio of heat actually
            transferred between supply and exhaust streams to the maximum heat that could be transferred if the
            streams reached thermal equilibrium. The minimum airflow rate (Vmin) is used as the denominator
            because it represents the limiting stream — the smaller flow has the shorter contact time and therefore
            controls the maximum possible transfer.
          </p>

          <div
            class="mt-8 rounded-2xl bg-slate-900 p-6 sm:p-8 text-slate-100 font-mono text-sm leading-relaxed overflow-x-auto"
          >
            <div class="text-teal-300"># Sensible Effectiveness (ASHRAE 84):</div>
            <div>&#949;s = [Vs &times; (t&#x2081; &minus; t&#x2082;)] / [Vmin &times; (t&#x2081; &minus; t&#x2083;)] &times; 100 &nbsp;[%]</div>
            <div class="mt-2 text-slate-400">&nbsp; Vs&nbsp;&nbsp; = supply airflow (CFM)</div>
            <div class="text-slate-400">&nbsp; Vmin = min(supply CFM, exhaust CFM)</div>
            <div class="text-slate-400">&nbsp; t&#x2081;&nbsp;&nbsp; = outdoor supply inlet temperature (°F)</div>
            <div class="text-slate-400">&nbsp; t&#x2082;&nbsp;&nbsp; = supply air leaving temperature (°F)</div>
            <div class="text-slate-400">&nbsp; t&#x2083;&nbsp;&nbsp; = indoor exhaust inlet temperature (°F)</div>
            <div class="mt-4 text-teal-300"># Flow imbalance check:</div>
            <div>R = |Vs &minus; Ve| / max(Vs, Ve) &nbsp;&#x2192;&nbsp; must be &#x2264; 0.10 (10%)</div>
            <div class="mt-4 text-teal-300"># Total sensible heat recovered (BTU/h):</div>
            <div>Q_sensible = 1.08 &times; Vs &times; (t&#x2082; &minus; t&#x2081;)</div>
          </div>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Why use Vmin?</h3>
              <p class="mt-2 text-sm text-slate-600">
                The smaller of supply and exhaust flows is always the limiting stream. Using total flow would
                overstate effectiveness when the streams are imbalanced.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">HRV vs ERV</h3>
              <p class="mt-2 text-sm text-slate-600">
                An HRV transfers sensible heat only (air temperature). An ERV transfers both sensible heat and
                moisture (latent energy), making it better suited for humid climates where dehumidification is
                valued.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Flow balance matters</h3>
              <p class="mt-2 text-sm text-slate-600">
                ASHRAE 84 specifies testing at balanced flow. An imbalance above 10% distorts the measured
                effectiveness and can cause building pressurisation problems — positive pressure in
                heating-dominated climates risks moisture drive into wall assemblies.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">ASHRAE 62.2 context</h3>
              <p class="mt-2 text-sm text-slate-600">
                HRVs and ERVs are often sized to meet ASHRAE 62.2 whole-building ventilation rates. The
                effectiveness calculator here verifies equipment performance; for required CFM targets, use the
                Ventilation Calculator.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================ (5) WORKED EXAMPLES ============================ -->
      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Worked examples</h2>
        <p class="mt-4 text-slate-600">
          Three scenarios covering a typical residential unit, a flow-imbalance warning, and a premium rotary ERV.
        </p>

        <div class="mt-8 space-y-6">
          <!-- Example 1 -->
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-teal-100 text-teal-700 font-bold"
                >1</span
              >
              <h3 class="text-lg font-bold text-slate-900">Balanced residential HRV — 150 CFM each, t&#x2081;=20°F, t&#x2082;=58°F, t&#x2083;=70°F</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              Vmin=150; &#949;s = 150&times;(20&minus;58) / (150&times;(20&minus;70)) &times; 100 = 150&times;(&minus;38) / (150&times;(&minus;50)) &times; 100 = 38/50 &times; 100 = <span class="font-bold text-teal-700">76%</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> 76% sensible effectiveness — typical for a mid-range plate exchanger in cold-climate heating season.
            </p>
          </div>

