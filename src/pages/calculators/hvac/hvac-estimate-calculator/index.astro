---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const title = "HVAC Estimate Calculator — Free Job Pricing Tool | TradesQuote";
const description =
  "Free HVAC estimate calculator for contractors. Price any job from the bottom up — labor hours, equipment, materials, overhead, and true profit margin (not markup). Instant, no sign-up.";

const pageUrl = "https://tradesquote.ai/calculators/hvac/hvac-estimate-calculator";

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://tradesquote.ai/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://tradesquote.ai/calculators" },
    { "@type": "ListItem", position: 3, name: "HVAC", item: "https://tradesquote.ai/calculators/hvac" },
    { "@type": "ListItem", position: 4, name: "HVAC Estimate Calculator", item: pageUrl },
  ],
};

const webAppData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "HVAC Estimate Calculator",
  url: pageUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (web-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description:
    "Free online HVAC estimate calculator that prices a job from the bottom up: labor hours and rate, equipment, materials, overhead percentage, and true profit margin, producing a quote price and profit breakdown.",
};

const faqData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How do I calculate an HVAC estimate?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Add up direct costs first: labor hours times your hourly rate, plus equipment and materials. Apply your overhead percentage to get break-even, then divide by one minus your target profit margin to get the quote price. A 16-hour install with $4,800 in equipment and materials at 15 percent overhead and 20 percent margin prices at $9,200.",
      },
    },
    {
      "@type": "Question",
      name: "What is the difference between markup and margin?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Markup multiplies cost upward; margin is profit as a share of the selling price. A 20 percent markup on a $7,360 break-even gives $8,832, but a true 20 percent margin requires $9,200 — dividing by 0.8, not multiplying by 1.2. Pricing by markup when you mean margin silently underprices every job.",
      },
    },
    {
      "@type": "Question",
      name: "How much should HVAC contractors charge per hour?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Billed labor rates typically run $75 to $150 per hour depending on market and specialty. The billed rate must cover far more than the technician's wage: payroll taxes, insurance, the truck, tools, training, and unbillable drive time all ride on every billable hour.",
      },
    },
    {
      "@type": "Question",
      name: "What profit margin should an HVAC company target?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Many shops target a 20 to 35 percent gross margin on installations and 40 to 60 percent on service and repair work, which typically nets out to single-digit to low-teens net profit after all overhead. Thin margins on installs are usually a markup-versus-margin mistake, not a market problem.",
      },
    },
    {
      "@type": "Question",
      name: "What counts as overhead in an HVAC estimate?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Overhead is every cost that is not tied to one specific job: rent, office staff, insurance, vehicle payments, fuel, software, marketing, and licenses. Most HVAC businesses run 10 to 25 percent overhead, and it must be loaded into every estimate or the company loses money while jobs look profitable.",
      },
    },
    {
      "@type": "Question",
      name: "Should I show the full cost breakdown to customers?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Show line items — equipment, labor, materials — because itemized quotes build trust and win against single-number bids. Keep internal numbers like your overhead percentage and margin private; customers should see what they get, not your cost accounting.",
      },
    },
    {
      "@type": "Question",
      name: "How is this different from the HVAC replacement cost calculator?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The replacement cost calculator gives homeowners a top-down national price range for budgeting. This estimate calculator works bottom-up from a contractor's actual numbers — hours, rates, equipment, overhead, and margin — to build the price a specific business should quote for a specific job.",
      },
    },
  ],
};

const relatedCalculators = [
  {
    href: "/calculators/hvac/hvac-replacement-cost-calculator",
    title: "Replacement Cost Calculator",
    description: "Homeowner price ranges by system, size & region.",
  },
  {
    href: "/calculators/hvac/hvac-btu-calculator",
    title: "BTU Calculator (Cooling)",
    description: "Full cooling load with climate, sun & insulation.",
  },
  {
    href: "/calculators/hvac/hvac-tonnage-calculator",
    title: "AC Tonnage Calculator",
    description: "Convert BTU to tons and find your system size.",
  },
  {
    href: "/calculators/hvac/hvac-furnace-btu-calculator",
    title: "Furnace BTU Calculator",
    description: "Heating size by climate zone and AFUE efficiency.",
  },
];
---

<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="HVAC Estimate Calculator — Free Job Pricing Tool" />
    <meta
      property="og:description"
      content="Price any HVAC job from the bottom up — labor, equipment, materials, overhead, and true profit margin. Free and instant."
    />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="TradesQuote" />
    <meta property="og:image" content="https://tradesquote.ai/logo.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="HVAC Estimate Calculator — Free Job Pricing Tool" />
    <meta
      name="twitter:description"
      content="Price any HVAC job from the bottom up — labor, equipment, materials, overhead, and true margin. Free, no sign-up."
    />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  </Fragment>

  <div class="bg-white min-h-screen text-slate-700">
    <Header />

    <main>
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-6">
          <nav class="flex flex-wrap items-center gap-2 text-sm text-slate-500 mb-6" aria-label="Breadcrumb">
            <a href="/" class="hover:text-blue-600 transition">Home</a>
            <span>/</span>
            <a href="/calculators" class="hover:text-blue-600 transition">Calculators</a>
            <span>/</span>
            <a href="/calculators/hvac" class="hover:text-blue-600 transition">HVAC</a>
            <span>/</span>
            <span class="text-slate-700 font-medium">HVAC Estimate Calculator</span>
          </nav>

          <div class="max-w-3xl">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-700"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
                ></path>
              </svg>
              HVAC Tools · Job Pricing · Free
            </span>

            <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
              HVAC Estimate Calculator <span class="text-rose-600">— Free Online Calculator</span>
            </h1>

            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              This HVAC estimate calculator prices a job from the bottom up — labor hours and rate, equipment,
              materials, your overhead percentage, and your target profit margin — and returns the quote price,
              break-even point, and actual profit. It uses true <em>margin</em> math (divide by 1&nbsp;−&nbsp;margin),
              not the markup shortcut that silently underprices jobs.
            </p>

            <div class="mt-6 flex items-start gap-3 rounded-xl border border-rose-100 bg-rose-50 p-4">
              <svg
                class="h-5 w-5 shrink-0 text-rose-600 mt-0.5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
              <p class="text-sm text-slate-600">
                <span class="font-semibold text-slate-900">Homeowner looking for a budget number instead?</span>
                This page is contractor pricing math. For a quick national price range, use the
                <a
                  href="/calculators/hvac/hvac-replacement-cost-calculator"
                  class="font-semibold text-rose-700 underline decoration-rose-300 hover:decoration-rose-600"
                  >Replacement Cost Calculator</a
                >
                — and size the equipment first with the
                <a
                  href="/calculators/hvac/hvac-btu-calculator"
                  class="font-semibold text-rose-700 underline decoration-rose-300 hover:decoration-rose-600"
                  >BTU Calculator</a
                >.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="calculator" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12 pt-4">
        <div class="grid lg:grid-cols-5 gap-6">
          <div class="lg:col-span-3 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
            <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
              <svg
                class="h-5 w-5 text-rose-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M12 17h.01M9 14h.01M12 14h.01M15 14h.01M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"
                ></path>
              </svg>
              Enter your job numbers
            </h2>

            <div class="mt-6 space-y-5">
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="estHours" class="text-sm font-semibold text-slate-800">Labor hours (total)</label>
                  <input
                    id="estHours"
                    type="number"
                    min="0"
                    max="500"
                    step="0.5"
                    value="16"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-900 focus:border-rose-500 focus:ring-2 focus:ring-rose-200 outline-none"
                  />
                </div>

                <div>
                  <label for="estRate" class="text-sm font-semibold text-slate-800">Billed labor rate ($/hr)</label>
                  <input
                    id="estRate"
                    type="number"
                    min="0"
                    max="500"
                    step="5"
                    value="100"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-900 focus:border-rose-500 focus:ring-2 focus:ring-rose-200 outline-none"
                  />
                </div>

                <div>
                  <label for="estEquip" class="text-sm font-semibold text-slate-800">Equipment cost ($)</label>
                  <input
                    id="estEquip"
                    type="number"
                    min="0"
                    max="100000"
                    step="100"
                    value="4000"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-900 focus:border-rose-500 focus:ring-2 focus:ring-rose-200 outline-none"
                  />
                </div>

                <div>
                  <label for="estMat" class="text-sm font-semibold text-slate-800">Materials & supplies ($)</label>
                  <input
                    id="estMat"
                    type="number"
                    min="0"
                    max="50000"
                    step="50"
                    value="800"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-900 focus:border-rose-500 focus:ring-2 focus:ring-rose-200 outline-none"
                  />
                </div>

                <div>
                  <label for="estOh" class="text-sm font-semibold text-slate-800">Overhead (%)</label>
                  <input
                    id="estOh"
                    type="number"
                    min="0"
                    max="60"
                    step="1"
                    value="15"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-900 focus:border-rose-500 focus:ring-2 focus:ring-rose-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">Rent, trucks, insurance, office — typically 10–25%</p>
                </div>

                <div>
                  <div class="flex items-center justify-between">
                    <label for="estMargin" class="text-sm font-semibold text-slate-800">Target profit margin</label>
                    <span id="marginLabel" class="text-sm font-bold text-rose-600">20%</span>
                  </div>
                  <input
                    id="estMargin"
                    type="range"
                    min="0"
                    max="50"
                    step="1"
                    value="20"
                    class="estimate-range mt-3 w-full bg-slate-200 accent-rose-600"
                  />
                  <div class="flex justify-between text-xs text-slate-400 mt-1">
                    <span>0%</span><span>50%</span>
                  </div>
                </div>
              </div>

              <button
                id="resetBtn"
                type="button"
                class="text-sm font-medium text-slate-500 hover:text-rose-600 transition flex items-center gap-1.5"
              >
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                  ></path>
                </svg>
                Reset to defaults
              </button>
            </div>
          </div>

          <div class="lg:col-span-2">
            <div
              class="lg:sticky lg:top-24 rounded-2xl bg-gradient-to-br from-rose-600 to-pink-500 p-6 sm:p-8 text-white shadow-lg"
            >
              <p class="text-sm font-medium text-rose-100">Quote this job at</p>
              <div class="mt-2 flex items-baseline gap-2">
                <span id="priceResult" class="text-5xl font-extrabold tracking-tight">$9,200</span>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-xl bg-white/15 p-4">
                  <p class="text-xs text-rose-100">Your profit</p>
                  <p id="profitResult" class="mt-1 text-2xl font-bold">$1,840</p>
                </div>
                <div class="rounded-xl bg-white/15 p-4">
                  <p class="text-xs text-rose-100">Break-even</p>
                  <p id="beResult" class="mt-1 text-2xl font-bold">$7,360</p>
                </div>
              </div>

              <div class="mt-3 rounded-xl bg-white/15 p-4">
                <p class="text-xs text-rose-100">Margin check</p>
                <p id="marginNote" class="mt-1 text-base font-semibold leading-snug">
                  20% true margin (markup would quote $8,832)
                </p>
              </div>

              <details class="group mt-5 rounded-xl bg-white/10">
                <summary class="flex items-center justify-between cursor-pointer px-4 py-3 text-sm font-semibold">
                  See the breakdown
                  <svg
                    class="h-4 w-4 transition-transform group-open:rotate-180"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="px-4 pb-4 text-sm space-y-1.5 text-rose-50">
                  <div class="flex justify-between">
                    <span>Labor (hours × rate)</span><span id="bd-labor" class="font-semibold">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Equipment</span><span id="bd-equip" class="font-semibold">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Materials</span><span id="bd-mat" class="font-semibold">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Overhead</span><span id="bd-oh" class="font-semibold">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Break-even</span><span id="bd-be" class="font-semibold">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>÷ (1 − margin)</span><span id="bd-margin" class="font-semibold">—</span>
                  </div>
                  <div class="flex justify-between border-t border-white/20 pt-1.5 mt-1.5 text-white">
                    <span class="font-bold">Quote price</span><span id="bd-price" class="font-bold">—</span>
                  </div>
                </div>
              </details>

              <p class="mt-4 text-xs text-rose-100 leading-relaxed">
                Internal pricing math — share the line items with your client, keep the overhead and margin
                numbers to yourself.
              </p>
            </div>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">Typical HVAC job hours & prices (quick reference)</h2>
          <p class="mt-2 text-sm text-slate-500">
            Ballpark labor hours and quoted price ranges for common residential jobs. Your rates and market set the real numbers.
          </p>
          <div class="mt-5 overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-500">
                  <th class="py-2.5 pr-4 font-semibold">Job type</th>
                  <th class="py-2.5 pr-4 font-semibold">Typical labor hours</th>
                  <th class="py-2.5 font-semibold">Typical quoted price</th>
                </tr>
              </thead>
              <tbody class="text-slate-700">
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Service call / repair</td>
                  <td class="py-2.5 pr-4">1 – 3 hrs</td>
                  <td class="py-2.5">$150 – $600</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Mini-split install (single zone)</td>
                  <td class="py-2.5 pr-4">8 – 12 hrs</td>
                  <td class="py-2.5">$3,000 – $5,500</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">AC replacement</td>
                  <td class="py-2.5 pr-4">12 – 16 hrs</td>
                  <td class="py-2.5">$4,000 – $8,000</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Full system replacement</td>
                  <td class="py-2.5 pr-4">16 – 24 hrs</td>
                  <td class="py-2.5">$8,000 – $15,000</td>
                </tr>
                <tr>
                  <td class="py-2.5 pr-4 font-semibold">Ductwork replacement (add-on)</td>
                  <td class="py-2.5 pr-4">24 – 40 hrs</td>
                  <td class="py-2.5">+$2,500 – $6,000</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-xs text-slate-500">
            Hours assume a two-tech crew on typical residential access. Price ranges align with the
            <a
              href="/calculators/hvac/hvac-replacement-cost-calculator"
              class="font-medium text-rose-600 hover:underline"
              >replacement cost calculator</a
            >'s national figures.
          </p>
        </div>
      </section>

      <section class="bg-slate-50 border-y border-slate-200">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">The formula, explained in plain English</h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Pricing a job is four short steps — and step four is where most money is silently lost,
            because markup and margin are not the same thing.
          </p>

          <div
            class="mt-8 rounded-2xl bg-slate-900 p-6 sm:p-8 text-slate-100 font-mono text-sm leading-relaxed overflow-x-auto"
          >
            <div class="text-rose-300"># Step 1 — Direct job costs</div>
            <div>direct&nbsp;=&nbsp;(hours × rate) + equipment + materials</div>
            <div class="mt-4 text-rose-300"># Step 2 — Load your overhead</div>
            <div>break-even&nbsp;=&nbsp;direct × (1 + overhead%)</div>
            <div class="mt-4 text-rose-300"># Step 3 — Price with TRUE margin (divide, don't multiply)</div>
            <div>price&nbsp;=&nbsp;break-even ÷ (1 − margin%)</div>
            <div class="mt-4 text-rose-300"># Step 4 — Profit is what's left</div>
            <div>
              profit&nbsp;=&nbsp;price − break-even&nbsp;&nbsp;<span class="text-slate-400"
                >// 20% margin on $7,360 → $9,200, not $8,832</span
              >
            </div>
          </div>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">The markup trap</h3>
              <p class="mt-2 text-sm text-slate-600">
                Multiplying cost by 1.2 gives a 20% <em>markup</em> but only a 16.7% <em>margin</em>. On a $7,360 break-even that's $368 left on the table — every single job.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Why overhead comes before margin</h3>
              <p class="mt-2 text-sm text-slate-600">
                Overhead is a real cost of doing business. If it isn't loaded into break-even, your "profit" is paying the rent and the job was never profitable.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">The billed rate is not the wage</h3>
              <p class="mt-2 text-sm text-slate-600">
                A $35/hr technician costs $50+ with taxes, insurance, and benefits — and rides in a truck you pay for. That's why billed rates run $75–$150/hr.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Margin varies by job type</h3>
              <p class="mt-2 text-sm text-slate-600">
                Installs typically carry 20–35% gross margin; service and repair 40–60%, because short jobs absorb proportionally more drive time and risk.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Worked examples</h2>
        <p class="mt-4 text-slate-600">Three pricing scenarios — including the markup mistake, in dollars.</p>

        <div class="mt-8 space-y-6">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-rose-100 text-rose-700 font-bold"
                >1</span
