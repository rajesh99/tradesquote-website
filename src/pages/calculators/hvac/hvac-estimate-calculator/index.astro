---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import HvacRelatedCalculators from "@/components/HvacRelatedCalculators.astro";
import CalculatorBreadcrumb from "@/components/CalculatorBreadcrumb.astro";
import CalculatorFaqSection from "@/components/CalculatorFaqSection.astro";
import CalculatorTradesQuoteCta from "@/components/CalculatorTradesQuoteCta.astro";
import { buildFaqPageSchema, type CalculatorFaq } from "@/lib/calculatorFaq";

const title = "HVAC Estimate & Price Calculator — Free Job Pricing Tool | TradesQuote";
const description =
  "Free HVAC estimate and price calculator for contractors. Price any job from the bottom up — labor hours, equipment, materials, overhead, and true profit margin (not markup). The fast, accurate way to handle estimating for HVAC work. Instant, no sign-up.";

const pageUrl = "https://www.tradesquote.ai/calculators/hvac/hvac-estimate-calculator";

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://www.tradesquote.ai/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://www.tradesquote.ai/calculators" },
    { "@type": "ListItem", position: 3, name: "HVAC", item: "https://www.tradesquote.ai/calculators/hvac" },
    { "@type": "ListItem", position: 4, name: "HVAC Estimate Calculator", item: pageUrl },
  ],
};

const webAppData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "HVAC Estimate Calculator",
  url: pageUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (web-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description:
    "Free online HVAC estimate calculator that prices a job from the bottom up: labor hours and rate, equipment, materials, overhead percentage, and true profit margin, producing a quote price and profit breakdown.",
};

const faqs: CalculatorFaq[] = [
  {
    question: "How do I calculate an HVAC estimate?",
    answer:
      "Add up direct costs first: <strong>labor hours × your rate, plus equipment and materials</strong>. Apply your overhead percentage to get break-even, then divide by (1 − target margin) to get the quote price. A 16-hour install with $4,800 in equipment and materials at 15% overhead and 20% margin prices at $9,200.",
  },
  {
    question: "What's the difference between markup and margin?",
    answer:
      "Markup multiplies cost upward; margin is profit as a share of the <strong>selling price</strong>. A 20% markup on a $7,360 break-even gives $8,832 — but a true 20% margin requires $9,200 (divide by 0.8, don't multiply by 1.2). Pricing by markup when you mean margin silently underprices every job.",
  },
  {
    question: "How much should HVAC contractors charge per hour?",
    answer:
      "Billed labor rates typically run <strong>$75 to $150 per hour</strong> depending on market and specialty. The billed rate must cover far more than the technician's wage: payroll taxes, insurance, the truck, tools, training, and unbillable drive time all ride on every billable hour.",
  },
  {
    question: "What profit margin should an HVAC company target?",
    answer:
      "Many shops target <strong>20–35% gross margin on installations and 40–60% on service and repair</strong>, which typically nets out to single-digit to low-teens net profit after all overhead. Thin margins on installs are usually a markup-versus-margin mistake, not a market problem.",
  },
  {
    question: "What counts as overhead in an HVAC estimate?",
    answer:
      "Overhead is every cost not tied to one specific job: <strong>rent, office staff, insurance, vehicle payments, fuel, software, marketing, licenses</strong>. Most HVAC businesses run 10–25% overhead — and it must be loaded into every estimate, or the company loses money while jobs look profitable.",
  },
  {
    question: "Should I show the full cost breakdown to customers?",
    answer:
      "Show <strong>line items</strong> — equipment, labor, materials — because itemized quotes build trust and win against single-number bids. Keep internal numbers like your overhead percentage and margin private; customers should see what they get, not your cost accounting.",
  },
  {
    question: "How is this different from the replacement cost calculator?",
    answer:
      'The <a href="/calculators/hvac/hvac-replacement-cost-calculator" class="font-semibold text-rose-700 underline decoration-rose-300 hover:decoration-rose-600">replacement cost calculator</a> gives homeowners a top-down national price range for budgeting. This one works <strong>bottom-up from a contractor\'s actual numbers</strong> — hours, rates, equipment, overhead, and margin — to build the price a specific business should quote.',
  },
];
const faqData = buildFaqPageSchema(faqs);

const ctaHeading = "This math, automated — for every job.";
const ctaDescription =
  "The calculator prices one job; TradesQuote prices them all. Describe the work or upload photos, and our AI builds the full line-item estimate with your real labor rates and pricing from your knowledge base — margins applied consistently, validated by a quality control agent, signed by the client online.";

const relatedCalculators = [
  {
    href: "/calculators/hvac/hvac-replacement-cost-calculator",
    title: "Replacement Cost Calculator",
    description: "Homeowner price ranges by system, size & region.",
  },
  {
    href: "/calculators/hvac/hvac-btu-calculator",
    title: "BTU Calculator (Cooling)",
    description: "Full cooling load with climate, sun & insulation.",
  },
  {
    href: "/calculators/hvac/hvac-tonnage-calculator",
    title: "AC Tonnage Calculator",
    description: "Convert BTU to tons and find your system size.",
  },
  {
    href: "/calculators/hvac/hvac-furnace-btu-calculator",
    title: "Furnace BTU Calculator",
    description: "Heating size by climate zone and AFUE efficiency.",
  },
];
---

<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="HVAC Estimate Calculator — Free Job Pricing Tool" />
    <meta
      property="og:description"
      content="Price any HVAC job from the bottom up — labor, equipment, materials, overhead, and true profit margin. Free and instant."
    />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="TradesQuote" />
    <meta property="og:image" content="https://www.tradesquote.ai/logo.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="HVAC Estimate Calculator — Free Job Pricing Tool" />
    <meta
      name="twitter:description"
      content="Price any HVAC job from the bottom up — labor, equipment, materials, overhead, and true margin. Free, no sign-up."
    />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  </Fragment>

  <div class="bg-white min-h-screen text-slate-700">
    <Header />

    <main>
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-6">
          <CalculatorBreadcrumb category="HVAC" categoryHref="/calculators/hvac" current="HVAC Estimate Calculator" />

          <div class="max-w-3xl">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-700"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
                ></path>
              </svg>
              HVAC Tools · Job Pricing · Free
            </span>

            <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
              HVAC Estimate Calculator <span class="text-rose-600">— Free Online Calculator</span>
            </h1>

            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              This HVAC estimate calculator prices a job from the bottom up — labor hours and rate, equipment,
              materials, your overhead percentage, and your target profit margin — and returns the quote price,
              break-even point, and actual profit. Whether you're new to estimating for HVAC or pricing your
              hundredth install, it uses true <em>margin</em> math (divide by 1&nbsp;−&nbsp;margin), not the markup
              shortcut that silently underprices jobs.
            </p>

            <div class="mt-6 flex items-start gap-3 rounded-xl border border-rose-100 bg-rose-50 p-4">
              <svg
                class="h-5 w-5 shrink-0 text-rose-600 mt-0.5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
              <p class="text-sm text-slate-600">
                <span class="font-semibold text-slate-900">Homeowner looking for a budget number instead?</span>
                This page is contractor pricing math. For a quick national price range, use the
                <a
                  href="/calculators/hvac/hvac-replacement-cost-calculator"
                  class="font-semibold text-rose-700 underline decoration-rose-300 hover:decoration-rose-600"
                  >Replacement Cost Calculator</a
                >
                — and size the equipment first with the
                <a
                  href="/calculators/hvac/hvac-btu-calculator"
                  class="font-semibold text-rose-700 underline decoration-rose-300 hover:decoration-rose-600"
                  >BTU Calculator</a
                >.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="calculator" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12 pt-4">
        <div class="mx-auto max-w-5xl rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
              <svg
                class="h-5 w-5 text-rose-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M12 17h.01M9 14h.01M12 14h.01M15 14h.01M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"
                ></path>
              </svg>
              Enter your job numbers
            </h2>

          <div class="mt-6 lg:grid lg:grid-cols-2 lg:gap-8 lg:items-start">
          <div class="space-y-6">

          </div>

          <!-- Results -->
          <div class="mt-6 lg:mt-0 rounded-xl border border-rose-100 bg-rose-50 p-5 sm:p-6">

              <p class="text-sm font-medium text-slate-600">Quote this job at</p>
              <div class="mt-2 flex items-baseline gap-2">
                <span id="priceResult" class="text-5xl font-extrabold tracking-tight text-rose-600">$9,200</span>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-xl border border-rose-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Your profit</p>
                  <p id="profitResult" class="mt-1 text-2xl font-bold text-slate-900">$1,840</p>
                </div>
                <div class="rounded-xl border border-rose-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Break-even</p>
                  <p id="beResult" class="mt-1 text-2xl font-bold text-slate-900">$7,360</p>
                </div>
              </div>

              <div class="mt-3 rounded-xl border border-rose-100 bg-white p-4">
                <p class="text-xs text-slate-500">Margin check</p>
                <p id="marginNote" class="mt-1 text-base font-semibold leading-snug text-slate-800">
                  20% true margin (markup would quote $8,832)
                </p>
              </div>

              <details class="group mt-5 rounded-xl border border-rose-100 bg-white">
                <summary class="flex items-center justify-between cursor-pointer px-4 py-3 text-sm font-semibold text-slate-800">
                  See the breakdown
                  <svg
                    class="h-4 w-4 text-slate-500 transition-transform group-open:rotate-180"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="px-4 pb-4 text-sm space-y-1.5 text-slate-600">
                  <div class="flex justify-between">
                    <span>Labor (hours × rate)</span><span id="bd-labor" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Equipment</span><span id="bd-equip" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Materials</span><span id="bd-mat" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Overhead</span><span id="bd-oh" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Break-even</span><span id="bd-be" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>÷ (1 − margin)</span><span id="bd-margin" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between border-t border-slate-200 pt-1.5 mt-1.5 text-slate-900">
                    <span class="font-bold text-slate-900">Quote price</span><span id="bd-price" class="font-bold text-slate-900">—</span>
                  </div>
                </div>
              </details>

              <p class="mt-4 text-xs text-slate-500 leading-relaxed">
                Internal pricing math — share the line items with your client, keep the overhead and margin
                numbers to yourself.
              </p>
            
          </div>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">Typical HVAC job hours & prices (quick reference)</h2>
          <p class="mt-2 text-sm text-slate-500">
            Ballpark labor hours and quoted price ranges for common residential jobs. Your rates and market set the real numbers.
          </p>
          <div class="mt-5 overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-500">
                  <th class="py-2.5 pr-4 font-semibold">Job type</th>
                  <th class="py-2.5 pr-4 font-semibold">Typical labor hours</th>
                  <th class="py-2.5 font-semibold">Typical quoted price</th>
                </tr>
              </thead>
              <tbody class="text-slate-700">
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Service call / repair</td>
                  <td class="py-2.5 pr-4">1 – 3 hrs</td>
                  <td class="py-2.5">$150 – $600</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Mini-split install (single zone)</td>
                  <td class="py-2.5 pr-4">8 – 12 hrs</td>
                  <td class="py-2.5">$3,000 – $5,500</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">AC replacement</td>
                  <td class="py-2.5 pr-4">12 – 16 hrs</td>
                  <td class="py-2.5">$4,000 – $8,000</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Full system replacement</td>
                  <td class="py-2.5 pr-4">16 – 24 hrs</td>
                  <td class="py-2.5">$8,000 – $15,000</td>
                </tr>
                <tr>
                  <td class="py-2.5 pr-4 font-semibold">Ductwork replacement (add-on)</td>
                  <td class="py-2.5 pr-4">24 – 40 hrs</td>
                  <td class="py-2.5">+$2,500 – $6,000</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-xs text-slate-500">
            Hours assume a two-tech crew on typical residential access. Price ranges align with the
            <a
              href="/calculators/hvac/hvac-replacement-cost-calculator"
              class="font-medium text-rose-600 hover:underline"
              >replacement cost calculator</a
            >'s national figures.
          </p>
        </div>
      </section>

      <section class="bg-slate-50 border-y border-slate-200">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">The formula, explained in plain English</h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Pricing a job is four short steps — and step four is where most money is silently lost,
            because markup and margin are not the same thing.
          </p>

          <div
            class="mt-8 rounded-2xl bg-slate-900 p-6 sm:p-8 text-slate-100 font-mono text-sm leading-relaxed overflow-x-auto"
          >
            <div class="text-rose-300"># Step 1 — Direct job costs</div>
            <div>direct&nbsp;=&nbsp;(hours × rate) + equipment + materials</div>
            <div class="mt-4 text-rose-300"># Step 2 — Load your overhead</div>
            <div>break-even&nbsp;=&nbsp;direct × (1 + overhead%)</div>
            <div class="mt-4 text-rose-300"># Step 3 — Price with TRUE margin (divide, don't multiply)</div>
            <div>price&nbsp;=&nbsp;break-even ÷ (1 − margin%)</div>
            <div class="mt-4 text-rose-300"># Step 4 — Profit is what's left</div>
            <div>
              profit&nbsp;=&nbsp;price − break-even&nbsp;&nbsp;<span class="text-slate-400"
                >// 20% margin on $7,360 → $9,200, not $8,832</span
              >
            </div>
          </div>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">The markup trap</h3>
              <p class="mt-2 text-sm text-slate-600">
                Multiplying cost by 1.2 gives a 20% <em>markup</em> but only a 16.7% <em>margin</em>. On a $7,360 break-even that's $368 left on the table — every single job.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Why overhead comes before margin</h3>
              <p class="mt-2 text-sm text-slate-600">
                Overhead is a real cost of doing business. If it isn't loaded into break-even, your "profit" is paying the rent and the job was never profitable.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">The billed rate is not the wage</h3>
              <p class="mt-2 text-sm text-slate-600">
                A $35/hr technician costs $50+ with taxes, insurance, and benefits — and rides in a truck you pay for. That's why billed rates run $75–$150/hr.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Margin varies by job type</h3>
              <p class="mt-2 text-sm text-slate-600">
                Installs typically carry 20–35% gross margin; service and repair 40–60%, because short jobs absorb proportionally more drive time and risk.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Worked examples</h2>
        <p class="mt-4 text-slate-600">Three pricing scenarios — including the markup mistake, in dollars.</p>

        <div class="mt-8 space-y-6">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-rose-100 text-rose-700 font-bold"
                >1</span
              >
              <h3 class="text-lg font-bold text-slate-900">Full system install — the default job</h3>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              16 hrs × $100 · $4,000 equipment · $800 materials · 15% overhead · 20% margin.
            </p>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              direct = 1,600 + 4,000 + 800 = $6,400<br />
              break-even = 6,400 × 1.15 = $7,360<br />
              price = 7,360 ÷ 0.80 = <span class="font-bold text-rose-700">$9,200 · profit $1,840</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> quote $9,200 — squarely inside the $8,000–$15,000 national range for a full system, with a real 20% margin locked in.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-rose-100 text-rose-700 font-bold"
                >2</span
              >
              <h3 class="text-lg font-bold text-slate-900">Small repair job — high margin, low ticket</h3>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              4 hrs × $125 · no equipment · $200 materials · 10% overhead · 30% margin.
            </p>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              direct = 500 + 0 + 200 = $700<br />
              break-even = 700 × 1.10 = $770<br />
              price = 770 ÷ 0.70 = <span class="font-bold text-rose-700">$1,100 · profit $330</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> $1,100. Short jobs carry higher margins because drive time, diagnosis risk, and callbacks eat a bigger share of small tickets.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-rose-100 text-rose-700 font-bold"
                >3</span
              >
              <h3 class="text-lg font-bold text-slate-900">The markup mistake — same job, $368 less</h3>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              Same $7,360 break-even as example 1, but priced with a 20% <em>markup</em> instead of a 20% <em>margin</em>.
            </p>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              markup: 7,360 × 1.20 = $8,832 → profit $1,472 (16.7% actual margin)<br />
              margin: 7,360 ÷ 0.80 = $9,200 → profit $1,840 (true 20%)<br />
              difference = <span class="font-bold text-rose-700">$368 lost per job to the markup shortcut</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> at 100 installs a year, pricing by markup instead of margin quietly gives away <strong>$36,800 annually</strong>. The calculator above always uses true margin.
            </p>
          </div>
        </div>
      </section>

      <CalculatorFaqSection
        faqs={faqs}
        accent="rose"
        subtitle="Common questions about pricing HVAC jobs."
      />

      <CalculatorTradesQuoteCta heading={ctaHeading} description={ctaDescription} />
      <HvacRelatedCalculators calculators={relatedCalculators} accent="rose" />
    </main>

    <Footer />
  </div>

