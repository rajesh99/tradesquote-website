---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import HvacRelatedCalculators from "@/components/HvacRelatedCalculators.astro";
import CalculatorBreadcrumb from "@/components/CalculatorBreadcrumb.astro";
import CalculatorFaqSection from "@/components/CalculatorFaqSection.astro";
import CalculatorTradesQuoteCta from "@/components/CalculatorTradesQuoteCta.astro";
import { buildFaqPageSchema, type CalculatorFaq } from "@/lib/calculatorFaq";

const title = "HVAC Fan Laws Calculator — CFM, Static Pressure & BHP at New RPM | TradesQuote";
const description =
  "Free HVAC fan laws calculator. Enter baseline CFM, static pressure, brake horsepower, and RPM, then predict performance at a new blower speed using fan affinity laws. Instant, no sign-up.";

const pageUrl = "https://www.tradesquote.ai/calculators/hvac/hvac-fan-laws-calculator";

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://www.tradesquote.ai/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://www.tradesquote.ai/calculators" },
    { "@type": "ListItem", position: 3, name: "HVAC", item: "https://www.tradesquote.ai/calculators/hvac" },
    { "@type": "ListItem", position: 4, name: "Fan Laws Calculator", item: pageUrl },
  ],
};

const webAppData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "HVAC Fan Laws Calculator",
  url: pageUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (web-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description:
    "Free online HVAC fan laws calculator that applies fan affinity laws to predict CFM, static pressure, and brake horsepower when blower RPM changes from a known operating point.",
};

const faqs: CalculatorFaq[] = [
  {
    question: "What are the fan affinity laws?",
    answer:
      "The fan affinity laws relate blower speed (RPM) to airflow and power on a fixed duct system: <strong>CFM changes linearly with RPM</strong>, <strong>static pressure changes with the square of RPM</strong>, and <strong>brake horsepower changes with the cube of RPM</strong>. They assume the same fan, same duct geometry, and the same air density.",
  },
  {
    question: "What happens to CFM if I slow the blower 10%?",
    answer:
      "CFM drops by the same percentage. A <strong>10% RPM reduction</strong> (ratio 0.9) cuts airflow from 1,200 CFM to <strong>1,080 CFM</strong>. Static pressure falls to 81% of the original (0.9²) and brake horsepower to about 73% (0.9³) — less power, but also less delivered airflow.",
  },
  {
    question: "When should I use fan laws on an HVAC job?",
    answer:
      "Use them when you know performance at one blower tap or speed and need to estimate another — for example after <strong>changing blower speed to fix high TESP</strong>, sizing a ECM speed reduction, or predicting what a 10% slowdown does to airflow before you commit to a duct modification.",
  },
  {
    question: "Do fan laws work if I change the duct system?",
    answer:
      "No — affinity laws assume <strong>the same fan on the same duct system</strong> with only speed changing. Adding a larger return, replacing flex with hard pipe, or opening dampers changes the system curve itself. Fan laws predict speed changes only, not duct redesign.",
  },
  {
    question: "How do fan laws relate to static pressure?",
    answer:
      "Static pressure scales with the <strong>square of speed</strong>. Slowing the blower 10% drops TESP to 81% of the original — often enough to bring a borderline system back under the nameplate limit. Pair fan-law predictions with actual TESP readings from the <strong>static pressure calculator</strong>.",
  },
  {
    question: "Can I use fan laws to size a new blower motor?",
    answer:
      "Fan laws estimate <strong>brake horsepower at a new speed</strong> from a known operating point — useful for checking whether a motor has headroom. They do not replace manufacturer fan curves, belt losses, or drive efficiency. Always verify amp draw and TESP in the field after any speed change.",
  },
];
const faqData = buildFaqPageSchema(faqs);

const ctaHeading = "Sized the blower change? Quote the repair in seconds.";
const ctaDescription =
  "Fan-law numbers tell you what the blower will do at the new speed — TradesQuote turns the repair into a detailed, line-item estimate in seconds. Describe the blower speed change, motor swap, or duct fix (or upload photos), and our AI builds quantities, unit prices, and totals, validated by a built-in quality control agent.";

const relatedCalculators = [
  {
    href: "/calculators/hvac/hvac-static-pressure-calculator",
    title: "Static Pressure Calculator",
    description: "Total TESP and compare to equipment max.",
  },
  {
    href: "/calculators/hvac/hvac-cfm-calculator",
    title: "CFM Calculator",
    description: "Target airflow per room and per ton.",
  },
  {
    href: "/calculators/hvac/hvac-duct-size-calculator",
    title: "Duct Size Calculator",
    description: "Right-size trunk and branch ducts.",
  },
  {
    href: "/calculators/hvac/hvac-delta-t-calculator",
    title: "Delta T Calculator",
    description: "Temperature split flags airflow problems.",
  },
];
---

<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="HVAC Fan Laws Calculator — CFM, Static Pressure & BHP at New RPM" />
    <meta
      property="og:description"
      content="Predict CFM, static pressure, and brake horsepower at a new blower RPM using fan affinity laws. Free and instant."
    />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="TradesQuote" />
    <meta property="og:image" content="https://www.tradesquote.ai/logo.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="HVAC Fan Laws Calculator — CFM, Static Pressure & BHP at New RPM" />
    <meta
      name="twitter:description"
      content="Apply fan affinity laws to predict blower performance at a new RPM. Free, instant, no sign-up."
    />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  </Fragment>

  <div class="bg-white min-h-screen text-slate-700">
    <Header />

    <main>
      <!-- ============================ HERO + H1 + INTRO ============================ -->
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-6">
          <CalculatorBreadcrumb
            category="HVAC"
            categoryHref="/calculators/hvac"
            current="Fan Laws Calculator"
          />

          <div class="max-w-3xl">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                ></path>
              </svg>
              HVAC Tools · Airflow · Free
            </span>

            <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
              Fan Laws Calculator <span class="text-blue-600">— Free Online Calculator</span>
            </h1>

            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              Fan affinity laws tell you exactly what happens to airflow, static pressure, and brake horsepower when
              you change blower speed — essential when you're deciding whether to drop a tap to fix high TESP or
              predict performance after a motor speed change. Enter your known operating point and the new RPM; this
              tool applies the three affinity laws and shows predicted CFM, static pressure, and BHP instantly.
            </p>
          </div>
        </div>
      </section>

      <!-- ============================ THE INTERACTIVE CALCULATOR ============================ -->
      <section id="calculator" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12">
        <div class="mx-auto max-w-5xl rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
              <svg
                class="h-5 w-5 text-blue-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M12 17h.01M9 14h.01M12 14h.01M15 14h.01M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"
                ></path>
              </svg>
              Enter baseline blower performance
            </h2>

          <div class="mt-6 lg:grid lg:grid-cols-2 lg:gap-8 lg:items-start">
          <div class="space-y-6">
<div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="fl-cfm1" class="text-sm font-semibold text-slate-800">Baseline CFM</label>
                  <input
                    id="fl-cfm1"
                    type="number"
                    min="0"
                    max="10000"
                    step="10"
                    value="1200"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">Known airflow at the current blower speed.</p>
                </div>

                <div>
                  <label for="fl-sp1" class="text-sm font-semibold text-slate-800"
                    >Baseline static pressure (in. w.c.)</label
                  >
                  <input
                    id="fl-sp1"
                    type="number"
                    min="0"
                    max="3"
                    step="0.01"
                    value="0.50"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">TESP or fan static at the baseline speed.</p>
                </div>

                <div>
                  <label for="fl-bhp1" class="text-sm font-semibold text-slate-800">Baseline brake HP (BHP)</label>
                  <input
                    id="fl-bhp1"
                    type="number"
                    min="0"
                    max="20"
                    step="0.01"
                    value="0.75"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">From nameplate, fan curve, or measured amp draw.</p>
                </div>

                <div>
                  <label for="fl-rpm1" class="text-sm font-semibold text-slate-800">Baseline RPM</label>
                  <input
                    id="fl-rpm1"
                    type="number"
                    min="1"
                    max="5000"
                    step="10"
                    value="1200"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">Current blower speed (measured or nameplate).</p>
                </div>

                <div class="sm:col-span-2">
                  <label for="fl-rpm2" class="text-sm font-semibold text-slate-800">New RPM (target speed)</label>
                  <input
                    id="fl-rpm2"
                    type="number"
                    min="0"
                    max="5000"
                    step="10"
                    value="1080"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">
                    Proposed blower speed — e.g. one tap lower on a multi-speed motor.
                  </p>
                </div>
              </div>

              <button
                id="resetBtn"
                type="button"
                class="text-sm font-medium text-slate-500 hover:text-blue-600 transition flex items-center gap-1.5"
              >
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                  ></path>
                </svg>
                Reset to defaults
              </button>
          </div>

          <!-- Results -->
          <div class="mt-6 lg:mt-0 rounded-xl border border-blue-100 bg-blue-50 p-5 sm:p-6">

              <p class="text-sm font-medium text-slate-600">Predicted CFM at new speed</p>
              <div class="mt-2 flex items-baseline gap-2">
                <span id="fl-cfm2" class="text-5xl font-extrabold tracking-tight text-blue-600">1,080 CFM</span>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-xl border border-blue-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Static pressure</p>
                  <p id="fl-sp2" class="mt-1 text-2xl font-bold text-slate-900">0.41 in. w.c.</p>
                </div>
                <div class="rounded-xl border border-blue-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Brake HP</p>
                  <p id="fl-bhp2" class="mt-1 text-2xl font-bold text-slate-900">0.55 BHP</p>
                </div>
              </div>

              <div class="mt-3 rounded-xl border border-blue-100 bg-white p-4">
                <p class="text-xs text-slate-500">Speed ratio (RPM₂ ÷ RPM₁)</p>
                <p id="fl-ratio" class="mt-1 text-2xl font-bold text-slate-900">0.90</p>
              </div>

              <div class="mt-3 rounded-xl border border-blue-100 bg-white p-4">
                <p class="text-xs text-slate-500">What this means</p>
                <p id="fl-status" class="mt-1 text-sm font-medium leading-snug">
                  Speed reduced — slower blower speed lowers CFM and static pressure proportionally.
                </p>
              </div>

              <!-- Breakdown -->
              <details class="group mt-5 rounded-xl border border-blue-100 bg-white">
                <summary
                  class="flex items-center justify-between cursor-pointer px-4 py-3 text-sm font-semibold text-slate-800"
                >
                  See the breakdown
                  <svg
                    class="h-4 w-4 text-slate-500 transition-transform group-open:rotate-180"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="px-4 pb-4 text-sm space-y-1.5 text-slate-600">
                  <div class="flex justify-between">
                    <span>Baseline CFM</span><span id="fl-bd-cfm1" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Baseline static pressure</span><span id="fl-bd-sp1" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Baseline BHP</span><span id="fl-bd-bhp1" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div
                    class="flex justify-between border-t border-slate-200 pt-1.5 mt-1.5 text-slate-900"
                  >
                    <span class="font-bold text-slate-900">Speed ratio</span><span id="fl-bd-ratio" class="font-bold text-slate-900">—</span>
                  </div>
                </div>
              </details>

              <p class="mt-4 text-xs text-slate-500 leading-relaxed">
                Affinity laws assume the same fan and duct system with only speed changing. Verify predicted CFM and
                TESP in the field after any blower speed adjustment.
              </p>
            
          </div>
          </div>
        </div>

        <!-- Reference table -->
        <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">Fan laws at common speed ratios</h2>
          <p class="mt-2 text-sm text-slate-500">
            Baseline: 1,200 CFM · 0.50 in. w.c. · 0.75 BHP at 1,200 RPM. Same fan, same duct — only speed changes.
          </p>
          <div class="mt-5 overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-500">
                  <th class="py-2.5 pr-4 font-semibold">Speed ratio</th>
                  <th class="py-2.5 pr-4 font-semibold">CFM</th>
                  <th class="py-2.5 pr-4 font-semibold">Static pressure</th>
                  <th class="py-2.5 font-semibold">Brake HP</th>
                </tr>
              </thead>
              <tbody class="text-slate-700">
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">0.80 (−20%)</td>
                  <td class="py-2.5 pr-4">960 CFM</td>
                  <td class="py-2.5 pr-4">0.32 in. w.c.</td>
                  <td class="py-2.5">0.38 BHP</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">0.90 (−10%)</td>
                  <td class="py-2.5 pr-4">1,080 CFM</td>
                  <td class="py-2.5 pr-4">0.41 in. w.c.</td>
                  <td class="py-2.5">0.55 BHP</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">1.00 (baseline)</td>
                  <td class="py-2.5 pr-4">1,200 CFM</td>
                  <td class="py-2.5 pr-4">0.50 in. w.c.</td>
                  <td class="py-2.5">0.75 BHP</td>
                </tr>
                <tr>
                  <td class="py-2.5 pr-4 font-semibold">1.10 (+10%)</td>
                  <td class="py-2.5 pr-4">1,320 CFM</td>
                  <td class="py-2.5 pr-4">0.61 in. w.c.</td>
                  <td class="py-2.5">1.00 BHP</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-xs text-slate-500">
            Sources &amp; standards: ACCA Manual D (residential duct design and blower performance) · Manufacturer
            fan curves and nameplate data · ASHRAE Handbook — HVAC Systems and Equipment (fan affinity laws).
          </p>
        </div>
      </section>

      <!-- ============================ FORMULA EXPLAINED ============================ -->
      <section class="bg-slate-50 border-y border-slate-200">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">
            The formula, explained in plain English
          </h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Fan affinity laws describe how a centrifugal blower behaves when you change only its speed on a fixed duct
            system. The speed ratio is the new RPM divided by the original RPM — every other quantity scales from that
            single number.
          </p>

          <div
            class="mt-8 rounded-2xl bg-slate-900 p-6 sm:p-8 text-slate-100 font-mono text-sm leading-relaxed overflow-x-auto"
          >
            <div class="text-blue-300"># Speed ratio:</div>
            <div>ratio&nbsp;=&nbsp;RPM₂ ÷ RPM₁</div>
            <div class="mt-4 text-blue-300"># Fan affinity laws:</div>
            <div>CFM₂&nbsp;=&nbsp;CFM₁ × ratio</div>
            <div>SP₂&nbsp;=&nbsp;SP₁ × ratio²</div>
            <div>BHP₂&nbsp;=&nbsp;BHP₁ × ratio³</div>
            <div class="mt-4 text-blue-300"># Example (defaults):</div>
            <div>
              1,200 → 1,080 RPM → ratio 0.90 →{" "}
              <span class="text-amber-300">1,080 CFM · 0.41 SP · 0.55 BHP</span>
            </div>
          </div>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">CFM is linear</h3>
              <p class="mt-2 text-sm text-slate-600">
                Airflow tracks speed one-for-one. Drop RPM 10% and you lose 10% of your CFM — critical when checking
                whether a slower tap still delivers 400 CFM/ton.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Static pressure is squared</h3>
              <p class="mt-2 text-sm text-slate-600">
                TESP falls faster than CFM when you slow down — a 10% speed cut drops static pressure 19%. That is why
                lowering blower speed is a common fix for borderline duct restrictions.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Power is cubed</h3>
              <p class="mt-2 text-sm text-slate-600">
                Brake horsepower drops steeply at lower speeds — 0.9³ ≈ 0.73, so a 10% slowdown saves roughly 27% of
                blower power. Speeding up has the opposite effect and can overload the motor.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Same system only</h3>
              <p class="mt-2 text-sm text-slate-600">
                These laws apply when the fan and duct geometry stay the same. Duct modifications, filter changes, or
                damper adjustments change the system curve — use fan laws for speed changes, not duct redesign.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================ WORKED EXAMPLES ============================ -->
      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Worked examples</h2>
        <p class="mt-4 text-slate-600">
          Three blower speed changes from a 3-ton system baseline: 1,200 CFM, 0.50 in. w.c., 0.75 BHP at 1,200 RPM.
        </p>

        <div class="mt-8 space-y-6">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-blue-100 text-blue-700 font-bold"
                >1</span
              >
              <h3 class="text-lg font-bold text-slate-900">10% slowdown — 1,200 → 1,080 RPM</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              ratio = 1,080 ÷ 1,200 = 0.90<br />
              CFM₂ = 1,200 × 0.90 = <span class="font-bold text-blue-700">1,080 CFM</span><br />
              SP₂ = 0.50 × 0.90² = <span class="font-bold text-blue-700">0.41 in. w.c.</span><br />
              BHP₂ = 0.75 × 0.90³ = <span class="font-bold text-blue-700">0.55 BHP</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> a common tap-down to relieve borderline TESP —
              airflow drops 120 CFM but static pressure falls from 0.50 to 0.41 in. w.c., often enough to get under a
              0.5 nameplate limit.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-blue-100 text-blue-700 font-bold"
