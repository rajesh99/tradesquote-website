---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import HvacRelatedCalculators from "@/components/HvacRelatedCalculators.astro";
import CalculatorBreadcrumb from "@/components/CalculatorBreadcrumb.astro";
import CalculatorFaqSection from "@/components/CalculatorFaqSection.astro";
import CalculatorTradesQuoteCta from "@/components/CalculatorTradesQuoteCta.astro";
import { buildFaqPageSchema, type CalculatorFaq } from "@/lib/calculatorFaq";

const title = "Furnace Replacement Cost Calculator — Free New Furnace Price Estimator | TradesQuote";
const description =
  "Free furnace replacement cost calculator. Estimate the installed cost of a new gas, electric, oil, or propane furnace — by size (BTU), AFUE efficiency, replacement vs. new install, and region. Instant, no sign-up.";

const pageUrl = "https://www.tradesquote.ai/calculators/hvac/hvac-furnace-replacement-cost-calculator";

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://www.tradesquote.ai/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://www.tradesquote.ai/calculators" },
    { "@type": "ListItem", position: 3, name: "HVAC", item: "https://www.tradesquote.ai/calculators/hvac" },
    { "@type": "ListItem", position: 4, name: "Furnace Replacement Cost Calculator", item: pageUrl },
  ],
};

const webAppData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Furnace Replacement Cost Calculator",
  url: pageUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (web-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description:
    "Free online furnace replacement cost calculator that estimates the installed price of a new gas, electric, oil, or propane furnace based on size in BTU, AFUE efficiency tier, replacement-vs-new-install scope, and regional labor market.",
};

const faqs: CalculatorFaq[] = [
  {
    question: "How much does it cost to replace a furnace?",
    answer:
      "A new furnace typically runs <strong>$3,500 to $7,500 installed</strong> for a standard gas unit, with about $5,000 as a national mid-point. Electric furnaces are cheaper to install (~$3,500), while oil and high-efficiency condensing gas furnaces run higher.",
  },
  {
    question: "How much does a high-efficiency furnace cost?",
    answer:
      "A 95–98% AFUE condensing gas furnace costs roughly <strong>20–25% more</strong> than an 80% model — typically $6,000 to $9,000 installed — because it adds a secondary heat exchanger and needs new PVC venting and a condensate drain. Utility rebates and tax credits often offset part of the premium.",
  },
  {
    question: "Is it cheaper to replace the furnace and AC together?",
    answer:
      'Yes. Replacing both at once shares the labor, permit, and startup visit, so a combined system costs less than two separate jobs. Price the full system or AC side with the <a href="/calculators/hvac/hvac-replacement-cost-calculator" class="font-semibold text-orange-700 underline decoration-orange-300 hover:decoration-orange-600">HVAC Replacement Cost Calculator</a>.',
  },
  {
    question: "What size furnace do I need, and does size change the price?",
    answer:
      'Furnaces are sized in BTU input — most homes need 60,000 to 100,000 BTU. Bigger units cost a bit more, but labor dominates, so the size factor only spans about 0.9–1.15. Size it properly with the <a href="/calculators/hvac/hvac-furnace-btu-calculator" class="font-semibold text-orange-700 underline decoration-orange-300 hover:decoration-orange-600">Furnace BTU Calculator</a> before buying.',
  },
  {
    question: "Should I repair or replace my furnace?",
    answer:
      "Replace if the furnace is <strong>over 15–20 years old, the heat exchanger is cracked, or repairs exceed about a third of replacement cost</strong>. A one-off igniter or flame sensor on a younger unit is worth repairing; repeated failures on an old furnace are money better spent on a new one.",
  },
  {
    question: "Why is a new-install furnace more expensive than a replacement?",
    answer:
      "A straight replacement reuses the existing gas line, venting, ducts, and electrical. A first-time or relocated install adds gas-line and venting runs, a new flue or PVC, and electrical work — which is why this calculator adds about 15% for a new install versus a like-for-like swap.",
  },
];
const faqData = buildFaqPageSchema(faqs);

const ctaHeading = "Quoting a furnace swap? Price it line by line in seconds.";
const ctaDescription =
  "This page gives homeowners a budget — TradesQuote gives contractors the winning quote. Describe the furnace job or upload photos, and our AI builds a line-item estimate: equipment, labor, venting, gas, and disposal, with quantities and unit prices validated by a built-in quality control agent.";

const relatedCalculators = [
  {
    href: "/calculators/hvac/hvac-replacement-cost-calculator",
    title: "Replacement Cost Calculator",
    description: "Price a full system, AC, heat pump, or mini-split.",
  },
  {
    href: "/calculators/hvac/hvac-ac-installation-cost-calculator",
    title: "AC Installation Cost",
    description: "Installed cost of new central air or a heat pump.",
  },
  {
    href: "/calculators/hvac/hvac-furnace-btu-calculator",
    title: "Furnace BTU Calculator",
    description: "Size the furnace by climate zone and AFUE.",
  },
  {
    href: "/calculators/hvac/hvac-afue-savings-calculator",
    title: "AFUE Savings Calculator",
    description: "Is a 95% AFUE furnace worth the extra cost?",
  },
];
---

<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Furnace Replacement Cost Calculator — Free New Furnace Price Estimator" />
    <meta
      property="og:description"
      content="Estimate the installed cost of a new gas, electric, oil, or propane furnace — by size, AFUE efficiency, scope, and region. Free and instant."
    />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="TradesQuote" />
    <meta property="og:image" content="https://www.tradesquote.ai/logo.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Furnace Replacement Cost Calculator — Free Price Estimator" />
    <meta
      name="twitter:description"
      content="Estimate the installed cost of a new gas, electric, or high-efficiency furnace. Free, no sign-up."
    />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  </Fragment>

  <div class="bg-white min-h-screen text-slate-700">
    <Header />

    <main>
      <!-- ============================ HERO + H1 + INTRO ============================ -->
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-6">
          <CalculatorBreadcrumb category="HVAC" categoryHref="/calculators/hvac" current="Furnace Replacement Cost Calculator" />

          <div class="max-w-3xl">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-orange-100 px-3 py-1 text-xs font-semibold text-orange-700">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>
              HVAC Tools · Cost · Free
            </span>

            <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
              Furnace Replacement Cost Calculator <span class="text-orange-600">— Free Estimator</span>
            </h1>

            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              This furnace replacement cost calculator estimates what a new furnace costs to install — gas, electric,
              oil, or propane — adjusted for size in BTU, AFUE efficiency tier, whether it's a straight replacement or
              a new install, and your local labor market. Use it to budget a furnace replacement before you collect
              quotes, or to sanity-check the prices you already have.
            </p>

            <div class="mt-6 flex items-start gap-3 rounded-xl border border-orange-100 bg-orange-50 p-4">
              <svg class="h-5 w-5 shrink-0 text-orange-600 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <p class="text-sm text-slate-600">
                <span class="font-semibold text-slate-900">Replacing the AC too?</span>
                A combined system is cheaper than two jobs — price the whole thing with the
                <a href="/calculators/hvac/hvac-replacement-cost-calculator" class="font-semibold text-orange-700 underline decoration-orange-300 hover:decoration-orange-600">HVAC Replacement Cost Calculator</a>.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================ THE INTERACTIVE CALCULATOR ============================ -->
      <section id="calculator" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12 pt-4">
        <div class="grid lg:grid-cols-5 gap-6">

          <!-- Inputs -->
          <div class="lg:col-span-3 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
            <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
              <svg class="h-5 w-5 text-orange-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M12 17h.01M9 14h.01M12 14h.01M15 14h.01M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
              Describe the furnace job
            </h2>

            <div class="mt-6 space-y-5">
              <!-- Fuel type -->
              <div>
                <label for="furnType" class="text-sm font-semibold text-slate-800">Furnace type / fuel</label>
                <select id="furnType"
                  class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none">
                  <option value="5000" selected>Gas furnace</option>
                  <option value="3500">Electric furnace</option>
                  <option value="5500">Propane (LP) furnace</option>
                  <option value="6800">Oil furnace</option>
                </select>
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <!-- Size -->
                <div>
                  <label for="furnSize" class="text-sm font-semibold text-slate-800">Furnace size (BTU input)</label>
                  <select id="furnSize"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none">
                    <option value="40000">40,000 BTU (small home)</option>
                    <option value="60000">60,000 BTU</option>
                    <option value="80000" selected>80,000 BTU (typical)</option>
                    <option value="100000">100,000 BTU</option>
                    <option value="120000">120,000 BTU (large home)</option>
                  </select>
                </div>

                <!-- Efficiency -->
                <div>
                  <label for="furnEff" class="text-sm font-semibold text-slate-800">Efficiency (AFUE)</label>
                  <select id="furnEff"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none">
                    <option value="1.0" selected>80% AFUE — standard</option>
                    <option value="1.1">90–92% AFUE — mid (+10%)</option>
                    <option value="1.22">95–98% AFUE — condensing (+22%)</option>
                  </select>
                </div>

                <!-- Project type -->
                <div>
                  <label for="furnProject" class="text-sm font-semibold text-slate-800">Project type</label>
                  <select id="furnProject"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none">
                    <option value="1.0" selected>Replacing an existing furnace</option>
                    <option value="1.15">New install / relocation (+15%)</option>
                  </select>
                </div>

                <!-- Labor market -->
                <div>
                  <label for="furnMarket" class="text-sm font-semibold text-slate-800">Local labor market</label>
                  <select id="furnMarket"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none">
                    <option value="0.9">Low-cost area (×0.9)</option>
                    <option value="1.0" selected>National average (×1.0)</option>
                    <option value="1.2">High-cost metro (×1.2)</option>
                  </select>
                </div>
              </div>

              <button id="resetBtn"
                class="text-sm font-medium text-slate-500 hover:text-orange-600 transition flex items-center gap-1.5">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                Reset to defaults
              </button>
            </div>
          </div>

          <!-- Results -->
          <div class="lg:col-span-2">
            <div class="lg:sticky lg:top-24 rounded-2xl bg-gradient-to-br from-orange-600 to-amber-500 p-6 sm:p-8 text-white shadow-lg">
              <p class="text-sm font-medium text-orange-100">Estimated installed cost</p>
              <div class="mt-2">
                <span id="rangeResult" class="text-4xl sm:text-[2.6rem] leading-tight font-extrabold tracking-tight">$4,250 – $5,750</span>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-xl bg-white/15 p-4">
                  <p class="text-xs text-orange-100">Typical mid-point</p>
                  <p id="midResult" class="mt-1 text-2xl font-bold">$5,000</p>
                </div>
                <div class="rounded-xl bg-white/15 p-4">
                  <p class="text-xs text-orange-100">If 95% AFUE</p>
                  <p id="effResult" class="mt-1 text-2xl font-bold">$6,100</p>
                </div>
              </div>

              <!-- Breakdown -->
              <details class="group mt-5 rounded-xl bg-white/10">
                <summary class="flex items-center justify-between cursor-pointer px-4 py-3 text-sm font-semibold">
                  See the breakdown
                  <svg class="h-4 w-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-4 pb-4 text-sm space-y-1.5 text-orange-50">
                  <div class="flex justify-between"><span>Base price (fuel type)</span><span id="bd-base" class="font-semibold">—</span></div>
                  <div class="flex justify-between"><span>Size adjustment</span><span id="bd-size" class="font-semibold">—</span></div>
                  <div class="flex justify-between"><span>Efficiency tier</span><span id="bd-eff" class="font-semibold">—</span></div>
                  <div class="flex justify-between"><span>Project type</span><span id="bd-project" class="font-semibold">—</span></div>
                  <div class="flex justify-between"><span>Labor market</span><span id="bd-market" class="font-semibold">—</span></div>
                  <div class="flex justify-between border-t border-white/20 pt-1.5 mt-1.5 text-white"><span class="font-bold">Mid-point estimate</span><span id="bd-total" class="font-bold">—</span></div>
                </div>
              </details>

              <p class="mt-4 text-xs text-orange-100 leading-relaxed">
                National 2026 ballparks for budgeting — furnace, labor, venting, and permit included.
                Your local line-item quotes are the real number; use this to sanity-check them.
              </p>
            </div>
          </div>
        </div>

        <!-- Reference table -->
        <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">Typical furnace replacement costs (quick reference)</h2>
          <p class="mt-2 text-sm text-slate-500">National installed-price ranges for a standard-efficiency (80% AFUE) furnace, straight replacement. High-efficiency 95%+ condensing models add roughly 20–25%.</p>
          <div class="mt-5 overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-500">
                  <th class="py-2.5 pr-4 font-semibold">Furnace type</th>
                  <th class="py-2.5 pr-4 font-semibold">Low</th>
                  <th class="py-2.5 pr-4 font-semibold">Typical</th>
                  <th class="py-2.5 font-semibold">High</th>
                </tr>
              </thead>
              <tbody class="text-slate-700">
                <tr class="border-b border-slate-100"><td class="py-2.5 pr-4 font-semibold">Gas furnace</td><td class="py-2.5 pr-4">$3,000</td><td class="py-2.5 pr-4">$5,000</td><td class="py-2.5">$7,500</td></tr>
                <tr class="border-b border-slate-100"><td class="py-2.5 pr-4 font-semibold">Electric furnace</td><td class="py-2.5 pr-4">$2,000</td><td class="py-2.5 pr-4">$3,500</td><td class="py-2.5">$5,500</td></tr>
                <tr class="border-b border-slate-100"><td class="py-2.5 pr-4 font-semibold">Propane (LP) furnace</td><td class="py-2.5 pr-4">$3,500</td><td class="py-2.5 pr-4">$5,500</td><td class="py-2.5">$8,000</td></tr>
                <tr class="border-b border-slate-100"><td class="py-2.5 pr-4 font-semibold">Oil furnace</td><td class="py-2.5 pr-4">$5,000</td><td class="py-2.5 pr-4">$6,800</td><td class="py-2.5">$10,000</td></tr>
                <tr><td class="py-2.5 pr-4 font-semibold">High-efficiency (95%+) add</td><td class="py-2.5 pr-4">+15%</td><td class="py-2.5 pr-4">+22%</td><td class="py-2.5">+25%</td></tr>
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-xs text-slate-500">Ranges reflect typical 2026 national pricing for residential jobs and vary by brand, region, and site conditions. Always compare multiple line-item quotes.</p>
        </div>
      </section>

      <!-- ============================ FORMULA EXPLAINED ============================ -->
      <section class="bg-slate-50 border-y border-slate-200">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">The formula, explained in plain English</h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Furnace pricing is a base price for the fuel type, scaled by size and efficiency, then adjusted for a new
            install versus a replacement and your local labor rates.
          </p>

          <div class="mt-8 rounded-2xl bg-slate-900 p-6 sm:p-8 text-slate-100 font-mono text-sm leading-relaxed overflow-x-auto">
            <div class="text-orange-300"># Step 1 — Start from the fuel type's base price</div>
            <div>base&nbsp;=&nbsp;gas <span class="text-amber-300">$5,000</span> · electric <span class="text-amber-300">$3,500</span> · propane <span class="text-amber-300">$5,500</span> · oil <span class="text-amber-300">$6,800</span></div>
            <div class="mt-4 text-orange-300"># Step 2 — Scale for size and efficiency</div>
            <div>cost&nbsp;=&nbsp;base × size factor (<span class="text-amber-300">0.9–1.15</span>) × AFUE tier (<span class="text-amber-300">1.0–1.22</span>)</div>
            <div class="mt-4 text-orange-300"># Step 3 — Adjust for scope and market</div>
            <div>total&nbsp;=&nbsp;cost × project (<span class="text-amber-300">1.0–1.15</span>) × market (<span class="text-amber-300">0.9–1.2</span>)</div>
            <div class="mt-4 text-orange-300"># Step 4 — Show it as a range, not a fake-precise number</div>
            <div>range&nbsp;=&nbsp;total × <span class="text-amber-300">0.85</span> … total × <span class="text-amber-300">1.15</span></div>
          </div>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Why fuel type sets the base</h3>
              <p class="mt-2 text-sm text-slate-600">Electric furnaces are simplest and cheapest to install; oil furnaces cost the most up front. Gas sits in the middle and is the most common replacement.</p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Why 95% AFUE adds ~22%</h3>
              <p class="mt-2 text-sm text-slate-600">Condensing furnaces add a secondary heat exchanger and require PVC venting plus a condensate drain — more equipment and labor, repaid through lower gas bills.</p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Why size barely moves the price</h3>
              <p class="mt-2 text-sm text-slate-600">A 100,000 BTU furnace costs only a little more than a 60,000 BTU one — labor is the same, so the size factor spans just 0.9–1.15.</p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Don't forget rebates</h3>
              <p class="mt-2 text-sm text-slate-600">High-efficiency gas furnaces often qualify for utility rebates and federal tax credits that claw back part of the efficiency premium.</p>
            </div>
          </div>
        </div>
      </section>

      <CalculatorFaqSection
        faqs={faqs}
        accent="orange"
        subtitle="Common questions about furnace replacement pricing."
      />

      <CalculatorTradesQuoteCta heading={ctaHeading} description={ctaDescription} />
      <HvacRelatedCalculators calculators={relatedCalculators} accent="orange" />
    </main>

    <Footer />
  </div>

  <script>
    import { initHvacFurnaceReplacementCostCalculator } from "@/scripts/calculators/hvac-furnace-replacement-cost-calculator";
    initHvacFurnaceReplacementCostCalculator();
  </script>
</Layout>
