---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import HvacRelatedCalculators from "@/components/HvacRelatedCalculators.astro";
import CalculatorBreadcrumb from "@/components/CalculatorBreadcrumb.astro";
import CalculatorFaqSection from "@/components/CalculatorFaqSection.astro";
import CalculatorTradesQuoteCta from "@/components/CalculatorTradesQuoteCta.astro";
import { buildFaqPageSchema, type CalculatorFaq } from "@/lib/calculatorFaq";

const title = "Subcooling Calculator — HVAC Refrigerant Charge Check | TradesQuote";
const description =
  "Free HVAC subcooling calculator. Measure subcooling from liquid line saturation temperature and liquid line temperature, with TXV and piston metering targets. Instant, no sign-up.";

const pageUrl = "https://tradesquote.ai/calculators/hvac/hvac-subcooling-calculator";

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://tradesquote.ai/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://tradesquote.ai/calculators" },
    { "@type": "ListItem", position: 3, name: "HVAC", item: "https://tradesquote.ai/calculators/hvac" },
    { "@type": "ListItem", position: 4, name: "Subcooling Calculator", item: pageUrl },
  ],
};

const webAppData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "HVAC Subcooling Calculator",
  url: pageUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (web-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description:
    "Free online HVAC subcooling calculator that computes measured subcooling from liquid saturation and liquid line temperatures, compares it to TXV or piston targets, and explains likely causes when the reading is off.",
};

const faqs: CalculatorFaq[] = [
  {
    question: "What should subcooling be on my AC?",
    answer:
      "For a <strong>TXV system, target 8–12°F</strong> of subcooling at the liquid line. For a <strong>piston (fixed-orifice) system</strong>, the typical band is <strong>10–15°F</strong>. Always confirm against the manufacturer's charging chart for your refrigerant and conditions.",
  },
  {
    question: "How do I calculate subcooling?",
    answer:
      "Read the liquid line pressure and convert it to saturation temperature on a PT chart, clamp a thermometer on the liquid line, then subtract: <strong>subcooling = liquid line saturation temp − liquid line temp</strong>.",
  },
  {
    question: "What does low subcooling mean?",
    answer:
      "Low subcooling means the liquid line is too close to saturation — usually <strong>undercharge, a dirty condenser, or poor heat rejection</strong>. The condenser isn't stacking enough liquid before it reaches the metering device.",
  },
  {
    question: "What does high subcooling mean?",
    answer:
      "High subcooling means excess refrigerant is cooled below saturation in the liquid line — typically <strong>overcharge</strong>, a restricted metering device, or unusually cool ambient conditions adding extra subcooling.",
  },
  {
    question: "Do I use subcooling or superheat to charge a TXV system?",
    answer:
      "Charge a <strong>TXV system by subcooling</strong> as the primary method — the expansion valve controls superheat automatically. Check superheat afterward as a cross-check that the evaporator is fed properly.",
  },
  {
    question: "Where on the liquid line should I measure?",
    answer:
      "Clamp the thermometer on the liquid line <strong>6–12 inches before the metering device</strong>, away from the condenser outlet and service valve so you read stable liquid temperature, not mixed gas.",
  },
];
const faqData = buildFaqPageSchema(faqs);

const ctaHeading = "Charge dialed in? Quote the repair in seconds.";
const ctaDescription =
  "Subcooling confirms the liquid side — TradesQuote turns the whole job into a detailed, line-item estimate in seconds. Describe the work or upload photos, and our AI builds quantities, unit prices, and totals, validated by a built-in quality control agent.";

const relatedCalculators = [
  {
    href: "/calculators/hvac/hvac-superheat-calculator",
    title: "Superheat Calculator",
    description: "Verify evaporator-side charge on fixed-orifice systems.",
  },
  {
    href: "/calculators/hvac/hvac-delta-t-calculator",
    title: "Delta T Calculator",
    description: "Screen airflow and capacity with a temperature split.",
  },
  {
    href: "/calculators/hvac/hvac-target-superheat-calculator",
    title: "Target Superheat Calculator",
    description: "Chart target superheat for piston meters.",
  },
  {
    href: "/calculators/hvac/hvac-refrigerant-charge-calculator",
    title: "Refrigerant Charge Calculator",
    description: "Line-set add-on charge beyond factory allowance.",
  },
];
---

<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Subcooling Calculator — HVAC Refrigerant Charge Check" />
    <meta
      property="og:description"
      content="Calculate measured subcooling and compare to TXV or piston targets. Free and instant."
    />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="TradesQuote" />
    <meta property="og:image" content="https://tradesquote.ai/logo.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Subcooling Calculator — HVAC Refrigerant Charge Check" />
    <meta
      name="twitter:description"
      content="Calculate measured subcooling from liquid saturation and line temps. Free, instant, no sign-up."
    />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  </Fragment>

  <div class="bg-white min-h-screen text-slate-700">
    <Header />

    <main>
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-6">
          <CalculatorBreadcrumb category="HVAC" categoryHref="/calculators/hvac" current="Subcooling Calculator" />

          <div class="max-w-3xl">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-sky-100 px-3 py-1 text-xs font-semibold text-sky-700"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
                ></path>
              </svg>
              HVAC Tools · Diagnostics · Free
            </span>

            <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
              Subcooling Calculator <span class="text-sky-600">— Free Online Calculator</span>
            </h1>

            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              Subcooling tells you how much the liquid refrigerant has cooled below its saturation temperature in
              the condenser — the primary charge check on TXV systems. Enter the liquid line saturation
              temperature and the liquid line temperature, and this tool gives your measured subcooling, whether
              it's in the healthy band, and the most likely causes when it isn't.
            </p>
          </div>
        </div>
      </section>

      <section id="calculator" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12">
        <div class="grid lg:grid-cols-5 gap-6">
          <div class="lg:col-span-3 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
            <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
              <svg
                class="h-5 w-5 text-sky-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M12 17h.01M9 14h.01M12 14h.01M15 14h.01M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"
                ></path>
              </svg>
              Enter liquid-side temperatures
            </h2>

            <div class="mt-6 space-y-6">
              <div>
                <label for="sc-meter" class="text-sm font-semibold text-slate-800">Metering device</label>
                <select
                  id="sc-meter"
                  class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 outline-none"
                >
                  <option value="txv" selected>TXV (expansion valve) — target 8–12°F</option>
                  <option value="piston">Piston (fixed orifice) — target 10–15°F</option>
                </select>
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="sc-sat" class="text-sm font-semibold text-slate-800"
                    >Liquid line saturation temp (°F)</label
                  >
                  <input
                    id="sc-sat"
                    type="number"
                    min="0"
                    max="200"
                    value="95"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">From liquid gauge converted on a PT chart</p>
                </div>

                <div>
                  <label for="sc-liquid" class="text-sm font-semibold text-slate-800"
                    >Liquid line temp (°F)</label
                  >
                  <input
                    id="sc-liquid"
                    type="number"
                    min="0"
                    max="200"
                    value="88"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">Pipe clamp thermometer on the liquid line</p>
                </div>
              </div>

              <button
                id="resetBtn"
                type="button"
                class="text-sm font-medium text-slate-500 hover:text-sky-600 transition flex items-center gap-1.5"
              >
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                  ></path>
                </svg>
                Reset to defaults
              </button>
            </div>
          </div>

          <div class="lg:col-span-2">
            <div
              class="lg:sticky lg:top-24 rounded-2xl bg-gradient-to-br from-sky-600 to-blue-500 p-6 sm:p-8 text-white shadow-lg"
            >
              <p class="text-sm font-medium text-sky-100">Measured subcooling</p>
              <div class="mt-2 flex items-baseline gap-2">
                <span id="sc-result" class="text-5xl font-extrabold tracking-tight">7°F</span>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-xl bg-white/15 p-4">
                  <p class="text-xs text-sky-100">Reading</p>
                  <p id="sc-status" class="mt-1 text-2xl font-bold">Low-normal</p>
                </div>
                <div class="rounded-xl bg-white/15 p-4">
                  <p class="text-xs text-sky-100">Ideal target</p>
                  <p id="sc-target" class="mt-1 text-2xl font-bold">8–12°F</p>
                </div>
              </div>

              <div class="mt-3 rounded-xl bg-white/15 p-4">
                <p class="text-xs text-sky-100">Likely causes</p>
                <p id="sc-causes" class="mt-1 text-sm font-medium leading-snug">
                  Below TXV target — undercharge, dirty condenser, or high ambient reducing condenser capacity.
                  Clean the coil and verify charge.
                </p>
              </div>

              <details class="group mt-5 rounded-xl bg-white/10">
                <summary
                  class="flex items-center justify-between cursor-pointer px-4 py-3 text-sm font-semibold"
                >
                  See the breakdown
                  <svg
                    class="h-4 w-4 transition-transform group-open:rotate-180"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="px-4 pb-4 text-sm space-y-1.5 text-sky-50">
                  <div class="flex justify-between">
                    <span>Liquid sat temp</span><span id="sc-bd-sat" class="font-semibold">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Liquid line temp</span><span id="sc-bd-liquid" class="font-semibold">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Subcooling</span><span id="sc-bd-sc" class="font-semibold">—</span>
                  </div>
                  <div
                    class="flex justify-between border-t border-white/20 pt-1.5 mt-1.5 text-white"
                  >
                    <span class="font-bold">Healthy range</span><span id="sc-bd-target" class="font-bold">—</span>
                  </div>
                </div>
              </details>

              <p class="mt-4 text-xs text-sky-100 leading-relaxed">
                Subcooling is the primary TXV charging method. Confirm superheat afterward and follow the
                manufacturer spec for your refrigerant type.
              </p>
            </div>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">What your reading means (TXV systems)</h2>
          <p class="mt-2 text-sm text-slate-500">
            Measured subcooling at the liquid line. Piston systems typically target 10–15°F.
          </p>
          <div class="mt-5 overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-500">
                  <th class="py-2.5 pr-4 font-semibold">Subcooling</th>
                  <th class="py-2.5 pr-4 font-semibold">Reading</th>
                  <th class="py-2.5 font-semibold">Most likely cause</th>
                </tr>
              </thead>
              <tbody class="text-slate-700">
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Under 4°F</td>
                  <td class="py-2.5 pr-4">Very low</td>
                  <td class="py-2.5">Undercharge or poor condenser heat rejection</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">4–8°F</td>
                  <td class="py-2.5 pr-4">Low</td>
                  <td class="py-2.5">Undercharge, dirty condenser, or high ambient</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">8–12°F</td>
                  <td class="py-2.5 pr-4 text-sky-700 font-semibold">Healthy</td>
                  <td class="py-2.5">Proper TXV charge — fully condensed liquid to the valve</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">12–18°F</td>
                  <td class="py-2.5 pr-4">High</td>
                  <td class="py-2.5">Overcharge, restricted metering, or cool ambient</td>
                </tr>
                <tr>
                  <td class="py-2.5 pr-4 font-semibold">Over 18°F</td>
                  <td class="py-2.5 pr-4">Very high</td>
                  <td class="py-2.5">Severe overcharge — recover excess refrigerant</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-xs text-slate-500">
            Sources &amp; standards: HVAC School —
            <a
              href="https://hvacrschool.com/subcooling/"
              class="underline hover:text-sky-600"
              target="_blank"
              rel="noopener">Subcooling charging fundamentals</a
            >
            · EPA Section 608 — refrigerant handling · Manufacturer TXV charging procedures.
          </p>
        </div>
      </section>

      <section class="bg-slate-50 border-y border-slate-200">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">
            The formula, explained in plain English
          </h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Subcooling is how many degrees the liquid refrigerant has cooled past its boiling point at condenser
            pressure. It confirms the condenser is delivering fully condensed liquid to the metering device.
          </p>

          <div
            class="mt-8 rounded-2xl bg-slate-900 p-6 sm:p-8 text-slate-100 font-mono text-sm leading-relaxed overflow-x-auto"
          >
            <div class="text-sky-300"># Measured subcooling:</div>
            <div>subcooling&nbsp;=&nbsp;liquid line saturation temp − liquid line temp</div>
            <div class="mt-4 text-sky-300"># TXV target:</div>
            <div>healthy band&nbsp;=&nbsp;<span class="text-amber-300">8–12°F</span></div>
            <div class="mt-4 text-sky-300"># Piston (fixed orifice):</div>
            <div>healthy band&nbsp;=&nbsp;<span class="text-amber-300">10–15°F</span></div>
            <div class="mt-4 text-sky-300"># Read it:</div>
            <div>too LOW = undercharge/condenser problem · too HIGH = overcharge</div>
          </div>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">What subcooling tells you</h3>
              <p class="mt-2 text-sm text-slate-600">
                Whether the condenser has fully condensed the refrigerant and stacked enough liquid before it
                reaches the metering device — the liquid-side charge check.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Where to measure</h3>
              <p class="mt-2 text-sm text-slate-600">
                Liquid line 6–12 inches before the metering device with a pipe clamp thermometer. Saturation
                temp comes from the liquid (high-side) gauge on a PT chart.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">TXV vs piston</h3>
              <p class="mt-2 text-sm text-slate-600">
                TXV systems are charged by subcooling because the valve adjusts superheat. Piston systems use
                superheat as primary and subcooling as a cross-check — target 10–15°F.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Ambient affects the reading</h3>
              <p class="mt-2 text-sm text-slate-600">
                Cool outdoor temps add subcooling even with correct charge. Always charge at stable, moderate
                ambient and compare to the manufacturer chart for your refrigerant.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Worked examples</h2>
        <p class="mt-4 text-slate-600">
          Three readings showing slightly low TXV subcooling, healthy charge, and overcharge from excess
          refrigerant.
        </p>

        <div class="mt-8 space-y-6">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-sky-100 text-sky-700 font-bold"
                >1</span
              >
              <h3 class="text-lg font-bold text-slate-900">Slightly low TXV — 95°F sat, 88°F liquid line</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              95 − 88 = <span class="font-bold text-sky-700">7°F → Low-normal</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> just below the 8–12°F TXV band — check
              for undercharge or a dirty condenser before adding refrigerant.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-sky-100 text-sky-700 font-bold"
                >2</span
              >
              <h3 class="text-lg font-bold text-slate-900">Healthy TXV — 102°F sat, 92°F liquid line</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              102 − 92 = <span class="font-bold text-sky-700">10°F → Healthy</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> 10°F sits in the 8–12°F TXV band — the
              condenser is delivering fully condensed liquid to the expansion valve.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-sky-100 text-sky-700 font-bold"
                >3</span
              >
              <h3 class="text-lg font-bold text-slate-900">Overcharge — 108°F sat, 88°F liquid line</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              108 − 88 = <span class="font-bold text-sky-700">20°F → Very high</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> excess refrigerant stacked in the
              condenser — recover to manufacturer subcooling target before returning to service.
            </p>
          </div>
        </div>
      </section>

      <CalculatorFaqSection
        faqs={faqs}
        accent="sky"
        subtitle="Common questions about measuring and interpreting HVAC subcooling."
      />

      <CalculatorTradesQuoteCta heading={ctaHeading} description={ctaDescription} />

      <HvacRelatedCalculators calculators={relatedCalculators} accent="sky" />
    </main>

    <Footer />
  </div>

  <script>
    import { initHvacSubcoolingCalculator } from "@/scripts/calculators/hvac-subcooling-calculator";
    initHvacSubcoolingCalculator();
  </script>
</Layout>
