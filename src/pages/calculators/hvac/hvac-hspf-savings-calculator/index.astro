---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import HvacRelatedCalculators from "@/components/HvacRelatedCalculators.astro";
import CalculatorBreadcrumb from "@/components/CalculatorBreadcrumb.astro";
import CalculatorFaqSection from "@/components/CalculatorFaqSection.astro";
import CalculatorTradesQuoteCta from "@/components/CalculatorTradesQuoteCta.astro";
import { buildFaqPageSchema, type CalculatorFaq } from "@/lib/calculatorFaq";

const title = "HSPF Savings Calculator — Heat Pump Efficiency Cost Comparison | TradesQuote";
const description =
  "Free HSPF savings calculator. Compare two heat pump HSPF ratings and see the annual heating electricity cost, dollar savings, and 15-year payoff of a higher-efficiency unit. Instant, no sign-up.";

const pageUrl = "https://tradesquote.ai/calculators/hvac/hvac-hspf-savings-calculator";

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://tradesquote.ai/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://tradesquote.ai/calculators" },
    { "@type": "ListItem", position: 3, name: "HVAC", item: "https://tradesquote.ai/calculators/hvac" },
    { "@type": "ListItem", position: 4, name: "HSPF Savings Calculator", item: pageUrl },
  ],
};

const webAppData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "HSPF Savings Calculator",
  url: pageUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (web-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description:
    "Free online HSPF savings calculator that compares two heat pump HSPF ratings and estimates annual heating electricity use, cost, dollar savings, and 15-year savings based on system size, heating hours, and electricity rate.",
};

const faqs: CalculatorFaq[] = [
  {
    question: "What is an HSPF rating?",
    answer:
      "HSPF — <strong>Heating Seasonal Performance Factor</strong> — measures how much heat a heat pump delivers per unit of electricity over a typical heating season: heating output in BTU divided by energy used in watt-hours. A higher HSPF means the same warmth for less electricity.",
  },
  {
    question: "How much does upgrading from HSPF 8 to HSPF 10 save?",
    answer:
      "Moving from HSPF 8 to 10 cuts heating electricity use by <strong>20%</strong>, since consumption scales with the ratio of the ratings. For a 3-ton system running 1,500 heating hours a year at $0.17/kWh, that's roughly <strong>$230 per year</strong>, or about $3,450 over a 15-year lifespan.",
  },
  {
    question: "What's the formula for HSPF savings?",
    answer:
      "Percent savings = <strong>1 − (old HSPF ÷ new HSPF)</strong>. For dollars: annual kWh = heating BTU/hr × yearly heating hours ÷ (HSPF × 1,000), multiply each by your electricity rate, and subtract. The calculator above runs all of it instantly.",
  },
  {
    question: "What is HSPF2 and how is it different from HSPF?",
    answer:
      "HSPF2 is the same efficiency concept measured under a tougher 2023 test that uses higher external static pressure to mimic real ductwork. HSPF2 values run about <strong>4–5% lower</strong> than the old HSPF number for the same unit. When comparing two systems, use the same scale for both.",
  },
  {
    question: "What HSPF rating should I buy?",
    answer:
      "Since 2023, new heat pumps must meet at least <strong>8.8 HSPF2 (≈9.2 HSPF) in northern states and 8.1 HSPF2 (≈8.5 HSPF) in the South</strong>. The sweet spot for most homes is HSPF 9–10; going higher pays off mainly in cold climates with long heating seasons.",
  },
  {
    question: "Is a higher HSPF heat pump worth the extra cost?",
    answer:
      "It depends on how much you heat with the heat pump. Savings scale with heating hours and electricity rates, so an upgrade that returns $150/yr in a mild climate can return <strong>$350+ in Minnesota or Maine</strong>. Compare the price premium against the 10–15 year savings this calculator shows — and check local utility rebates.",
  },
  {
    question: "Does HSPF affect cooling costs too?",
    answer:
      'HSPF only measures <strong>heating</strong> efficiency. Heat pump cooling is rated separately as SEER/SEER2. If you\'re comparing cooling equipment, use the <a href="/calculators/hvac/hvac-seer-savings-calculator" class="font-semibold text-indigo-700 underline decoration-indigo-300 hover:decoration-indigo-600">SEER Savings Calculator</a>; for gas backup, see the <a href="/calculators/hvac/hvac-afue-savings-calculator" class="font-semibold text-indigo-700 underline decoration-indigo-300 hover:decoration-indigo-600">AFUE Savings Calculator</a>.',
  },
];
const faqData = buildFaqPageSchema(faqs);

const ctaHeading = "Selling the upgrade? Quote it in seconds.";
const ctaDescription =
  "Energy savings win the conversation — a fast, professional estimate wins the job. TradesQuote turns the full heat pump replacement into a line-item quote: equipment, labor, materials, and disposal, with quantities, unit prices, and totals validated by a built-in quality control agent.";

const relatedCalculators = [
  {
    href: "/calculators/hvac/hvac-heat-pump-calculator",
    title: "Heat Pump Sizing Calculator",
    description: "Size a heat pump for heating and cooling load.",
  },
  {
    href: "/calculators/hvac/hvac-seer-savings-calculator",
    title: "SEER Savings Calculator",
    description: "Compare cooling efficiency and running cost.",
  },
  {
    href: "/calculators/hvac/hvac-operating-cost-calculator",
    title: "HVAC Operating Cost Calculator",
    description: "Annual heating and cooling cost by fuel type.",
  },
  {
    href: "/calculators/hvac/hvac-afue-savings-calculator",
    title: "AFUE Savings Calculator",
    description: "Compare furnace efficiency and fuel savings.",
  },
];
---

<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="HSPF Savings Calculator — Heat Pump Efficiency Cost Comparison" />
    <meta
      property="og:description"
      content="Compare two HSPF ratings and see annual heating electricity costs, dollar savings, and the 15-year payoff. Free and instant."
    />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="TradesQuote" />
    <meta property="og:image" content="https://tradesquote.ai/logo.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="HSPF Savings Calculator — Heat Pump Efficiency Cost Comparison" />
    <meta
      name="twitter:description"
      content="Compare two HSPF ratings and see annual heating electricity costs and savings. Free, no sign-up."
    />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  </Fragment>

  <div class="bg-white min-h-screen text-slate-700">
    <Header />

    <main>
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-6">
          <CalculatorBreadcrumb category="HVAC" categoryHref="/calculators/hvac" current="HSPF Savings Calculator" />

          <div class="max-w-3xl">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-indigo-100 px-3 py-1 text-xs font-semibold text-indigo-700"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M16 3l4 4-4 4M20 7H8a4 4 0 00-4 4v1M8 21l-4-4 4-4"
                ></path>
              </svg>
              HVAC Tools · Efficiency · Free
            </span>

            <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
              HSPF Savings Calculator <span class="text-indigo-600">— Free Online Calculator</span>
            </h1>

            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              This HSPF savings calculator compares two heat pump heating efficiency ratings and shows the annual
              electricity use, yearly cost, and dollar savings of the higher-HSPF unit — plus what that adds up
              to over a 15-year lifespan. Use it to decide whether a more efficient heat pump is worth the price
              premium before you buy or quote.
            </p>

            <div class="mt-6 flex items-start gap-3 rounded-xl border border-indigo-100 bg-indigo-50 p-4">
              <svg
                class="h-5 w-5 shrink-0 text-indigo-600 mt-0.5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
              <p class="text-sm text-slate-600">
                <span class="font-semibold text-slate-900">Don't know your system size in tons?</span>
                Find it with the
                <a
                  href="/calculators/hvac/hvac-heat-pump-calculator"
                  class="font-semibold text-indigo-700 underline decoration-indigo-300 hover:decoration-indigo-600"
                  >Heat Pump Sizing Calculator</a
                >
                — or compare cooling savings with the
                <a
                  href="/calculators/hvac/hvac-seer-savings-calculator"
                  class="font-semibold text-indigo-700 underline decoration-indigo-300 hover:decoration-indigo-600"
                  >SEER Savings Calculator</a
                >.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="calculator" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12 pt-4">
        <div class="mx-auto max-w-5xl rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
              <svg
                class="h-5 w-5 text-indigo-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M12 17h.01M9 14h.01M12 14h.01M15 14h.01M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"
                ></path>
              </svg>
              Compare two HSPF ratings
            </h2>

          <div class="mt-6 lg:grid lg:grid-cols-2 lg:gap-8 lg:items-start">
          <div class="space-y-6">
<div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="hspf-old" class="text-sm font-semibold text-slate-800">Current / lower HSPF</label>
                  <input
                    id="hspf-old"
                    type="number"
                    min="5"
                    max="15"
                    step="0.1"
                    value="8"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">Older units: ~7–8 · 2015–2022 installs: ~8–9</p>
                </div>

                <div>
                  <label for="hspf-new" class="text-sm font-semibold text-slate-800">New / higher HSPF</label>
                  <input
                    id="hspf-new"
                    type="number"
                    min="5"
                    max="15"
                    step="0.1"
                    value="10"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">Use the same scale (HSPF or HSPF2) for both.</p>
                </div>

                <div>
                  <label for="hspf-tons" class="text-sm font-semibold text-slate-800">System size</label>
                  <select
                    id="hspf-tons"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none"
                  >
                    <option value="1.5">1.5 tons (18,000 BTU)</option>
                    <option value="2">2 tons (24,000 BTU)</option>
                    <option value="2.5">2.5 tons (30,000 BTU)</option>
                    <option value="3" selected>3 tons (36,000 BTU)</option>
                    <option value="3.5">3.5 tons (42,000 BTU)</option>
                    <option value="4">4 tons (48,000 BTU)</option>
                    <option value="5">5 tons (60,000 BTU)</option>
                  </select>
                </div>

                <div>
                  <label for="hspf-hours" class="text-sm font-semibold text-slate-800"
                    >Heating season (climate)</label
                  >
                  <select
                    id="hspf-hours"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none"
                  >
                    <option value="600">Mild — short winters (600 hrs/yr)</option>
                    <option value="1500" selected>Moderate — typical US (1,500 hrs/yr)</option>
                    <option value="2200">Cold — long winters (2,200 hrs/yr)</option>
                    <option value="3000">Very cold — northern US (3,000 hrs/yr)</option>
                  </select>
                </div>

                <div class="sm:col-span-2">
                  <div class="flex items-center justify-between">
                    <label for="hspf-rate" class="text-sm font-semibold text-slate-800">Electricity rate</label>
                    <div class="flex items-center gap-1">
                      <span class="text-sm text-slate-500">$</span>
                      <input
                        id="hspf-rate"
                        type="number"
                        min="0.05"
                        max="0.60"
                        step="0.01"
                        value="0.17"
                        class="w-24 rounded-lg border border-slate-300 px-3 py-1.5 text-right text-sm font-semibold text-slate-900 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none"
                      />
                      <span class="text-sm text-slate-500">/kWh</span>
                    </div>
                  </div>
                  <input
                    id="hspf-rate-range"
                    type="range"
                    min="0.08"
                    max="0.40"
                    step="0.01"
                    value="0.17"
                    class="hspf-range mt-3 w-full bg-slate-200 accent-indigo-600"
                  />
                  <div class="flex justify-between text-xs text-slate-400 mt-1">
                    <span>$0.08</span><span>US average ≈ $0.17</span><span>$0.40</span>
                  </div>
                </div>
              </div>

              <button
                id="resetBtn"
                type="button"
                class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition flex items-center gap-1.5"
              >
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                  ></path>
                </svg>
                Reset to defaults
              </button>
          </div>

          <!-- Results -->
          <div class="mt-6 lg:mt-0 rounded-xl border border-indigo-100 bg-indigo-50 p-5 sm:p-6">

              <p class="text-sm font-medium text-slate-600">You'd save every year</p>
              <div class="mt-2 flex items-baseline gap-2">
                <span id="savingsResult" class="text-5xl font-extrabold tracking-tight text-indigo-600">$230</span>
                <span class="text-lg font-semibold text-slate-600">/year</span>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-xl border border-indigo-100 bg-white p-4">
                  <p id="oldLabel" class="text-xs text-slate-500">At HSPF 8</p>
                  <p id="oldCost" class="mt-1 text-2xl font-bold text-slate-900">$1,148/yr</p>
                </div>
                <div class="rounded-xl border border-indigo-100 bg-white p-4">
                  <p id="newLabel" class="text-xs text-slate-500">At HSPF 10</p>
                  <p id="newCost" class="mt-1 text-2xl font-bold text-slate-900">$918/yr</p>
                </div>
              </div>

              <div class="mt-3 rounded-xl border border-indigo-100 bg-white p-4">
                <p class="text-xs text-slate-500">Over a 15-year lifespan</p>
                <p id="lifetimeResult" class="mt-1 text-base font-semibold leading-snug text-slate-800">
                  $3,450 saved · 20% less electricity
                </p>
              </div>

              <details class="group mt-5 rounded-xl border border-indigo-100 bg-white">
                <summary
                  class="flex items-center justify-between cursor-pointer px-4 py-3 text-sm font-semibold text-slate-800"
                >
                  See the breakdown
                  <svg
                    class="h-4 w-4 text-slate-500 transition-transform group-open:rotate-180"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="px-4 pb-4 text-sm space-y-1.5 text-slate-600">
                  <div class="flex justify-between">
                    <span>Heating capacity</span><span id="bd-btu" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>kWh/yr at lower HSPF</span><span id="bd-kwh-old" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>kWh/yr at higher HSPF</span><span id="bd-kwh-new" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div class="flex justify-between">
                    <span>Electricity saved</span><span id="bd-kwh-saved" class="font-semibold text-slate-900">—</span>
                  </div>
                  <div
                    class="flex justify-between border-t border-slate-200 pt-1.5 mt-1.5 text-slate-900"
                  >
                    <span class="font-bold text-slate-900">10-year savings</span><span id="bd-tenyr" class="font-bold text-slate-900">—</span>
                  </div>
                </div>
              </details>

              <p class="mt-4 text-xs text-slate-500 leading-relaxed">
                Estimates assume the unit runs at rated efficiency in heat-pump mode. Real bills vary with
                weather, thermostat habits, auxiliary heat use, duct condition, and rate changes.
              </p>
            
          </div>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">Annual heating cost by HSPF rating (quick reference)</h2>
          <p class="mt-2 text-sm text-slate-500">
            3-ton system · 1,500 heating hours per year · $0.17/kWh. Your numbers scale with size, hours, and
            rate.
          </p>
          <div class="mt-5 overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-500">
                  <th class="py-2.5 pr-4 font-semibold">HSPF rating</th>
                  <th class="py-2.5 pr-4 font-semibold">Electricity used</th>
                  <th class="py-2.5 pr-4 font-semibold">Annual cost</th>
                  <th class="py-2.5 font-semibold">vs. HSPF 8</th>
                </tr>
              </thead>
              <tbody class="text-slate-700">
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">HSPF 6</td>
                  <td class="py-2.5 pr-4">9,000 kWh</td>
                  <td class="py-2.5 pr-4">$1,530</td>
                  <td class="py-2.5 text-rose-700 font-semibold">+$382/yr</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">HSPF 7</td>
                  <td class="py-2.5 pr-4">7,714 kWh</td>
                  <td class="py-2.5 pr-4">$1,311</td>
                  <td class="py-2.5 text-rose-700 font-semibold">+$163/yr</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">HSPF 8 (old unit)</td>
                  <td class="py-2.5 pr-4">6,750 kWh</td>
                  <td class="py-2.5 pr-4">$1,148</td>
                  <td class="py-2.5">—</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">HSPF 9</td>
                  <td class="py-2.5 pr-4">6,000 kWh</td>
                  <td class="py-2.5 pr-4">$1,020</td>
                  <td class="py-2.5 text-indigo-700 font-semibold">save $128/yr</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">HSPF 10</td>
                  <td class="py-2.5 pr-4">5,400 kWh</td>
                  <td class="py-2.5 pr-4">$918</td>
                  <td class="py-2.5 text-indigo-700 font-semibold">save $230/yr</td>
                </tr>
                <tr>
                  <td class="py-2.5 pr-4 font-semibold">HSPF 11</td>
                  <td class="py-2.5 pr-4">4,909 kWh</td>
                  <td class="py-2.5 pr-4">$835</td>
                  <td class="py-2.5 text-indigo-700 font-semibold">save $313/yr</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-xs text-slate-500">
            Sources &amp; standards: DOE — Heating Seasonal Performance Factor (HSPF/HSPF2) test procedures ·
            ENERGY STAR — heat pump efficiency requirements · EIA — average US residential electricity rates.
            Estimates for comparison only; actual usage varies with weather, auxiliary heat, and thermostat
            settings.
          </p>
        </div>
      </section>

      <section class="bg-slate-50 border-y border-slate-200">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">The formula, explained in plain English</h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            HSPF is just "heating delivered per electricity used." Once you know that, the savings math is three
            short steps — and one elegant shortcut.
          </p>

          <div
            class="mt-8 rounded-2xl bg-slate-900 p-6 sm:p-8 text-slate-100 font-mono text-sm leading-relaxed overflow-x-auto"
          >
            <div class="text-indigo-300"># Step 1 — Electricity used per year (for each HSPF)</div>
            <div>
              kWh&nbsp;=&nbsp;(tons × <span class="text-amber-300">12,000</span> BTU) × heating hours ÷ (HSPF ×
              <span class="text-amber-300">1,000</span>)
            </div>
            <div class="mt-4 text-indigo-300"># Step 2 — Annual cost</div>
            <div>cost&nbsp;=&nbsp;kWh × electricity rate ($/kWh)</div>
            <div class="mt-4 text-indigo-300"># Step 3 — Savings</div>
            <div>savings&nbsp;=&nbsp;cost<sub>old</sub> − cost<sub>new</sub></div>
            <div class="mt-4 text-indigo-300"># The shortcut — % saved needs only the two ratings</div>
            <div>
              % saved&nbsp;=&nbsp;1 − (old HSPF ÷ new HSPF)&nbsp;&nbsp;<span class="text-slate-400">// 8→10 = 20%</span>
            </div>
          </div>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">What HSPF actually is</h3>
              <p class="mt-2 text-sm text-slate-600">
                Seasonal BTU of heating divided by watt-hours of electricity. An HSPF 10 heat pump delivers 10
                BTU of heat for every watt-hour it consumes over a typical heating season.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Why ÷ (HSPF × 1,000)?</h3>
              <p class="mt-2 text-sm text-slate-600">
                Dividing BTU by HSPF gives watt-hours; the extra 1,000 converts watt-hours to kilowatt-hours —
                the unit on your power bill.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Heating hours drive everything</h3>
              <p class="mt-2 text-sm text-slate-600">
                A Minnesota winter runs the heat pump 3,000+ hours; a southern one closer to 600. The same HSPF
                upgrade saves 4–5× more money in the cold climate.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">HSPF vs. HSPF2</h3>
              <p class="mt-2 text-sm text-slate-600">
                HSPF2 (2023+) is the same idea tested under realistic duct pressure; values read ~4–5% lower.
                Compare like with like — never HSPF against HSPF2.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Worked examples</h2>
        <p class="mt-4 text-slate-600">
          Three common upgrade decisions — including one where the upgrade isn't obviously worth it.
        </p>

        <div class="mt-8 space-y-6">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-indigo-100 text-indigo-700 font-bold"
                >1</span
              >
              <h3 class="text-lg font-bold text-slate-900">
                Replacing an old unit — HSPF 8 → 10, 3 tons, moderate climate
              </h3>
            </div>
            <p class="mt-3 text-sm text-slate-600">1,500 heating hours · $0.17/kWh.</p>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              old: 36,000 × 1,500 ÷ (8 × 1,000) = 6,750 kWh → $1,148/yr<br />
              new: 36,000 × 1,500 ÷ (10 × 1,000) = 5,400 kWh → $918/yr<br />
              savings = <span class="font-bold text-indigo-700">$230/yr · 20% less electricity</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> about $230 per year, roughly $3,450 over
              15 years — a strong tailwind on top of replacing a unit that was due anyway.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-indigo-100 text-indigo-700 font-bold"
                >2</span
              >
              <h3 class="text-lg font-bold text-slate-900">
                Cold climate, small step — HSPF 9 vs. 10, 3 tons, northern winter
              </h3>
            </div>
            <p class="mt-3 text-sm text-slate-600">3,000 heating hours · $0.17/kWh.</p>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              HSPF 9: 36,000 × 3,000 ÷ 9,000 = 12,000 kWh → $2,040/yr<br />
              HSPF 10: 36,000 × 3,000 ÷ 10,000 = 10,800 kWh → $1,836/yr<br />
              savings = <span class="font-bold text-indigo-700">$204/yr · 11.1% less electricity</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> even a one-point HSPF step saves ~$204 a
              year when the heating season is long — about $3,060 over 15 years.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-indigo-100 text-indigo-700 font-bold"
                >3</span
              >
              <h3 class="text-lg font-bold text-slate-900">
                The honest case — HSPF 8 → 10, small 2-ton system, mild climate
              </h3>
            </div>
            <p class="mt-3 text-sm text-slate-600">600 heating hours · $0.17/kWh.</p>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              HSPF 8: 24,000 × 600 ÷ 8,000 = 1,800 kWh → $306/yr<br />
              HSPF 10: 24,000 × 600 ÷ 10,000 = 1,440 kWh → $245/yr<br />
              savings = <span class="font-bold text-indigo-700">$61/yr · 20% less electricity</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> about $61 a year. If the working unit
              would cost thousands to replace early, energy savings alone don't justify it — efficiency pays best
              on big systems, long winters, or units already due for replacement.
            </p>
          </div>
        </div>
      </section>

      <CalculatorFaqSection
        faqs={faqs}
        accent="indigo"
        subtitle="Common questions about HSPF ratings and heat pump heating savings."
      />

      <CalculatorTradesQuoteCta heading={ctaHeading} description={ctaDescription} />

      <HvacRelatedCalculators calculators={relatedCalculators} accent="indigo" />
    </main>

    <Footer />
