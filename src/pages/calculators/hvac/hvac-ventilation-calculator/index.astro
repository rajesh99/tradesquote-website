---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import HvacRelatedCalculators from "@/components/HvacRelatedCalculators.astro";
import CalculatorBreadcrumb from "@/components/CalculatorBreadcrumb.astro";
import CalculatorFaqSection from "@/components/CalculatorFaqSection.astro";
import CalculatorTradesQuoteCta from "@/components/CalculatorTradesQuoteCta.astro";
import { buildFaqPageSchema, type CalculatorFaq } from "@/lib/calculatorFaq";

const title = "Ventilation Calculator — ASHRAE 62.2 & 62.1 CFM Tool | TradesQuote";
const description =
  "Free HVAC ventilation calculator. Size whole-building ventilation CFM using ASHRAE 62.2 residential rates or ASHRAE 62.1 commercial people-and-area rates. Instant, no sign-up.";

const pageUrl = "https://tradesquote.ai/calculators/hvac/hvac-ventilation-calculator";

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://tradesquote.ai/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://tradesquote.ai/calculators" },
    { "@type": "ListItem", position: 3, name: "HVAC", item: "https://tradesquote.ai/calculators/hvac" },
    { "@type": "ListItem", position: 4, name: "Ventilation Calculator", item: pageUrl },
  ],
};

const webAppData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "HVAC Ventilation Calculator",
  url: pageUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (web-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description:
    "Free online HVAC ventilation calculator that sizes whole-building ventilation CFM using ASHRAE 62.2 residential whole-building rates or ASHRAE 62.1 commercial people-and-area ventilation rates.",
};

const faqs: CalculatorFaq[] = [
  {
    question: "What is ASHRAE 62.2 and when do I use it?",
    answer:
      "ASHRAE Standard 62.2 is the <strong>residential ventilation and acceptable indoor air quality</strong> standard. Use it for single-family homes, townhouses, and similar dwellings. The whole-building rate combines a floor-area component (0.03 CFM per sq ft) plus an occupancy component (7.5 CFM per person, estimated as bedrooms + 1). This calculator applies that simplified whole-building formula — confirm local code adoption and any amendments.",
  },
  {
    question: "What is ASHRAE 62.1 and how is it different from 62.2?",
    answer:
      "ASHRAE Standard 62.1 covers <strong>commercial and institutional buildings</strong>. Ventilation rates come from Table 6-1 by space type — typically a people rate (CFM per occupant) plus an area rate (CFM per sq ft). ASHRAE 62.2 is residential-only. Switch the calculator to commercial mode and enter occupancy and rates from your space category in 62.1.",
  },
  {
    question: "How do I size an ERV or HRV from this CFM number?",
    answer:
      "The calculated CFM is your <strong>continuous whole-building ventilation target</strong>. Size the ERV or HRV to deliver at least that rate at balanced supply and exhaust. Most manufacturers list nominal CFM at a specific static pressure — pick a unit rated at or above your result and verify duct runs, filters, and defrost performance for your climate. Pair with the <a href=\"/calculators/hvac/hvac-duct-size-calculator\" class=\"font-semibold text-teal-700 underline decoration-teal-300 hover:decoration-teal-600\">Duct Size Calculator</a> for the ventilation trunk and branches.",
  },
  {
    question: "What's the difference between this and the CFM calculator?",
    answer:
      "They answer different questions. The <a href=\"/calculators/hvac/hvac-cfm-calculator\" class=\"font-semibold text-teal-700 underline decoration-teal-300 hover:decoration-teal-600\">CFM Calculator</a> sizes <strong>heating and cooling airflow</strong> — room air changes, CFM per ton, and equipment delivery. This ventilation calculator sizes <strong>outdoor air for indoor air quality</strong> per ASHRAE 62.2 or 62.1. A 3-ton system might move 1,200 CFM of conditioned air while the whole-building ventilation requirement is only 60–120 CFM of fresh outdoor air.",
  },
  {
    question: "Does ASHRAE 62.2 include kitchen and bathroom exhaust?",
    answer:
      "The whole-building rate in 62.2 is the <strong>continuous baseline ventilation</strong> — it does not replace intermittent local exhaust for kitchens and bathrooms. Those are separate requirements (typically 25–100 CFM intermittent for kitchens, 50 CFM for bathrooms). An ERV/HRV handles the continuous portion; range hoods and bath fans handle peak moisture and contaminant loads.",
  },
  {
    question: "What CFM does a typical 2,000 sq ft home need?",
    answer:
      "Using ASHRAE 62.2 defaults — 2,000 sq ft and 3 bedrooms — the whole-building rate is <strong>90 CFM</strong>: 60 CFM from floor area (0.03 × 2,000) plus 30 CFM from occupancy (7.5 × 4 people). A 1,500 sq ft, 2-bedroom home is about 68 CFM; a 2,500 sq ft, 4-bedroom home is about 113 CFM.",
  },
  {
    question: "Can I use this for a small office or retail space?",
    answer:
      "Yes — switch to <strong>commercial mode</strong> and enter occupancy plus people and area rates from ASHRAE 62.1 Table 6-1 for your space type. The default office example (10 people, 17.5 CFM/person, 0.06 CFM/sq ft on 2,000 sq ft) yields 295 CFM. Large or complex buildings still need engineering-grade load calculations; treat results here as a first-pass sizing check.",
  },
];
const faqData = buildFaqPageSchema(faqs);

const ctaHeading = "Ventilation CFM set? Quote the ERV or duct job in seconds.";
const ctaDescription =
  "You know the continuous ventilation rate — TradesQuote turns ERV/HRV installs, fresh-air duct runs, and balanced ventilation upgrades into a detailed, line-item estimate in seconds. Describe the job or upload photos, and our AI builds quantities, unit prices, and totals, validated by a built-in quality control agent.";

const relatedCalculators = [
  {
    href: "/calculators/hvac/hvac-cfm-calculator",
    title: "CFM Calculator",
    description: "Target heating and cooling airflow per room and per ton.",
  },
  {
    href: "/calculators/hvac/hvac-dew-point-calculator",
    title: "Dew Point Calculator",
    description: "Moisture load and condensation risk on ducts and surfaces.",
  },
  {
    href: "/calculators/hvac/hvac-sensible-latent-heat-calculator",
    title: "Sensible & Latent Heat Calculator",
    description: "Split total coil load into sensible and latent BTU.",
  },
  {
    href: "/calculators/hvac/hvac-duct-size-calculator",
    title: "Duct Size Calculator",
    description: "Right-size ventilation trunk and branch ducts.",
  },
];
---

<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Ventilation Calculator — ASHRAE 62.2 & 62.1 CFM Tool" />
    <meta
      property="og:description"
      content="Size whole-building ventilation CFM with ASHRAE 62.2 residential or 62.1 commercial rates. Free and instant."
    />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="TradesQuote" />
    <meta property="og:image" content="https://tradesquote.ai/logo.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Ventilation Calculator — ASHRAE 62.2 & 62.1 CFM Tool" />
    <meta
      name="twitter:description"
      content="Calculate whole-building ventilation CFM per ASHRAE 62.2 or 62.1. Free, instant, no sign-up."
    />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  </Fragment>

  <div class="bg-white min-h-screen text-slate-700">
    <Header />

    <main>
      <!-- ============================ HERO + H1 + INTRO ============================ -->
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-6">
          <CalculatorBreadcrumb
            category="HVAC"
            categoryHref="/calculators/hvac"
            current="Ventilation Calculator"
          />

          <div class="max-w-3xl">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-teal-100 px-3 py-1 text-xs font-semibold text-teal-700"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4 8h9a2.5 2.5 0 10-2.5-2.5M4 12h13a2.5 2.5 0 11-2.5 2.5M4 16h7"
                ></path>
              </svg>
              HVAC Tools · Ventilation · Free
            </span>

            <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
              Ventilation Calculator <span class="text-teal-600">— Free Online Calculator</span>
            </h1>

            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              Whole-building ventilation CFM is the baseline outdoor air rate your home or commercial space needs for
              acceptable indoor air quality — separate from heating and cooling airflow. Enter floor area and bedrooms
              for ASHRAE 62.2 residential sizing, or switch to commercial mode for ASHRAE 62.1 people-and-area rates.
              This tool splits the result into area and occupancy components so you can size an ERV, HRV, or fresh-air
              duct run with confidence.
            </p>
          </div>
        </div>
      </section>

      <!-- ============================ THE INTERACTIVE CALCULATOR ============================ -->
      <section id="calculator" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12">
        <div class="mx-auto max-w-5xl rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
              <svg
                class="h-5 w-5 text-teal-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M12 17h.01M9 14h.01M12 14h.01M15 14h.01M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"
                ></path>
              </svg>
              Enter building details
            </h2>

          <div class="mt-6 lg:grid lg:grid-cols-2 lg:gap-8 lg:items-start">
          <div class="space-y-6">
<div>
                <label for="vent-mode" class="text-sm font-semibold text-slate-800">Standard / building type</label>
                <select
                  id="vent-mode"
                  class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                >
                  <option value="residential" selected>Residential — ASHRAE 62.2</option>
                  <option value="commercial">Commercial — ASHRAE 62.1</option>
                </select>
                <p class="mt-1.5 text-xs text-slate-500">
                  62.2 for homes and dwellings; 62.1 for offices, retail, and other commercial spaces.
                </p>
              </div>

              <div>
                <label for="vent-area" class="text-sm font-semibold text-slate-800">Floor area (sq ft)</label>
                <input
                  id="vent-area"
                  type="number"
                  min="0"
                  max="100000"
                  step="50"
                  value="2000"
                  class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                />
                <p class="mt-1.5 text-xs text-slate-500">Conditioned floor area of the building or zone.</p>
              </div>

              <div id="vent-residential-fields">
                <label for="vent-bedrooms" class="text-sm font-semibold text-slate-800">Bedrooms</label>
                <input
                  id="vent-bedrooms"
                  type="number"
                  min="0"
                  max="20"
                  step="1"
                  value="3"
                  class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                />
                <p class="mt-1.5 text-xs text-slate-500">
                  ASHRAE 62.2 estimates occupants as bedrooms + 1 (e.g. 3 bedrooms → 4 people).
                </p>
              </div>

              <div id="vent-commercial-fields" class="hidden space-y-5">
                <div>
                  <label for="vent-occupants" class="text-sm font-semibold text-slate-800">Occupants</label>
                  <input
                    id="vent-occupants"
                    type="number"
                    min="0"
                    max="1000"
                    step="1"
                    value="10"
                    class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                  />
                  <p class="mt-1.5 text-xs text-slate-500">Design occupancy for the space — from 62.1 Table 6-1.</p>
                </div>

                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="vent-cfm-person" class="text-sm font-semibold text-slate-800"
                      >People rate (CFM/person)</label
                    >
                    <input
                      id="vent-cfm-person"
                      type="number"
                      min="0"
                      max="100"
                      step="0.5"
                      value="17.5"
                      class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                    />
                    <p class="mt-1.5 text-xs text-slate-500">Default 17.5 for open office — check your space type.</p>
                  </div>

                  <div>
                    <label for="vent-cfm-sqft" class="text-sm font-semibold text-slate-800"
                      >Area rate (CFM/sq ft)</label
                    >
                    <input
                      id="vent-cfm-sqft"
                      type="number"
                      min="0"
                      max="1"
                      step="0.01"
                      value="0.06"
                      class="mt-2 w-full rounded-lg border border-slate-300 px-4 py-3 text-lg font-semibold text-slate-900 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                    />
                    <p class="mt-1.5 text-xs text-slate-500">Default 0.06 for office — from ASHRAE 62.1 Table 6-1.</p>
                  </div>
                </div>
              </div>

              <button
                id="resetBtn"
                type="button"
                class="text-sm font-medium text-slate-500 hover:text-teal-600 transition flex items-center gap-1.5"
              >
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                  ></path>
                </svg>
                Reset to defaults
              </button>
          </div>

          <!-- Results -->
          <div class="mt-6 lg:mt-0 rounded-xl border border-teal-100 bg-teal-50 p-5 sm:p-6">

              <p class="text-sm font-medium text-slate-600">Required ventilation CFM</p>
              <div class="mt-2 flex items-baseline gap-2">
                <span id="vent-result-cfm" class="text-5xl font-extrabold tracking-tight text-teal-600">90 CFM</span>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-xl border border-teal-100 bg-white p-4">
                  <p class="text-xs text-slate-500">Area component</p>
                  <p id="vent-result-area" class="mt-1 text-2xl font-bold text-slate-900">60 CFM</p>
                </div>
                <div class="rounded-xl border border-teal-100 bg-white p-4">
                  <p class="text-xs text-slate-500">People component</p>
                  <p id="vent-result-people" class="mt-1 text-2xl font-bold text-slate-900">30 CFM</p>
                </div>
              </div>

              <div class="mt-3 rounded-xl border border-teal-100 bg-white p-4">
                <p class="text-xs text-slate-500">What this means</p>
                <p id="vent-status" class="mt-1 text-sm font-medium leading-snug">
                  Typical small home — Falls in the common ASHRAE 62.2 range for a 1,500–2,500 sq ft home with 2–4
                  bedrooms — confirm with local mechanical code and balanced supply/exhaust design.
                </p>
              </div>

              <!-- Breakdown -->
              <details class="group mt-5 rounded-xl border border-teal-100 bg-white">
                <summary
                  class="flex items-center justify-between cursor-pointer px-4 py-3 text-sm font-semibold text-slate-800"
                >
                  See the breakdown
                  <svg
                    class="h-4 w-4 text-slate-500 transition-transform group-open:rotate-180"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="px-4 pb-4 text-sm space-y-1.5 text-slate-600">
                  <div class="flex justify-between">
                    <span>Formula</span><span id="vent-bd-formula" class="font-semibold text-right max-w-[55%]"
                      >ASHRAE 62.2 whole-building rate</span
                    >
                  </div>
                  <div class="flex justify-between">
                    <span>Area component</span><span id="vent-bd-area" class="font-semibold text-slate-900">60 CFM</span>
                  </div>
                  <div
                    class="flex justify-between border-t border-slate-200 pt-1.5 mt-1.5 text-slate-900"
                  >
                    <span class="font-bold text-slate-900">People component</span><span id="vent-bd-people" class="font-bold text-slate-900"
                      >30 CFM</span
                    >
                  </div>
                </div>
              </details>

              <p class="mt-4 text-xs text-slate-500 leading-relaxed">
                Results are simplified whole-building rates. Local codes may add kitchen/bath exhaust, infiltration
                credit, or balanced-ventilation requirements — verify before specifying equipment.
              </p>
            
          </div>
          </div>
        </div>

        <!-- Reference table -->
        <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">Ventilation CFM at common building sizes</h2>
          <p class="mt-2 text-sm text-slate-500">
            Residential rows use ASHRAE 62.2 (0.03 CFM/sq ft + 7.5 CFM per bedroom + 1). Commercial row uses a
            typical open-office rate from ASHRAE 62.1 (17.5 CFM/person + 0.06 CFM/sq ft).
          </p>
          <div class="mt-5 overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-500">
                  <th class="py-2.5 pr-4 font-semibold">Building type</th>
                  <th class="py-2.5 pr-4 font-semibold">Floor area</th>
                  <th class="py-2.5 pr-4 font-semibold">Bedrooms / occupants</th>
                  <th class="py-2.5 pr-4 font-semibold">Area CFM</th>
                  <th class="py-2.5 pr-4 font-semibold">People CFM</th>
                  <th class="py-2.5 font-semibold">Total CFM</th>
                </tr>
              </thead>
              <tbody class="text-slate-700">
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Residential (62.2)</td>
                  <td class="py-2.5 pr-4">1,500 sq ft</td>
                  <td class="py-2.5 pr-4">2 bedrooms</td>
                  <td class="py-2.5 pr-4">45 CFM</td>
                  <td class="py-2.5 pr-4">23 CFM</td>
                  <td class="py-2.5">68 CFM</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Residential (62.2)</td>
                  <td class="py-2.5 pr-4">2,000 sq ft</td>
                  <td class="py-2.5 pr-4">3 bedrooms</td>
                  <td class="py-2.5 pr-4">60 CFM</td>
                  <td class="py-2.5 pr-4">30 CFM</td>
                  <td class="py-2.5">90 CFM</td>
                </tr>
                <tr class="border-b border-slate-100">
                  <td class="py-2.5 pr-4 font-semibold">Residential (62.2)</td>
                  <td class="py-2.5 pr-4">2,500 sq ft</td>
                  <td class="py-2.5 pr-4">4 bedrooms</td>
                  <td class="py-2.5 pr-4">75 CFM</td>
                  <td class="py-2.5 pr-4">38 CFM</td>
                  <td class="py-2.5">113 CFM</td>
                </tr>
                <tr>
                  <td class="py-2.5 pr-4 font-semibold">Commercial office (62.1)</td>
                  <td class="py-2.5 pr-4">2,000 sq ft</td>
                  <td class="py-2.5 pr-4">10 occupants</td>
                  <td class="py-2.5 pr-4">120 CFM</td>
                  <td class="py-2.5 pr-4">175 CFM</td>
                  <td class="py-2.5">295 CFM</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-xs text-slate-500">
            Sources &amp; standards: ASHRAE Standard 62.2 (Ventilation and Acceptable Indoor Air Quality in
            Residential Buildings) · ASHRAE Standard 62.1 (Ventilation and Acceptable Indoor Air Quality).
          </p>
        </div>
      </section>

      <!-- ============================ FORMULA EXPLAINED ============================ -->
      <section class="bg-slate-50 border-y border-slate-200">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">
            The formula, explained in plain English
          </h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Whole-building ventilation CFM is the continuous outdoor air rate needed to dilute indoor contaminants —
            not the same as heating or cooling airflow. Residential and commercial standards use different formulas,
            but both split the rate into an area-based component and a people-based component.
          </p>

          <div
            class="mt-8 rounded-2xl bg-slate-900 p-6 sm:p-8 text-slate-100 font-mono text-sm leading-relaxed overflow-x-auto"
          >
            <div class="text-teal-300"># ASHRAE 62.2 (residential):</div>
            <div>area&nbsp;=&nbsp;0.03 × floor_area_sqft</div>
            <div>people&nbsp;=&nbsp;7.5 × (bedrooms + 1)</div>
            <div>CFM&nbsp;=&nbsp;area + people</div>
            <div class="mt-4 text-teal-300"># ASHRAE 62.1 (commercial):</div>
            <div>area&nbsp;=&nbsp;floor_area_sqft × CFM_per_sqft</div>
            <div>people&nbsp;=&nbsp;occupants × CFM_per_person</div>
            <div>CFM&nbsp;=&nbsp;area + people</div>
            <div class="mt-4 text-teal-300"># Example (defaults):</div>
            <div>
              2,000 sqft · 3 bed →{" "}
              <span class="text-amber-300">60 + 30 = 90 CFM</span>
            </div>
          </div>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">62.2 is for homes</h3>
              <p class="mt-2 text-sm text-slate-600">
                The residential whole-building rate scales with floor area and estimated occupancy (bedrooms + 1).
                Typical results are 60–120 CFM for single-family homes — much lower than cooling system airflow.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">62.1 is for commercial</h3>
              <p class="mt-2 text-sm text-slate-600">
                Commercial rates come from Table 6-1 by space type. Open offices often use ~17.5 CFM/person plus
                0.06 CFM/sq ft — people ventilation usually dominates in occupied spaces.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Not the same as CFM/ton</h3>
              <p class="mt-2 text-sm text-slate-600">
                A 3-ton AC moving 1,200 CFM is conditioned air through the coil. Ventilation CFM is fresh outdoor
                air for IAQ — sized with this calculator, not the CFM per ton rule of thumb.
              </p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-slate-900">Size ERV/HRV to this rate</h3>
              <p class="mt-2 text-sm text-slate-600">
                Pick a balanced ventilation unit rated at or above the calculated CFM. Then size the dedicated
                ventilation duct with the duct calculator — typically smaller than main supply trunks.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================ WORKED EXAMPLES ============================ -->
      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Worked examples</h2>
        <p class="mt-4 text-slate-600">
          Three common sizing scenarios — two residential homes per ASHRAE 62.2 and one commercial open office per
          ASHRAE 62.1.
        </p>

        <div class="mt-8 space-y-6">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-teal-100 text-teal-700 font-bold"
                >1</span
              >
              <h3 class="text-lg font-bold text-slate-900">2,000 sq ft home — 3 bedrooms (defaults)</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              area = 0.03 × 2,000 = <span class="font-bold text-teal-700">60 CFM</span><br />
              people = 7.5 × (3 + 1) = <span class="font-bold text-teal-700">30 CFM</span><br />
              total = 60 + 30 = <span class="font-bold text-teal-700">90 CFM</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> a typical mid-size home needs 90 CFM
              continuous ventilation — size a 90–100 CFM ERV/HRV and verify balanced supply/exhaust per local code.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-teal-100 text-teal-700 font-bold"
                >2</span
              >
              <h3 class="text-lg font-bold text-slate-900">2,500 sq ft home — 4 bedrooms</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              area = 0.03 × 2,500 = <span class="font-bold text-teal-700">75 CFM</span><br />
              people = 7.5 × (4 + 1) = <span class="font-bold text-teal-700">37.5 CFM</span><br />
              total = 75 + 37.5 = <span class="font-bold text-teal-700">113 CFM</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> larger floor area and an extra bedroom push
              ventilation to 113 CFM — common for 4-bedroom homes; confirm duct sizing for the longer fresh-air run.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 items-center justify-center rounded-full bg-teal-100 text-teal-700 font-bold"
                >3</span
              >
              <h3 class="text-lg font-bold text-slate-900">2,000 sq ft open office — 10 occupants</h3>
            </div>
            <div class="mt-4 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
              area = 2,000 × 0.06 = <span class="font-bold text-teal-700">120 CFM</span><br />
              people = 10 × 17.5 = <span class="font-bold text-teal-700">175 CFM</span><br />
              total = 120 + 175 = <span class="font-bold text-teal-700">295 CFM</span>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              <span class="font-semibold text-slate-900">Result:</span> people ventilation dominates in an occupied
              office — 295 CFM total outdoor air. Verify space type in ASHRAE 62.1 Table 6-1 before specifying DOAS
              or AHU outdoor air.
            </p>
          </div>
        </div>
      </section>

      <CalculatorFaqSection
        faqs={faqs}
        accent="teal"
        subtitle="Common questions about ASHRAE 62.2, 62.1, ERV/HRV sizing, and ventilation vs. cooling CFM."
      />

