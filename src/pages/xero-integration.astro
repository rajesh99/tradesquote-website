---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Xero Integration — TradesQuote";
const description =
  "Coming soon: Connect TradesQuote with Xero. Push accepted estimates as invoices automatically — no double data entry, contacts synced, and your books always current.";

const benefits = [
  {
    title: "Accepted estimate → Xero invoice, automatically",
    body:
      "When a client accepts your estimate in TradesQuote, it is pushed to Xero as a draft invoice with every line item, quantity, and price already filled in. No manual re-entry required.",
    accent: "blue",
  },
  {
    title: "Contacts synced between both systems",
    body:
      "New clients in TradesQuote are created as Contacts in Xero. Existing contacts are matched automatically so your address book stays clean — no duplicates.",
    accent: "cyan",
  },
  {
    title: "Zero double data entry",
    body:
      "The exact line items from your estimate land in Xero every time. No copy-paste, no transcription errors, no missed items — just accurate invoices, instantly.",
    accent: "sky",
  },
  {
    title: "Real-time receivables visibility",
    body:
      "Invoices appear in Xero the moment a job is won. Your bookkeeper or accountant gets an accurate, up-to-date picture of your outstanding receivables without chasing you for data.",
    accent: "indigo",
  },
  {
    title: "No App Store listing required",
    body:
      "The integration connects via the Xero API directly — no marketplace approval or listing needed. You authorise with your own Xero credentials using a standard OAuth 2.0 flow.",
    accent: "violet",
  },
  {
    title: "Developer sandbox for testing",
    body:
      "Xero provides a free demo company environment. The integration will be tested thoroughly against real Xero data before launch to ensure accuracy.",
    accent: "purple",
  },
] as const;

const plannedFlow = [
  {
    n: 1,
    title: "Connect your Xero organisation",
    body: "From Settings → Connections, click Connect Xero. You are redirected to Xero to log in and select your organisation — your password is never shared with TradesQuote.",
  },
  {
    n: 2,
    title: "Client accepts your estimate",
    body: "When a client signs or accepts an estimate via the shared link, TradesQuote detects the acceptance automatically.",
  },
  {
    n: 3,
    title: "Draft invoice created in Xero",
    body: "TradesQuote pushes the accepted estimate to Xero as a draft invoice — line items, contact details, and total all pre-filled.",
  },
  {
    n: 4,
    title: "Review and approve in Xero",
    body: "Log into Xero, review the draft invoice, approve it, and send to your client. No data entry needed — just a final review.",
  },
];

const faqs = [
  {
    q: "When will the Xero integration be available?",
    a: "We are actively building this integration. Sign up for a free trial and you will be notified by email as soon as it launches.",
  },
  {
    q: "Which Xero plans does it support?",
    a: "The integration targets Xero's Starter, Standard, and Premium plans via the Xero API. It does not require a Xero App Store listing for the initial release.",
  },
  {
    q: "Is this different from the QuickBooks integration?",
    a: "Functionally the same: accepted estimate → draft invoice, with contacts synced. Xero is more popular in Canada, Australia, and the UK. QuickBooks dominates in the US. We are building both.",
  },
  {
    q: "What data will be pushed to Xero?",
    a: "Accepted estimates are pushed as draft invoices: contact name, line item descriptions, quantities, unit prices, and totals. No personal or financial data beyond the estimate is transmitted.",
  },
  {
    q: "Does data flow back from Xero into TradesQuote?",
    a: "Not in the first release. The initial version is a one-way push: TradesQuote → Xero. Future versions may sync invoice payment status back to TradesQuote.",
  },
  {
    q: "Is my Xero password shared with TradesQuote?",
    a: "No. The integration uses OAuth 2.0 — the same standard used by Google and Microsoft sign-ins. TradesQuote never sees or stores your Xero password.",
  },
];

const accentRing: Record<(typeof benefits)[number]["accent"], string> = {
  blue: "ring-blue-500/25 bg-blue-500/5",
  cyan: "ring-cyan-500/25 bg-cyan-500/5",
  sky: "ring-sky-500/25 bg-sky-500/5",
  indigo: "ring-indigo-500/25 bg-indigo-500/5",
  violet: "ring-violet-500/25 bg-violet-500/5",
  purple: "ring-purple-500/25 bg-purple-500/5",
};
---

<Layout {title} {description}>
  <div class="bg-stone-50 min-h-screen">
    <Header />

    <!-- Coming Soon banner -->
    <div class="w-full bg-amber-50 border-b border-amber-200 px-6 py-3">
      <div class="max-w-6xl mx-auto flex items-center justify-center gap-3 flex-wrap">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-100 text-amber-800 text-xs font-bold uppercase tracking-wider border border-amber-300">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          Coming Soon
        </span>
        <p class="text-sm text-amber-900 font-medium">
          The Xero integration is in development and not yet available. Sign up to be notified when it launches.
        </p>
        <a
          href="/contact"
          class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-600 text-white text-xs font-semibold rounded-lg hover:bg-amber-700 transition-colors duration-150"
        >
          Notify me
        </a>
      </div>
    </div>

    <!-- Dark hero -->
    <header class="relative isolate overflow-hidden bg-slate-950 text-white pt-6 pb-20 sm:pb-28 px-6 sm:px-8">
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.35]"
        style={`background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.06'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")`}
        aria-hidden="true"
      ></div>
      <div class="pointer-events-none absolute -top-32 right-0 h-[420px] w-[420px] rounded-full bg-blue-600/25 blur-[100px]" aria-hidden="true"></div>
      <div class="pointer-events-none absolute bottom-0 left-1/4 h-[280px] w-[500px] rounded-full bg-cyan-500/15 blur-[90px]" aria-hidden="true"></div>

      <div class="relative z-10 max-w-6xl mx-auto">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-12 lg:gap-8 mt-12 sm:mt-16">
          <div class="max-w-2xl">
            <p class="text-xs font-semibold tracking-[0.25em] uppercase text-blue-300/90 mb-4">
              Integration · Xero
            </p>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.08] text-white">
              <span class="block text-slate-300 font-bold text-2xl sm:text-3xl mb-2 tracking-normal">
                TradesQuote
              </span>
              <span class="bg-gradient-to-r from-white via-blue-200 to-cyan-200 bg-clip-text text-transparent">
                + Xero
              </span>
            </h1>
            <p class="mt-6 text-lg sm:text-xl text-slate-400 leading-relaxed max-w-xl">
              Win the job in TradesQuote, invoice in Xero — without touching the data twice. Accepted
              estimates become Xero draft invoices automatically.
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 lg:pb-1">
            <div class="rounded-2xl border border-amber-400/40 bg-amber-500/10 px-5 py-4 backdrop-blur-sm min-w-[200px]">
              <p class="text-[11px] font-bold uppercase tracking-wider text-amber-300 mb-1">Status</p>
              <p class="text-2xl font-bold text-amber-300 tabular-nums">Coming Soon</p>
              <p class="text-sm text-amber-400/80 mt-0.5">Integration in development</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 px-5 py-4 backdrop-blur-sm min-w-[200px]">
              <p class="text-[11px] font-bold uppercase tracking-wider text-slate-500 mb-1">Security</p>
              <p class="text-lg font-semibold text-white leading-snug">OAuth 2.0</p>
              <p class="text-xs text-slate-500 mt-1">Password never shared</p>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 sm:px-8 pb-20 sm:pb-24 flex flex-col gap-20 sm:gap-24 pt-16">

      <!-- Benefits bento -->
      <section id="why" aria-labelledby="why-heading">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8 sm:mb-10">
          <div>
            <h2 id="why-heading" class="text-2xl sm:text-3xl font-bold text-stone-900 tracking-tight">
              Why connect TradesQuote to Xero?
            </h2>
            <p class="mt-2 text-stone-600 max-w-xl">
              Bridge the gap between estimating and accounting — no spreadsheets, no re-entry, no lag.
            </p>
          </div>
          <p class="text-xs font-semibold uppercase tracking-widest text-stone-400">Planned features</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-6 gap-4 auto-rows-fr">
          <div class="md:col-span-4 md:row-span-1 rounded-3xl p-8 sm:p-10 bg-gradient-to-br from-blue-600 via-blue-700 to-slate-900 text-white shadow-xl shadow-blue-900/20 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3" aria-hidden="true"></div>
            <p class="relative text-sm font-semibold text-blue-200 uppercase tracking-wider mb-3">Core value</p>
            <h3 class="relative text-2xl sm:text-3xl font-bold leading-tight max-w-md">{benefits[0].title}</h3>
            <p class="relative mt-4 text-blue-100/95 leading-relaxed max-w-xl text-sm sm:text-base">{benefits[0].body}</p>
          </div>

          <div class="md:col-span-2 flex flex-col gap-4">
            <div class={`flex-1 rounded-3xl p-6 ring-1 ${accentRing[benefits[1].accent]} border border-stone-200/60 bg-white`}>
              <h3 class="text-base font-bold text-stone-900">{benefits[1].title}</h3>
              <p class="mt-2 text-sm text-stone-600 leading-relaxed">{benefits[1].body}</p>
            </div>
            <div class={`flex-1 rounded-3xl p-6 ring-1 ${accentRing[benefits[2].accent]} border border-stone-200/60 bg-white`}>
              <h3 class="text-base font-bold text-stone-900">{benefits[2].title}</h3>
              <p class="mt-2 text-sm text-stone-600 leading-relaxed">{benefits[2].body}</p>
            </div>
          </div>

          {benefits.slice(3).map((b) => (
            <div class={`md:col-span-2 rounded-3xl p-6 sm:p-7 ring-1 ${accentRing[b.accent]} border border-stone-200/60 bg-white`}>
              <h3 class="text-base font-bold text-stone-900">{b.title}</h3>
              <p class="mt-3 text-sm text-stone-600 leading-relaxed">{b.body}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Planned flow -->
      <section id="flow" aria-labelledby="flow-heading">
        <div class="mb-6 rounded-2xl border border-amber-200 bg-amber-50 px-6 py-4 flex items-start gap-3">
          <svg class="shrink-0 mt-0.5 w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke-width="2"/><line x1="12" y1="8" x2="12" y2="12" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12.01" y2="16" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <p class="text-sm text-amber-900 leading-relaxed">
            <strong class="font-semibold">This integration is coming soon.</strong> The workflow below shows how it will work once available. <a href="https://app.tradesquote.ai/auth/sign-up" class="underline underline-offset-2 font-medium hover:text-amber-800">Sign up</a> to be notified at launch.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 items-start opacity-60 pointer-events-none select-none">
          <div class="lg:col-span-4 lg:sticky lg:top-32">
            <h2 id="flow-heading" class="text-2xl sm:text-3xl font-bold text-stone-900 tracking-tight">
              How it will work
            </h2>
            <p class="mt-3 text-stone-600 leading-relaxed">
              From accepted estimate to Xero invoice — the full flow runs in the background automatically.
            </p>
            <div class="mt-8 rounded-2xl border border-blue-200/80 bg-blue-50/80 p-5 text-sm text-blue-950 leading-relaxed">
              <p class="font-semibold text-blue-900 mb-1 flex items-center gap-2">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-lg bg-blue-600 text-white" aria-hidden="true">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                  </svg>
                </span>
                OAuth 2.0
              </p>
              <p class="m-0 text-blue-900/90">
                Your Xero password is never shared with TradesQuote. All credentials are encrypted and stored securely.
              </p>
            </div>
          </div>

          <div class="lg:col-span-8 relative">
            <div class="absolute left-[19px] top-3 bottom-3 w-px bg-gradient-to-b from-blue-400 via-blue-300 to-cyan-400 hidden sm:block" aria-hidden="true"></div>
            <ol class="relative space-y-6 m-0 p-0 list-none">
              {plannedFlow.map((step) => (
                <li class="relative flex gap-5 sm:gap-6 pl-0 sm:pl-2">
                  <span class="relative z-10 flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-white border-2 border-blue-500 text-sm font-bold text-blue-700 shadow-sm" aria-hidden="true">
                    {step.n}
                  </span>
                  <div class="min-w-0 flex-1 rounded-2xl border border-stone-200 bg-white p-5 sm:p-6 shadow-sm">
                    <h3 class="text-base font-bold text-stone-900 m-0">{step.title}</h3>
                    <p class="mt-2 text-sm sm:text-base text-stone-600 leading-relaxed m-0">{step.body}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section id="faq" aria-labelledby="faq-heading" class="pb-4">
        <h2 id="faq-heading" class="text-2xl sm:text-3xl font-bold text-stone-900 tracking-tight mb-8">
          Frequently asked questions
        </h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-5">
          {faqs.map((item, i) => (
            <details class="group rounded-2xl border border-stone-200 bg-white p-0 hover:border-blue-200/80 transition-colors duration-200 open:ring-2 open:ring-blue-100">
              <summary class="cursor-pointer list-none flex items-start justify-between gap-3 px-5 py-4 text-left font-semibold text-stone-900 text-sm [&::-webkit-details-marker]:hidden">
                <span class="pt-0.5">{item.q}</span>
                <span class="mt-0.5 shrink-0 flex h-8 w-8 items-center justify-center rounded-xl bg-stone-100 text-stone-500 group-open:bg-blue-100 group-open:text-blue-700 transition-colors" aria-hidden="true">
                  <svg class="w-4 h-4 transition-transform duration-200 group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 5v14M5 12h14" stroke-linecap="round"/>
                  </svg>
                </span>
              </summary>
              <div class={`px-5 pb-4 text-sm text-stone-600 leading-relaxed border-t border-stone-100 ${i % 2 === 0 ? "lg:border-l-4 lg:border-l-blue-200" : "lg:border-l-4 lg:border-l-cyan-200"}`}>
                <p class="m-0 pt-3">{item.a}</p>
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- Notify CTA -->
      <section class="rounded-3xl bg-slate-950 px-8 py-12 text-center relative overflow-hidden">
        <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(59,130,246,0.12), transparent 60%);" aria-hidden="true"></div>
        <p class="relative text-xs font-bold uppercase tracking-widest text-blue-400 mb-4">Coming Soon</p>
        <h2 class="relative text-2xl sm:text-3xl font-bold text-white mb-3">Be first to use the Xero integration</h2>
        <p class="relative text-slate-400 text-base max-w-lg mx-auto mb-8">
          Sign up for a free 14-day trial today. We will notify you by email the moment the Xero integration is live.
        </p>
        <a
          href="https://app.tradesquote.ai/auth/sign-up"
          class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-blue-600 text-white text-base font-semibold rounded-xl hover:bg-blue-500 active:scale-[0.98] transition-all duration-150 shadow-lg shadow-blue-500/25"
        >
          Get started — free 14-day trial
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </section>

      <p class="text-center text-xs text-[#808285] max-w-2xl mx-auto leading-relaxed px-2">
        Xero® and the Xero logo are trademarks of Xero Limited. TradesQuote is not affiliated with or endorsed by Xero Limited.
      </p>
    </main>
  </div>

  <Footer />
</Layout>
