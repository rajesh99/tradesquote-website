---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Privacy Policy — TradesQuote.ai";
const description =
  "Learn how Veersoft Solutions LLC collects, uses, and protects your information when you use TradesQuote.ai.";

const lastUpdated = "March 14, 2026";

const sections = [
  {
    id: "introduction",
    title: "Introduction",
    content: [
      "Veersoft Solutions LLC ('we', 'our', or 'us') operates the TradesQuote.ai service and related websites. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you use our service, including our integration with GetJobber.",
      "By using TradesQuote.ai, you agree to the collection and use of information in accordance with this policy. If you do not agree, please do not use our service.",
    ],
  },
  {
    id: "information-we-collect",
    title: "Information We Collect",
    content: [
      "We collect information you provide directly (e.g., account details, name, email, company information when you sign up or contact us), information from connected services as permitted by you, and automatically collected information (e.g., IP address, device type, usage data) to operate and improve our service.",
    ],
  },
  {
    id: "how-we-use",
    title: "How We Use Your Information",
    content: [
      "We use the information to provide, maintain, and improve TradesQuote.ai; to communicate with you about the service; to analyze usage and fix issues; and to comply with legal obligations and enforce our terms.",
    ],
  },
  {
    id: "sharing",
    title: "Sharing and Disclosure",
    content: [
      "We do not sell or rent your personal information to third parties. We only share information in the limited circumstances described below.",
      "Service providers: We share information with vendors who perform services on our behalf, such as hosting, infrastructure, email delivery, and analytics. These providers are only permitted to use your information to perform services for us and are bound by confidentiality obligations.",
      "GetJobber integration: If you choose to connect TradesQuote.ai with GetJobber, we share the estimate and quote data necessary to create and sync Quotes in your GetJobber account, as authorized by you through the OAuth connection. You can revoke this access at any time from your GetJobber or TradesQuote.ai account settings.",
      "Legal requirements: We may disclose information if required to do so by law, subpoena, or other legal process, or if we believe in good faith that disclosure is necessary to comply with legal obligations, protect the rights, property, or safety of TradesQuote.ai, our users, or others, or detect and prevent fraud or security issues.",
      "Business transfers: If we are involved in a merger, acquisition, financing, or sale of all or a portion of our assets, your information may be transferred as part of that transaction. We will notify you of any such change in ownership or control of your personal information.",
      "Any other sharing of your personal information will only occur with your consent.",
    ],
  },
  {
    id: "data-security",
    title: "Data Security",
    content: [
      "We implement appropriate technical and organizational measures to protect your data. No method of transmission or storage is 100% secure; we encourage you to use strong credentials and keep your GetJobber and TradesQuote.ai access secure.",
    ],
  },
  {
    id: "retention",
    title: "Data Retention",
    content: [
      "We retain your information for as long as your account is active or as needed to provide the service, comply with law, resolve disputes, and enforce our agreements. You may request deletion of your data subject to applicable law.",
    ],
  },
  {
    id: "your-rights",
    title: "Your Rights",
    content: [
      "Depending on your location, you may have rights to access, correct, delete, or port your data, or to object to or restrict certain processing. Contact us at the email below to exercise these rights. You may also unsubscribe from marketing emails at any time.",
    ],
  },
  {
    id: "cookies",
    title: "Cookies and Similar Technologies",
    content: [
      "We use cookies and similar technologies to operate our websites and service, remember preferences, and analyze usage. You can control cookies through your browser settings.",
    ],
  },
  {
    id: "changes",
    title: "Changes to This Policy",
    content: [
      "We may update this Privacy Policy from time to time. We will post the updated policy on this page and update the 'Last updated' date. Continued use of TradesQuote.ai after changes constitutes acceptance of the revised policy.",
    ],
  },
  {
    id: "contact",
    title: "Contact Us",
    content: [
      "For privacy-related questions or requests, contact us at sales@veersoftsolutions.com or at the address provided in the footer of this website.",
    ],
  },
];

const nav = sections.map((s) => ({ id: s.id, label: s.title }));
---

<Layout {title} {description}>
  <div class="bg-stone-50 min-h-screen">
    <Header />

    <!-- Dark hero -->
    <header
      class="relative isolate overflow-hidden bg-slate-950 text-white pt-6 pb-20 sm:pb-28 px-6 sm:px-8"
    >
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.35]"
        style={`background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.06'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")`}
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute -top-32 right-0 h-[420px] w-[420px] rounded-full bg-violet-600/30 blur-[100px]"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute bottom-0 left-1/4 h-[280px] w-[500px] rounded-full bg-emerald-500/15 blur-[90px]"
        aria-hidden="true"
      >
      </div>

      <div class="relative z-10 max-w-6xl mx-auto mt-12 sm:mt-16">
        <p class="text-xs font-semibold tracking-[0.25em] uppercase text-violet-300/90 mb-4">
          Legal · Privacy Policy
        </p>
        <h1
          class="text-4xl sm:text-5xl font-extrabold tracking-tight leading-[1.08] bg-gradient-to-r from-white via-violet-200 to-emerald-200 bg-clip-text text-transparent"
        >
          Privacy Policy
        </h1>
        <p class="mt-4 text-slate-400 text-base sm:text-lg">
          Last updated: {lastUpdated}
        </p>
      </div>
    </header>

    <!-- Sticky section nav -->
    <nav
      class="sticky top-16 z-40 border-b border-stone-200/80 bg-stone-50/85 backdrop-blur-md -mt-px"
      aria-label="On this page"
    >
      <div
        class="max-w-6xl mx-auto px-4 sm:px-6 py-2.5 flex gap-1 sm:gap-2 overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
      >
        {
          nav.map((item) => (
            <a
              href={`#${item.id}`}
              class="shrink-0 px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium text-stone-600 hover:text-violet-700 hover:bg-violet-50 transition-colors duration-150"
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </nav>

    <main class="max-w-6xl mx-auto px-6 sm:px-8 pb-20 sm:pb-24">
      <div class="max-w-3xl mx-auto flex flex-col gap-6 pt-10 sm:pt-14">
        {
          sections.map((section) => (
            <section
              id={section.id}
              class="scroll-mt-36 rounded-2xl border border-stone-200 bg-white p-6 sm:p-8 shadow-sm"
            >
              <h2 class="text-lg sm:text-xl font-bold text-stone-900 tracking-tight mb-4">
                {section.title}
              </h2>
              <div class="flex flex-col gap-3">
                {section.content.map((paragraph) => (
                  <p class="text-sm sm:text-base text-stone-600 leading-relaxed m-0">
                    {paragraph}
                  </p>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </main>
  </div>

  <Footer />
</Layout>
