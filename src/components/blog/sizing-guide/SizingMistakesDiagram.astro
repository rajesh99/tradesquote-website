---
import { C, FONT } from "../infographicTokens";

// Four common sizing mistakes from the post's "Common Sizing Mistakes" section
const mistakes: [string, string, typeof C.red | typeof C.orange | typeof C.blue | typeof C.muted][] = [
  ["Oversized AC", "Short cycles · poor dehumidification · higher bills", C.red],
  ["Undersized AC", "Runs nonstop · never reaches setpoint on design days", C.orange],
  ["Ignoring duct losses", "15–25% capacity lost in unconditioned attic ducts", C.blue],
  ["Square footage only", "Same footprint, different loads — wrong equipment every time", C.muted],
];

const lightMap: Record<string, string> = {
  [C.red]: C.redLight,
  [C.orange]: C.orangeLight,
  [C.blue]: C.blueLight,
  [C.muted]: "#F4F4F5",
};
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 250" fill="none" aria-hidden="true">
  <title>Four common HVAC sizing mistakes</title>
  <desc>
    The four most common HVAC sizing mistakes: oversizing AC causes short cycling and poor
    dehumidification; undersizing makes the unit run constantly; ignoring duct losses wastes
    15–25% of capacity; and sizing by square footage alone ignores window and insulation loads.
  </desc>

  <rect x="8" y="8" width="704" height="234" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Common sizing mistakes to avoid</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Each mistake adds cost, discomfort, or early equipment failure</text>

  {mistakes.map((m, i) => {
    const col = i % 2;
    const row = Math.floor(i / 2);
    const x = 24 + col * 348;
    const y = 72 + row * 82;
    const bg = lightMap[m[2]] ?? C.panelBg;
    return (
      <g>
        <rect x={x} y={y} width="328" height="68" rx="9" fill={bg} stroke={m[2]} stroke-width="1.4" stroke-opacity="0.5" />
        <circle cx={x + 22} cy={y + 22} r="10" fill={m[2]} fill-opacity="0.85" />
        <text x={x + 22} y={y + 27} text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="800">!</text>
        <text x={x + 42} y={y + 26} fill={C.dark} font-family={FONT} font-size="12" font-weight="800">{m[0]}</text>
        <text x={x + 14} y={y + 50} fill={C.muted} font-family={FONT} font-size="10.5">{m[1]}</text>
      </g>
    );
  })}
</svg>
