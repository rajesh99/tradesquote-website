---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 200" fill="none" aria-hidden="true">
  <title>Four steps to measure HVAC static pressure</title>
  <desc>Drill supply and return test holes, measure with a manometer after 10 minutes, then add absolute values.</desc>

  <rect x="16" y="8" width="160" height="184" rx="12" fill={C.panelBg} stroke={C.border} />
  <circle cx="44" cy="36" r="16" fill={C.primary} />
  <text x="44" y="41" text-anchor="middle" fill={C.white} font-family={FONT} font-size="14" font-weight="700">1</text>
  <text x="96" y="88" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Drill supply hole</text>
  <text x="96" y="114" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">18 in. downstream</text>
  <text x="96" y="128" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">of air handler</text>

  <path d="M184 100 H200" stroke={C.primary} stroke-width="2" marker-end="url(#tesp-step-arr)" />

  <rect x="192" y="8" width="160" height="184" rx="12" fill={C.panelBg} stroke={C.border} />
  <circle cx="220" cy="36" r="16" fill={C.primary} />
  <text x="220" y="41" text-anchor="middle" fill={C.white} font-family={FONT} font-size="14" font-weight="700">2</text>
  <text x="272" y="88" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Drill return hole</text>
  <text x="272" y="114" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">6 in. upstream</text>
  <text x="272" y="128" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">of inlet</text>

  <path d="M360 100 H376" stroke={C.primary} stroke-width="2" marker-end="url(#tesp-step-arr)" />

  <rect x="368" y="8" width="160" height="184" rx="12" fill={C.panelBg} stroke={C.border} />
  <circle cx="396" cy="36" r="16" fill={C.primary} />
  <text x="396" y="41" text-anchor="middle" fill={C.white} font-family={FONT} font-size="14" font-weight="700">3</text>
  <text x="448" y="88" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Measure 10+ min</text>
  <text x="448" y="114" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Manometer on</text>
  <text x="448" y="128" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">both ports</text>

  <path d="M536 100 H552" stroke={C.primary} stroke-width="2" marker-end="url(#tesp-step-arr)" />

  <rect x="544" y="8" width="160" height="184" rx="12" fill={C.panelBg} stroke={C.border} />
  <circle cx="572" cy="36" r="16" fill={C.primary} />
  <text x="572" y="41" text-anchor="middle" fill={C.white} font-family={FONT} font-size="14" font-weight="700">4</text>
  <text x="624" y="88" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Add absolutes</text>
  <text x="624" y="114" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">|supply| + |return|</text>
  <text x="624" y="164" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="18" font-weight="700">= TESP</text>

  <defs>
    <marker id="tesp-step-arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.primary} />
    </marker>
  </defs>
</svg>
