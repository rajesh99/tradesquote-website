---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 260" fill="none" aria-hidden="true">
  <title>TESP concept: supply and return static pressure</title>
  <desc>Total external static pressure equals the absolute value of supply static plus return static at the air handler.</desc>

  <rect x="8" y="8" width="704" height="244" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Air handler static pressure</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">TESP = |supply| + |return|</text>

  <!-- Return side -->
  <rect x="40" y="80" width="200" height="100" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="140" y="108" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Return plenum</text>
  <text x="140" y="132" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="20" font-weight="700">−0.21</text>
  <text x="140" y="152" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">in.w.c. (negative)</text>
  <path d="M248 130 H288" stroke={C.blue} stroke-width="2" marker-end="url(#tesp-arr-blue)" />

  <!-- Air handler -->
  <rect x="292" y="90" width="136" height="80" rx="8" fill={C.dark} />
  <text x="360" y="122" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="600">Air handler</text>
  <text x="360" y="142" text-anchor="middle" fill="#a1a5ae" font-family={FONT} font-size="9">Blower</text>
  <path d="M436 130 H476" stroke={C.orange} stroke-width="2" marker-end="url(#tesp-arr-orange)" />

  <!-- Supply side -->
  <rect x="480" y="80" width="200" height="100" rx="8" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="580" y="108" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Supply plenum</text>
  <text x="580" y="132" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="20" font-weight="700">+0.32</text>
  <text x="580" y="152" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">in.w.c. (positive)</text>

  <!-- Formula -->
  <rect x="120" y="200" width="480" height="40" rx="8" fill={C.white} stroke={C.border} />
  <text x="360" y="226" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="600">
    TESP = 0.32 + 0.21 = <tspan fill={C.primary} font-weight="700">0.53 in.w.c.</tspan>
  </text>

  <defs>
    <marker id="tesp-arr-blue" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.blue} />
    </marker>
    <marker id="tesp-arr-orange" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.orange} />
    </marker>
  </defs>
</svg>
