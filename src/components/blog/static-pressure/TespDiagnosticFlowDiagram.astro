---
import { C, FONT } from "../infographicTokens";
const steps = ["Dirty air filter", "Dirty evaporator coil", "Undersized return duct", "Kinked flex duct", "Closed dampers"];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>High TESP diagnostic flow</title>
  <desc>High static pressure: check filter, coil, return duct, flex duct, and dampers.</desc>

  <rect x="280" y="8" width="160" height="44" rx="8" fill={C.dark} />
  <text x="360" y="28" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="600">High TESP</text>
  <text x="360" y="42" text-anchor="middle" fill="#a1a5ae" font-family={FONT} font-size="9">Above nameplate rating</text>
  <path d="M360 52 V76" stroke={C.border} stroke-width="2" marker-end="url(#tesp-diag-arr)" />

  {steps.map((label, i) => {
    const y = 80 + i * 44;
    const highlight = i === 0;
    return (
      <g>
        <rect x="200" y={y} width="320" height="32" rx="6" fill={highlight ? C.primaryLight : C.panelBg} stroke={highlight ? C.primary : C.border} stroke-width={highlight ? 1.5 : 1} />
        <text x="220" y={y + 20} fill={C.dark} font-family={FONT} font-size="10" font-weight="600">{`${i + 1}. ${label}`}</text>
        {i < 4 ? <path d={`M360 ${y + 32} V${y + 44}`} stroke={C.border} stroke-width="2" /> : null}
      </g>
    );
  })}

  <rect x="200" y="300" width="320" height="16" rx="4" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="360" y="312" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="9" font-weight="600">Start with filter — often adds 0.15–0.30 in.w.c.</text>

  <defs>
    <marker id="tesp-diag-arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.border} />
    </marker>
  </defs>
</svg>
