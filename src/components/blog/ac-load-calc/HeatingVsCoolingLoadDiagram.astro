---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 250" fill="none" aria-hidden="true">
  <title>Heating load versus cooling load</title>
  <desc>
    A load calculation produces two numbers. Heating load is the heat a building loses in winter, in BTU
    per hour. Cooling load is the heat it gains in summer, which splits into sensible heat (temperature)
    and latent heat (moisture removal).
  </desc>

  <rect x="8" y="8" width="704" height="234" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Two loads every calc produces</text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">Heating sizes the winter peak; cooling sizes the summer peak — and adds moisture</text>

  <rect x="24" y="70" width="320" height="156" rx="10" fill={C.orangeLight} stroke={C.orange} stroke-width="1.4" />
  <text x="40" y="96" fill={C.orange} font-family={FONT} font-size="12.5" font-weight="800">Heating load</text>
  <text x="40" y="126" fill={C.dark} font-family={FONT} font-size="17" font-weight="800">Winter heat LOSS</text>
  <text x="40" y="148" fill={C.muted} font-family={FONT} font-size="11">Measured in BTU/hr</text>
  <text x="40" y="186" fill={C.muted} font-family={FONT} font-size="10.5">Pure heat loss through walls, roof,</text>
  <text x="40" y="202" fill={C.muted} font-family={FONT} font-size="10.5">windows, and infiltration.</text>

  <rect x="376" y="70" width="320" height="156" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.4" />
  <text x="392" y="96" fill={C.blue} font-family={FONT} font-size="12.5" font-weight="800">Cooling load</text>
  <text x="392" y="124" fill={C.dark} font-family={FONT} font-size="17" font-weight="800">Summer heat GAIN</text>
  <text x="392" y="146" fill={C.muted} font-family={FONT} font-size="11">BTU/hr — sensible + latent</text>
  <rect x="392" y="160" width="138" height="50" rx="8" fill={C.white} stroke={C.border} stroke-width="1.2" />
  <text x="461" y="182" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Sensible</text>
  <text x="461" y="198" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">temperature</text>
  <rect x="544" y="160" width="138" height="50" rx="8" fill={C.white} stroke={C.border} stroke-width="1.2" />
  <text x="613" y="182" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Latent</text>
  <text x="613" y="198" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">moisture removal</text>
</svg>
