---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>The three heat formulas</title>
  <desc>Sensible heat uses 1.08 and delta T, latent heat uses 0.68 and delta grains, and total heat uses 4.5 and delta enthalpy.</desc>

  <text x="360" y="32" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">The three heat formulas</text>

  <!-- Sensible -->
  <rect x="60" y="54" width="600" height="68" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="84" y="82" fill={C.blue} font-family={FONT} font-size="12" font-weight="700">SENSIBLE HEAT</text>
  <text x="84" y="104" fill={C.dark} font-family={FONT} font-size="19" font-weight="800">Qs = 1.08 &#215; CFM &#215; &#916;T</text>
  <text x="636" y="82" text-anchor="end" fill={C.muted} font-family={FONT} font-size="11">temperature change</text>
  <text x="636" y="104" text-anchor="end" fill={C.muted} font-family={FONT} font-size="11">(dry-bulb &#916;T)</text>

  <!-- Latent -->
  <rect x="60" y="130" width="600" height="68" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="84" y="158" fill={C.primary} font-family={FONT} font-size="12" font-weight="700">LATENT HEAT</text>
  <text x="84" y="180" fill={C.dark} font-family={FONT} font-size="19" font-weight="800">Ql = 0.68 &#215; CFM &#215; &#916;Grains</text>
  <text x="636" y="158" text-anchor="end" fill={C.muted} font-family={FONT} font-size="11">moisture removed</text>
  <text x="636" y="180" text-anchor="end" fill={C.muted} font-family={FONT} font-size="11">(humidity &#916;)</text>

  <!-- Total -->
  <rect x="60" y="206" width="600" height="68" rx="10" fill={C.panelBg} stroke={C.border} stroke-width="1.5" />
  <text x="84" y="234" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">TOTAL HEAT</text>
  <text x="84" y="256" fill={C.dark} font-family={FONT} font-size="19" font-weight="800">Qt = 4.5 &#215; CFM &#215; &#916;h</text>
  <text x="636" y="234" text-anchor="end" fill={C.muted} font-family={FONT} font-size="11">sensible + latent</text>
  <text x="636" y="256" text-anchor="end" fill={C.muted} font-family={FONT} font-size="11">(enthalpy &#916;h)</text>

  <text x="360" y="302" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Sensible tracks temperature, latent tracks moisture, total combines both via enthalpy.</text>
</svg>
