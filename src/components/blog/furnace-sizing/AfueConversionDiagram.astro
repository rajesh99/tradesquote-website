---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 220" fill="none" aria-hidden="true">
  <title>AFUE input vs output BTU conversion</title>
  <desc>Input BTU equals output BTU divided by AFUE. Nameplate shows input BTU.</desc>

  <rect x="8" y="8" width="704" height="204" rx="12" fill={C.panelBg} stroke={C.border} />

  <rect x="40" y="48" width="160" height="72" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="120" y="76" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Output needed</text>
  <text x="120" y="104" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="22" font-weight="700">80,000</text>

  <text x="240" y="88" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="20">÷</text>

  <rect x="280" y="48" width="120" height="72" rx="8" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="340" y="76" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">AFUE</text>
  <text x="340" y="104" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="22" font-weight="700">0.96</text>

  <text x="440" y="88" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="20">=</text>

  <rect x="480" y="48" width="200" height="72" rx="8" fill={C.dark} />
  <text x="580" y="76" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="700">Input (nameplate)</text>
  <text x="580" y="104" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="22" font-weight="700">83,333 BTU</text>

  <rect x="40" y="140" width="640" height="56" rx="8" fill={C.white} stroke={C.border} />
  <text x="360" y="164" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">At 80% AFUE: 80,000 ÷ 0.80 = 100,000 input — one full nameplate size larger</text>
  <text x="360" y="182" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="10" font-weight="600">Always convert before comparing furnace prices</text>
</svg>
