---
import { C, FONT } from "../infographicTokens";

// Tons per 1,000 sq ft by building type — from post table
const rows = [
  { label: "Warehouse (minimal)", low: 1.0, high: 2.0, color: C.muted },
  { label: "Office (open plan)",  low: 2.5, high: 3.5, color: C.blue },
  { label: "Retail",              low: 3.0, high: 4.0, color: C.primary },
  { label: "Restaurant kitchen",  low: 8.0, high: 12.0, color: C.orange },
];

const scaleMax = 13;
const barLeft = 210;
const barWidth = 460;
const toX = (v: number) => barLeft + (v / scaleMax) * barWidth;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 260" fill="none" aria-hidden="true">
  <title>Commercial HVAC tons per 1,000 sq ft by building type</title>
  <desc>
    Horizontal bars showing cooling load rules of thumb: warehouses need 1–2 tons per 1,000 sq ft,
    offices 2.5–3.5, retail 3–4, and restaurant kitchens 8–12.
  </desc>

  <rect x="8" y="8" width="704" height="244" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">
    Tons per 1,000 sq ft — commercial rule of thumb
  </text>
  <text x="24" y="55" fill={C.muted} font-family={FONT} font-size="11">
    Starting-point estimates only — restaurant kitchens and data centers need detailed load analysis
  </text>

  {/* Scale lines */}
  {[0, 3, 6, 9, 12].map((v) => (
    <g>
      <line x1={toX(v)} y1="68" x2={toX(v)} y2="224" stroke={C.border} stroke-width="1" stroke-dasharray="3 3" />
      <text x={toX(v)} y="238" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">
        {v}
      </text>
    </g>
  ))}
  <text x={toX(6)} y="252" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">
    tons / 1,000 sf
  </text>

  {rows.map((r, i) => {
    const y = 76 + i * 38;
    return (
      <g>
        <text x="24" y={y + 14} fill={C.dark} font-family={FONT} font-size="11" font-weight="600">
          {r.label}
        </text>
        <rect
          x={toX(r.low)}
          y={y}
          width={toX(r.high) - toX(r.low)}
          height="20"
          rx="5"
          fill={r.color}
          opacity="0.82"
        />
        <text x={toX(r.low) - 4} y={y + 14} text-anchor="end" fill={C.muted} font-family={FONT} font-size="9">
          {r.low}
        </text>
        <text x={toX(r.high) + 4} y={y + 14} fill={C.muted} font-family={FONT} font-size="9">
          {r.high}
        </text>
      </g>
    );
  })}
</svg>
