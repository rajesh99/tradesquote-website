---
import { C, FONT } from "../infographicTokens";

// Inputs/drivers from the post's "What a Cost Calculator Asks" table + "Cost Drivers Most Calculators Miss"
const drivers = [
  { label: "System type",         detail: "AC-only vs full system vs heat pump", color: C.blue,   bgColor: C.blueLight },
  { label: "Tonnage / BTU",       detail: "Larger = more equipment cost",         color: C.primary, bgColor: C.primaryLight },
  { label: "SEER2 / AFUE tier",   detail: "High efficiency adds $1,500–$4,000",   color: C.green,  bgColor: C.greenLight },
  { label: "Duct condition",      detail: "Replacement adds $2,000–$6,000",       color: C.orange, bgColor: C.orangeLight },
  { label: "Region",              detail: "NE / West Coast +25–35% labor",        color: C.blue,   bgColor: C.blueLight },
  { label: "Electrical upgrade",  detail: "Heat pump may need $500–$1,500",       color: C.primary, bgColor: C.primaryLight },
];

const missed = [
  { label: "Permits",             detail: "$150–$500" },
  { label: "Line set replace",    detail: "$200–$800" },
  { label: "Thermostat upgrade",  detail: "$150–$400" },
  { label: "Condensate rework",   detail: "varies" },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 370" fill="none" aria-hidden="true">
  <title>HVAC replacement cost drivers and hidden extras</title>
  <desc>
    Six calculator inputs that move the price — system type, tonnage, efficiency tier, duct condition, region, and electrical — plus four costs most calculators miss: permits, line set replacement, thermostat upgrade, and condensate rework.
  </desc>

  <rect x="8" y="8" width="704" height="354" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">
    What drives the final price
  </text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">
    Calculator inputs (top) · costs most calculators miss (bottom)
  </text>

  {/* Calculator input cards — 3 per row */}
  {drivers.map((d, i) => {
    const col = i % 3;
    const row = Math.floor(i / 3);
    const x = 24 + col * 226;
    const y = 68 + row * 72;
    return (
      <g>
        <rect x={x} y={y} width="212" height="58" rx="8" fill={d.bgColor} stroke={d.color} stroke-width="1.2" stroke-opacity="0.5" />
        <text x={x + 12} y={y + 22} fill={d.color} font-family={FONT} font-size="11" font-weight="700">
          {d.label}
        </text>
        <text x={x + 12} y={y + 40} fill={C.muted} font-family={FONT} font-size="10">
          {d.detail}
        </text>
      </g>
    );
  })}

  {/* Divider */}
  <line x1="24" y1="224" x2="696" y2="224" stroke={C.border} stroke-width="1" stroke-dasharray="4 3" />
  <text x="24" y="245" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">
    Extras most calculators miss
  </text>

  {/* Missed-cost pills — 4 in a row */}
  {missed.map((m, i) => {
    const x = 24 + i * 170;
    return (
      <g>
        <rect x={x} y="256" width="156" height="52" rx="8" fill={C.redLight} stroke={C.red} stroke-width="1.1" stroke-opacity="0.45" />
        <text x={x + 12} y="276" fill={C.red} font-family={FONT} font-size="10.5" font-weight="700">
          {m.label}
        </text>
        <text x={x + 12} y="296" fill={C.muted} font-family={FONT} font-size="10">
          {m.detail}
        </text>
      </g>
    );
  })}
</svg>
