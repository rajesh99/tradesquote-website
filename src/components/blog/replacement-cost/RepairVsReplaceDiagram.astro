---
import { C, FONT } from "../infographicTokens";

// Repair-vs-replace signals; numbers grounded in the post's FAQ ($7k–$14k full system, component cost ranges)
const repairSignals = [
  "System under 10 years old",
  "Repair cost under $1,000",
  "Good ductwork + efficiency",
  "Refrigerant R-410A (in stock)",
];

const replaceSignals = [
  "System 15+ years old",
  "Repair cost > ½ replacement",
  "R-22 refrigerant (phased out)",
  "Frequent breakdowns or inefficient",
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 250" fill="none" aria-hidden="true">
  <title>Repair vs replace decision signals</title>
  <desc>
    Two columns: signals that favor repairing the existing HVAC system versus signals that favor full replacement, to help homeowners use the calculator result in context.
  </desc>

  <rect x="8" y="8" width="704" height="234" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">
    Repair vs. replace decision guide
  </text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">
    Use alongside calculator output — cost alone doesn't tell the whole story
  </text>

  {/* Repair column */}
  <rect x="24" y="66" width="320" height="162" rx="8" fill={C.greenLight} stroke={C.green} stroke-width="1.3" stroke-opacity="0.5" />
  <text x="44" y="90" fill={C.green} font-family={FONT} font-size="12" font-weight="700">
    Lean toward REPAIR
  </text>
  {repairSignals.map((s, i) => (
    <g>
      <circle cx="44" cy={108 + i * 30} r="5" fill={C.green} opacity="0.7" />
      <text x="58" y={113 + i * 30} fill={C.dark} font-family={FONT} font-size="10.5">
        {s}
      </text>
    </g>
  ))}

  {/* Replace column */}
  <rect x="376" y="66" width="320" height="162" rx="8" fill={C.redLight} stroke={C.red} stroke-width="1.3" stroke-opacity="0.45" />
  <text x="396" y="90" fill={C.red} font-family={FONT} font-size="12" font-weight="700">
    Lean toward REPLACE
  </text>
  {replaceSignals.map((s, i) => (
    <g>
      <circle cx="396" cy={108 + i * 30} r="5" fill={C.red} opacity="0.65" />
      <text x="410" y={113 + i * 30} fill={C.dark} font-family={FONT} font-size="10.5">
        {s}
      </text>
    </g>
  ))}

  {/* VS badge */}
  <circle cx="360" cy="148" r="20" fill={C.dark} />
  <text x="360" y="154" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="800">VS</text>
</svg>
