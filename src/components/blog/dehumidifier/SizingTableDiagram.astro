---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 340" fill="none" aria-hidden="true">
  <title>Dehumidifier sizing by area and dampness</title>
  <desc>
    Approximate pints-per-day capacity under the 2019 DOE rating, by floor area and dampness level.
    Larger and damper spaces need more capacity; round up and add for laundry, crawlspaces, or coastal air.
  </desc>

  <rect x="8" y="8" width="704" height="324" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Dehumidifier sizing by area &amp; dampness</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Approximate pints per day (2019 DOE rating)</text>

  <!-- Column headers -->
  <text x="150" y="92" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Area</text>
  <rect x="232" y="76" width="148" height="24" rx="6" fill={C.greenLight} stroke={C.green} stroke-width="1" />
  <text x="306" y="92" text-anchor="middle" fill={C.green} font-family={FONT} font-size="11" font-weight="700">Damp</text>
  <rect x="392" y="76" width="148" height="24" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1" />
  <text x="466" y="92" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="11" font-weight="700">Wet</text>
  <rect x="552" y="76" width="148" height="24" rx="6" fill={C.redLight} stroke={C.red} stroke-width="1" />
  <text x="626" y="92" text-anchor="middle" fill={C.red} font-family={FONT} font-size="11" font-weight="700">Extremely wet</text>

  <!-- Row 1: 300 sq ft -->
  <text x="40" y="130" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">300 sq ft</text>
  <rect x="232" y="114" width="148" height="28" rx="6" fill={C.greenLight} stroke={C.border} />
  <text x="306" y="133" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">8&#8211;10 pt</text>
  <rect x="392" y="114" width="148" height="28" rx="6" fill={C.orangeLight} stroke={C.border} />
  <text x="466" y="133" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">12 pt</text>
  <rect x="552" y="114" width="148" height="28" rx="6" fill={C.redLight} stroke={C.border} />
  <text x="626" y="133" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">14 pt</text>

  <!-- Row 2: 500 sq ft -->
  <text x="40" y="166" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">500 sq ft</text>
  <rect x="232" y="150" width="148" height="28" rx="6" fill={C.greenLight} stroke={C.border} />
  <text x="306" y="169" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">10&#8211;12 pt</text>
  <rect x="392" y="150" width="148" height="28" rx="6" fill={C.orangeLight} stroke={C.border} />
  <text x="466" y="169" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">14 pt</text>
  <rect x="552" y="150" width="148" height="28" rx="6" fill={C.redLight} stroke={C.border} />
  <text x="626" y="169" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">16 pt</text>

  <!-- Row 3: 800 sq ft -->
  <text x="40" y="202" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">800 sq ft</text>
  <rect x="232" y="186" width="148" height="28" rx="6" fill={C.greenLight} stroke={C.border} />
  <text x="306" y="205" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">12 pt</text>
  <rect x="392" y="186" width="148" height="28" rx="6" fill={C.orangeLight} stroke={C.border} />
  <text x="466" y="205" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">16 pt</text>
  <rect x="552" y="186" width="148" height="28" rx="6" fill={C.redLight} stroke={C.border} />
  <text x="626" y="205" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">18&#8211;20 pt</text>

  <!-- Row 4: 1,200 sq ft -->
  <text x="40" y="238" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">1,200 sq ft</text>
  <rect x="232" y="222" width="148" height="28" rx="6" fill={C.greenLight} stroke={C.border} />
  <text x="306" y="241" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">14&#8211;16 pt</text>
  <rect x="392" y="222" width="148" height="28" rx="6" fill={C.orangeLight} stroke={C.border} />
  <text x="466" y="241" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">18&#8211;20 pt</text>
  <rect x="552" y="222" width="148" height="28" rx="6" fill={C.redLight} stroke={C.border} />
  <text x="626" y="241" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">22 pt</text>

  <!-- Row 5: 1,500+ sq ft -->
  <text x="40" y="274" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">1,500+ sq ft</text>
  <rect x="232" y="258" width="148" height="28" rx="6" fill={C.greenLight} stroke={C.border} />
  <text x="306" y="277" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">18&#8211;20 pt</text>
  <rect x="392" y="258" width="148" height="28" rx="6" fill={C.orangeLight} stroke={C.border} />
  <text x="466" y="277" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">22&#8211;25 pt</text>
  <rect x="552" y="258" width="148" height="28" rx="6" fill={C.redLight} stroke={C.border} />
  <text x="626" y="277" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">30+ pt</text>

  <text x="360" y="312" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">
    Approximate pints-per-day (2019 DOE rating). Round up; add capacity for laundry, crawlspaces, or coastal air.
  </text>
</svg>
