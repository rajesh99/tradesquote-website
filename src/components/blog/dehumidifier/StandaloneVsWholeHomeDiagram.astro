---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Portable vs whole-house dehumidifier</title>
  <desc>
    Portable units suit a single room or basement, up to about 50 pints, with a manual tank or hose and
    lower cost. Whole-house ducted units serve the entire home, integrate with the HVAC system, run
    hands-off, cost more, and suit large or tight homes.
  </desc>

  <rect x="8" y="8" width="704" height="304" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Portable vs whole-house</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Two ways to control indoor humidity</text>

  <!-- Portable column -->
  <rect x="32" y="76" width="320" height="196" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="48" y="104" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Portable / standalone</text>
  <text x="48" y="124" fill={C.blue} font-family={FONT} font-size="11" font-weight="600">Single room or basement</text>

  <circle cx="56" cy="148" r="3" fill={C.blue} />
  <text x="68" y="152" fill={C.muted} font-family={FONT} font-size="10">Capacity up to ~50 pt (new standard)</text>
  <circle cx="56" cy="172" r="3" fill={C.blue} />
  <text x="68" y="176" fill={C.muted} font-family={FONT} font-size="10">Empty a tank or run a condensate hose</text>
  <circle cx="56" cy="196" r="3" fill={C.blue} />
  <text x="68" y="200" fill={C.muted} font-family={FONT} font-size="10">Lower upfront cost, plug-and-play</text>
  <circle cx="56" cy="220" r="3" fill={C.blue} />
  <text x="68" y="224" fill={C.muted} font-family={FONT} font-size="10">Audible in the room it serves</text>
  <circle cx="56" cy="244" r="3" fill={C.blue} />
  <text x="68" y="248" fill={C.muted} font-family={FONT} font-size="10">Needs airflow clearance around it</text>

  <!-- Whole-house column -->
  <rect x="368" y="76" width="320" height="196" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="384" y="104" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Whole-house ducted</text>
  <text x="384" y="124" fill={C.primary} font-family={FONT} font-size="11" font-weight="600">Entire home</text>

  <circle cx="392" cy="148" r="3" fill={C.primary} />
  <text x="404" y="152" fill={C.muted} font-family={FONT} font-size="10">Sized for the whole home (70&#8211;155 pt class)</text>
  <circle cx="392" cy="172" r="3" fill={C.primary} />
  <text x="404" y="176" fill={C.muted} font-family={FONT} font-size="10">Integrates with HVAC or own ducting</text>
  <circle cx="392" cy="196" r="3" fill={C.primary} />
  <text x="404" y="200" fill={C.muted} font-family={FONT} font-size="10">Hands-off, drains automatically</text>
  <circle cx="392" cy="220" r="3" fill={C.primary} />
  <text x="404" y="224" fill={C.muted} font-family={FONT} font-size="10">Quieter, consistent whole-home control</text>
  <circle cx="392" cy="244" r="3" fill={C.primary} />
  <text x="404" y="248" fill={C.muted} font-family={FONT} font-size="10">Higher cost; best for large/tight homes</text>

  <text x="360" y="296" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">
    One damp room &#8594; portable. Whole-home or tight construction &#8594; ducted whole-house unit.
  </text>
</svg>
