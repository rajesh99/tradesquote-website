---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>How damp is the space?</title>
  <desc>
    Four dampness tiers and their tell-tale signs: Damp (musty smell, 50 to 60 percent RH),
    Moderately damp (damp feel, 60 to 70 percent RH), Wet (visible moisture), and Extremely wet
    (standing water or sweating walls, 80 percent RH and above).
  </desc>

  <rect x="8" y="8" width="704" height="304" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">How damp is the space?</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Match the tier to what you can see and smell</text>

  <!-- Tier 1: Damp -->
  <rect x="24" y="76" width="320" height="100" rx="10" fill={C.greenLight} stroke={C.green} stroke-width="1.5" />
  <text x="40" y="102" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Damp</text>
  <text x="40" y="122" fill={C.green} font-family={FONT} font-size="11" font-weight="600">~50&#8211;60% RH</text>
  <text x="40" y="146" fill={C.muted} font-family={FONT} font-size="10">Musty smell in humid weather.</text>
  <text x="40" y="162" fill={C.muted} font-family={FONT} font-size="10">No visible moisture.</text>

  <!-- Tier 2: Moderately damp -->
  <rect x="376" y="76" width="320" height="100" rx="10" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="392" y="102" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Moderately damp</text>
  <text x="392" y="122" fill={C.orange} font-family={FONT} font-size="11" font-weight="600">~60&#8211;70% RH</text>
  <text x="392" y="146" fill={C.muted} font-family={FONT} font-size="10">Air feels damp and clammy.</text>
  <text x="392" y="162" fill={C.muted} font-family={FONT} font-size="10">Persistent musty odor.</text>

  <!-- Tier 3: Wet -->
  <rect x="24" y="188" width="320" height="100" rx="10" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="40" y="214" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Wet</text>
  <text x="40" y="234" fill={C.orange} font-family={FONT} font-size="11" font-weight="600">~70&#8211;80% RH</text>
  <text x="40" y="258" fill={C.muted} font-family={FONT} font-size="10">Visible moisture on walls/floor.</text>
  <text x="40" y="274" fill={C.muted} font-family={FONT} font-size="10">Occasional seepage.</text>

  <!-- Tier 4: Extremely wet -->
  <rect x="376" y="188" width="320" height="100" rx="10" fill={C.redLight} stroke={C.red} stroke-width="1.5" />
  <text x="392" y="214" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Extremely wet</text>
  <text x="392" y="234" fill={C.red} font-family={FONT} font-size="11" font-weight="600">~80&#8211;90%+ RH</text>
  <text x="392" y="258" fill={C.muted} font-family={FONT} font-size="10">Standing water, sweating walls.</text>
  <text x="392" y="274" fill={C.muted} font-family={FONT} font-size="10">Active seepage.</text>

  <text x="360" y="304" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">
    Match the dampness level to the symptoms you can see and smell.
  </text>
</svg>
