---
import { C, FONT } from "../infographicTokens";

const standards = [
  {
    label: "Manual J",
    purpose: "Load calculation",
    output: "BTU/hr heating & cooling load",
    color: C.blue,
    bg: C.blueLight,
  },
  {
    label: "Manual S",
    purpose: "Equipment selection",
    output: "Match equipment to Manual J load",
    color: C.orange,
    bg: C.orangeLight,
  },
  {
    label: "Manual D",
    purpose: "Duct design",
    output: "Duct sizes, CFM per room, friction rate",
    color: C.primary,
    bg: C.primaryLight,
  },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 240" fill="none" aria-hidden="true">
  <title>Manual J, S, and D — what each ACCA standard does</title>
  <desc>
    Three ACCA standards work in sequence: Manual J calculates the load, Manual S selects equipment,
    and Manual D sizes the ductwork to deliver that load to every room.
  </desc>

  <rect x="8" y="8" width="704" height="224" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">The three ACCA design standards</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Load → Equipment → Ducts — each step feeds the next</text>

  {standards.map((s, i) => {
    const x = 24 + i * 228;
    return (
      <g>
        <rect x={x} y="74" width="210" height="138" rx="10" fill={s.bg} stroke={s.color} stroke-width="1.6" stroke-opacity="0.5" />
        <rect x={x} y="74" width="210" height="30" rx="10" fill={s.color} fill-opacity="0.18" />
        <rect x={x} y="90" width="210" height="14" rx="0" fill={s.color} fill-opacity="0.18" />
        <text x={x + 105} y="94" text-anchor="middle" fill={s.color} font-family={FONT} font-size="15" font-weight="800">{s.label}</text>
        <text x={x + 105} y="122" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">{s.purpose}</text>
        <text x={x + 105} y="148" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">{s.output.split(",")[0]}</text>
        {s.output.includes(",") && (
          <text x={x + 105} y="164" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">{s.output.split(",").slice(1).join(",").trim()}</text>
        )}
        {i < standards.length - 1 && (
          <path d={`M${x + 210} 143 l 16 0`} stroke={C.muted} stroke-width="1.6" fill="none" marker-end="url(#mds-arr)" />
        )}
      </g>
    );
  })}

  <defs>
    <marker id="mds-arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.muted} />
    </marker>
  </defs>
</svg>
