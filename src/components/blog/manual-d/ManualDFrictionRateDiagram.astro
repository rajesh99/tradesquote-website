---
import { C, FONT } from "../infographicTokens";

// Chain: Available Static Pressure → minus losses → Friction Rate → duct size
const chain = [
  { label: "Blower capacity", sub: "from equipment specs", color: C.blue, bg: C.blueLight },
  { label: "Minus losses", sub: "coil + filter + grille", color: C.orange, bg: C.orangeLight },
  { label: "Available static", sub: "inches w.c. remaining", color: C.primary, bg: C.primaryLight },
  { label: "÷ Longest run", sub: "in hundreds of feet", color: C.muted, bg: C.white },
  { label: "Friction rate", sub: "in.wc / 100 ft", color: C.primary, bg: C.primaryLight },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 200" fill="none" aria-hidden="true">
  <title>How Manual D friction rate is derived from available static pressure</title>
  <desc>
    Subtract coil, filter, and grille pressure losses from the blower rating to get available static.
    Divide that by the longest duct run length to get the design friction rate for duct sizing.
  </desc>

  <rect x="8" y="8" width="704" height="184" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">From blower capacity to friction rate</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Friction rate = available static pressure ÷ longest run length</text>

  {chain.map((c, i) => {
    const x = 20 + i * 137;
    const isResult = i === chain.length - 1;
    return (
      <g>
        <rect x={x} y="74" width="122" height="88" rx="9" fill={c.bg} stroke={c.color} stroke-width={isResult ? 2.2 : 1.4} stroke-opacity={isResult ? 0.9 : 0.5} />
        <text x={x + 61} y="107" text-anchor="middle" fill={c.color} font-family={FONT} font-size="11" font-weight="800">{c.label}</text>
        <text x={x + 61} y="126" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">{c.sub}</text>
        {isResult && (
          <text x={x + 61} y="150" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="13" font-weight="800">0.1 in.wc/100ft</text>
        )}
        {i < chain.length - 1 && (
          <path d={`M${x + 122} 118 l 13 0`} stroke={C.muted} stroke-width="1.4" fill="none" marker-end="url(#mdfr-arr)" />
        )}
      </g>
    );
  })}

  <defs>
    <marker id="mdfr-arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.muted} />
    </marker>
  </defs>
</svg>
