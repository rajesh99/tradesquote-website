---
import { C, FONT } from "../infographicTokens";

const rows = [
  { sqft: "600 – 1,000", tons: "1.5 ton", w: 90 },
  { sqft: "1,000 – 1,300", tons: "2 ton", w: 120 },
  { sqft: "1,300 – 1,600", tons: "2.5 ton", w: 150 },
  { sqft: "1,600 – 1,900", tons: "3 ton", w: 180 },
  { sqft: "1,900 – 2,200", tons: "3.5 ton", w: 210 },
  { sqft: "2,200 – 2,600", tons: "4 ton", w: 240 },
  { sqft: "2,600 – 3,200", tons: "5 ton", w: 270 },
];
const rowH = 28;
const top = 70;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Square footage to tonnage chart</title>
  <desc>A chart mapping conditioned square footage ranges to recommended air conditioner tonnage, from 1.5 ton up to 5 ton, assuming about 20 BTU per square foot in a moderate climate.</desc>

  <text x="360" y="34" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Square footage &#8594; recommended tonnage</text>

  <!-- Column headers -->
  <text x="50" y="58" fill={C.muted} font-family={FONT} font-size="11" font-weight="700">CONDITIONED AREA</text>
  <text x="300" y="58" fill={C.muted} font-family={FONT} font-size="11" font-weight="700">RELATIVE SIZE</text>
  <text x="670" y="58" text-anchor="end" fill={C.muted} font-family={FONT} font-size="11" font-weight="700">TONNAGE</text>

  {rows.map((r, i) => {
    const y = top + i * rowH;
    return (
      <g>
        <text x="50" y={y + 14} fill={C.dark} font-family={FONT} font-size="12" font-weight="600">{r.sqft} sq ft</text>
        <rect x="300" y={y + 4} width={r.w} height="14" rx="4" fill={C.primary} opacity={0.85} />
        <text x="670" y={y + 14} text-anchor="end" fill={C.primary} font-family={FONT} font-size="12" font-weight="800">{r.tons}</text>
      </g>
    );
  })}

  <text x="360" y="302" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Assumes &#8776; 20 BTU/sq ft in a moderate climate. Adjust up for hot/sunny, down for cool/shaded.</text>
</svg>
