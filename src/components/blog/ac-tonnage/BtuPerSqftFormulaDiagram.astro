---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Tonnage from square footage</title>
  <desc>Tons equals square feet times BTU per square foot divided by 12,000, with a worked example for a 1,600 square foot home.</desc>

  <text x="360" y="34" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Sizing tonnage from square footage</text>

  <!-- Main formula -->
  <rect x="60" y="58" width="600" height="62" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="360" y="98" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="20" font-weight="800">Tons = (sq ft &#215; BTU/sq ft) &#247; 12,000</text>

  <!-- One ton note -->
  <rect x="160" y="138" width="400" height="52" rx="8" fill={C.panelBg} stroke={C.border} />
  <text x="360" y="160" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">The anchor</text>
  <text x="360" y="180" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">1 ton = 12,000 BTU/hr of cooling &#183; rule of thumb &#8776; 20 BTU/sq ft</text>

  <!-- Worked plug-in -->
  <rect x="60" y="210" width="600" height="64" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1" />
  <text x="360" y="234" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="11" font-weight="700">Worked example: a 1,600 sq ft home at 20 BTU/sq ft (moderate climate)</text>
  <text x="360" y="258" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">1,600 &#215; 20 = 32,000 BTU/hr &#247; 12,000 &#8776; 2.7 &#8594; round to 3 ton</text>

  <text x="360" y="302" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Multiply area by the per-square-foot load, then divide by 12,000 BTU/hr to get tons.</text>
</svg>
