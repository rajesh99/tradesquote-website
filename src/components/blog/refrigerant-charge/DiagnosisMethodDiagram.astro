---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Which reading to trust</title>
  <desc>Branch on metering device type to decide whether to charge to subcooling or to superheat.</desc>

  <text x="360" y="26" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Which reading to trust</text>

  <!-- Start node -->
  <rect x="280" y="44" width="160" height="40" rx="8" fill={C.dark} />
  <text x="360" y="69" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="600">What metering device?</text>

  <!-- Branch lines -->
  <path d="M360 84 V104" stroke={C.border} stroke-width="2" />
  <path d="M180 104 H540" stroke={C.border} stroke-width="2" />
  <path d="M180 104 V124" stroke={C.border} stroke-width="2" />
  <path d="M540 104 V124" stroke={C.border} stroke-width="2" />

  <!-- TXV / EEV branch -->
  <rect x="60" y="124" width="240" height="40" rx="6" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="180" y="149" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">TXV / EEV (expansion valve)</text>
  <path d="M180 164 V184" stroke={C.primary} stroke-width="2" />
  <rect x="60" y="184" width="240" height="80" rx="6" fill={C.panelBg} stroke={C.border} />
  <text x="180" y="210" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="12" font-weight="700">Charge to SUBCOOLING</text>
  <text x="180" y="230" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Target ~10&#8211;12&#176;F (per data plate)</text>
  <text x="180" y="248" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Valve holds superheat steady</text>

  <!-- Fixed orifice branch -->
  <rect x="420" y="124" width="240" height="40" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="540" y="149" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Fixed orifice / piston</text>
  <path d="M540 164 V184" stroke={C.orange} stroke-width="2" />
  <rect x="420" y="184" width="240" height="80" rx="6" fill={C.panelBg} stroke={C.border} />
  <text x="540" y="210" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="12" font-weight="700">Charge to SUPERHEAT</text>
  <text x="540" y="230" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Target from manufacturer chart</text>
  <text x="540" y="248" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Indoor WB &amp; outdoor DB based</text>

  <rect x="160" y="290" width="400" height="16" rx="4" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="360" y="301" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="9" font-weight="600">TXV systems: charge to subcooling. Fixed-orifice systems: charge to superheat.</text>
</svg>
