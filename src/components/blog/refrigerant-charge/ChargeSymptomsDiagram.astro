---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Undercharge vs overcharge symptoms</title>
  <desc>Two columns comparing the symptoms of an undercharged system against an overcharged system.</desc>

  <text x="360" y="26" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Undercharge vs overcharge symptoms</text>

  <!-- Undercharge column -->
  <rect x="48" y="44" width="296" height="36" rx="6" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="196" y="67" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="12" font-weight="700">Undercharge (too little refrigerant)</text>
  <rect x="48" y="88" width="296" height="196" rx="6" fill={C.panelBg} stroke={C.border} />
  <text x="68" y="116" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">High superheat</text>
  <text x="68" y="144" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Low subcooling</text>
  <text x="68" y="172" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Low suction pressure</text>
  <text x="68" y="200" fill={C.muted} font-family={FONT} font-size="11">Warm / insufficient supply air</text>
  <text x="68" y="228" fill={C.muted} font-family={FONT} font-size="11">Long run times, reduced capacity</text>
  <text x="68" y="256" fill={C.muted} font-family={FONT} font-size="11">Possible evaporator icing</text>

  <!-- Overcharge column -->
  <rect x="376" y="44" width="296" height="36" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="524" y="67" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="12" font-weight="700">Overcharge (too much refrigerant)</text>
  <rect x="376" y="88" width="296" height="196" rx="6" fill={C.panelBg} stroke={C.border} />
  <text x="396" y="116" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">High head (discharge) pressure</text>
  <text x="396" y="144" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Low superheat</text>
  <text x="396" y="172" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">High subcooling</text>
  <text x="396" y="200" fill={C.muted} font-family={FONT} font-size="11">Elevated compressor amp draw</text>
  <text x="396" y="228" fill={C.muted} font-family={FONT} font-size="11">High discharge temperature</text>
  <text x="396" y="256" fill={C.red} font-family={FONT} font-size="11" font-weight="600">Liquid floodback / slugging risk</text>

  <rect x="180" y="296" width="360" height="16" rx="4" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="360" y="307" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="9" font-weight="600">Superheat and subcooling move in opposite directions for under- vs overcharge.</text>
</svg>
