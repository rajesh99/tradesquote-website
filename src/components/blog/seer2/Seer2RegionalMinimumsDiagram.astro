---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 280" fill="none" aria-hidden="true">
  <title>SEER2 federal minimum standards by region</title>
  <desc>
    Since January 2023, South and Southwest require SEER2 14 minimum (was 14 SEER). North requires
    SEER2 13.4 (was 13 SEER). Old SEER 14 units rate only SEER2 13.3 and no longer qualify in the South.
  </desc>

  <rect x="8" y="8" width="704" height="264" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Federal minimums — January 2023</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">SEER2 replaces SEER for new residential equipment</text>

  <!-- South/Southwest -->
  <rect x="32" y="76" width="320" height="120" rx="10" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="48" y="104" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">South &amp; Southwest</text>
  <text x="48" y="128" fill={C.muted} font-family={FONT} font-size="10">Previously: 14 SEER</text>
  <text x="48" y="160" fill={C.orange} font-family={FONT} font-size="28" font-weight="700">14 SEER2</text>
  <text x="48" y="184" fill={C.muted} font-family={FONT} font-size="9">Same number, harder M2 test</text>

  <!-- North -->
  <rect x="368" y="76" width="320" height="120" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="384" y="104" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">North region</text>
  <text x="384" y="128" fill={C.muted} font-family={FONT} font-size="10">Previously: 13 SEER</text>
  <text x="384" y="160" fill={C.blue} font-family={FONT} font-size="28" font-weight="700">13.4 SEER2</text>
  <text x="384" y="184" fill={C.muted} font-family={FONT} font-size="9">Slightly higher bar than before</text>

  <!-- Disqualification callout -->
  <rect x="32" y="212" width="656" height="48" rx="8" fill={C.redLight} stroke={C.red} stroke-width="1" />
  <text x="360" y="234" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">
    Old SEER 14 unit → only <tspan fill={C.red} font-weight="700">SEER2 13.3</tspan> — below southern minimum
  </text>
  <text x="360" y="252" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">
    Pre-2023 inventory could still be sold for a transition period
  </text>
</svg>
