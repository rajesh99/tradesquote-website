---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>SEER to SEER2 conversion formula</title>
  <desc>
    SEER2 equals SEER times 0.95. SEER 14 becomes SEER2 13.3, SEER 14.7 becomes SEER2 14.0, and
    SEER 16 becomes SEER2 15.2.
  </desc>

  <rect x="8" y="8" width="704" height="304" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">SEER → SEER2 conversion</text>

  <rect x="32" y="56" width="656" height="48" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="360" y="86" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">
    SEER2 = SEER × <tspan fill={C.primary}>0.95</tspan>
  </text>

  <!-- Conversion table -->
  <rect x="32" y="120" width="200" height="28" rx="4" fill={C.dark} />
  <text x="132" y="138" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="600">SEER (old)</text>
  <rect x="240" y="120" width="80" height="28" rx="4" fill={C.muted} />
  <text x="280" y="138" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="600">× 0.95</text>
  <rect x="328" y="120" width="200" height="28" rx="4" fill={C.primary} />
  <text x="428" y="138" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="600">SEER2 (new)</text>

  <!-- Rows -->
  <rect x="32" y="156" width="200" height="32" rx="0" fill={C.white} stroke={C.border} />
  <text x="132" y="176" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12">13.0</text>
  <rect x="328" y="156" width="200" height="32" fill={C.white} stroke={C.border} />
  <text x="428" y="176" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="12" font-weight="600">12.4</text>

  <rect x="32" y="188" width="200" height="32" fill={C.white} stroke={C.border} />
  <text x="132" y="208" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12">14.0</text>
  <rect x="328" y="188" width="200" height="32" fill={C.white} stroke={C.border} />
  <text x="428" y="208" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="12" font-weight="600">13.3</text>

  <rect x="32" y="220" width="200" height="32" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="132" y="240" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">14.7</text>
  <rect x="328" y="220" width="200" height="32" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="428" y="240" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="12" font-weight="700">14.0</text>

  <rect x="32" y="252" width="200" height="32" fill={C.white} stroke={C.border} />
  <text x="132" y="272" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12">16.0</text>
  <rect x="328" y="252" width="200" height="32" fill={C.white} stroke={C.border} />
  <text x="428" y="272" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="12" font-weight="600">15.2</text>

  <rect x="32" y="284" width="200" height="32" fill={C.white} stroke={C.border} />
  <text x="132" y="304" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12">18.0</text>
  <rect x="328" y="284" width="200" height="32" fill={C.white} stroke={C.border} />
  <text x="428" y="304" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="12" font-weight="600">17.1</text>

  <rect x="548" y="156" width="140" height="160" rx="8" fill={C.white} stroke={C.border} />
  <text x="618" y="180" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="700">Key point</text>
  <text x="618" y="204" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">SEER2 14 ≈</text>
  <text x="618" y="220" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="11" font-weight="700">old SEER 14.7</text>
  <text x="618" y="248" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Same hardware,</text>
  <text x="618" y="264" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">stricter test</text>
  <text x="618" y="296" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="8">Mini-splits use different factor</text>
</svg>
