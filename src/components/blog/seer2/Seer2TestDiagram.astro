---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 280" fill="none" aria-hidden="true">
  <title>SEER vs SEER2 test procedure change</title>
  <desc>
    SEER used the M1 test at 0.1 in.w.c. external static pressure. SEER2 uses the M2 test at 0.5
    in.w.c., five times higher, producing ratings about 5% lower for the same equipment.
  </desc>

  <rect x="8" y="8" width="344" height="264" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Old SEER (M1 test)</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Laboratory conditions</text>

  <rect x="32" y="80" width="296" height="64" rx="8" fill={C.white} stroke={C.border} />
  <text x="180" y="108" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">External static pressure</text>
  <text x="180" y="132" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="22" font-weight="700">0.1 in.w.c.</text>

  <rect x="32" y="160" width="296" height="48" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1" />
  <text x="180" y="190" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11">Low resistance · optimistic rating</text>

  <text x="180" y="240" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Did not reflect real ductwork</text>

  <rect x="368" y="8" width="344" height="264" rx="12" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="384" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">New SEER2 (M2 test)</text>
  <text x="384" y="56" fill={C.muted} font-family={FONT} font-size="11">Realistic installed conditions</text>

  <rect x="392" y="80" width="296" height="64" rx="8" fill={C.white} stroke={C.border} />
  <text x="540" y="108" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">External static pressure</text>
  <text x="540" y="132" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="22" font-weight="700">0.5 in.w.c.</text>

  <rect x="392" y="160" width="296" height="48" rx="8" fill={C.orangeLight} stroke={C.orange} stroke-width="1" />
  <text x="540" y="184" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">5× higher resistance</text>
  <text x="540" y="200" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Filters · bends · grilles · ducts</text>

  <rect x="392" y="224" width="296" height="40" rx="8" fill={C.white} stroke={C.primary} stroke-width="1.5" />
  <text x="540" y="250" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="600">
    Same unit → rating drops <tspan fill={C.primary} font-weight="700">~5%</tspan>
  </text>
</svg>
