---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 200" fill="none" aria-hidden="true">
  <title>Duct sizing rules of thumb flow</title>
  <desc>CFM divided by velocity gives area, then convert to round duct diameter.</desc>

  {[
    { label: "CFM", sub: "400 CFM/ton", x: 24 },
    { label: "÷ Velocity", sub: "600–900 fpm", x: 192 },
    { label: "Area", sub: "sq ft → sq in", x: 360 },
    { label: "Diameter", sub: "Round up to std size", x: 528 },
  ].map((s, i) => (
    <g>
      <rect x={s.x} y="40" width="144" height="120" rx="12" fill={C.panelBg} stroke={C.border} />
      <circle cx={s.x + 72} cy="72" r="16" fill={C.primary} />
      <text x={s.x + 72} y="77" text-anchor="middle" fill={C.white} font-family={FONT} font-size="14" font-weight="700">{i + 1}</text>
      <text x={s.x + 72} y="110" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">{s.label}</text>
      <text x={s.x + 72} y="132" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">{s.sub}</text>
      {i < 3 ? <path d={`M${s.x + 152} 100 H${s.x + 168}`} stroke={C.primary} stroke-width="2" marker-end="url(#duct-arr)" /> : null}
    </g>
  ))}

  <rect x="120" y="172" width="480" height="24" rx="6" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="360" y="188" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="9" font-weight="600">Example: 200 CFM ÷ 600 fpm = 8" round duct</text>

  <defs>
    <marker id="duct-arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.primary} />
    </marker>
  </defs>
</svg>
