---
import { C, FONT } from "../infographicTokens";
const mistakes = [
  "Undersized return duct",
  "Oversized supply trunk",
  "Flex duct with too many bends",
  "Fittings not in TEL calc",
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 240" fill="none" aria-hidden="true">
  <title>Common duct sizing mistakes</title>
  <desc>Four common duct sizing errors that cause high static pressure and comfort problems.</desc>

  <text x="360" y="28" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Common sizing mistakes</text>

  {mistakes.map((m, i) => {
    const col = i % 2;
    const row = Math.floor(i / 2);
    const x = 40 + col * 340;
    const y = 48 + row * 96;
    return (
      <g>
        <rect x={x} y={y} width="300" height="80" rx="10" fill={C.redLight} stroke={C.red} stroke-width="1.5" />
        <circle cx={x + 28} cy={y + 28} r="14" fill={C.red} />
        <text x={x + 28} y={y + 33} text-anchor="middle" fill={C.white} font-family={FONT} font-size="12" font-weight="700">{i + 1}</text>
        <text x={x + 160} y={y + 48} text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">{m}</text>
      </g>
    );
  })}
</svg>
