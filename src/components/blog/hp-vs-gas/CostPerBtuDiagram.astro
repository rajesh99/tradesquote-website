---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>Cost per 100,000 BTU delivered: heat pump vs gas furnace</title>
  <desc>
    Fair comparison uses cost per 100,000 BTU delivered. A 96% AFUE furnace at $1.20/therm costs
    $1.25. A heat pump at COP 3.0 costs $0.98 at $0.10/kWh and $1.27 at $0.13/kWh.
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Cost per 100,000 BTU delivered</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">The only fair comparison — not cost per unit of fuel</text>

  <!-- Gas furnace bar -->
  <text x="32" y="88" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">96% AFUE gas furnace · $1.20/therm</text>
  <rect x="32" y="96" width="400" height="32" rx="6" fill={C.orangeLight} stroke={C.border} />
  <rect x="32" y="96" width="320" height="32" rx="6" fill={C.orange} />
  <text x="448" y="116" fill={C.orange} font-family={FONT} font-size="13" font-weight="700">$1.25</text>
  <text x="32" y="144" fill={C.muted} font-family={FONT} font-size="9">96,000 BTU delivered per therm · 4% lost up the flue</text>

  <!-- Heat pump bars -->
  <text x="32" y="172" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Heat pump · COP 3.0 at 47°F outdoor</text>

  <text x="32" y="196" fill={C.muted} font-family={FONT} font-size="10">$0.10/kWh</text>
  <rect x="100" y="184" width="400" height="24" rx="4" fill={C.primaryLight} stroke={C.border} />
  <rect x="100" y="184" width="251" height="24" rx="4" fill={C.primary} />
  <text x="512" y="200" fill={C.primary} font-family={FONT} font-size="12" font-weight="700">$0.98</text>

  <text x="32" y="224" fill={C.muted} font-family={FONT} font-size="10">$0.13/kWh</text>
  <rect x="100" y="212" width="400" height="24" rx="4" fill={C.primaryLight} stroke={C.border} />
  <rect x="100" y="212" width="326" height="24" rx="4" fill={C.primary} />
  <text x="512" y="228" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">$1.27 ≈ tied</text>

  <text x="32" y="252" fill={C.muted} font-family={FONT} font-size="10">$0.20/kWh</text>
  <rect x="100" y="240" width="400" height="24" rx="4" fill={C.primaryLight} stroke={C.border} />
  <rect x="100" y="240" width="390" height="24" rx="4" fill={C.red} />
  <text x="512" y="256" fill={C.red} font-family={FONT} font-size="12" font-weight="700">$1.95</text>

  <rect x="540" y="88" width="160" height="176" rx="8" fill={C.white} stroke={C.border} />
  <text x="620" y="116" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="700">At 47°F</text>
  <text x="620" y="140" text-anchor="middle" fill={C.green} font-family={FONT} font-size="10" font-weight="600">HP wins below</text>
  <text x="620" y="158" text-anchor="middle" fill={C.green} font-family={FONT} font-size="12" font-weight="700">$0.13/kWh</text>
  <text x="620" y="188" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="10" font-weight="600">Furnace wins above</text>
  <text x="620" y="206" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="12" font-weight="700">$0.13/kWh</text>
  <text x="620" y="240" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">COP 3.0 · 10,236 BTU/kWh</text>
</svg>
