---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>Heat pump COP decline with outdoor temperature</title>
  <desc>
    Heat pump COP drops as outdoor temperature falls. Standard models reach COP 2.0 at 17°F and 1.5
    at 0°F. Cold-climate models maintain COP 1.8 even at −13°F.
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">COP drops with cold outdoor temperatures</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Less heat in the air to extract → lower efficiency</text>

  <!-- Chart area -->
  <line x1="80" y1="240" x2="640" y2="240" stroke={C.border} stroke-width="1.5" />
  <line x1="80" y1="80" x2="80" y2="240" stroke={C.border} stroke-width="1.5" />

  <text x="72" y="88" text-anchor="end" fill={C.muted} font-family={FONT} font-size="9">3.5</text>
  <text x="72" y="128" text-anchor="end" fill={C.muted} font-family={FONT} font-size="9">3.0</text>
  <text x="72" y="168" text-anchor="end" fill={C.muted} font-family={FONT} font-size="9">2.0</text>
  <text x="72" y="208" text-anchor="end" fill={C.muted} font-family={FONT} font-size="9">1.5</text>
  <text x="72" y="244" text-anchor="end" fill={C.muted} font-family={FONT} font-size="9">1.0</text>

  <text x="140" y="258" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">47°F</text>
  <text x="280" y="258" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">17°F</text>
  <text x="420" y="258" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">0°F</text>
  <text x="560" y="258" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">−13°F</text>

  <!-- Standard HP line -->
  <polyline points="140,128 280,168 420,208 560,224" fill="none" stroke={C.blue} stroke-width="2.5" />
  <circle cx="140" cy="128" r="5" fill={C.blue} />
  <circle cx="280" cy="168" r="5" fill={C.blue} />
  <circle cx="420" cy="208" r="5" fill={C.blue} />
  <circle cx="560" cy="224" r="5" fill={C.blue} />

  <!-- Cold-climate HP line -->
  <polyline points="140,120 280,152 420,176 560,192" fill="none" stroke={C.primary} stroke-width="2.5" />
  <circle cx="140" cy="120" r="5" fill={C.primary} />
  <circle cx="280" cy="152" r="5" fill={C.primary} />
  <circle cx="420" cy="176" r="5" fill={C.primary} />
  <circle cx="560" cy="192" r="5" fill={C.primary} />

  <!-- Labels on points -->
  <text x="140" y="118" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="9" font-weight="700">3.0</text>
  <text x="280" y="182" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="9" font-weight="700">2.0</text>
  <text x="420" y="222" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="9" font-weight="700">1.5</text>
  <text x="560" y="238" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="9" font-weight="700">1.2</text>

  <text x="140" y="108" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="9" font-weight="700">3.2–3.5</text>
  <text x="560" y="184" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="9" font-weight="700">1.8</text>

  <!-- Legend -->
  <rect x="480" y="64" width="216" height="56" rx="6" fill={C.white} stroke={C.border} />
  <line x1="496" y1="84" x2="520" y2="84" stroke={C.blue} stroke-width="2.5" />
  <text x="528" y="88" fill={C.dark} font-family={FONT} font-size="10">Standard heat pump</text>
  <line x1="496" y1="104" x2="520" y2="104" stroke={C.primary} stroke-width="2.5" />
  <text x="528" y="108" fill={C.dark} font-family={FONT} font-size="10">Cold-climate model</text>

  <rect x="80" y="268" width="560" height="20" rx="4" fill={C.orangeLight} stroke={C.orange} stroke-width="1" />
  <text x="360" y="282" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10">
    At COP 2.0 &amp; $0.13/kWh → $1.90/100K BTU vs furnace $1.25
  </text>
</svg>
