---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 280" fill="none" aria-hidden="true">
  <title>Break-even electricity price for heat pump vs gas furnace</title>
  <desc>
    At COP 2.5 and $1.20/therm gas, break-even electricity is about $0.145/kWh. At COP 2.0 in cold
    weather, break-even drops to about $0.116/kWh.
  </desc>

  <rect x="8" y="8" width="704" height="264" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Break-even electricity price</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">96% AFUE furnace · $1.20/therm gas</text>

  <!-- COP 2.5 scenario -->
  <rect x="32" y="76" width="320" height="100" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="48" y="100" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">COP 2.5 (moderate temps)</text>
  <text x="48" y="122" fill={C.muted} font-family={FONT} font-size="10">Heat pump matches furnace at:</text>
  <text x="48" y="152" fill={C.primary} font-family={FONT} font-size="24" font-weight="700">$0.145/kWh</text>
  <text x="48" y="168" fill={C.muted} font-family={FONT} font-size="9">Below → HP wins · Above → gas wins</text>

  <!-- COP 2.0 scenario -->
  <rect x="368" y="76" width="320" height="100" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="384" y="100" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">COP 2.0 (cold temps)</text>
  <text x="384" y="122" fill={C.muted} font-family={FONT} font-size="10">Break-even drops to:</text>
  <text x="384" y="152" fill={C.blue} font-family={FONT} font-size="24" font-weight="700">$0.116/kWh</text>
  <text x="384" y="168" fill={C.muted} font-family={FONT} font-size="9">Cold weather favors gas harder</text>

  <!-- Regional examples -->
  <rect x="32" y="192" width="656" height="68" rx="8" fill={C.white} stroke={C.border} />
  <text x="48" y="216" fill={C.green} font-family={FONT} font-size="10" font-weight="700">HP wins:</text>
  <text x="120" y="216" fill={C.dark} font-family={FONT} font-size="10">Southeast $0.11–0.14 · Pacific NW $0.10–0.13</text>
  <text x="48" y="240" fill={C.orange} font-family={FONT} font-size="10" font-weight="700">Gas wins:</text>
  <text x="120" y="240" fill={C.dark} font-family={FONT} font-size="10">Northeast $0.18–0.28 · California $0.22–0.35 (many hrs below 20°F)</text>
</svg>
