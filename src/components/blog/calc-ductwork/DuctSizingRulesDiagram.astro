---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 210" fill="none" aria-hidden="true">
  <title>The two rules behind every duct size</title>
  <desc>
    Every duct size follows two rules. Rule one, friction rate: residential branch runs target 0.08 to 0.10
    inches of water column per 100 feet. Rule two, velocity: keep branch runs under about 900 feet per
    minute to avoid register whistle, and run returns slower so they end up one size larger.
  </desc>

  <rect x="8" y="8" width="704" height="194" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Two rules behind every duct size</text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">Friction rate sets the size; velocity keeps it quiet — always check both</text>

  <rect x="24" y="70" width="320" height="120" rx="10" fill={C.white} stroke={C.border} stroke-width="1.3" />
  <circle cx="52" cy="98" r="15" fill={C.primary} />
  <text x="52" y="103" text-anchor="middle" fill={C.white} font-family={FONT} font-size="13" font-weight="800">1</text>
  <text x="80" y="96" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">Friction rate</text>
  <text x="80" y="114" fill={C.muted} font-family={FONT} font-size="10.5">Static pressure used per 100 ft of duct</text>
  <rect x="44" y="134" width="280" height="40" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1.2" />
  <text x="184" y="159" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">0.08 – 0.10 in.wg / 100 ft</text>

  <rect x="376" y="70" width="320" height="120" rx="10" fill={C.white} stroke={C.border} stroke-width="1.3" />
  <circle cx="404" cy="98" r="15" fill={C.blue} />
  <text x="404" y="103" text-anchor="middle" fill={C.white} font-family={FONT} font-size="13" font-weight="800">2</text>
  <text x="432" y="96" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">Velocity</text>
  <text x="432" y="114" fill={C.muted} font-family={FONT} font-size="10.5">Air speed in feet per minute (fpm)</text>
  <rect x="396" y="134" width="280" height="40" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1.2" />
  <text x="536" y="151" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11.5" font-weight="800">Branches under ~900 fpm</text>
  <text x="536" y="166" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">returns run slower → one size larger</text>
</svg>
