---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 230" fill="none" aria-hidden="true">
  <title>Round to rectangular duct equivalent by equal area</title>
  <desc>
    To convert round duct to rectangular when ceiling space is tight, match cross-sectional area. A 10-inch
    round duct is about 78.5 square inches, roughly equal to an 8 by 10 rectangular duct at 80 square
    inches. Area equals pi times the radius squared.
  </desc>

  <rect x="8" y="8" width="704" height="214" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Round ↔ rectangular: match the area</text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">When ceiling space limits round duct, convert by equal cross-sectional area</text>

  <circle cx="170" cy="124" r="52" fill={C.primaryLight} stroke={C.primary} stroke-width="1.6" />
  <text x="170" y="120" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">10 in round</text>
  <text x="170" y="138" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10.5">78.5 sq in</text>

  <text x="320" y="134" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="30" font-weight="700">≈</text>

  <rect x="410" y="78" width="120" height="96" rx="6" fill={C.blueLight} stroke={C.blue} stroke-width="1.6" />
  <text x="470" y="120" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">8 × 10 rect</text>
  <text x="470" y="138" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10.5">80 sq in</text>

  <rect x="560" y="100" width="136" height="48" rx="9" fill={C.white} stroke={C.border} stroke-width="1.2" />
  <text x="628" y="122" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">Area (sq in) =</text>
  <text x="628" y="138" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11.5" font-weight="800">π × (d ÷ 2)²</text>
</svg>
