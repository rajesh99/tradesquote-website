---
import { C, FONT } from "../infographicTokens";

const cats = [
  { title: "Sizing & Load", color: C.primary, items: ["BTU · Tonnage", "Manual J · Heat pump", "Furnace · Mini-split"] },
  { title: "Airflow & Duct", color: C.blue, items: ["CFM", "Duct size · Friction rate", "Static pressure"] },
  { title: "Diagnostics & Refrigerant", color: C.orange, items: ["Delta T · Superheat", "Subcooling", "Refrigerant charge"] },
  { title: "Efficiency & Cost", color: C.green, items: ["SEER savings · Operating cost", "Replacement · Install cost", "Contractor estimate"] },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>HVAC calculator categories at a glance</title>
  <desc>
    Four families of free calculators: sizing and load (BTU, tonnage, Manual J, heat pump, furnace,
    mini-split); airflow and duct (CFM, duct size, friction rate, static pressure); diagnostics and
    refrigerant (delta T, superheat, subcooling, refrigerant charge); and efficiency and cost (SEER
    savings, operating cost, replacement, installation, contractor estimate).
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Every tool, by category</text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">Four families of free calculators on TradesQuote</text>

  {cats.map((c, i) => {
    const col = i % 2;
    const row = Math.floor(i / 2);
    const x = 24 + col * 344;
    const y = 68 + row * 112;
    return (
      <g>
        <rect x={x} y={y} width="328" height="100" rx="10" fill={C.white} stroke={C.border} stroke-width="1.2" />
        <rect x={x} y={y} width="5" height="100" rx="2.5" fill={c.color} />
        <text x={x + 18} y={y + 26} fill={C.dark} font-family={FONT} font-size="12.5" font-weight="800">{c.title}</text>
        {c.items.map((it, j) => (
          <text x={x + 18} y={y + 48 + j * 17} fill={C.muted} font-family={FONT} font-size="9.8">{it}</text>
        ))}
      </g>
    );
  })}
</svg>
