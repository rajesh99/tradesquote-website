---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 260" fill="none" aria-hidden="true">
  <title>Phoenix vs Chicago BTU comparison for same home</title>
  <desc>1,800 sq ft home needs 45,540 BTU in Phoenix vs 26,163 BTU in Chicago.</desc>

  <text x="360" y="28" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Same 1,800 sq ft home — different climates</text>

  <rect x="40" y="48" width="300" height="200" rx="12" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="190" y="76" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Phoenix, AZ</text>
  <text x="190" y="100" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Climate 1.15 · Sun 1.10 · Insul 1.0</text>
  <text x="190" y="150" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="28" font-weight="700">45,540</text>
  <text x="190" y="174" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">BTU (~4 tons)</text>
  <text x="190" y="220" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Hot, sunny, average insulation</text>

  <rect x="380" y="48" width="300" height="200" rx="12" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="530" y="76" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Chicago, IL</text>
  <text x="530" y="100" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Climate 0.85 · Sun 0.95 · Insul 0.90</text>
  <text x="530" y="150" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="28" font-weight="700">26,163</text>
  <text x="530" y="174" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">BTU (~2.5 tons)</text>
  <text x="530" y="220" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Cool, shaded, well insulated</text>

  <rect x="200" y="252" width="320" height="4" rx="2" fill={C.primaryLight} />
</svg>
