---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 220" fill="none" aria-hidden="true">
  <title>Oversized AC short-cycling consequences</title>
  <desc>Oversized unit cools fast, shuts off, poor dehumidification, and wears compressor faster.</desc>

  <rect x="280" y="8" width="160" height="40" rx="8" fill={C.dark} />
  <text x="360" y="33" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="600">Oversized AC</text>

  <path d="M360 48 V72" stroke={C.primary} stroke-width="2" marker-end="url(#btu-cycle)" />
  <rect x="240" y="76" width="240" height="36" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="360" y="98" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">Cools space too fast → shuts off</text>

  <path d="M360 112 V136" stroke={C.primary} stroke-width="2" marker-end="url(#btu-cycle)" />
  <rect x="200" y="140" width="320" height="36" rx="6" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="360" y="162" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">Poor dehumidification — cool but clammy</text>

  <path d="M360 176 V200" stroke={C.primary} stroke-width="2" marker-end="url(#btu-cycle)" />
  <path d="M120 200 H600" stroke={C.red} stroke-width="1.5" stroke-dasharray="4 3" />
  <text x="360" y="216" text-anchor="middle" fill={C.red} font-family={FONT} font-size="9" font-weight="600">Higher bills · Shorter compressor life · Restarts in minutes</text>

  <defs>
    <marker id="btu-cycle" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.primary} />
    </marker>
  </defs>
</svg>
