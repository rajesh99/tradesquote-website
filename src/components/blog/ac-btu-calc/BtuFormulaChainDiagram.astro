---
import { C, FONT } from "../infographicTokens";

// Worked example from the post: 18×14 ft (252 sq ft), 10-ft ceilings, hot climate, sunny windows
// BTU = 252 × 20 × 1.25 × 1.15 × 1.10 = 9,975
const steps: { label: string; value: string; sub: string }[] = [
  { label: "Sq Footage",  value: "252",   sub: "18 × 14 ft" },
  { label: "Base rate",   value: "× 20",  sub: "BTU/sq ft"  },
  { label: "Ceiling",     value: "× 1.25", sub: "10 ft"     },
  { label: "Climate",     value: "× 1.15", sub: "Hot/humid"  },
  { label: "Sun",         value: "× 1.10", sub: "S/W windows"},
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 210" fill="none" aria-hidden="true">
  <title>BTU formula worked example</title>
  <desc>
    Worked example: 252 sq ft room × 20 base rate × 1.25 ceiling factor × 1.15 climate factor
    × 1.10 sun factor = 9,975 BTU, rounded up to a 10,000 BTU unit.
  </desc>

  <defs>
    <marker id="btu-formula-arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.primary} />
    </marker>
  </defs>

  <rect x="8" y="8" width="704" height="194" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">BTU formula — worked example</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">252 sq ft · 10-ft ceilings · hot climate · sunny windows → buy a 10,000 BTU unit</text>

  {steps.map(({ label, value, sub }, i) => {
    const x = 24 + i * 132;
    return (
      <g>
        <rect x={x} y="72" width="116" height="90" rx="9"
          fill={C.white} stroke={C.border} stroke-width="1.4" />
        <text x={x + 58} y="100" text-anchor="middle" fill={C.muted}
          font-family={FONT} font-size="9.5" font-weight="700">{label}</text>
        <text x={x + 58} y="124" text-anchor="middle" fill={C.primary}
          font-family={FONT} font-size="18" font-weight="800">{value}</text>
        <text x={x + 58} y="144" text-anchor="middle" fill={C.muted}
          font-family={FONT} font-size="9.5">{sub}</text>
        {i < steps.length - 1 && (
          <path d={`M${x + 116} 117 l 14 0 m -6 -4 l 6 4 l -6 4`}
            stroke={C.primary} stroke-width="1.8" fill="none" />
        )}
      </g>
    );
  })}

  {/* Result badge */}
  <rect x="684" y="72" width="0" height="0" rx="0" />
  <path d="M680 117 l 14 0 m -6 -4 l 6 4 l -6 4" stroke={C.primary} stroke-width="1.8" fill="none" />
  <rect x="28" y="170" width="664" height="28" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1.2" />
  <text x="360" y="189" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">
    = 9,975 BTU → buy a 10,000 BTU unit
  </text>
</svg>
