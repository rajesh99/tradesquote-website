---
import { C, FONT } from "../infographicTokens";

const systems = [
  { label: "Central AC (std)", low: 4000, high: 6500, color: C.blue },
  { label: "Central AC (hi-eff)", low: 6500, high: 10000, color: C.blue },
  { label: "Gas furnace 80%", low: 2500, high: 4500, color: C.orange },
  { label: "Gas furnace 96%", low: 3500, high: 6000, color: C.orange },
  { label: "Full system (std)", low: 7000, high: 11000, color: C.primary },
  { label: "Full system (hi-eff)", low: 10000, high: 16000, color: C.primary },
  { label: "Heat pump", low: 5500, high: 9000, color: C.green },
  { label: "Mini-split (1 zone)", low: 2500, high: 4500, color: C.muted },
];

const scaleMin = 0;
const scaleMax = 17000;
const barLeft = 160;
const barWidth = 520;
const toX = (v: number) => barLeft + ((v - scaleMin) / (scaleMax - scaleMin)) * barWidth;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 340" fill="none" aria-hidden="true">
  <title>2025 HVAC installed cost ranges by system type</title>
  <desc>
    Horizontal bars showing installed cost ranges for central AC, furnaces, full systems, heat pumps,
    and mini-splits for a typical 2,000 sq ft home.
  </desc>

  <rect x="8" y="8" width="704" height="324" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">
    2025 installed cost ranges (2,000 sq ft home)
  </text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">
    Equipment + labor · existing ductwork assumed
  </text>

  {/* Scale */}
  {[0, 5000, 10000, 15000].map((v) => (
    <g>
      <line x1={toX(v)} y1="68" x2={toX(v)} y2="300" stroke={C.border} stroke-width="1" stroke-dasharray="3 3" />
      <text x={toX(v)} y="316" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">
        ${(v / 1000).toFixed(0)}k
      </text>
    </g>
  ))}

  {systems.map((s, i) => {
    const y = 76 + i * 28;
  return (
    <g>
      <text x="24" y={y + 14} fill={C.dark} font-family={FONT} font-size="10" font-weight="600">
        {s.label}
      </text>
      <rect
        x={toX(s.low)}
        y={y}
        width={toX(s.high) - toX(s.low)}
        height="18"
        rx="4"
        fill={s.color}
        opacity="0.85"
      />
      <text x={toX(s.low) - 4} y={y + 13} text-anchor="end" fill={C.muted} font-family={FONT} font-size="8">
        ${(s.low / 1000).toFixed(1)}k
      </text>
      <text x={toX(s.high) + 4} y={y + 13} fill={C.muted} font-family={FONT} font-size="8">
        ${(s.high / 1000).toFixed(0)}k
      </text>
    </g>
  );
  })}
</svg>
