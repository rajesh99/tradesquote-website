---
import { C, FONT } from "../infographicTokens";

const credits = [
  { label: "Air source heat pump", amount: "Up to $2,000", detail: "30% of cost, capped", color: C.primary, bg: C.primaryLight },
  { label: "High-efficiency central AC", amount: "Up to $600", detail: "CEE Tier required", color: C.blue, bg: C.blueLight },
  { label: "High-efficiency gas furnace", amount: "Up to $600", detail: "96% AFUE or higher", color: C.orange, bg: C.orangeLight },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 220" fill="none" aria-hidden="true">
  <title>IRA federal tax credits for HVAC in 2026</title>
  <desc>
    Federal non-refundable tax credits: heat pumps up to $2,000, high-efficiency AC and furnaces up to
    $600 each. State and utility rebates may stack on top.
  </desc>

  <rect x="8" y="8" width="704" height="204" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">
    IRA tax credits available in 2026
  </text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">
    Federal income tax credits · extended through 2032
  </text>

  {credits.map((c, i) => {
    const x = 24 + i * 232;
    return (
      <g>
        <rect x={x} y="72" width="216" height="120" rx="10" fill={c.bg} stroke={c.color} stroke-width="1.5" />
        <text x={x + 108} y="100" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">
          {c.label}
        </text>
        <text x={x + 108} y="132" text-anchor="middle" fill={c.color} font-family={FONT} font-size="22" font-weight="700">
          {c.amount}
        </text>
        <text x={x + 108} y="156" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">
          {c.detail}
        </text>
      </g>
    );
  })}

  <rect x="24" y="184" width="672" height="20" rx="4" fill={C.greenLight} stroke={C.green} stroke-width="1" />
  <text x="360" y="198" text-anchor="middle" fill={C.green} font-family={FONT} font-size="9" font-weight="600">
    Stack state & utility rebates on top — high-incentive states can return $2k–$4k on a $10k heat pump
  </text>
</svg>
