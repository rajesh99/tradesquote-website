---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 360" fill="none" aria-hidden="true">
  <title>Superheat and subcooling diagnostic readings</title>
  <desc>High/low superheat and subcooling readings and their likely causes.</desc>

  <rect x="280" y="8" width="160" height="40" rx="8" fill={C.dark} />
  <text x="360" y="33" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="600">Reading analysis</text>

  <path d="M360 48 V68" stroke={C.border} stroke-width="2" />
  <path d="M180 68 H360 V88" stroke={C.border} stroke-width="2" />
  <path d="M360 68 H540 V88" stroke={C.border} stroke-width="2" />

  <!-- High superheat -->
  <rect x="60" y="88" width="240" height="36" rx="6" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="180" y="110" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="700">High superheat</text>
  <rect x="60" y="132" width="240" height="80" rx="6" fill={C.panelBg} stroke={C.border} />
  <text x="180" y="154" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Undercharge · Restricted metering</text>
  <text x="180" y="170" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Low evap airflow · Liquid restriction</text>
  <text x="180" y="198" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="9" font-weight="600">Check airflow before adding charge</text>

  <!-- Low superheat -->
  <rect x="420" y="88" width="240" height="36" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="540" y="110" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="700">Low superheat</text>
  <rect x="420" y="132" width="240" height="80" rx="6" fill={C.panelBg} stroke={C.border} />
  <text x="540" y="154" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Overcharge · TXV stuck open</text>
  <text x="540" y="170" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">High latent load · Flooded start</text>
  <text x="540" y="198" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="9" font-weight="600">Below 5°F risks liquid slugging</text>

  <!-- High subcooling -->
  <rect x="60" y="232" width="240" height="36" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="180" y="254" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="700">High subcooling (&gt;18°F)</text>
  <rect x="60" y="276" width="240" height="56" rx="6" fill={C.panelBg} stroke={C.border} />
  <text x="180" y="298" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Overcharge · Liquid line restriction</text>
  <text x="180" y="316" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Check filter-drier temp split</text>

  <!-- Low subcooling -->
  <rect x="420" y="232" width="240" height="36" rx="6" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="540" y="254" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="700">Low subcooling (&lt;5°F)</text>
  <rect x="420" y="276" width="240" height="56" rx="6" fill={C.panelBg} stroke={C.border} />
  <text x="540" y="298" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Undercharge · Liquid line heat gain</text>
  <text x="540" y="316" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Fouled condenser coil</text>

  <rect x="200" y="344" width="320" height="14" rx="4" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="360" y="354" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="8" font-weight="600">TXV: charge to subcooling · Fixed-orifice: charge to superheat</text>
</svg>
