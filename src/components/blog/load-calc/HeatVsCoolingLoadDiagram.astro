---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Heating load vs cooling load</title>
  <desc>
    The heating load is heat loss driven by the temperature difference between inside and outside,
    using Q equals U times A times delta T. The cooling load is heat gain split into sensible heat
    (temperature) and latent heat (moisture), plus solar gain through windows.
  </desc>

  <rect x="8" y="8" width="704" height="304" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Heating load vs cooling load</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Two separate calculations: heat you lose in winter, heat you gain in summer</text>

  <!-- Heating load panel -->
  <rect x="24" y="76" width="320" height="212" rx="10" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="40" y="100" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Heating load</text>
  <text x="40" y="118" fill={C.muted} font-family={FONT} font-size="10">Heat loss through the building shell</text>

  <rect x="40" y="132" width="288" height="44" rx="8" fill={C.white} stroke={C.orange} stroke-width="1.2" />
  <text x="184" y="160" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="800">Q = U &#215; A &#215; &#916;T</text>

  <text x="40" y="200" fill={C.dark} font-family={FONT} font-size="10.5" font-weight="600">U &#215; A = how fast the shell leaks heat</text>
  <text x="40" y="220" fill={C.dark} font-family={FONT} font-size="10.5" font-weight="600">&#916;T = indoor minus outdoor design temp</text>
  <text x="40" y="244" fill={C.muted} font-family={FONT} font-size="10">Driven purely by temperature difference</text>
  <text x="40" y="262" fill={C.muted} font-family={FONT} font-size="10">No moisture, no sun &#8212; just heat loss</text>

  <!-- Cooling load panel -->
  <rect x="376" y="76" width="320" height="212" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="392" y="100" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Cooling load</text>
  <text x="392" y="118" fill={C.muted} font-family={FONT} font-size="10">Heat gain the system must remove</text>

  <rect x="392" y="132" width="138" height="60" rx="8" fill={C.white} stroke={C.blue} stroke-width="1.2" />
  <text x="461" y="154" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Sensible</text>
  <text x="461" y="171" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">temperature gain</text>
  <text x="461" y="185" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">+ solar through glass</text>

  <rect x="542" y="132" width="138" height="60" rx="8" fill={C.white} stroke={C.blue} stroke-width="1.2" />
  <text x="611" y="154" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Latent</text>
  <text x="611" y="171" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">moisture removal</text>
  <text x="611" y="185" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">humidity load</text>

  <text x="392" y="216" fill={C.dark} font-family={FONT} font-size="10.5" font-weight="600">Cooling load = sensible + latent</text>
  <text x="392" y="240" fill={C.muted} font-family={FONT} font-size="10">Adds solar gain through windows and</text>
  <text x="392" y="258" fill={C.muted} font-family={FONT} font-size="10">the energy to dry out humid indoor air</text>
</svg>
