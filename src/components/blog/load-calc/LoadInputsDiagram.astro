---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>What feeds a load calculation</title>
  <desc>
    Five building inputs — climate and design temperatures, insulation R-value, window area and
    orientation, air infiltration, and occupants and internal gains — flow into a single load
    result expressed in BTU per hour for heating and cooling.
  </desc>

  <rect x="8" y="8" width="704" height="304" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">What feeds a load calculation</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Manual J builds the load from the actual building, not a square-footage shortcut</text>

  <!-- Input row -->
  <rect x="24" y="80" width="124" height="58" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1.2" />
  <text x="86" y="104" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Climate</text>
  <text x="86" y="121" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">design temps</text>

  <rect x="158" y="80" width="124" height="58" rx="8" fill={C.greenLight} stroke={C.green} stroke-width="1.2" />
  <text x="220" y="104" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Insulation</text>
  <text x="220" y="121" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">wall/roof R-value</text>

  <rect x="292" y="80" width="124" height="58" rx="8" fill={C.orangeLight} stroke={C.orange} stroke-width="1.2" />
  <text x="354" y="104" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Windows</text>
  <text x="354" y="121" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">area &amp; orientation</text>

  <rect x="426" y="80" width="124" height="58" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1.2" />
  <text x="488" y="104" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Infiltration</text>
  <text x="488" y="121" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">air-tightness (ACH)</text>

  <rect x="560" y="80" width="124" height="58" rx="8" fill={C.greenLight} stroke={C.green} stroke-width="1.2" />
  <text x="622" y="104" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Occupants</text>
  <text x="622" y="121" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">+ internal gains</text>

  <!-- Connectors funneling down to the load node -->
  <g stroke={C.border} stroke-width="1.5">
    <path d="M86 138 V176 H360" />
    <path d="M220 138 V176 H360" />
    <path d="M354 138 V176" />
    <path d="M488 138 V176 H360" />
    <path d="M622 138 V176 H360" />
    <path d="M360 176 V204" />
  </g>

  <!-- Load result node -->
  <rect x="220" y="204" width="280" height="62" rx="12" fill={C.primaryLight} stroke={C.primary} stroke-width="2" />
  <text x="360" y="230" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Load result</text>
  <text x="360" y="251" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">BTU/hr heating &amp; cooling</text>

  <text x="360" y="296" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Five building inputs feed one load result &#8594; the BTU/hr a home actually needs.</text>
</svg>
