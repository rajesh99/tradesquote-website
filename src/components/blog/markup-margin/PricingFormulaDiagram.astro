---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 260" fill="none" aria-hidden="true">
  <title>Pricing mistake: 30% markup vs 30% margin on a $10,000 job</title>
  <desc>
    Adding 30% markup to $10,000 yields $13,000 (23.1% margin). To hit 30% margin, divide by 0.70 for
    $14,286 — a $1,286 difference per job.
  </desc>

  {/* Wrong way */}
  <rect x="8" y="8" width="344" height="244" rx="12" fill={C.redLight} stroke={C.red} stroke-width="1.5" />
  <text x="24" y="36" fill={C.red} font-family={FONT} font-size="14" font-weight="700">30% markup (wrong)</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">$10,000 × 1.30</text>

  <rect x="40" y="76" width="280" height="44" rx="6" fill={C.white} stroke={C.border} />
  <text x="180" y="104" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">
    $10,000 × 1.30 = $13,000
  </text>

  <rect x="40" y="132" width="136" height="56" rx="6" fill={C.white} stroke={C.border} />
  <text x="108" y="156" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Thought margin</text>
  <text x="108" y="176" text-anchor="middle" fill={C.red} font-family={FONT} font-size="16" font-weight="700">30%</text>

  <rect x="184" y="132" width="136" height="56" rx="6" fill={C.white} stroke={C.red} stroke-width="1.5" />
  <text x="252" y="156" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Actual margin</text>
  <text x="252" y="176" text-anchor="middle" fill={C.red} font-family={FONT} font-size="16" font-weight="700">23.1%</text>

  <rect x="40" y="200" width="280" height="40" rx="6" fill={C.redLight} stroke={C.red} stroke-width="1" />
  <text x="180" y="218" text-anchor="middle" fill={C.red} font-family={FONT} font-size="10" font-weight="600">
    Missing $896 gross profit per job
  </text>
  <text x="180" y="232" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">× 20 jobs/yr ≈ $18,000 left on table</text>

  {/* Right way */}
  <rect x="368" y="8" width="344" height="244" rx="12" fill={C.greenLight} stroke={C.green} stroke-width="1.5" />
  <text x="384" y="36" fill={C.green} font-family={FONT} font-size="14" font-weight="700">30% margin (correct)</text>
  <text x="384" y="56" fill={C.muted} font-family={FONT} font-size="11">$10,000 ÷ 0.70</text>

  <rect x="400" y="76" width="280" height="44" rx="6" fill={C.white} stroke={C.border} />
  <text x="540" y="104" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">
    $10,000 ÷ 0.70 = $14,286
  </text>

  <rect x="400" y="132" width="136" height="56" rx="6" fill={C.white} stroke={C.border} />
  <text x="468" y="156" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Gross profit</text>
  <text x="468" y="176" text-anchor="middle" fill={C.green} font-family={FONT} font-size="16" font-weight="700">$4,286</text>

  <rect x="544" y="132" width="136" height="56" rx="6" fill={C.white} stroke={C.green} stroke-width="1.5" />
  <text x="612" y="156" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Actual margin</text>
  <text x="612" y="176" text-anchor="middle" fill={C.green} font-family={FONT} font-size="16" font-weight="700">30%</text>

  <rect x="400" y="200" width="280" height="40" rx="6" fill={C.greenLight} stroke={C.green} stroke-width="1" />
  <text x="540" y="218" text-anchor="middle" fill={C.green} font-family={FONT} font-size="10" font-weight="600">
    Price = Total Cost ÷ (1 − target margin)
  </text>
  <text x="540" y="232" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Always divide — never multiply by markup %</text>
</svg>
