---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 280" fill="none" aria-hidden="true">
  <title>50% markup is not 50% margin</title>
  <desc>
    A $1,000 job with 50% markup sells for $1,500 (33.3% margin). To achieve 50% margin, the selling
    price must be $2,000 (100% markup).
  </desc>

  {/* 50% markup panel */}
  <rect x="8" y="8" width="344" height="264" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">50% markup on cost</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Price = Cost × 1.50</text>

  <rect x="40" y="80" width="120" height="48" rx="6" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="100" y="100" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">Job cost</text>
  <text x="100" y="118" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="14" font-weight="700">$1,000</text>

  <text x="180" y="110" fill={C.muted} font-family={FONT} font-size="18">+</text>

  <rect x="200" y="80" width="120" height="48" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="260" y="100" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">50% markup</text>
  <text x="260" y="118" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="14" font-weight="700">$500</text>

  <text x="180" y="150" fill={C.muted} font-family={FONT} font-size="18">=</text>

  <rect x="40" y="160" width="280" height="48" rx="6" fill={C.white} stroke={C.border} />
  <text x="100" y="180" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">Selling price</text>
  <text x="100" y="198" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">$1,500</text>
  <text x="260" y="190" text-anchor="middle" fill={C.red} font-family={FONT} font-size="12" font-weight="700">Actual margin</text>
  <text x="260" y="206" text-anchor="middle" fill={C.red} font-family={FONT} font-size="16" font-weight="700">33.3%</text>

  <rect x="40" y="224" width="280" height="36" rx="6" fill={C.redLight} stroke={C.red} stroke-width="1" />
  <text x="180" y="246" text-anchor="middle" fill={C.red} font-family={FONT} font-size="10" font-weight="600">
    Not 50% profit — markup ≠ margin
  </text>

  {/* 50% margin panel */}
  <rect x="368" y="8" width="344" height="264" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="384" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">50% margin on price</text>
  <text x="384" y="56" fill={C.muted} font-family={FONT} font-size="11">Price = Cost ÷ 0.50</text>

  <rect x="400" y="80" width="120" height="48" rx="6" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="460" y="100" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">Job cost</text>
  <text x="460" y="118" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="14" font-weight="700">$1,000</text>

  <text x="540" y="110" fill={C.muted} font-family={FONT} font-size="18">+</text>

  <rect x="560" y="80" width="120" height="48" rx="6" fill={C.greenLight} stroke={C.green} stroke-width="1.5" />
  <text x="620" y="100" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">100% markup</text>
  <text x="620" y="118" text-anchor="middle" fill={C.green} font-family={FONT} font-size="14" font-weight="700">$1,000</text>

  <text x="540" y="150" fill={C.muted} font-family={FONT} font-size="18">=</text>

  <rect x="400" y="160" width="280" height="48" rx="6" fill={C.white} stroke={C.border} />
  <text x="460" y="180" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">Selling price</text>
  <text x="460" y="198" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">$2,000</text>
  <text x="620" y="190" text-anchor="middle" fill={C.green} font-family={FONT} font-size="12" font-weight="700">Actual margin</text>
  <text x="620" y="206" text-anchor="middle" fill={C.green} font-family={FONT} font-size="16" font-weight="700">50%</text>

  <rect x="400" y="224" width="280" height="36" rx="6" fill={C.greenLight} stroke={C.green} stroke-width="1" />
  <text x="540" y="246" text-anchor="middle" fill={C.green} font-family={FONT} font-size="10" font-weight="600">
    $500 more revenue per $1,000 cost
  </text>
</svg>
