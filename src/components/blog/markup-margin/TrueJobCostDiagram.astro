---
import { C, FONT } from "../infographicTokens";

const items = [
  { label: "Burdened labor", detail: "$28/hr wage → $38–42/hr true cost", color: C.primary },
  { label: "Equipment", detail: "Wholesale cost + freight", color: C.blue },
  { label: "Materials & consumables", detail: "Refrigerant, fittings, wire, tape", color: C.orange },
  { label: "Permit fees", detail: "Actual permit cost", color: C.muted },
  { label: "Drive time", detail: "Billable even if not charged", color: C.green },
  { label: "Overhead allocation", detail: "$15–$35 per tech hour", color: C.red },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>What belongs in true HVAC job cost</title>
  <desc>
    Complete job cost includes burdened labor, wholesale equipment, all materials, permits, drive time,
    and overhead allocation before applying markup or margin.
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">True job cost checklist</text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">
    Incomplete cost baseline is the #1 reason contractors underprice
  </text>

  {items.map((item, i) => {
    const col = i % 2;
    const row = Math.floor(i / 2);
    const x = 24 + col * 348;
    const y = 68 + row * 72;
    return (
      <g>
        <rect x={x} y={y} width="332" height="60" rx="8" fill={C.white} stroke={item.color} stroke-width="1.5" />
        <circle cx={x + 20} cy={y + 30} r="10" fill={item.color} />
        <text x={x + 20} y={y + 34} text-anchor="middle" fill={C.white} font-family={FONT} font-size="10" font-weight="700">
          {i + 1}
        </text>
        <text x={x + 40} y={y + 26} fill={C.dark} font-family={FONT} font-size="11" font-weight="700">{item.label}</text>
        <text x={x + 40} y={y + 44} fill={C.muted} font-family={FONT} font-size="10">{item.detail}</text>
      </g>
    );
  })}
</svg>
