---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 380" fill="none" aria-hidden="true">
  <title>HRV vs ERV side-by-side comparison</title>
  <desc>
    HRV recovers sensible heat only in cold dry climates (zones 5–7). ERV also transfers moisture,
    suited to hot humid climates (zones 1–3) and very tight cold homes.
  </desc>

  <rect x="8" y="8" width="344" height="364" rx="12" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">HRV</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Heat Recovery Ventilator</text>

  <rect x="24" y="72" width="312" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="40" y="92" fill={C.muted} font-family={FONT} font-size="10">Recovers</text>
  <text x="40" y="106" fill={C.blue} font-family={FONT} font-size="11" font-weight="700">Sensible heat only</text>

  <rect x="24" y="120" width="312" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="40" y="140" fill={C.muted} font-family={FONT} font-size="10">Moisture transfer</text>
  <text x="40" y="154" fill={C.red} font-family={FONT} font-size="11" font-weight="600">No</text>

  <rect x="24" y="168" width="312" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="40" y="188" fill={C.muted} font-family={FONT} font-size="10">Core material</text>
  <text x="40" y="202" fill={C.dark} font-family={FONT} font-size="11">Aluminum / polypropylene</text>

  <rect x="24" y="216" width="312" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="40" y="236" fill={C.muted} font-family={FONT} font-size="10">Best climate</text>
  <text x="40" y="250" fill={C.blue} font-family={FONT} font-size="11" font-weight="700">Zones 5–7 (cold/dry)</text>

  <rect x="24" y="264" width="312" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="40" y="284" fill={C.muted} font-family={FONT} font-size="10">Winter RH impact</text>
  <text x="40" y="298" fill={C.dark} font-family={FONT} font-size="11">No change</text>

  <rect x="24" y="312" width="312" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="40" y="332" fill={C.muted} font-family={FONT} font-size="10">Sensible effectiveness</text>
  <text x="40" y="346" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">70–85%</text>

  <rect x="368" y="8" width="344" height="364" rx="12" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="384" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">ERV</text>
  <text x="384" y="56" fill={C.muted} font-family={FONT} font-size="11">Energy Recovery Ventilator</text>

  <rect x="384" y="72" width="312" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="400" y="92" fill={C.muted} font-family={FONT} font-size="10">Recovers</text>
  <text x="400" y="106" fill={C.primary} font-family={FONT} font-size="11" font-weight="700">Sensible + latent energy</text>

  <rect x="384" y="120" width="312" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="400" y="140" fill={C.muted} font-family={FONT} font-size="10">Moisture transfer</text>
  <text x="400" y="154" fill={C.green} font-family={FONT} font-size="11" font-weight="700">Yes</text>

  <rect x="384" y="168" width="312" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="400" y="188" fill={C.muted} font-family={FONT} font-size="10">Core material</text>
  <text x="400" y="202" fill={C.dark} font-family={FONT} font-size="11">Hygroscopic membrane</text>

  <rect x="384" y="216" width="312" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="400" y="236" fill={C.muted} font-family={FONT} font-size="10">Best climate</text>
  <text x="400" y="250" fill={C.primary} font-family={FONT} font-size="11" font-weight="700">Zones 1–3 (hot/humid)</text>

  <rect x="384" y="264" width="312" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="400" y="284" fill={C.muted} font-family={FONT} font-size="10">Summer RH impact</text>
  <text x="400" y="298" fill={C.green} font-family={FONT} font-size="11" font-weight="600">Reduces incoming humidity</text>

  <rect x="384" y="312" width="312" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="400" y="332" fill={C.muted} font-family={FONT} font-size="10">Sensible effectiveness</text>
  <text x="400" y="346" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">70–80%</text>
</svg>
