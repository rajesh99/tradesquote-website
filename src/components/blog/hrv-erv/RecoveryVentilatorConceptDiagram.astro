---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 280" fill="none" aria-hidden="true">
  <title>Heat recovery ventilator concept</title>
  <desc>
    HRV and ERV units exhaust stale indoor air and bring in fresh outdoor air, passing both streams
    through a heat exchanger core that recovers 70–85% of energy before separating.
  </desc>

  <rect x="8" y="8" width="704" height="264" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">What both HRV and ERV do</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Continuous balanced ventilation with energy recovery</text>

  <!-- Outdoor air in -->
  <rect x="32" y="80" width="80" height="48" rx="6" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="72" y="100" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="9" font-weight="600">Outdoor</text>
  <text x="72" y="116" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="10" font-weight="700">Fresh air</text>
  <path d="M120 104 H160" stroke={C.blue} stroke-width="2" marker-end="url(#hrv-arr-b)" />

  <!-- Heat exchanger core -->
  <rect x="164" y="72" width="160" height="120" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="2" />
  <text x="244" y="100" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Heat exchanger</text>
  <text x="244" y="118" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">core</text>
  <text x="244" y="142" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="12" font-weight="700">70–85%</text>
  <text x="244" y="160" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">energy recovered</text>
  <text x="244" y="178" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Airstreams never mix</text>

  <path d="M332 104 H372" stroke={C.blue} stroke-width="2" marker-end="url(#hrv-arr-b)" />
  <rect x="376" y="80" width="80" height="48" rx="6" fill={C.greenLight} stroke={C.green} stroke-width="1.5" />
  <text x="416" y="100" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="9" font-weight="600">Supply to</text>
  <text x="416" y="116" text-anchor="middle" fill={C.green} font-family={FONT} font-size="10" font-weight="700">home</text>

  <!-- Exhaust path -->
  <rect x="376" y="168" width="80" height="48" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="416" y="188" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="9" font-weight="600">Stale indoor</text>
  <text x="416" y="204" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="10" font-weight="700">exhaust</text>
  <path d="M372 192 H332" stroke={C.orange} stroke-width="2" marker-end="url(#hrv-arr-o)" />

  <path d="M160 192 H120" stroke={C.orange} stroke-width="2" marker-end="url(#hrv-arr-o)" />
  <rect x="32" y="168" width="80" height="48" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="72" y="188" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="9" font-weight="600">Exhaust</text>
  <text x="72" y="204" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="10" font-weight="700">out</text>

  <!-- Key difference callout -->
  <rect x="488" y="80" width="208" height="136" rx="8" fill={C.white} stroke={C.border} />
  <text x="504" y="104" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">The difference:</text>
  <text x="504" y="126" fill={C.muted} font-family={FONT} font-size="10">HRV transfers</text>
  <text x="504" y="142" fill={C.blue} font-family={FONT} font-size="10" font-weight="600">sensible heat only</text>
  <text x="504" y="166" fill={C.muted} font-family={FONT} font-size="10">ERV also transfers</text>
  <text x="504" y="182" fill={C.primary} font-family={FONT} font-size="10" font-weight="600">water vapor (latent)</text>
  <text x="504" y="206" fill={C.muted} font-family={FONT} font-size="9">Climate zone drives the choice</text>

  <rect x="32" y="232" width="656" height="32" rx="6" fill={C.white} stroke={C.border} />
  <text x="360" y="252" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">
    Solves stale air in airtight homes without wasting conditioned energy
  </text>

  <defs>
    <marker id="hrv-arr-b" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill={C.blue} /></marker>
    <marker id="hrv-arr-o" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill={C.orange} /></marker>
  </defs>
</svg>
