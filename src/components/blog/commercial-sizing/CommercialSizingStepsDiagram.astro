---
import { C, FONT } from "../infographicTokens";

const steps = [
  ["1", "Start with use type, not just area", "A restaurant and a warehouse of equal size need wildly different tonnage"],
  ["2", "Run a block load (ACCA Manual N)", "The commercial standard — Manual J is residential only"],
  ["3", "Add the outdoor-air load", "Code ventilation (ASHRAE 62.1) brings in hot, humid air that must be conditioned"],
  ["4", "Add internal & process gains", "People, lighting, equipment, kitchen and server heat — often the largest piece"],
  ["5", "Zone it", "Cores, perimeters, and different uses rarely peak together — size and zone accordingly"],
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 360" fill="none" aria-hidden="true">
  <title>How to size a commercial HVAC system</title>
  <desc>
    Five steps: start from the building use rather than area, run a block load using ACCA Manual N (the
    commercial standard, not residential Manual J), add the outdoor-air ventilation load, add internal
    and process gains, and zone the building because areas rarely peak together.
  </desc>

  <rect x="8" y="8" width="704" height="344" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Sizing a commercial system the right way</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">The square-foot chart is a sanity check — this is the actual process</text>

  {steps.map((s, i) => {
    const y = 76 + i * 54;
    return (
      <g>
        <rect x="24" y={y} width="672" height="46" rx="9" fill={C.white} stroke={C.border} />
        <circle cx="52" cy={y + 23} r="14" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
        <text x="52" y={y + 28} text-anchor="middle" fill={C.primary} font-family={FONT} font-size="14" font-weight="800">{s[0]}</text>
        <text x="80" y={y + 20} fill={C.dark} font-family={FONT} font-size="12" font-weight="700">{s[1]}</text>
        <text x="80" y={y + 37} fill={C.muted} font-family={FONT} font-size="10.5">{s[2]}</text>
      </g>
    );
  })}
</svg>
