---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>Why commercial loads differ from residential</title>
  <desc>
    A residential cooling load is dominated by the building envelope — walls, windows, and roof. A
    commercial load is dominated by internal gains: dense occupancy, lighting, equipment, process heat,
    and the large outdoor-air ventilation requirement.
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Why commercial loads are different</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">The envelope still matters — but internal gains usually run the show</text>

  <!-- Residential -->
  <rect x="24" y="76" width="320" height="200" rx="10" fill={C.greenLight} stroke={C.green} stroke-width="1.5" />
  <text x="40" y="100" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Residential — envelope-driven</text>
  <text x="40" y="120" fill={C.muted} font-family={FONT} font-size="10">Load follows the building shell</text>
  <text x="40" y="148" fill={C.green} font-family={FONT} font-size="11" font-weight="700">• Walls, roof, windows (conduction + solar)</text>
  <text x="40" y="172" fill={C.green} font-family={FONT} font-size="11" font-weight="700">• Air infiltration</text>
  <text x="40" y="196" fill={C.green} font-family={FONT} font-size="11" font-weight="700">• A few occupants</text>
  <text x="40" y="220" fill={C.muted} font-family={FONT} font-size="10">Square-foot rules are at least</text>
  <text x="40" y="236" fill={C.muted} font-family={FONT} font-size="10">in the right ballpark.</text>
  <text x="40" y="262" fill={C.muted} font-family={FONT} font-size="10">~500–700 sq ft per ton typical</text>

  <!-- Commercial -->
  <rect x="376" y="76" width="320" height="200" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="392" y="100" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Commercial — internal-gain driven</text>
  <text x="392" y="120" fill={C.muted} font-family={FONT} font-size="10">Load follows what's inside</text>
  <text x="392" y="148" fill={C.blue} font-family={FONT} font-size="11" font-weight="700">• Dense occupancy (people add heat)</text>
  <text x="392" y="172" fill={C.blue} font-family={FONT} font-size="11" font-weight="700">• Lighting + equipment + process heat</text>
  <text x="392" y="196" fill={C.blue} font-family={FONT} font-size="11" font-weight="700">• Large outdoor-air ventilation load</text>
  <text x="392" y="220" fill={C.red} font-family={FONT} font-size="10.5" font-weight="700">Square-foot rules can be off by</text>
  <text x="392" y="236" fill={C.red} font-family={FONT} font-size="10.5" font-weight="700">a factor of 5+ between uses.</text>
  <text x="392" y="262" fill={C.muted} font-family={FONT} font-size="10">~50–400 sq ft per ton by use type</text>
</svg>
