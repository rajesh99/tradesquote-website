---
import { C, FONT } from "../infographicTokens";

const inputs = [
  { label: "CFM", sub: "airflow required", color: C.blue, light: C.blueLight },
  { label: "Friction Rate", sub: "in.wg / 100 ft", color: C.primary, light: C.primaryLight },
];
const outputs = [
  { label: "Round Size", sub: "diameter in inches", color: C.primary, light: C.primaryLight },
  { label: "Velocity", sub: "fpm — check vs limit", color: C.orange, light: C.orangeLight },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 200" fill="none" aria-hidden="true">
  <title>How a ductulator resolves inputs to outputs</title>
  <desc>
    A ductulator takes two inputs — CFM and friction rate — and outputs round duct size plus velocity.
    The lookup works both ways: supply duct size and CFM to get friction rate instead.
  </desc>

  <defs>
    <marker id="duct-flow-arrow-primary" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.primary} />
    </marker>
    <marker id="duct-flow-arrow-blue" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.blue} />
    </marker>
  </defs>

  <rect x="8" y="8" width="704" height="184" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">How a ductulator works: inputs → outputs</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Bidirectional lookup — give any two values to solve for the third</text>

  <!-- Inputs -->
  {inputs.map((item, i) => {
    const y = 74 + i * 52;
    return (
      <g>
        <rect x="24" y={y} width="184" height="38" rx="8" fill={item.light} stroke={item.color} stroke-width="1.4" />
        <text x="116" y={y + 16} text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">{item.label}</text>
        <text x="116" y={y + 30} text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">{item.sub}</text>
      </g>
    );
  })}

  <!-- Center box: Ductulator -->
  <rect x="258" y="76" width="200" height="74" rx="10" fill={C.primary} />
  <text x="358" y="108" text-anchor="middle" fill={C.white} font-family={FONT} font-size="15" font-weight="800">Ductulator</text>
  <text x="358" y="128" text-anchor="middle" fill={C.white} font-family={FONT} font-size="10" font-weight="500">slide rule / online calculator</text>

  <!-- Arrows in -->
  <line x1="208" y1="93" x2="256" y2="104" stroke={C.blue} stroke-width="1.8" marker-end="url(#duct-flow-arrow-blue)" />
  <line x1="208" y1="137" x2="256" y2="124" stroke={C.primary} stroke-width="1.8" marker-end="url(#duct-flow-arrow-primary)" />

  <!-- Arrows out -->
  <line x1="460" y1="104" x2="494" y2="93" stroke={C.primary} stroke-width="1.8" marker-end="url(#duct-flow-arrow-primary)" />
  <line x1="460" y1="124" x2="494" y2="137" stroke={C.primary} stroke-width="1.8" marker-end="url(#duct-flow-arrow-primary)" />

  <!-- Outputs -->
  {outputs.map((item, i) => {
    const y = 74 + i * 52;
    return (
      <g>
        <rect x="496" y={y} width="200" height="38" rx="8" fill={item.light} stroke={item.color} stroke-width="1.4" />
        <text x="596" y={y + 16} text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">{item.label}</text>
        <text x="596" y={y + 30} text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">{item.sub}</text>
      </g>
    );
  })}
</svg>
