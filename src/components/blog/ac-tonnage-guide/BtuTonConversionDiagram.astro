---
import { C, FONT } from "../infographicTokens";

// Three estimation methods from the post
const methods = [
  {
    num: "1",
    title: "BTU conversion",
    formula: "Tons = BTU ÷ 12,000",
    example: "36,000 BTU ÷ 12,000 = 3 tons",
    color: C.primary,
    bg: C.primaryLight,
    border: C.primary,
  },
  {
    num: "2",
    title: "Sq ft rule of thumb",
    formula: "Tons ≈ Sq ft ÷ 600",
    example: "2,000 sq ft ÷ 600 ≈ 3.3 tons",
    color: C.blue,
    bg: C.blueLight,
    border: C.blue,
  },
  {
    num: "3",
    title: "Manual J load calc",
    formula: "Full climate + envelope inputs",
    example: "Only method accepted by code",
    color: C.green,
    bg: C.greenLight,
    border: C.green,
  },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 210" fill="none" aria-hidden="true">
  <title>Three methods to estimate AC tonnage</title>
  <desc>
    Method 1: divide total BTU by 12,000. Method 2: divide square footage by 600 for a rule of
    thumb. Method 3: run a Manual J load calculation — the only method accepted by code.
  </desc>

  <rect x="8" y="8" width="704" height="194" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">
    Three ways to estimate AC tonnage
  </text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">
    Methods 1 &amp; 2 are rules of thumb — Manual J is the gold standard for central AC sizing
  </text>

  {methods.map((m, i) => {
    const x = 24 + i * 228;
    return (
      <g>
        <rect x={x} y="68" width="212" height="118" rx="10" fill={m.bg} stroke={m.border} stroke-width="1.4" stroke-opacity="0.6" />
        <circle cx={x + 22} cy={84} r="13" fill={m.color} />
        <text x={x + 22} y={89} text-anchor="middle" fill={C.white} font-family={FONT} font-size="13" font-weight="800">
          {m.num}
        </text>
        <text x={x + 44} y={89} fill={C.dark} font-family={FONT} font-size="11.5" font-weight="700">
          {m.title}
        </text>
        <text x={x + 12} y={118} fill={m.color} font-family={FONT} font-size="11" font-weight="800">
          {m.formula}
        </text>
        <text x={x + 12} y={140} fill={C.muted} font-family={FONT} font-size="9.5">
          {m.example}
        </text>
      </g>
    );
  })}
</svg>
