---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 240" fill="none" aria-hidden="true">
  <title>Replacement versus new HVAC installation</title>
  <desc>
    A replacement reuses existing ductwork, line set, and electrical, so it costs less. A new install adds
    duct design and runs, line set routing, and often electrical work, so it costs significantly more.
  </desc>

  <rect x="8" y="8" width="704" height="224" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Replacement vs new install</text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">What's reused versus what's added is the biggest cost swing</text>

  <rect x="24" y="70" width="320" height="150" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.4" />
  <text x="40" y="98" fill={C.primary} font-family={FONT} font-size="13" font-weight="800">Replacement</text>
  <circle cx="46" cy="120" r="3" fill={C.primary} />
  <text x="58" y="124" fill={C.dark} font-family={FONT} font-size="10.5">Reuses existing ductwork</text>
  <circle cx="46" cy="142" r="3" fill={C.primary} />
  <text x="58" y="146" fill={C.dark} font-family={FONT} font-size="10.5">Reuses line set &amp; electrical</text>
  <circle cx="46" cy="164" r="3" fill={C.primary} />
  <text x="58" y="168" fill={C.dark} font-family={FONT} font-size="10.5">Mostly equipment-swap labor</text>
  <text x="40" y="204" fill={C.primary} font-family={FONT} font-size="10" font-weight="700">Lower cost — most jobs</text>

  <rect x="376" y="70" width="320" height="150" rx="10" fill={C.orangeLight} stroke={C.orange} stroke-width="1.4" />
  <text x="392" y="98" fill={C.orange} font-family={FONT} font-size="13" font-weight="800">New install</text>
  <circle cx="398" cy="120" r="3" fill={C.orange} />
  <text x="410" y="124" fill={C.dark} font-family={FONT} font-size="10.5">New duct design &amp; runs</text>
  <circle cx="398" cy="142" r="3" fill={C.orange} />
  <text x="410" y="146" fill={C.dark} font-family={FONT} font-size="10.5">Line set routing &amp; penetrations</text>
  <circle cx="398" cy="164" r="3" fill={C.orange} />
  <text x="410" y="168" fill={C.dark} font-family={FONT} font-size="10.5">Often electrical work</text>
  <text x="392" y="204" fill={C.orange} font-family={FONT} font-size="10" font-weight="700">Higher cost — first-time central air</text>
</svg>
