---
import { C, FONT } from "../infographicTokens";

// Payback guidance from post: hot climate ~2,000 hrs → ~$300/yr savings from 14→18 upgrade
// Mild climate ~600 hrs → ~$90/yr savings
// Post says hot climate 5–8 yr payback on 14-to-18 upgrade
const tiers = [
  {
    label: "Low-use / mild climate",
    hours: "< 800 hrs/yr",
    savings: "~$90/yr",
    payback: "10+ yrs",
    verdict: "Skip upgrade",
    verdictColor: C.orange,
    bg: C.orangeLight,
    border: C.orange,
  },
  {
    label: "Moderate climate",
    hours: "800–1,500 hrs/yr",
    savings: "~$150–$220/yr",
    payback: "7–10 yrs",
    verdict: "Mid-tier (15–16)",
    verdictColor: C.blue,
    bg: C.blueLight,
    border: C.blue,
  },
  {
    label: "Hot climate",
    hours: "1,500+ hrs/yr",
    savings: "~$300/yr",
    payback: "5–8 yrs",
    verdict: "Upgrade makes sense",
    verdictColor: C.primary,
    bg: C.primaryLight,
    border: C.primary,
  },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 260" fill="none" aria-hidden="true">
  <title>SEER upgrade payback by climate tier</title>
  <desc>
    Three climate tiers: low-use mild climates under 800 cooling hours save about $90/yr — payback exceeds 10 years so skipping the upgrade is recommended.
    Moderate climates at 800–1,500 hours save $150–$220/yr with 7–10 year payback — mid-tier SEER2 15–16 is advised.
    Hot climates over 1,500 hours save ~$300/yr with 5–8 year payback, making the upgrade worthwhile.
  </desc>

  <rect x="8" y="8" width="704" height="244" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">
    SEER upgrade payback — by cooling climate
  </text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">
    3-ton / $0.22/kWh · SEER2 14 → 18 upgrade scenario
  </text>

  {tiers.map((t, i) => {
    const x = 24 + i * 226;
    const cardW = 210;
    return (
      <g>
        <rect x={x} y="70" width={cardW} height="166" rx="10" fill={t.bg} stroke={t.border} stroke-width="1.5" stroke-opacity="0.6" />

        {/* Label */}
        <text x={x + cardW / 2} y="96" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="800">
          {t.label}
        </text>

        {/* Hours */}
        <text x={x + cardW / 2} y="118" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">
          {t.hours}
        </text>

        {/* Divider */}
        <line x1={x + 20} y1="130" x2={x + cardW - 20} y2="130" stroke={t.border} stroke-width="0.8" stroke-opacity="0.4" />

        {/* Savings */}
        <text x={x + 20} y="150" fill={C.muted} font-family={FONT} font-size="9" font-weight="600">SAVINGS</text>
        <text x={x + cardW - 20} y="150" text-anchor="end" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">
          {t.savings}
        </text>

        {/* Payback */}
        <text x={x + 20} y="170" fill={C.muted} font-family={FONT} font-size="9" font-weight="600">PAYBACK</text>
        <text x={x + cardW - 20} y="170" text-anchor="end" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">
          {t.payback}
        </text>

        {/* Verdict pill */}
        <rect x={x + 20} y="186" width={cardW - 40} height="30" rx="8" fill={t.verdictColor} fill-opacity="0.15" stroke={t.verdictColor} stroke-width="1" stroke-opacity="0.4" />
        <text x={x + cardW / 2} y="206" text-anchor="middle" fill={t.verdictColor} font-family={FONT} font-size="10" font-weight="700">
          {t.verdict}
        </text>
      </g>
    );
  })}
</svg>
