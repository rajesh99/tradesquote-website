---
import { C, FONT } from "../infographicTokens";

const steps = [
  { label: "BTU/hr × cooling hours", sub: "cooling load × run hours" },
  { label: "÷ (SEER × 1,000)", sub: "efficiency denominator" },
  { label: "= Annual kWh", sub: "energy consumed" },
  { label: "× $/kWh rate", sub: "annual cost" },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 200" fill="none" aria-hidden="true">
  <title>SEER savings formula flow</title>
  <desc>
    Annual kWh equals BTU/hr times cooling hours divided by SEER times 1,000.
    Multiply by your electricity rate to get annual cost. Subtract higher-SEER cost from lower-SEER cost for annual savings.
  </desc>

  <defs>
    <marker id="seer-formula-arrow-primary" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.primary} />
    </marker>
  </defs>

  <rect x="8" y="8" width="704" height="184" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">SEER savings formula — step by step</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">SEER is in the denominator — higher SEER directly cuts kWh for the same cooling output</text>

  {steps.map((s, i) => {
    const x = 24 + i * 174;
    const isResult = i === steps.length - 1;
    return (
      <g>
        <rect
          x={x}
          y="72"
          width="158"
          height="84"
          rx="9"
          fill={isResult ? C.primaryLight : C.white}
          stroke={isResult ? C.primary : C.border}
          stroke-width="1.4"
        />
        <text x={x + 79} y="104" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="800">
          {s.label}
        </text>
        <text x={x + 79} y="124" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">
          {s.sub}
        </text>
        {i < steps.length - 1 && (
          <path
            d={`M${x + 158} 114 l16 0`}
            stroke={C.muted}
            stroke-width="1.6"
            fill="none"
            marker-end="url(#seer-formula-arrow-primary)"
          />
        )}
      </g>
    );
  })}
</svg>
