---
import { C, FONT } from "../infographicTokens";

const rules = [
  ["Match the supply", "Total return airflow should equal total supply — about 400 CFM per ton", C.primary, C.primaryLight],
  ["Run it slower", "Size returns at lower velocity than supplies so they stay quiet — they end up larger", C.blue, C.blueLight],
  ["Mind the filter grille", "Keep filter face velocity low (~300 fpm) or the filter chokes airflow and whistles", C.orange, C.orangeLight],
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 220" fill="none" aria-hidden="true">
  <title>Three rules for sizing return air ducts</title>
  <desc>
    Three rules: total return airflow should equal total supply (about 400 CFM per ton), size returns at
    a lower velocity than supplies so they are quieter and larger, and keep the filter grille face
    velocity low so the filter does not choke airflow.
  </desc>

  <rect x="8" y="8" width="704" height="204" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Three rules for sizing returns</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Get these right and the blower breathes; get them wrong and static pressure spikes</text>

  {rules.map((r, i) => {
    const x = 24 + i * 224;
    return (
      <g>
        <rect x={x} y="74" width="208" height="116" rx="10" fill={r[3] as string} stroke={r[2] as string} stroke-width="1.5" />
        <circle cx={x + 26} cy="102" r="13" fill={C.white} stroke={r[2] as string} stroke-width="1.5" />
        <text x={x + 26} y="107" text-anchor="middle" fill={r[2] as string} font-family={FONT} font-size="13" font-weight="800">{i + 1}</text>
        <text x={x + 48} y="106" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">{r[0]}</text>
        <text x={x + 16} y="138" fill={C.muted} font-family={FONT} font-size="10">
          <tspan x={x + 16} dy="0">{(r[1] as string).slice(0, 38)}</tspan>
          <tspan x={x + 16} dy="15">{(r[1] as string).slice(38, 76)}</tspan>
          <tspan x={x + 16} dy="15">{(r[1] as string).slice(76)}</tspan>
        </text>
      </g>
    );
  })}
</svg>
