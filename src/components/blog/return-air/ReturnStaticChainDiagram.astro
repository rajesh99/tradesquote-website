---
import { C, FONT } from "../infographicTokens";

const chain = [
  ["Undersized return", "Too little return-air path"],
  ["Starved blower", "Fan can't pull enough air"],
  ["High static pressure", "TESP climbs past spec"],
  ["Low airflow + strain", "Hot/cold rooms, higher bills, early failure"],
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 200" fill="none" aria-hidden="true">
  <title>What an undersized return air duct causes</title>
  <desc>
    Undersizing the return starves the blower, which drives static pressure up, which cuts airflow and
    strains the system — causing uneven temperatures, higher bills, and early equipment failure.
  </desc>

  <rect x="8" y="8" width="704" height="184" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">The undersized-return chain reaction</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Returns are half the duct system — starve them and everything downstream suffers</text>

  {chain.map((c, i) => {
    const x = 24 + i * 174;
    return (
      <g>
        <rect x={x} y="80" width="156" height="78" rx="9" fill={i === chain.length - 1 ? C.redLight : C.white} stroke={i === chain.length - 1 ? C.red : C.border} stroke-width="1.4" />
        <text x={x + 78} y="108" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11.5" font-weight="800">{c[0]}</text>
        <text x={x + 78} y="130" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.2">{c[1]}</text>
        {i < chain.length - 1 && (
          <path d={`M${x + 156} 119 l 16 0 m -6 -4 l 6 4 l -6 4`} stroke={C.muted} stroke-width="1.6" fill="none" />
        )}
      </g>
    );
  })}
</svg>
