---
interface Props {
  title: string;
  caption?: string;
  id?: string;
}

const { title, caption, id } = Astro.props;
const figureId = id ?? `infographic-${title.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "")}`;
const ariaLabel = caption ? `${title}. ${caption}` : title;
---

<figure class="not-prose my-8" aria-labelledby={`${figureId}-title`}>
  <p id={`${figureId}-title`} class="mb-3 text-base font-bold text-dark sm:text-lg">
    {title}
  </p>

  <div
    class="overflow-hidden rounded-2xl border border-border bg-light/80 p-4 sm:p-6"
    role="img"
    aria-label={ariaLabel}
  >
    <div class="w-full [&_svg]:h-auto [&_svg]:w-full [&_svg]:max-w-full">
      <slot />
    </div>
  </div>

  {
    caption && (
      <figcaption class="mt-3 text-sm leading-relaxed text-text">{caption}</figcaption>
    )
  }
</figure>
