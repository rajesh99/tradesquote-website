---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 280" fill="none" aria-hidden="true">
  <title>Heat pump balance point diagram</title>
  <desc>Balance point is where heat pump output equals home heat loss. Below it, backup heat is needed.</desc>

  <text x="24" y="28" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Capacity vs outdoor temperature</text>

  <!-- Axes -->
  <line x1="60" y1="240" x2="660" y2="240" stroke={C.border} stroke-width="1.5" />
  <line x1="60" y1="240" x2="60" y2="40" stroke={C.border} stroke-width="1.5" />
  <text x="360" y="268" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Outdoor temp (°F)</text>
  <text x="24" y="140" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10" transform="rotate(-90 24 140)">BTU/hr</text>

  <!-- Heat loss line (rising as temp drops) -->
  <path d="M 100 80 L 620 220" stroke={C.orange} stroke-width="2.5" />
  <text x="630" y="225" fill={C.orange} font-family={FONT} font-size="9" font-weight="600">Heat loss</text>

  <!-- HP capacity curve (declining) -->
  <path d="M 100 200 Q 280 180 400 140 T 620 60" stroke={C.primary} stroke-width="2.5" />
  <text x="630" y="65" fill={C.primary} font-family={FONT} font-size="9" font-weight="600">HP output</text>

  <!-- Balance point -->
  <circle cx="380" cy="155" r="6" fill={C.dark} />
  <line x1="380" y1="155" x2="380" y2="240" stroke={C.dark} stroke-width="1" stroke-dasharray="3 3" />
  <text x="380" y="256" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="9" font-weight="600">Balance point</text>

  <rect x="420" y="48" width="280" height="72" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="560" y="72" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="700">Standard HP: ~30–40°F</text>
  <text x="560" y="90" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Cold-climate HP: ~5–15°F</text>
  <text x="560" y="108" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Below balance → backup heat runs</text>
</svg>
