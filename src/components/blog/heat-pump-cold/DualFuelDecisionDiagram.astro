---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 260" fill="none" aria-hidden="true">
  <title>Dual-fuel vs all-electric heat pump decision</title>
  <desc>Dual-fuel pairs heat pump with gas furnace; all-electric uses cold-climate HP with resistance strips.</desc>

  <rect x="40" y="16" width="300" height="220" rx="12" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="190" y="48" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Dual-fuel</text>
  <text x="190" y="80" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Heat pump + gas furnace</text>
  <rect x="80" y="100" width="220" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="190" y="125" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="9">HP handles most of season</text>
  <rect x="80" y="152" width="220" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="190" y="177" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="9">Furnace on coldest days only</text>
  <text x="190" y="220" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="9" font-weight="600">Best where gas is available</text>

  <rect x="380" y="16" width="300" height="220" rx="12" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="530" y="48" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">All-electric</text>
  <text x="530" y="80" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Cold-climate HP + strips</text>
  <rect x="420" y="100" width="220" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="530" y="125" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="9">No gas line required</text>
  <rect x="420" y="152" width="220" height="40" rx="6" fill={C.white} stroke={C.border} />
  <text x="530" y="177" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="9">Backup strips on design days</text>
  <text x="530" y="220" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="9" font-weight="600">Cost depends on $/kWh</text>
</svg>
