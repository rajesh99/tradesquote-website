---
import { C, FONT } from "../infographicTokens";

// Data from post table: Flex vs Rigid Capacity at ~0.10 fr
const rows = [
  ["6 in",  100,  80,  100],
  ["8 in",  225, 180,  225],
  ["10 in", 450, 360,  450],
  ["12 in", 700, 560,  700],
  ["14 in", 1100, 880, 1100],
];

const scaleMax = 1100;
const barLeft = 90;
const barAvail = 550;
const toW = (v: number) => (v / scaleMax) * barAvail;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Flex duct vs rigid metal CFM capacity by diameter</title>
  <desc>
    At every diameter, flex duct carries 15–20% less air than rigid metal at the same friction rate.
    A 10-inch flex run moves 360 CFM versus 450 CFM for rigid; a 12-inch flex moves 560 versus 700 for rigid.
  </desc>

  <rect x="8" y="8" width="704" height="304" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Flex vs rigid CFM capacity (0.10 in.wg/100 ft)</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Flex carries 15–20% less at the same nominal diameter — size up one increment</text>

  {/* Legend */}
  <rect x="500" y="22" width="14" height="12" rx="3" fill={C.blue} opacity="0.85" />
  <text x="518" y="33" fill={C.muted} font-family={FONT} font-size="10">Rigid metal</text>
  <rect x="590" y="22" width="14" height="12" rx="3" fill={C.primary} opacity="0.85" />
  <text x="608" y="33" fill={C.muted} font-family={FONT} font-size="10">Flex duct</text>

  {rows.map((r, i) => {
    const y = 74 + i * 46;
    const rigidW = toW(r[1] as number);
    const flexW  = toW(r[2] as number);
    return (
      <g>
        <text x="28" y={y + 14} fill={C.dark} font-family={FONT} font-size="12" font-weight="700">{r[0]}</text>
        {/* Rigid bar */}
        <rect x={barLeft} y={y} width={rigidW} height="16" rx="4" fill={C.blue} opacity="0.80" />
        <text x={barLeft + rigidW + 6} y={y + 13} fill={C.dark} font-family={FONT} font-size="11" font-weight="600">{r[1]} CFM</text>
        {/* Flex bar */}
        <rect x={barLeft} y={y + 20} width={flexW} height="16" rx="4" fill={C.primary} opacity="0.82" />
        <text x={barLeft + flexW + 6} y={y + 33} fill={C.dark} font-family={FONT} font-size="11" font-weight="600">{r[2]} CFM</text>
      </g>
    );
  })}
</svg>
