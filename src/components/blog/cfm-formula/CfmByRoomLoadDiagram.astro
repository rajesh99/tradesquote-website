---
import { C, FONT } from "../infographicTokens";

// CFM at ΔT=20°F from post table
const rows: [string, number, number][] = [
  ["4,000 BTU/hr",  185, 185],
  ["6,000 BTU/hr",  278, 278],
  ["8,000 BTU/hr",  370, 370],
  ["10,000 BTU/hr", 463, 463],
];

const barLeft = 150;
const scaleMax = 520;
const barArea = 520;
const toW = (v: number) => (v / scaleMax) * barArea;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 270" fill="none" aria-hidden="true">
  <title>CFM by room cooling load at ΔT = 20°F</title>
  <desc>
    At a 20°F coil temperature split: a 4,000 BTU/hr room needs 185 CFM, 6,000 needs 278 CFM,
    8,000 needs 370 CFM, and 10,000 needs 463 CFM.
  </desc>

  <rect x="8" y="8" width="704" height="254" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">CFM per room at ΔT = 20°F</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">CFM = Room BTU/hr ÷ (1.08 × 20) — design ΔT varies 18–22°F</text>

  {/* Scale gridlines */}
  {([0, 100, 200, 300, 400, 500] as number[]).map((v) => {
    const x = barLeft + toW(v);
    return (
      <g>
        <line x1={x} y1="64" x2={x} y2="234" stroke={C.border} stroke-width="1" stroke-dasharray="3 3" />
        <text x={x} y="248" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">{v}</text>
      </g>
    );
  })}
  <text x={barLeft + toW(250)} y="262" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">CFM</text>

  {rows.map(([label, cfm, barVal], i) => {
    const y = 72 + i * 42;
    return (
      <g>
        <text x="24" y={y + 16} fill={C.dark} font-family={FONT} font-size="11.5" font-weight="700">{label}</text>
        <rect x={barLeft} y={y} width={toW(barVal)} height="26" rx="6" fill={C.primaryLight} stroke={C.primary} stroke-width="1.2" />
        <text x={barLeft + toW(barVal) + 8} y={y + 17} fill={C.dark} font-family={FONT} font-size="12" font-weight="800">{cfm} CFM</text>
      </g>
    );
  })}
</svg>
