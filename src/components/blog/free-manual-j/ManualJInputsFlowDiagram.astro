---
import { C, FONT } from "../infographicTokens";

const inputs = [
  "Zip / climate zone",
  "Floor area + ceiling ht.",
  "Wall & attic insulation",
  "Window area + type",
  "Duct location",
  "Occupants",
  "Infiltration (ACH)",
];

const outputs = [
  { label: "Heating load", unit: "BTU/hr", color: C.orange },
  { label: "Cooling sensible", unit: "BTU/hr", color: C.blue },
  { label: "Cooling latent", unit: "BTU/hr", color: C.blue },
  { label: "Airflow req.", unit: "CFM", color: C.primary },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 280" fill="none" aria-hidden="true">
  <title>Manual J inputs and outputs</title>
  <desc>
    Seven envelope and occupancy inputs feed into the Manual J calculation engine, which produces
    three load values — heating BTU/hr, sensible and latent cooling BTU/hr — plus a CFM airflow requirement.
  </desc>

  <rect x="8" y="8" width="704" height="264" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Manual J: inputs → outputs</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Every free calculator needs these 7 inputs to give useful results</text>

  <defs>
    <marker id="mj-flow-arrow-primary" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.primary} />
    </marker>
    <marker id="mj-flow-arrow-blue" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.blue} />
    </marker>
  </defs>

  {/* Input pills column */}
  {inputs.map((label, i) => {
    const y = 76 + i * 27;
    return (
      <g>
        <rect x="20" y={y} width="188" height="22" rx="6" fill={C.primaryLight} stroke={C.primary} stroke-width="1.1" stroke-opacity="0.6" />
        <text x="114" y={y + 15} text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10.5" font-weight="600">{label}</text>
      </g>
    );
  })}

  {/* Funnel lines converging to center box */}
  {inputs.map((_, i) => {
    const y = 76 + i * 27 + 11;
    return (
      <line x1="208" y1={y} x2="268" y2="168" stroke={C.primary} stroke-width="1" stroke-opacity="0.28" />
    );
  })}

  {/* Arrow to center box */}
  <path d="M268 168 H294" stroke={C.primary} stroke-width="2.2" marker-end="url(#mj-flow-arrow-primary)" />

  {/* Central calc box */}
  <rect x="294" y="138" width="104" height="60" rx="10" fill={C.white} stroke={C.primary} stroke-width="2" />
  <text x="346" y="162" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">Manual J</text>
  <text x="346" y="178" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="10.5" font-weight="700">Calculation</text>
  <text x="346" y="192" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="8.5">ACCA 8th Ed.</text>

  {/* Arrow out to outputs */}
  <path d="M398 168 H426" stroke={C.blue} stroke-width="2.2" marker-end="url(#mj-flow-arrow-blue)" />

  {/* Output rows */}
  {outputs.map((o, i) => {
    const y = 88 + i * 38;
    return (
      <g>
        <rect x="426" y={y} width="268" height="30" rx="7" fill={C.blueLight} stroke={o.color} stroke-width="1.4" stroke-opacity="0.65" />
        <text x="444" y={y + 20} fill={C.dark} font-family={FONT} font-size="11" font-weight="700">{o.label}</text>
        <rect x="622" y={y + 5} width="60" height="20" rx="5" fill={o.color} fill-opacity="0.12" />
        <text x="652" y={y + 19} text-anchor="middle" fill={o.color} font-family={FONT} font-size="10" font-weight="800">{o.unit}</text>
      </g>
    );
  })}
</svg>
