---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>Minneapolis vs Dallas: 96% AFUE payback comparison</title>
  <desc>
    Minneapolis pays back a $600 premium in 2.2 years with $4,005 in 15-year savings. Dallas takes 8
    years with $1,125 in 15-year savings.
  </desc>

  {/* Minneapolis */}
  <rect x="8" y="8" width="344" height="284" rx="12" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="24" y="36" fill={C.primary} font-family={FONT} font-size="14" font-weight="700">Minneapolis (Zone 6)</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Long, hard heating season</text>

  {[
    { label: "Annual heating bill", value: "$1,600" },
    { label: "Annual savings (16.7%)", value: "$267/yr", highlight: C.green },
    { label: "Installed premium", value: "$600" },
    { label: "Payback period", value: "2.2 years", highlight: C.primary },
    { label: "15-year total savings", value: "$4,005", highlight: C.green },
  ].map((row, i) => {
    const y = 76 + i * 40;
    return (
      <g>
        <rect x="24" y={y} width="312" height="32" rx="6" fill={C.white} stroke={C.border} />
        <text x="36" y={y + 20} fill={C.muted} font-family={FONT} font-size="10">{row.label}</text>
        <text x="324" y={y + 20} text-anchor="end" fill={row.highlight ?? C.dark} font-family={FONT} font-size="11" font-weight="700">
          {row.value}
        </text>
      </g>
    );
  })}

  <rect x="24" y="276" width="312" height="8" rx="2" fill={C.primary} />
  <text x="180" y="272" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="9" font-weight="600">
    Clear case for 96% AFUE
  </text>

  {/* Dallas */}
  <rect x="368" y="8" width="344" height="284" rx="12" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="384" y="36" fill={C.orange} font-family={FONT} font-size="14" font-weight="700">Dallas (Zone 2)</text>
  <text x="384" y="56" fill={C.muted} font-family={FONT} font-size="11">Short heating season</text>

  {[
    { label: "Annual heating bill", value: "$450" },
    { label: "Annual savings (16.7%)", value: "$75/yr", highlight: C.green },
    { label: "Installed premium", value: "$600" },
    { label: "Payback period", value: "8 years", highlight: C.orange },
    { label: "15-year total savings", value: "$1,125", highlight: C.orange },
  ].map((row, i) => {
    const y = 76 + i * 40;
    return (
      <g>
        <rect x="384" y={y} width="312" height="32" rx="6" fill={C.white} stroke={C.border} />
        <text x="396" y={y + 20} fill={C.muted} font-family={FONT} font-size="10">{row.label}</text>
        <text x="684" y={y + 20} text-anchor="end" fill={row.highlight ?? C.dark} font-family={FONT} font-size="11" font-weight="700">
          {row.value}
        </text>
      </g>
    );
  })}

  <rect x="384" y="276" width="312" height="8" rx="2" fill={C.orange} />
  <text x="540" y="272" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="9" font-weight="600">
    Thin margin — 80% often makes sense
  </text>
</svg>
