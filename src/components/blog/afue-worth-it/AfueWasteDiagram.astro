---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 260" fill="none" aria-hidden="true">
  <title>AFUE waste comparison: 80% vs 96%</title>
  <desc>
    An 80% AFUE furnace wastes 20 cents per dollar up the flue. A 96% AFUE furnace wastes only 4 cents
    per dollar.
  </desc>

  {/* 80% panel */}
  <rect x="8" y="8" width="344" height="244" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">80% AFUE</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">20 cents of every dollar wasted</text>

  <rect x="40" y="80" width="280" height="40" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <rect x="40" y="80" width="224" height="40" rx="6" fill={C.primary} />
  <text x="152" y="106" text-anchor="middle" fill={C.white} font-family={FONT} font-size="13" font-weight="700">80¢ heats home</text>
  <text x="296" y="106" text-anchor="end" fill={C.orange} font-family={FONT} font-size="12" font-weight="700">20¢</text>

  {/* Flue arrow */}
  <path d="M180 136 V168" stroke={C.red} stroke-width="2" marker-end="url(#afue-arr-red)" />
  <rect x="140" y="172" width="80" height="36" rx="6" fill={C.redLight} stroke={C.red} stroke-width="1.5" />
  <text x="180" y="194" text-anchor="middle" fill={C.red} font-family={FONT} font-size="10" font-weight="600">Up flue</text>

  <rect x="40" y="220" width="280" height="24" rx="4" fill={C.white} stroke={C.border} />
  <text x="180" y="236" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">
  $1,200 bill → <tspan fill={C.red} font-weight="600">$240 wasted</tspan> per year
  </text>

  {/* 96% panel */}
  <rect x="368" y="8" width="344" height="244" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="384" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">96% AFUE</text>
  <text x="384" y="56" fill={C.muted} font-family={FONT} font-size="11">Only 4 cents of every dollar wasted</text>

  <rect x="400" y="80" width="280" height="40" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <rect x="400" y="80" width="268" height="40" rx="6" fill={C.primary} />
  <text x="534" y="106" text-anchor="middle" fill={C.white} font-family={FONT} font-size="13" font-weight="700">96¢ heats home</text>
  <text x="668" y="106" text-anchor="end" fill={C.orange} font-family={FONT} font-size="12" font-weight="700">4¢</text>

  <path d="M540 136 V168" stroke={C.red} stroke-width="2" marker-end="url(#afue-arr-red)" />
  <rect x="500" y="172" width="80" height="36" rx="6" fill={C.redLight} stroke={C.red} stroke-width="1.5" />
  <text x="540" y="194" text-anchor="middle" fill={C.red} font-family={FONT} font-size="10" font-weight="600">Up flue</text>

  <rect x="400" y="220" width="280" height="24" rx="4" fill={C.white} stroke={C.border} />
  <text x="540" y="236" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">
  $1,200 bill → <tspan fill={C.green} font-weight="600">$48 wasted</tspan> · saves $192/yr
  </text>

  <defs>
    <marker id="afue-arr-red" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.red} />
    </marker>
  </defs>
</svg>
