---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>How a sell price is built</title>
  <desc>A stacked build-up showing materials plus labor plus overhead plus margin adding up to the sell price.</desc>

  <text x="360" y="34" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Building the sell price</text>

  <!-- Stacked bar -->
  <rect x="120" y="64" width="200" height="44" rx="6" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="220" y="91" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Materials &amp; equipment</text>

  <rect x="120" y="116" width="200" height="44" rx="6" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="220" y="143" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Labor (hrs &#215; rate)</text>

  <rect x="120" y="168" width="200" height="44" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="220" y="195" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Overhead allocation</text>

  <rect x="120" y="220" width="200" height="44" rx="6" fill={C.greenLight} stroke={C.green} stroke-width="1.5" />
  <text x="220" y="247" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Target margin</text>

  <!-- Brace / equals -->
  <text x="372" y="170" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="30" font-weight="800">=</text>

  <!-- Sell price box -->
  <rect x="408" y="116" width="232" height="96" rx="12" fill={C.dark} />
  <text x="524" y="152" text-anchor="middle" fill={C.white} font-family={FONT} font-size="12" font-weight="600" opacity="0.8">SELL PRICE</text>
  <text x="524" y="186" text-anchor="middle" fill={C.white} font-family={FONT} font-size="22" font-weight="800">Cost &#247; (1 &#8722; margin)</text>

  <text x="360" y="300" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">True cost is materials + labor + overhead. Your margin sits on top of all three &#8212; never on materials alone.</text>
</svg>
