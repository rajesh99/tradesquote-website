---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Common estimating mistakes and their fixes</title>
  <desc>Four common estimating mistakes paired with the fix for each: forgetting overhead, undercharging labor, no contingency, and guessing instead of measuring.</desc>

  <text x="360" y="34" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Estimating mistakes vs the fix</text>

  <!-- Column headers -->
  <text x="210" y="62" text-anchor="middle" fill={C.red} font-family={FONT} font-size="12" font-weight="700">THE MISTAKE</text>
  <text x="510" y="62" text-anchor="middle" fill={C.green} font-family={FONT} font-size="12" font-weight="700">THE FIX</text>

  <!-- Row template -->
  <!-- Row 1 -->
  <rect x="40" y="72" width="340" height="48" rx="8" fill={C.redLight} stroke={C.red} stroke-width="1" />
  <text x="56" y="101" fill={C.dark} font-family={FONT} font-size="12.5" font-weight="600">Forgetting overhead</text>
  <rect x="400" y="72" width="280" height="48" rx="8" fill={C.greenLight} stroke={C.green} stroke-width="1" />
  <text x="416" y="101" fill={C.dark} font-family={FONT} font-size="12.5" font-weight="600">Allocate it per labor hour</text>

  <!-- Row 2 -->
  <rect x="40" y="128" width="340" height="48" rx="8" fill={C.redLight} stroke={C.red} stroke-width="1" />
  <text x="56" y="157" fill={C.dark} font-family={FONT} font-size="12.5" font-weight="600">Undercharging labor</text>
  <rect x="400" y="128" width="280" height="48" rx="8" fill={C.greenLight} stroke={C.green} stroke-width="1" />
  <text x="416" y="157" fill={C.dark} font-family={FONT} font-size="12.5" font-weight="600">Use a fully loaded rate</text>

  <!-- Row 3 -->
  <rect x="40" y="184" width="340" height="48" rx="8" fill={C.redLight} stroke={C.red} stroke-width="1" />
  <text x="56" y="213" fill={C.dark} font-family={FONT} font-size="12.5" font-weight="600">No contingency buffer</text>
  <rect x="400" y="184" width="280" height="48" rx="8" fill={C.greenLight} stroke={C.green} stroke-width="1" />
  <text x="416" y="213" fill={C.dark} font-family={FONT} font-size="12.5" font-weight="600">Add 5&#8211;10% for surprises</text>

  <!-- Row 4 -->
  <rect x="40" y="240" width="340" height="48" rx="8" fill={C.redLight} stroke={C.red} stroke-width="1" />
  <text x="56" y="269" fill={C.dark} font-family={FONT} font-size="12.5" font-weight="600">Guessing the load</text>
  <rect x="400" y="240" width="280" height="48" rx="8" fill={C.greenLight} stroke={C.green} stroke-width="1" />
  <text x="416" y="269" fill={C.dark} font-family={FONT} font-size="12.5" font-weight="600">Measure &#8212; run a Manual J</text>

  <!-- Arrows -->
  <text x="390" y="101" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="16" font-weight="800">&#8594;</text>
  <text x="390" y="157" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="16" font-weight="800">&#8594;</text>
  <text x="390" y="213" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="16" font-weight="800">&#8594;</text>
  <text x="390" y="269" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="16" font-weight="800">&#8594;</text>
</svg>
