---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>The estimating workflow</title>
  <desc>A six-step flow: measure and load calc, scope and takeoff, labor estimate, add overhead, apply margin, present the quote.</desc>

  <defs>
    <marker id="est-flow-arrow" markerWidth="9" markerHeight="9" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.primary} />
    </marker>
  </defs>

  <text x="360" y="34" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">A repeatable estimating workflow</text>

  <!-- Row 1 -->
  <g>
    <rect x="40" y="68" width="180" height="56" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
    <text x="130" y="92" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">1. Measure</text>
    <text x="130" y="110" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Site visit + load calc</text>

    <rect x="270" y="68" width="180" height="56" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
    <text x="360" y="92" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">2. Scope + takeoff</text>
    <text x="360" y="110" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">List every material</text>

    <rect x="500" y="68" width="180" height="56" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
    <text x="590" y="92" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">3. Labor estimate</text>
    <text x="590" y="110" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Hours &#215; loaded rate</text>
  </g>

  <!-- arrows row 1 -->
  <line x1="222" y1="96" x2="266" y2="96" stroke={C.primary} stroke-width="2" marker-end="url(#est-flow-arrow)" />
  <line x1="452" y1="96" x2="496" y2="96" stroke={C.primary} stroke-width="2" marker-end="url(#est-flow-arrow)" />

  <!-- down connector -->
  <path d="M590 124 L590 150 L360 150" stroke={C.primary} stroke-width="2" fill="none" />
  <path d="M360 150 L360 184" stroke={C.primary} stroke-width="2" fill="none" marker-end="url(#est-flow-arrow)" />

  <!-- Row 2 -->
  <g>
    <rect x="40" y="190" width="180" height="56" rx="10" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
    <text x="130" y="214" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">4. Add overhead</text>
    <text x="130" y="232" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Per-hour allocation</text>

    <rect x="270" y="190" width="180" height="56" rx="10" fill={C.greenLight} stroke={C.green} stroke-width="1.5" />
    <text x="360" y="214" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">5. Apply margin</text>
    <text x="360" y="232" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">+ contingency</text>

    <rect x="500" y="190" width="180" height="56" rx="10" fill={C.dark} />
    <text x="590" y="214" text-anchor="middle" fill={C.white} font-family={FONT} font-size="13" font-weight="700">6. Present quote</text>
    <text x="590" y="232" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" opacity="0.8">Clear, itemized</text>
  </g>

  <!-- arrows row 2 (right to left visual order corrected: 4 -> 5 -> 6) -->
  <line x1="222" y1="218" x2="266" y2="218" stroke={C.primary} stroke-width="2" marker-end="url(#est-flow-arrow)" />
  <line x1="452" y1="218" x2="496" y2="218" stroke={C.primary} stroke-width="2" marker-end="url(#est-flow-arrow)" />

  <!-- connector from step 3 box into step 4 -->
  <path d="M360 184 L360 168" stroke={C.primary} stroke-width="0" fill="none" />

  <text x="360" y="298" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Same steps, every job: measure &#8594; takeoff &#8594; labor &#8594; overhead &#8594; margin &#8594; quote.</text>
</svg>
