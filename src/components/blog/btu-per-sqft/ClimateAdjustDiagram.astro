---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>BTU per square foot by climate and adjustments</title>
  <desc>BTU per square foot shifts by climate zone, from about 18 in cool zones to 22 to 25 in hot humid zones, plus the main adjustment factors for sun, shade, people, and kitchens.</desc>

  <text x="360" y="30" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">BTU per sq ft shifts with climate</text>

  <!-- Cool zone -->
  <rect x="48" y="54" width="196" height="92" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="146" y="80" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="12" font-weight="700">COOL / NORTHERN</text>
  <text x="146" y="112" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="22" font-weight="800">~18</text>
  <text x="146" y="134" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">BTU per sq ft</text>

  <!-- Moderate zone -->
  <rect x="262" y="54" width="196" height="92" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="360" y="80" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="12" font-weight="700">MODERATE</text>
  <text x="360" y="112" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="22" font-weight="800">~20</text>
  <text x="360" y="134" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">baseline</text>

  <!-- Hot zone -->
  <rect x="476" y="54" width="196" height="92" rx="10" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="574" y="80" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="12" font-weight="700">HOT / HUMID</text>
  <text x="574" y="112" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="22" font-weight="800">22&#8211;25</text>
  <text x="574" y="134" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">BTU per sq ft</text>

  <!-- Adjustments header -->
  <text x="360" y="182" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="700">THEN ADJUST FOR</text>

  <!-- Adjustment chips -->
  <rect x="48" y="196" width="196" height="40" rx="8" fill={C.panelBg} stroke={C.border} />
  <text x="146" y="221" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">+10% heavy sun</text>

  <rect x="262" y="196" width="196" height="40" rx="8" fill={C.panelBg} stroke={C.border} />
  <text x="360" y="221" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">&#8211;10% heavy shade</text>

  <rect x="476" y="196" width="196" height="40" rx="8" fill={C.panelBg} stroke={C.border} />
  <text x="574" y="221" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">+600 BTU / extra person</text>

  <rect x="155" y="246" width="196" height="40" rx="8" fill={C.panelBg} stroke={C.border} />
  <text x="253" y="271" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">+4,000 BTU kitchen</text>

  <rect x="369" y="246" width="196" height="40" rx="8" fill={C.panelBg} stroke={C.border} />
  <text x="467" y="271" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">ceiling &gt; 8 ft adds load</text>

  <text x="360" y="308" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Climate sets the base rate; the adjustments fine-tune it for the room.</text>
</svg>
