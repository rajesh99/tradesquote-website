---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>BTU per square foot formula</title>
  <desc>BTU per hour equals square feet times BTU per square foot, with a worked example of a 500 square foot sunny room reaching 11,000 BTU after a 10 percent sun adjustment.</desc>

  <text x="360" y="34" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Sizing cooling from floor area</text>

  <!-- Main formula -->
  <rect x="120" y="58" width="480" height="62" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="360" y="98" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="20" font-weight="800">BTU/hr = sq ft &#215; BTU per sq ft</text>

  <!-- Baseline note -->
  <rect x="160" y="138" width="400" height="52" rx="8" fill={C.panelBg} stroke={C.border} />
  <text x="360" y="160" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">The baseline rate</text>
  <text x="360" y="180" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">&#8776; 20 BTU per sq ft for cooling (range 18&#8211;25)</text>

  <!-- Worked plug-in -->
  <rect x="60" y="210" width="600" height="64" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1" />
  <text x="360" y="234" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="11" font-weight="700">Worked example: a 500 sq ft sunny room (+10% for heavy sun)</text>
  <text x="360" y="258" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">500 &#215; 20 = 10,000 &#8594; +10% = 11,000 BTU/hr</text>

  <text x="360" y="302" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">BTU/hr = sq ft &#215; BTU per sq ft. Start at ~20, then adjust for sun, occupancy, and climate.</text>
</svg>
