---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>BTU per square foot sizing chart</title>
  <desc>A chart relating room square footage to the BTU needed at 20 BTU per square foot and the approximate tons of cooling.</desc>

  <text x="360" y="30" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Sq ft &#8594; BTU &#8594; tons (at 20 BTU/sq ft)</text>

  <!-- Column headers -->
  <text x="70" y="64" fill={C.muted} font-family={FONT} font-size="11" font-weight="700">SQ FT</text>
  <text x="360" y="64" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="700">BTU/HR NEEDED</text>
  <text x="700" y="64" text-anchor="end" fill={C.muted} font-family={FONT} font-size="11" font-weight="700">TONS</text>

  <!-- Row: 300 -->
  <text x="70" y="92" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">300</text>
  <rect x="150" y="80" width="78" height="18" rx="4" fill={C.primary} fill-opacity="0.85" />
  <text x="236" y="93" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">6,000 BTU</text>
  <text x="700" y="93" text-anchor="end" fill={C.muted} font-family={FONT} font-size="12" font-weight="700">0.5</text>

  <!-- Row: 500 -->
  <text x="70" y="126" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">500</text>
  <rect x="150" y="114" width="130" height="18" rx="4" fill={C.primary} fill-opacity="0.85" />
  <text x="288" y="127" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">10,000 BTU</text>
  <text x="700" y="127" text-anchor="end" fill={C.muted} font-family={FONT} font-size="12" font-weight="700">0.8</text>

  <!-- Row: 750 -->
  <text x="70" y="160" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">750</text>
  <rect x="150" y="148" width="195" height="18" rx="4" fill={C.primary} fill-opacity="0.85" />
  <text x="353" y="161" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">15,000 BTU</text>
  <text x="700" y="161" text-anchor="end" fill={C.muted} font-family={FONT} font-size="12" font-weight="700">1.25</text>

  <!-- Row: 1,000 -->
  <text x="70" y="194" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">1,000</text>
  <rect x="150" y="182" width="260" height="18" rx="4" fill={C.blue} fill-opacity="0.85" />
  <text x="418" y="195" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">20,000 BTU</text>
  <text x="700" y="195" text-anchor="end" fill={C.muted} font-family={FONT} font-size="12" font-weight="700">1.67</text>

  <!-- Row: 1,500 -->
  <text x="70" y="228" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">1,500</text>
  <rect x="150" y="216" width="360" height="18" rx="4" fill={C.blue} fill-opacity="0.85" />
  <text x="518" y="229" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">30,000 BTU</text>
  <text x="700" y="229" text-anchor="end" fill={C.muted} font-family={FONT} font-size="12" font-weight="700">2.5</text>

  <!-- Row: 2,000 -->
  <text x="70" y="262" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">2,000</text>
  <rect x="150" y="250" width="460" height="18" rx="4" fill={C.orange} fill-opacity="0.85" />
  <text x="700" y="263" text-anchor="end" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">3.5</text>

  <text x="360" y="298" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">12,000 BTU = 1 ton. Divide BTU by 12,000 to get tons. Bars scaled to BTU.</text>
</svg>
