---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 220" fill="none" aria-hidden="true">
  <title>Ton to BTU conversion concept</title>
  <desc>
    1 ton equals 12,000 BTU per hour. To convert tons to BTU multiply by 12,000;
    to convert BTU to tons divide by 12,000. The term "ton" originates from the heat needed
    to melt one ton of ice (2,000 lb) in 24 hours.
  </desc>

  <defs>
    <marker id="tonbtu-concept-arrow-primary" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.primary} />
    </marker>
    <marker id="tonbtu-concept-arrow-blue" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.blue} />
    </marker>
  </defs>

  <!-- Panel background -->
  <rect x="8" y="8" width="704" height="204" rx="12" fill={C.panelBg} stroke={C.border} />

  <!-- Title + subtitle -->
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">The ton ↔ BTU/hr conversion</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">One relationship, two directions — multiply or divide by 12,000</text>

  <!-- Central equality badge -->
  <rect x="270" y="72" width="180" height="56" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="2" />
  <text x="360" y="97" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">1 ton</text>
  <text x="360" y="116" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="12" font-weight="700">= 12,000 BTU/hr</text>

  <!-- Left box: Tons → BTU formula -->
  <rect x="28" y="80" width="200" height="42" rx="8" fill={C.white} stroke={C.border} stroke-width="1.4" />
  <text x="128" y="97" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">BTU/hr = Tons × 12,000</text>
  <text x="128" y="113" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9.5">tons → BTU</text>

  <!-- Right box: BTU → Tons formula -->
  <rect x="492" y="80" width="200" height="42" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1.4" />
  <text x="592" y="97" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Tons = BTU/hr ÷ 12,000</text>
  <text x="592" y="113" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="9.5">BTU → tons</text>

  <!-- Arrow left box → center -->
  <line x1="228" y1="101" x2="266" y2="101" stroke={C.primary} stroke-width="1.8" marker-end="url(#tonbtu-concept-arrow-primary)" />

  <!-- Arrow center → right box -->
  <line x1="452" y1="101" x2="488" y2="101" stroke={C.blue} stroke-width="1.8" marker-end="url(#tonbtu-concept-arrow-blue)" />

  <!-- Origin note -->
  <rect x="28" y="152" width="664" height="44" rx="8" fill={C.white} stroke={C.border} stroke-width="1.2" />
  <text x="48" y="170" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Why "ton"?</text>
  <text x="48" y="186" fill={C.muted} font-family={FONT} font-size="10.5">Heat removed to melt 1 ton (2,000 lb) of ice in 24 hours = 12,000 BTU/hr — the original definition still used today.</text>
</svg>
