---
import { C, FONT } from "../infographicTokens";

const rows = [
  ["0.75 ton", "9,000 BTU/hr",  "Small mini-split head",             9000],
  ["1.0 ton",  "12,000 BTU/hr", "Window unit, small mini-split",    12000],
  ["1.5 ton",  "18,000 BTU/hr", "Mini-split, small central",        18000],
  ["2.0 ton",  "24,000 BTU/hr", "Central AC, large mini-split",     24000],
  ["2.5 ton",  "30,000 BTU/hr", "Central AC",                       30000],
  ["3.0 ton",  "36,000 BTU/hr", "Central AC (most common)",         36000],
  ["3.5 ton",  "42,000 BTU/hr", "Central AC",                       42000],
  ["4.0 ton",  "48,000 BTU/hr", "Central AC",                       48000],
  ["5.0 ton",  "60,000 BTU/hr", "Large residential central AC",     60000],
];

const scaleMax = 60000;
const barLeft  = 104;
const barArea  = 388; // px width for full scale
const toW = (v: number) => (v / scaleMax) * barArea;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 370" fill="none" aria-hidden="true">
  <title>Ton to BTU/hr chart for common AC sizes</title>
  <desc>
    Horizontal bar chart showing BTU/hr for AC tonnages from 0.75 to 5.0 tons.
    0.75 ton = 9,000; 1.0 = 12,000; 1.5 = 18,000; 2.0 = 24,000; 2.5 = 30,000;
    3.0 = 36,000; 3.5 = 42,000; 4.0 = 48,000; 5.0 = 60,000 BTU/hr.
  </desc>

  <!-- Panel background -->
  <rect x="8" y="8" width="704" height="354" rx="12" fill={C.panelBg} stroke={C.border} />

  <!-- Title + subtitle -->
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Ton to BTU/hr — common AC sizes</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Each ton = 12,000 BTU/hr · bars scaled proportionally</text>

  {/* Scale lines */}
  {[0, 15000, 30000, 45000, 60000].map((v) => (
    <g>
      <line
        x1={barLeft + toW(v)} y1="68"
        x2={barLeft + toW(v)} y2="334"
        stroke={C.border} stroke-width="1" stroke-dasharray="3 3"
      />
      <text
        x={barLeft + toW(v)} y="348"
        text-anchor="middle"
        fill={C.muted} font-family={FONT} font-size="9"
      >
        {v === 0 ? "0" : `${(v / 1000).toFixed(0)}k`}
      </text>
    </g>
  ))}

  {rows.map((r, i) => {
    const y   = 76 + i * 29;
    const w   = toW(r[3] as number);
    const btu = r[3] as number;
    // Alternate teal / blue for visual rhythm
    const fill   = i % 2 === 0 ? C.primary : C.blue;
    const opacity = "0.82";
    return (
      <g>
        {/* Tonnage label */}
        <text x="28" y={y + 15} fill={C.dark} font-family={FONT} font-size="11" font-weight="700">{r[0]}</text>
        {/* Bar */}
        <rect x={barLeft} y={y + 2} width={w} height="20" rx="5" fill={fill} opacity={opacity} />
        {/* BTU label inside or after bar */}
        <text
          x={barLeft + w + 6} y={y + 15}
          fill={C.dark} font-family={FONT} font-size="10.5" font-weight="700"
        >{r[1]}</text>
        {/* Equipment note */}
        <text
          x={barLeft + w + 6} y={y + 26}
          fill={C.muted} font-family={FONT} font-size="8.5"
        >{r[2]}</text>
      </g>
    );
  })}
</svg>
