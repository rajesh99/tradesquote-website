---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Installed central AC cost by tonnage</title>
  <desc>Vertical bars showing the typical installed price range for central air conditioners from 2 to 5 tons, rising with system size.</desc>

  <text x="360" y="30" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Installed cost by tonnage</text>

  <!-- Baseline -->
  <line x1="60" y1="250" x2="680" y2="250" stroke={C.border} stroke-width="1.5" />

  <!-- Bars: x positions evenly spaced, taller = pricier -->
  <!-- 2 ton -->
  <rect x="78" y="178" width="64" height="72" rx="5" fill={C.primary} />
  <text x="110" y="170" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="800">$3.8k&#8211;$5.5k</text>
  <text x="110" y="270" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">2 ton</text>

  <!-- 2.5 ton -->
  <rect x="182" y="160" width="64" height="90" rx="5" fill={C.primary} />
  <text x="214" y="152" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="800">$4.2k&#8211;$6.2k</text>
  <text x="214" y="270" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">2.5 ton</text>

  <!-- 3 ton -->
  <rect x="286" y="142" width="64" height="108" rx="5" fill={C.blue} />
  <text x="318" y="134" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="800">$4.6k&#8211;$6.8k</text>
  <text x="318" y="270" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">3 ton</text>

  <!-- 3.5 ton -->
  <rect x="390" y="124" width="64" height="126" rx="5" fill={C.blue} />
  <text x="422" y="116" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="800">$5.0k&#8211;$7.4k</text>
  <text x="422" y="270" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">3.5 ton</text>

  <!-- 4 ton -->
  <rect x="494" y="104" width="64" height="146" rx="5" fill={C.orange} />
  <text x="526" y="96" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="800">$5.4k&#8211;$8.2k</text>
  <text x="526" y="270" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">4 ton</text>

  <!-- 5 ton -->
  <rect x="598" y="84" width="64" height="166" rx="5" fill={C.orange} />
  <text x="630" y="76" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="800">$6.0k&#8211;$9.0k</text>
  <text x="630" y="270" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">5 ton</text>

  <text x="360" y="300" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Typical 2026 US installed ranges (standard-efficiency); larger systems and higher SEER2 push higher.</text>
</svg>
