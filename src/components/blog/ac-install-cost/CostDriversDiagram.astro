---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>What moves the central AC install price</title>
  <desc>Six cards showing the main factors that raise or lower a central air installation cost: system size, SEER2 efficiency, ductwork, line set and electrical, removal and disposal, and permits and labor.</desc>

  <text x="360" y="30" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">What moves the price</text>

  <!-- Row 1 -->
  <!-- Card 1: System size -->
  <rect x="40" y="54" width="206" height="112" rx="12" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="143" y="84" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">System size (tonnage)</text>
  <text x="143" y="110" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">From a Manual J load calc</text>
  <text x="143" y="132" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">&#8212; bigger ton = more</text>
  <text x="143" y="152" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="11" font-weight="700">biggest single driver</text>

  <!-- Card 2: SEER2 -->
  <rect x="257" y="54" width="206" height="112" rx="12" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="360" y="84" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">SEER2 efficiency tier</text>
  <text x="360" y="110" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">14&#8211;16 vs 18+ SEER2</text>
  <text x="360" y="132" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">higher tier = pricier unit</text>
  <text x="360" y="152" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="11" font-weight="700">but lower running cost</text>

  <!-- Card 3: Ductwork -->
  <rect x="474" y="54" width="206" height="112" rx="12" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="577" y="84" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">Ductwork</text>
  <text x="577" y="110" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">New ducts add the most</text>
  <text x="577" y="132" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">vs reusing existing</text>
  <text x="577" y="152" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="11" font-weight="700">+$1,400&#8211;$5,600</text>

  <!-- Row 2 -->
  <!-- Card 4: Line set & electrical -->
  <rect x="40" y="178" width="206" height="112" rx="12" fill={C.panelBg} stroke={C.border} stroke-width="1.5" />
  <text x="143" y="208" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">Line set &amp; electrical</text>
  <text x="143" y="234" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">New refrigerant line,</text>
  <text x="143" y="256" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">disconnect &amp; whip,</text>
  <text x="143" y="276" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">panel capacity</text>

  <!-- Card 5: Removal & disposal -->
  <rect x="257" y="178" width="206" height="112" rx="12" fill={C.panelBg} stroke={C.border} stroke-width="1.5" />
  <text x="360" y="208" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">Removal &amp; disposal</text>
  <text x="360" y="234" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">Hauling out the old</text>
  <text x="360" y="256" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">condenser &amp; coil,</text>
  <text x="360" y="276" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">recovering refrigerant</text>

  <!-- Card 6: Permits & labor -->
  <rect x="474" y="178" width="206" height="112" rx="12" fill={C.panelBg} stroke={C.border} stroke-width="1.5" />
  <text x="577" y="208" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">Permits, labor &amp; access</text>
  <text x="577" y="234" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">Region, brand, and how</text>
  <text x="577" y="256" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">easy the unit is to reach</text>
  <text x="577" y="276" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">permits ~$250&#8211;$500</text>
</svg>
