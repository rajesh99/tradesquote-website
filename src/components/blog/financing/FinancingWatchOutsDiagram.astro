---
import { C, FONT } from "../infographicTokens";

// Four watch-outs from post "What to Watch For" section
const items = [
  {
    num: "1",
    title: "Deferred interest",
    detail: "0% promos charge retroactive interest if balance isn't paid off by promo end date",
    accent: C.orange,
    bg: C.orangeLight,
  },
  {
    num: "2",
    title: "Origination fees",
    detail: "Added to principal — raise the effective APR above the advertised rate",
    accent: C.blue,
    bg: C.blueLight,
  },
  {
    num: "3",
    title: "Equipment markup",
    detail: "Some contractors inflate the installed price on financed jobs to cover dealer fees",
    accent: C.red,
    bg: C.redLight,
  },
  {
    num: "4",
    title: "Prepayment penalties",
    detail: "Rare but check loan terms — paying early should not cost extra",
    accent: C.primary,
    bg: C.primaryLight,
  },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 220" fill="none" aria-hidden="true">
  <title>Four HVAC financing watch-outs</title>
  <desc>
    Deferred interest, origination fees, equipment markup, and prepayment penalties are the four
    key risks to watch for when financing an HVAC system.
  </desc>

  <rect x="8" y="8" width="704" height="204" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">
    What to watch for in HVAC financing
  </text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">
    Four common traps that raise the true cost above the advertised rate
  </text>

  {items.map((item, i) => {
    const col = i % 2;
    const row = Math.floor(i / 2);
    const x = 24 + col * 348;
    const y = 68 + row * 72;
    return (
      <g>
        <rect x={x} y={y} width="336" height="60" rx="9" fill={item.bg} stroke={item.accent} stroke-width="1.2" stroke-opacity="0.5" />
        <circle cx={x + 22} cy={y + 20} r="12" fill={item.accent} />
        <text x={x + 22} y={y + 25} text-anchor="middle" fill={C.white} font-family={FONT} font-size="12" font-weight="800">{item.num}</text>
        <text x={x + 42} y={y + 22} fill={C.dark} font-family={FONT} font-size="12" font-weight="700">{item.title}</text>
        <text x={x + 14} y={y + 42} fill={C.muted} font-family={FONT} font-size="9.5">{item.detail}</text>
      </g>
    );
  })}
</svg>
