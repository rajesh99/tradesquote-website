---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 340" fill="none" aria-hidden="true">
  <title>Mini-split vs central air head-to-head comparison</title>
  <desc>
    Side-by-side comparison of upfront cost, SEER rating, ductwork, zoning, and heating capability
    for mini-split and central air systems.
  </desc>

  <rect x="8" y="8" width="344" height="324" rx="12" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Mini-Split</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Ductless, zoned control</text>

  <rect x="24" y="72" width="312" height="44" rx="6" fill={C.white} stroke={C.border} />
  <text x="40" y="92" fill={C.muted} font-family={FONT} font-size="10">Installed cost</text>
  <text x="40" y="108" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">$3,000–$5,000 per zone</text>

  <rect x="24" y="124" width="312" height="44" rx="6" fill={C.white} stroke={C.border} />
  <text x="40" y="144" fill={C.muted} font-family={FONT} font-size="10">Typical SEER</text>
  <text x="40" y="160" fill={C.primary} font-family={FONT} font-size="11" font-weight="700">18–25+</text>

  <rect x="24" y="176" width="312" height="44" rx="6" fill={C.white} stroke={C.border} />
  <text x="40" y="196" fill={C.muted} font-family={FONT} font-size="10">Ductwork</text>
  <text x="40" y="212" fill={C.green} font-family={FONT} font-size="11" font-weight="600">Not required</text>

  <rect x="24" y="228" width="312" height="44" rx="6" fill={C.white} stroke={C.border} />
  <text x="40" y="248" fill={C.muted} font-family={FONT} font-size="10">Zoned control</text>
  <text x="40" y="264" fill={C.green} font-family={FONT} font-size="11" font-weight="600">Yes — each head independent</text>

  <rect x="24" y="280" width="312" height="44" rx="6" fill={C.white} stroke={C.border} />
  <text x="40" y="300" fill={C.muted} font-family={FONT} font-size="10">Heating</text>
  <text x="40" y="316" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Heat pump (down to 5–15°F)</text>

  <rect x="368" y="8" width="344" height="324" rx="12" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="384" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Central Air</text>
  <text x="384" y="56" fill={C.muted} font-family={FONT} font-size="11">Ducted, whole-house</text>

  <rect x="384" y="72" width="312" height="44" rx="6" fill={C.white} stroke={C.border} />
  <text x="400" y="92" fill={C.muted} font-family={FONT} font-size="10">Installed cost</text>
  <text x="400" y="108" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">$5,000–$12,000 whole house</text>

  <rect x="384" y="124" width="312" height="44" rx="6" fill={C.white} stroke={C.border} />
  <text x="400" y="144" fill={C.muted} font-family={FONT} font-size="10">Typical SEER</text>
  <text x="400" y="160" fill={C.blue} font-family={FONT} font-size="11" font-weight="700">13–18</text>

  <rect x="384" y="176" width="312" height="44" rx="6" fill={C.white} stroke={C.border} />
  <text x="400" y="196" fill={C.muted} font-family={FONT} font-size="10">Ductwork</text>
  <text x="400" y="212" fill={C.orange} font-family={FONT} font-size="11" font-weight="600">Required</text>

  <rect x="384" y="228" width="312" height="44" rx="6" fill={C.white} stroke={C.border} />
  <text x="400" y="248" fill={C.muted} font-family={FONT} font-size="10">Zoned control</text>
  <text x="400" y="264" fill={C.muted} font-family={FONT} font-size="11">Single thermostat (standard)</text>

  <rect x="384" y="280" width="312" height="44" rx="6" fill={C.white} stroke={C.border} />
  <text x="400" y="300" fill={C.muted} font-family={FONT} font-size="10">Heating</text>
  <text x="400" y="316" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Separate furnace needed</text>
</svg>
