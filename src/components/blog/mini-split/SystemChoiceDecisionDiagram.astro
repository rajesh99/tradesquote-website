---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 360" fill="none" aria-hidden="true">
  <title>When to choose mini-split vs central air</title>
  <desc>
    Decision guide: mini-split wins for additions, garages, historic homes, single-room cooling, and
    leaky ducts. Central air wins for new construction, filtration, sealed ducts, and simplicity.
  </desc>

  <rect x="8" y="8" width="704" height="344" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="360" y="36" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Which system fits your home?</text>

  <!-- Central air wins column -->
  <rect x="24" y="56" width="328" height="32" rx="6" fill={C.blue} />
  <text x="188" y="77" text-anchor="middle" fill={C.white} font-family={FONT} font-size="12" font-weight="700">Central air wins</text>

  <rect x="24" y="100" width="328" height="56" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1" />
  <text x="40" y="122" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">New construction</text>
  <text x="40" y="140" fill={C.muted} font-family={FONT} font-size="10">Ducts designed in · $5–8K vs $12–18K multi-zone</text>

  <rect x="24" y="168" width="328" height="56" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1" />
  <text x="40" y="190" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Whole-house air filtration</text>
  <text x="40" y="208" fill={C.muted} font-family={FONT} font-size="10">MERV 11–13 · UV-C · ERV/HRV integration</text>

  <rect x="24" y="236" width="328" height="56" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1" />
  <text x="40" y="258" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Existing sealed ductwork</text>
  <text x="40" y="276" fill={C.muted} font-family={FONT} font-size="10">Low blower-door leakage · infrastructure paid for</text>

  <rect x="24" y="304" width="328" height="40" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1" />
  <text x="40" y="330" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Single-thermostat simplicity</text>

  <!-- Mini-split wins column -->
  <rect x="368" y="56" width="328" height="32" rx="6" fill={C.primary} />
  <text x="532" y="77" text-anchor="middle" fill={C.white} font-family={FONT} font-size="12" font-weight="700">Mini-split wins</text>

  <rect x="368" y="100" width="328" height="56" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="384" y="122" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Room additions &amp; sunrooms</text>
  <text x="384" y="140" fill={C.muted} font-family={FONT} font-size="10">Avoid $1,500–$3,000 duct extension</text>

  <rect x="368" y="168" width="328" height="56" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="384" y="190" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Garages &amp; detached structures</text>
  <text x="384" y="208" fill={C.muted} font-family={FONT} font-size="10">One line set through the wall</text>

  <rect x="368" y="236" width="328" height="56" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="384" y="258" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Historic homes without ducts</text>
  <text x="384" y="276" fill={C.muted} font-family={FONT} font-size="10">Duct install $8–15K · no structural mods</text>

  <rect x="368" y="304" width="328" height="40" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="384" y="322" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Old leaky ducts · single hot room</text>
</svg>
