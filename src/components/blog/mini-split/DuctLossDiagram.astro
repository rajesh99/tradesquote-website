---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Central air duct loss vs ductless mini-split efficiency</title>
  <desc>
    Central air loses 20–30% of conditioned air through duct leakage, reducing effective SEER from 14
    to 10–11. Mini-splits deliver 100% of output directly to the room.
  </desc>

  <!-- Central air row -->
  <rect x="8" y="8" width="704" height="140" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="32" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Central air — SEER 14 rated</text>
  <text x="24" y="50" fill={C.muted} font-family={FONT} font-size="10">3-ton · 1,500 hrs · $0.14/kWh → $540/yr at rated SEER</text>

  <rect x="32" y="68" width="56" height="40" rx="5" fill={C.dark} />
  <text x="60" y="92" text-anchor="middle" fill={C.white} font-family={FONT} font-size="8" font-weight="600">Outdoor</text>
  <path d="M96 88 H120" stroke={C.blue} stroke-width="2" marker-end="url(#ms-arr-b)" />

  <rect x="124" y="60" width="200" height="56" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" stroke-dasharray="5 3" />
  <text x="224" y="82" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">Duct system</text>
  <text x="224" y="100" text-anchor="middle" fill={C.red} font-family={FONT} font-size="10" font-weight="700">20–30% loss</text>
  <path d="M332 88 H356" stroke={C.blue} stroke-width="2" marker-end="url(#ms-arr-b)" />

  <rect x="360" y="68" width="56" height="40" rx="5" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="388" y="84" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="8" font-weight="600">Rooms</text>
  <text x="388" y="98" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="10" font-weight="700">70–80%</text>

  <rect x="440" y="64" width="256" height="72" rx="8" fill={C.redLight} stroke={C.red} stroke-width="1" />
  <text x="568" y="92" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">
    Effective SEER ≈ <tspan fill={C.red} font-weight="700">10–11</tspan>
  </text>
  <text x="568" y="112" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Real-world cost gap: +$280–$340/yr</text>

  <!-- Mini-split row -->
  <rect x="8" y="164" width="704" height="148" rx="12" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="24" y="188" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Mini-split — SEER 22</text>
  <text x="24" y="206" fill={C.muted} font-family={FONT} font-size="10">3-ton equivalent · 1,500 hrs · $0.14/kWh → $344/yr</text>

  <rect x="32" y="224" width="56" height="40" rx="5" fill={C.dark} />
  <text x="60" y="248" text-anchor="middle" fill={C.white} font-family={FONT} font-size="8" font-weight="600">Outdoor</text>
  <path d="M96 244 H120" stroke={C.primary} stroke-width="2" marker-end="url(#ms-arr-p)" />

  <rect x="124" y="232" width="48" height="24" rx="4" fill={C.dark} />
  <text x="148" y="248" text-anchor="middle" fill={C.white} font-family={FONT} font-size="8" font-weight="600">Line set</text>
  <path d="M180 244 H204" stroke={C.primary} stroke-width="2" marker-end="url(#ms-arr-p)" />

  <rect x="208" y="224" width="56" height="40" rx="5" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="236" y="240" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="8" font-weight="600">Indoor</text>
  <text x="236" y="254" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="10" font-weight="700">100%</text>

  <rect x="288" y="220" width="200" height="48" rx="8" fill={C.white} stroke={C.border} />
  <text x="388" y="242" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">No ducts — every BTU reaches the room</text>
  <text x="388" y="258" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Rated SEER = real-world efficiency</text>

  <rect x="512" y="220" width="184" height="48" rx="8" fill={C.greenLight} stroke={C.green} stroke-width="1" />
  <text x="604" y="242" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">
    Saves <tspan fill={C.green} font-weight="700">$196–$340/yr</tspan>
  </text>
  <text x="604" y="258" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">36% less electricity + zero duct loss</text>

  <defs>
    <marker id="ms-arr-b" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill={C.blue} /></marker>
    <marker id="ms-arr-p" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill={C.primary} /></marker>
  </defs>
</svg>
