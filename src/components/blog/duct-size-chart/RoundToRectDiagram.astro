---
import { C, FONT } from "../infographicTokens";

const pairs = [
  ['8" round', "≈ 8 × 6 rect"],
  ['10" round', "≈ 12 × 8 rect"],
  ['12" round', "≈ 14 × 10 rect"],
  ['14" round', "≈ 18 × 12 rect"],
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>Converting round duct to a rectangular equivalent</title>
  <desc>
    Rectangular ducts are matched to round by equivalent diameter, not equal area, because a flatter duct
    has more friction. The equivalent-diameter formula and common pairings: 8 inch round is about 8 by 6
    rectangular, 10 inch round about 12 by 8, 12 inch round about 14 by 10.
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Round → rectangular equivalent</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Match by equivalent diameter, not equal area — a flatter duct fights more friction</text>

  <!-- Formula -->
  <rect x="40" y="76" width="640" height="46" rx="9" fill={C.white} stroke={C.blue} stroke-width="1.3" />
  <text x="360" y="105" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">De = 1.30 × (a·b)^0.625 ÷ (a+b)^0.25</text>

  {pairs.map((p, i) => {
    const x = 40 + (i % 2) * 320;
    const y = 138 + Math.floor(i / 2) * 64;
    return (
      <g>
        <rect x={x} y={y} width="300" height="52" rx="9" fill={C.primaryLight} stroke={C.primary} stroke-width="1.2" />
        <text x={x + 16} y={y + 32} fill={C.dark} font-family={FONT} font-size="13" font-weight="800">{p[0]}</text>
        <text x={x + 284} y={y + 32} text-anchor="end" fill={C.primary} font-family={FONT} font-size="13" font-weight="700">{p[1]}</text>
      </g>
    );
  })}
</svg>
