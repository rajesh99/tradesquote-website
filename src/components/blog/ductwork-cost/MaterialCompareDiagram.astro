---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Duct material cost comparison</title>
  <desc>Three columns comparing flexible duct, sheet metal, and fiberglass ductboard on rough installed cost per linear foot with a one-line note on each.</desc>

  <text x="360" y="34" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Duct material vs. installed $/ft</text>

  <!-- Card 1: Flexible duct -->
  <rect x="40" y="58" width="200" height="226" rx="12" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="140" y="88" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">Flexible duct</text>
  <text x="140" y="128" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="26" font-weight="800">$8&#8211;$15</text>
  <text x="140" y="148" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">per linear foot, installed</text>
  <text x="140" y="186" text-anchor="middle" fill={C.green} font-family={FONT} font-size="11" font-weight="700">+ Cheapest, fast to install</text>
  <text x="140" y="206" text-anchor="middle" fill={C.green} font-family={FONT} font-size="11" font-weight="700">+ Good in tight attics</text>
  <text x="140" y="236" text-anchor="middle" fill={C.red} font-family={FONT} font-size="11" font-weight="700">&#8722; Kinks &amp; sags cut airflow</text>
  <text x="140" y="256" text-anchor="middle" fill={C.red} font-family={FONT} font-size="11" font-weight="700">&#8722; Shorter service life</text>

  <!-- Card 2: Sheet metal -->
  <rect x="260" y="58" width="200" height="226" rx="12" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="360" y="88" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">Sheet metal</text>
  <text x="360" y="128" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="26" font-weight="800">$15&#8211;$30</text>
  <text x="360" y="148" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">per linear foot, installed</text>
  <text x="360" y="186" text-anchor="middle" fill={C.green} font-family={FONT} font-size="11" font-weight="700">+ Most durable, long life</text>
  <text x="360" y="206" text-anchor="middle" fill={C.green} font-family={FONT} font-size="11" font-weight="700">+ Smooth, best airflow</text>
  <text x="360" y="236" text-anchor="middle" fill={C.red} font-family={FONT} font-size="11" font-weight="700">&#8722; Highest labor cost</text>
  <text x="360" y="256" text-anchor="middle" fill={C.red} font-family={FONT} font-size="11" font-weight="700">&#8722; Needs sealing &amp; wrap</text>

  <!-- Card 3: Fiberglass ductboard -->
  <rect x="480" y="58" width="200" height="226" rx="12" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="580" y="88" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">Fiberglass ductboard</text>
  <text x="580" y="128" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="26" font-weight="800">$10&#8211;$20</text>
  <text x="580" y="148" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">per linear foot, installed</text>
  <text x="580" y="186" text-anchor="middle" fill={C.green} font-family={FONT} font-size="11" font-weight="700">+ Built-in insulation</text>
  <text x="580" y="206" text-anchor="middle" fill={C.green} font-family={FONT} font-size="11" font-weight="700">+ Quiet operation</text>
  <text x="580" y="236" text-anchor="middle" fill={C.red} font-family={FONT} font-size="11" font-weight="700">&#8722; Can harbor mold if wet</text>
  <text x="580" y="256" text-anchor="middle" fill={C.red} font-family={FONT} font-size="11" font-weight="700">&#8722; Harder to clean</text>

  <text x="360" y="306" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Installed $/ft includes material and labor; figures are typical 2026 US ranges, not quotes.</text>
</svg>
