---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Where ductwork replacement money goes</title>
  <desc>A stacked bar splitting a typical whole-house ductwork job into labor, materials, removal and disposal, and registers and permits, with a total range.</desc>

  <text x="360" y="34" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Where a ductwork job&#8217;s cost goes</text>

  <!-- Stacked horizontal bar: total width 600 mapped from x=60 to x=660 -->
  <!-- Labor 45%, Materials 30%, Removal 15%, Registers/permits 10% -->
  <rect x="60" y="78" width="270" height="48" fill={C.primary} />
  <rect x="330" y="78" width="180" height="48" fill={C.blue} />
  <rect x="510" y="78" width="90" height="48" fill={C.orange} />
  <rect x="600" y="78" width="60" height="48" fill={C.muted} />
  <rect x="60" y="78" width="600" height="48" rx="6" fill="none" stroke={C.border} stroke-width="1" />

  <text x="195" y="107" text-anchor="middle" fill={C.white} font-family={FONT} font-size="13" font-weight="800">Labor 45%</text>
  <text x="420" y="107" text-anchor="middle" fill={C.white} font-family={FONT} font-size="13" font-weight="800">Materials 30%</text>
  <text x="555" y="107" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="700">Removal 15%</text>
  <text x="630" y="107" text-anchor="middle" fill={C.white} font-family={FONT} font-size="10" font-weight="700">10%</text>

  <!-- Legend rows -->
  <g font-family={FONT}>
    <rect x="60" y="156" width="14" height="14" rx="3" fill={C.primary} />
    <text x="82" y="168" fill={C.dark} font-size="12" font-weight="600">Labor &#8212; install crew hours, the biggest single line</text>

    <rect x="60" y="182" width="14" height="14" rx="3" fill={C.blue} />
    <text x="82" y="194" fill={C.dark} font-size="12" font-weight="600">Materials &#8212; duct, fittings, plenum, insulation, sealant</text>

    <rect x="60" y="208" width="14" height="14" rx="3" fill={C.orange} />
    <text x="82" y="220" fill={C.dark} font-size="12" font-weight="600">Removal &#038; disposal &#8212; tearing out the old duct runs</text>

    <rect x="60" y="234" width="14" height="14" rx="3" fill={C.muted} />
    <text x="82" y="246" fill={C.dark} font-size="12" font-weight="600">Registers, returns &#038; permits</text>
  </g>

  <!-- Total range badge -->
  <rect x="60" y="266" width="600" height="38" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="360" y="290" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">Typical whole-house total: ~$1,400&#8211;$5,600 (most homes ~$3,000&#8211;$4,000)</text>
</svg>
