---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Installed furnace cost by efficiency</title>
  <desc>Horizontal bars comparing typical installed price ranges for an 80 percent AFUE furnace, a 90 to 96 percent condensing furnace, and a modulating high-efficiency furnace.</desc>

  <text x="360" y="30" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Installed furnace cost by efficiency</text>

  <!-- Axis hint -->
  <text x="120" y="58" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10.5" font-weight="600">$2k</text>
  <text x="290" y="58" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10.5" font-weight="600">$5k</text>
  <text x="460" y="58" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10.5" font-weight="600">$8k</text>
  <text x="630" y="58" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10.5" font-weight="600">$11k</text>

  <!-- Row 1: 80% AFUE -->
  <text x="40" y="104" fill={C.dark} font-family={FONT} font-size="12.5" font-weight="800">80% AFUE</text>
  <text x="40" y="120" fill={C.muted} font-family={FONT} font-size="10.5" font-weight="600">standard, vented gas</text>
  <rect x="120" y="86" width="170" height="34" rx="6" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="205" y="108" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="14" font-weight="800">$3,000&#8211;$5,500</text>

  <!-- Row 2: 90-96% condensing -->
  <text x="40" y="170" fill={C.dark} font-family={FONT} font-size="12.5" font-weight="800">90&#8211;96% AFUE</text>
  <text x="40" y="186" fill={C.muted} font-family={FONT} font-size="10.5" font-weight="600">condensing, PVC vent</text>
  <rect x="120" y="152" width="290" height="34" rx="6" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="265" y="174" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="14" font-weight="800">$4,500&#8211;$7,500</text>

  <!-- Row 3: modulating high-eff -->
  <text x="40" y="236" fill={C.dark} font-family={FONT} font-size="12.5" font-weight="800">Modulating</text>
  <text x="40" y="252" fill={C.muted} font-family={FONT} font-size="10.5" font-weight="600">97&#8211;98%, variable speed</text>
  <rect x="120" y="218" width="430" height="34" rx="6" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="335" y="240" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="14" font-weight="800">$6,000&#8211;$10,000+</text>

  <text x="360" y="300" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Typical 2026 US installed ranges including labor &#8212; estimates, not quotes.</text>
</svg>
