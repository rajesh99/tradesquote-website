---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>What drives furnace replacement cost</title>
  <desc>Seven factors that move the installed price of a furnace: size in BTU, AFUE efficiency, staging and blower type, venting changes, fuel type, removal and disposal, and permits.</desc>

  <text x="360" y="30" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">What moves your furnace cost</text>

  <!-- Center node -->
  <rect x="290" y="138" width="140" height="44" rx="22" fill={C.primary} />
  <text x="360" y="160" text-anchor="middle" fill={C.white} font-family={FONT} font-size="13" font-weight="800">Installed</text>
  <text x="360" y="176" text-anchor="middle" fill={C.white} font-family={FONT} font-size="13" font-weight="800">price</text>

  <!-- Top row factors -->
  <rect x="40" y="56" width="190" height="48" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="135" y="78" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">Furnace size (BTU)</text>
  <text x="135" y="95" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10" font-weight="600">from a load calc</text>

  <rect x="265" y="56" width="190" height="48" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="360" y="78" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">AFUE efficiency</text>
  <text x="360" y="95" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10" font-weight="600">80% vs condensing</text>

  <rect x="490" y="56" width="190" height="48" rx="10" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="585" y="78" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">Staging &amp; blower</text>
  <text x="585" y="95" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10" font-weight="600">1-stage to variable</text>

  <!-- Side factors -->
  <rect x="40" y="138" width="190" height="44" rx="10" fill={C.panelBg} stroke={C.border} stroke-width="1.5" />
  <text x="135" y="158" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">Fuel type</text>
  <text x="135" y="174" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10" font-weight="600">gas / electric / oil</text>

  <rect x="490" y="138" width="190" height="44" rx="10" fill={C.panelBg} stroke={C.border} stroke-width="1.5" />
  <text x="585" y="158" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">Venting changes</text>
  <text x="585" y="174" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10" font-weight="600">PVC + condensate</text>

  <!-- Bottom row factors -->
  <rect x="120" y="216" width="200" height="48" rx="10" fill={C.panelBg} stroke={C.border} stroke-width="1.5" />
  <text x="220" y="238" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">Removal &amp; disposal</text>
  <text x="220" y="255" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10" font-weight="600">old unit haul-away</text>

  <rect x="400" y="216" width="200" height="48" rx="10" fill={C.panelBg} stroke={C.border} stroke-width="1.5" />
  <text x="500" y="238" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">Permits &amp; region</text>
  <text x="500" y="255" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10" font-weight="600">local rates &amp; code</text>

  <!-- Connectors to center -->
  <line x1="135" y1="104" x2="300" y2="142" stroke={C.border} stroke-width="1.5" />
  <line x1="360" y1="104" x2="360" y2="138" stroke={C.border} stroke-width="1.5" />
  <line x1="585" y1="104" x2="420" y2="142" stroke={C.border} stroke-width="1.5" />
  <line x1="230" y1="160" x2="290" y2="160" stroke={C.border} stroke-width="1.5" />
  <line x1="490" y1="160" x2="430" y2="160" stroke={C.border} stroke-width="1.5" />
  <line x1="220" y1="216" x2="310" y2="180" stroke={C.border} stroke-width="1.5" />
  <line x1="500" y1="216" x2="410" y2="180" stroke={C.border} stroke-width="1.5" />

  <text x="360" y="304" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Two homes the same size can quote thousands apart on these factors.</text>
</svg>
