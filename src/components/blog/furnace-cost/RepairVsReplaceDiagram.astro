---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Repair or replace your furnace</title>
  <desc>A decision flow that checks furnace age, a cracked heat exchanger, repeated repairs, and rising bills to decide whether a repair is enough or replacement is the better call.</desc>

  <text x="360" y="30" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Repair, or replace your furnace?</text>

  <!-- Decision 1: age -->
  <polygon points="120,120 200,86 280,120 200,154" fill={C.panelBg} stroke={C.border} stroke-width="1.5" />
  <text x="200" y="112" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Furnace under</text>
  <text x="200" y="128" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">15 yrs old?</text>

  <!-- Yes -> repair -->
  <line x1="280" y1="120" x2="330" y2="120" stroke={C.border} stroke-width="2" />
  <text x="305" y="112" text-anchor="middle" fill={C.green} font-family={FONT} font-size="11" font-weight="700">Yes</text>
  <rect x="330" y="92" width="240" height="56" rx="10" fill={C.greenLight} stroke={C.green} stroke-width="1.5" />
  <text x="450" y="114" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">Repair is usually best</text>
  <text x="450" y="134" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10.5" font-weight="600">If the fix costs well under a new unit</text>

  <!-- No -> second check -->
  <line x1="200" y1="154" x2="200" y2="196" stroke={C.border} stroke-width="2" />
  <text x="214" y="178" fill={C.red} font-family={FONT} font-size="11" font-weight="700">No</text>

  <polygon points="120,230 200,196 280,230 200,264" fill={C.panelBg} stroke={C.border} stroke-width="1.5" />
  <text x="200" y="222" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10.5" font-weight="700">Cracked exchanger,</text>
  <text x="200" y="238" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10.5" font-weight="700">repeat repairs or</text>
  <text x="200" y="253" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10.5" font-weight="700">rising bills?</text>

  <!-- No (minor) -> targeted repair -->
  <line x1="280" y1="230" x2="330" y2="230" stroke={C.border} stroke-width="2" />
  <text x="305" y="222" text-anchor="middle" fill={C.green} font-family={FONT} font-size="11" font-weight="700">No</text>
  <rect x="330" y="202" width="240" height="56" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="450" y="224" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">Targeted repair OK</text>
  <text x="450" y="244" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10.5" font-weight="600">Fix the fault, plan ahead for end of life</text>

  <!-- Yes -> replace -->
  <line x1="200" y1="264" x2="200" y2="290" stroke={C.red} stroke-width="2" />
  <text x="214" y="284" fill={C.red} font-family={FONT} font-size="11" font-weight="700">Yes</text>
  <rect x="240" y="284" width="330" height="30" rx="8" fill={C.redLight} stroke={C.red} stroke-width="1.5" />
  <text x="405" y="304" text-anchor="middle" fill={C.red} font-family={FONT} font-size="12" font-weight="800">Replace &#8212; safer, more efficient, lower lifetime cost</text>
</svg>
