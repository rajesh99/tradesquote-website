---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Why 10% faster costs 33% more power</title>
  <desc>A 10 percent speed increase raises airflow 10 percent, static pressure 21 percent, and power 33 percent.</desc>

  <rect x="8" y="8" width="704" height="304" rx="12" fill={C.panelBg} stroke={C.border} />

  <text x="360" y="40" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Why 10% faster costs 33% more power</text>
  <text x="360" y="60" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Effect of a 1.10 speed ratio (+10% RPM)</text>

  {/* baseline axis */}
  <line x1="120" y1="250" x2="600" y2="250" stroke={C.border} stroke-width="1.5" />

  {[
    { label: "Airflow", pct: "+10%", h: 30, color: C.blue, x: 170, note: "× speed" },
    { label: "Static pressure", pct: "+21%", h: 63, color: C.orange, x: 340, note: "× speed²" },
    { label: "Power", pct: "+33%", h: 99, color: C.red, x: 510, note: "× speed³" },
  ].map((b) => (
    <g>
      <rect x={b.x - 36} y={250 - b.h} width="72" height={b.h} rx="4" fill={b.color} />
      <text x={b.x} y={250 - b.h - 10} text-anchor="middle" fill={b.color} font-family={FONT} font-size="15" font-weight="700">{b.pct}</text>
      <text x={b.x} y="270" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">{b.label}</text>
      <text x={b.x} y="286" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">{b.note}</text>
    </g>
  ))}

  <text x="360" y="306" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">A 10% speed bump: +10% air, +21% pressure, +33% power — power rises fastest.</text>
</svg>
