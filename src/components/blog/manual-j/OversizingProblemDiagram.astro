---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>Why oversizing backfires</title>
  <desc>
    A right-sized unit runs long steady cycles that remove humidity, while an oversized unit
    short-cycles — cooling the air fast then shutting off before pulling moisture out, leaving
    the home cold and clammy with more wear and higher bills.
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Why oversizing backfires</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Run length, not raw capacity, controls comfort</text>

  <!-- Right-sized panel -->
  <rect x="32" y="76" width="320" height="196" rx="10" fill={C.greenLight} stroke={C.green} stroke-width="1.5" />
  <text x="48" y="100" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Right-sized unit</text>
  <text x="48" y="118" fill={C.muted} font-family={FONT} font-size="10">Long, steady run cycle</text>

  <!-- Right-sized cycle: one long run -->
  <line x1="56" y1="180" x2="328" y2="180" stroke={C.border} stroke-width="1" />
  <path d="M56 180 L96 180 L116 140 L268 140 L288 180 L328 180"
        fill="none" stroke={C.green} stroke-width="2.5" stroke-linejoin="round" />
  <text x="192" y="206" text-anchor="middle" fill={C.green} font-family={FONT} font-size="10" font-weight="600">one long cycle</text>
  <text x="48" y="234" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">Removes humidity</text>
  <text x="48" y="252" fill={C.muted} font-family={FONT} font-size="10">Even temps, quieter, longer life</text>

  <!-- Oversized panel -->
  <rect x="368" y="76" width="320" height="196" rx="10" fill={C.redLight} stroke={C.red} stroke-width="1.5" />
  <text x="384" y="100" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Oversized unit</text>
  <text x="384" y="118" fill={C.muted} font-family={FONT} font-size="10">Short cycles on and off</text>

  <!-- Oversized cycle: several short spikes -->
  <line x1="392" y1="180" x2="664" y2="180" stroke={C.border} stroke-width="1" />
  <path d="M392 180 L404 180 L414 144 L426 144 L436 180
           L456 180 L466 144 L478 144 L488 180
           L508 180 L518 144 L530 144 L540 180
           L560 180 L570 144 L582 144 L592 180 L664 180"
        fill="none" stroke={C.red} stroke-width="2.5" stroke-linejoin="round" />
  <text x="528" y="206" text-anchor="middle" fill={C.red} font-family={FONT} font-size="10" font-weight="600">short cycling</text>
  <text x="384" y="234" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">Cold but clammy</text>
  <text x="384" y="252" fill={C.muted} font-family={FONT} font-size="10">More wear, uneven temps, higher bills</text>
</svg>
