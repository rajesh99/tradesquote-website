---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>What Manual J accounts for</title>
  <desc>
    A central Manual J load node connects to six building inputs: square footage and volume,
    insulation R-value, windows (area, orientation, U-factor), air infiltration (ACH),
    occupants and internal gains, and local design temperatures.
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">What Manual J accounts for</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">The calculation is built from the actual building, not a square-footage shortcut</text>

  <!-- Central node -->
  <rect x="290" y="78" width="140" height="56" rx="12" fill={C.primaryLight} stroke={C.primary} stroke-width="2" />
  <text x="360" y="103" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Manual J load</text>
  <text x="360" y="121" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">heating &amp; cooling</text>

  <!-- Connectors -->
  <g stroke={C.border} stroke-width="1.5">
    <path d="M290 106 H150 V172" />
    <path d="M290 106 H360 V172" />
    <path d="M430 106 H570 V172" />
    <path d="M150 224 V232" />
    <path d="M360 224 V232" />
    <path d="M570 224 V232" />
  </g>

  <!-- Row 1 inputs -->
  <rect x="32" y="172" width="200" height="52" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1.2" />
  <text x="48" y="194" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Square footage &amp; volume</text>
  <text x="48" y="211" fill={C.muted} font-family={FONT} font-size="10">floor area × ceiling height</text>

  <rect x="260" y="172" width="200" height="52" rx="8" fill={C.greenLight} stroke={C.green} stroke-width="1.2" />
  <text x="276" y="194" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Insulation R-value</text>
  <text x="276" y="211" fill={C.muted} font-family={FONT} font-size="10">walls, ceiling, floor</text>

  <rect x="488" y="172" width="200" height="52" rx="8" fill={C.orangeLight} stroke={C.orange} stroke-width="1.2" />
  <text x="504" y="194" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Windows</text>
  <text x="504" y="211" fill={C.muted} font-family={FONT} font-size="10">area, orientation, U-factor</text>

  <!-- Row 2 inputs -->
  <rect x="32" y="232" width="200" height="48" rx="8" fill={C.white} stroke={C.border} stroke-width="1.2" />
  <text x="48" y="252" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Air infiltration (ACH)</text>
  <text x="48" y="269" fill={C.muted} font-family={FONT} font-size="10">how tight the home is</text>

  <rect x="260" y="232" width="200" height="48" rx="8" fill={C.white} stroke={C.border} stroke-width="1.2" />
  <text x="276" y="252" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Occupants &amp; internal gains</text>
  <text x="276" y="269" fill={C.muted} font-family={FONT} font-size="10">people, appliances, lighting</text>

  <rect x="488" y="232" width="200" height="48" rx="8" fill={C.white} stroke={C.border} stroke-width="1.2" />
  <text x="504" y="252" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">Local design temps</text>
  <text x="504" y="269" fill={C.muted} font-family={FONT} font-size="10">99% heating / 1% cooling</text>
</svg>
