---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>Manual J vs rule of thumb</title>
  <desc>
    Rule of thumb is fast, free, and a ballpark that ignores the building and tends to oversize,
    fine for budgeting. Manual J is room-by-room, accounts for the real building, is required by
    code, and produces a right-sized result but needs data and software.
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Manual J vs rule of thumb</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Different tools for different jobs</text>

  <!-- Rule of thumb column -->
  <rect x="32" y="76" width="320" height="196" rx="10" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="48" y="100" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Rule of thumb</text>
  <text x="48" y="118" fill={C.muted} font-family={FONT} font-size="10">~400–600 sq ft per ton</text>

  <g font-family={FONT} font-size="11" fill={C.dark}>
    <circle cx="54" cy="140" r="2.5" fill={C.orange} /><text x="66" y="144">Fast and free</text>
    <circle cx="54" cy="164" r="2.5" fill={C.orange} /><text x="66" y="168">Ballpark estimate</text>
    <circle cx="54" cy="188" r="2.5" fill={C.orange} /><text x="66" y="192">Ignores the building</text>
    <circle cx="54" cy="212" r="2.5" fill={C.orange} /><text x="66" y="216">Tends to oversize</text>
    <circle cx="54" cy="236" r="2.5" fill={C.orange} /><text x="66" y="240">OK for budgeting</text>
  </g>

  <!-- Manual J column -->
  <rect x="368" y="76" width="320" height="196" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="384" y="100" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Manual J</text>
  <text x="384" y="118" fill={C.muted} font-family={FONT} font-size="10">ANSI/ACCA load calculation</text>

  <g font-family={FONT} font-size="11" fill={C.dark}>
    <circle cx="390" cy="140" r="2.5" fill={C.primary} /><text x="402" y="144">Room-by-room</text>
    <circle cx="390" cy="164" r="2.5" fill={C.primary} /><text x="402" y="168">Accounts for the real building</text>
    <circle cx="390" cy="188" r="2.5" fill={C.primary} /><text x="402" y="192">Required by code for permits</text>
    <circle cx="390" cy="212" r="2.5" fill={C.primary} /><text x="402" y="216">Right-sized result</text>
    <circle cx="390" cy="236" r="2.5" fill={C.primary} /><text x="402" y="240">Needs data &amp; software</text>
  </g>
</svg>
