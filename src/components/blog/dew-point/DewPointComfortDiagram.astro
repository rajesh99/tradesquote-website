---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>How dew point feels</title>
  <desc>
    A horizontal dew point comfort scale: below 55&#176;F is dry and comfortable, 55 to 60&#176;F becomes
    sticky, 60 to 65&#176;F is humid and muggy, 65 to 70&#176;F is oppressive, and above 70&#176;F is miserable.
    Comfort tracks dew point, not just temperature.
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">How dew point feels</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Indoor or outdoor dew point and perceived comfort</text>

  <!-- Bands -->
  <!-- comfortable -->
  <rect x="32" y="92" width="128" height="96" rx="8" fill={C.greenLight} stroke={C.green} stroke-width="1.5" />
  <text x="96" y="120" text-anchor="middle" fill={C.green} font-family={FONT} font-size="14" font-weight="700">&lt;55&#176;F</text>
  <text x="96" y="148" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Comfortable</text>
  <text x="96" y="166" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">dry, pleasant</text>

  <!-- sticky -->
  <rect x="168" y="92" width="128" height="96" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="232" y="120" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="14" font-weight="700">55&#8211;60&#176;F</text>
  <text x="232" y="148" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Sticky</text>
  <text x="232" y="166" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">becoming noticeable</text>

  <!-- humid -->
  <rect x="304" y="92" width="128" height="96" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="368" y="120" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="14" font-weight="700">60&#8211;65&#176;F</text>
  <text x="368" y="148" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Humid</text>
  <text x="368" y="166" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">noticeably muggy</text>

  <!-- oppressive -->
  <rect x="440" y="92" width="128" height="96" rx="8" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="504" y="120" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="14" font-weight="700">65&#8211;70&#176;F</text>
  <text x="504" y="148" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Oppressive</text>
  <text x="504" y="166" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">heavy, sweaty air</text>

  <!-- miserable -->
  <rect x="576" y="92" width="112" height="96" rx="8" fill={C.redLight} stroke={C.red} stroke-width="1.5" />
  <text x="632" y="120" text-anchor="middle" fill={C.red} font-family={FONT} font-size="14" font-weight="700">&gt;70&#176;F</text>
  <text x="632" y="148" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Miserable</text>
  <text x="632" y="166" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">tropical, draining</text>

  <!-- Gradient track -->
  <rect x="32" y="204" width="656" height="10" rx="5" fill="url(#dpf-grad)" />
  <text x="32" y="232" fill={C.muted} font-family={FONT} font-size="9">drier &#8594; more moisture in the air</text>

  <!-- Indoor target callout -->
  <rect x="32" y="248" width="656" height="32" rx="6" fill={C.white} stroke={C.border} />
  <text x="360" y="268" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">
    Indoor summer target: keep dew point comfortable &#8212; generally around <tspan fill={C.primary} font-weight="700">45&#8211;50% RH</tspan>
  </text>

  <defs>
    <linearGradient id="dpf-grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color={C.green} />
      <stop offset="35%" stop-color={C.primary} />
      <stop offset="55%" stop-color={C.blue} />
      <stop offset="78%" stop-color={C.orange} />
      <stop offset="100%" stop-color={C.red} />
    </linearGradient>
  </defs>
</svg>
