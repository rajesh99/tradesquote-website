---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Why ducts sweat in attics</title>
  <desc>
    A cold supply duct with a 55&#176;F surface runs through a hot humid attic at 90&#176;F with a 72&#176;F dew
    point. A bare duct surface sits below the dew point and sweats, dripping water and growing mold.
    An insulated duct with a vapor barrier keeps the exterior surface above the dew point and stays dry.
  </desc>

  <rect x="8" y="8" width="704" height="304" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Why ducts sweat in attics</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Hot humid attic: 90&#176;F air, dew point ~72&#176;F &#183; cold supply duct surface ~55&#176;F</text>

  <!-- Bare duct (sweats) -->
  <rect x="32" y="76" width="320" height="216" rx="10" fill={C.redLight} stroke={C.red} stroke-width="1.5" />
  <text x="48" y="102" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Bare duct</text>

  <rect x="64" y="120" width="200" height="56" rx="8" fill={C.white} stroke={C.muted} stroke-width="1.5" />
  <text x="164" y="143" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">Surface 55&#176;F</text>
  <text x="164" y="161" text-anchor="middle" fill={C.red} font-family={FONT} font-size="10" font-weight="700">below 72&#176;F dew point</text>

  <!-- Drips -->
  <g fill={C.blue} opacity="0.8">
    <path d="M96 184 q5 9 0 13 q-5 -4 0 -13 Z" />
    <path d="M132 188 q5 9 0 13 q-5 -4 0 -13 Z" />
    <path d="M168 184 q5 9 0 13 q-5 -4 0 -13 Z" />
    <path d="M204 188 q5 9 0 13 q-5 -4 0 -13 Z" />
    <path d="M232 184 q5 9 0 13 q-5 -4 0 -13 Z" />
  </g>

  <rect x="48" y="216" width="288" height="60" rx="8" fill={C.white} stroke={C.red} />
  <text x="64" y="238" fill={C.red} font-family={FONT} font-size="11" font-weight="700">Condensation &#8594; drips</text>
  <text x="64" y="256" fill={C.muted} font-family={FONT} font-size="10">Stains ceilings, soaks insulation,</text>
  <text x="64" y="270" fill={C.muted} font-family={FONT} font-size="10">rots framing, grows mold</text>

  <!-- Insulated duct (dry) -->
  <rect x="368" y="76" width="320" height="216" rx="10" fill={C.greenLight} stroke={C.green} stroke-width="1.5" />
  <text x="384" y="102" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Insulated + vapor barrier</text>

  <rect x="400" y="120" width="256" height="56" rx="8" fill={C.white} stroke={C.green} stroke-width="1.5" />
  <rect x="400" y="120" width="256" height="14" rx="7" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="528" y="131" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="8" font-weight="700">vapor barrier faces warm/humid side</text>
  <text x="528" y="155" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10" font-weight="600">Exterior surface ~85&#176;F</text>
  <text x="528" y="170" text-anchor="middle" fill={C.green} font-family={FONT} font-size="10" font-weight="700">above 72&#176;F dew point</text>

  <rect x="384" y="216" width="288" height="60" rx="8" fill={C.white} stroke={C.green} />
  <text x="400" y="238" fill={C.green} font-family={FONT} font-size="11" font-weight="700">No condensation &#8594; dry</text>
  <text x="400" y="256" fill={C.muted} font-family={FONT} font-size="10">Insulation keeps the outer surface</text>
  <text x="400" y="270" fill={C.muted} font-family={FONT} font-size="10">warmer than the ambient dew point</text>
</svg>
