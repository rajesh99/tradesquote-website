---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Square-foot rule vs a real load calculation</title>
  <desc>
    The same 1,800 square foot home: a 600-square-foot-per-ton rule of thumb returns 3 tons, while a
    detailed load calculation that accounts for insulation, windows, and air-tightness returns 2.5 tons.
    Oversizing causes short cycling and poor humidity control.
  </desc>

  <rect x="8" y="8" width="704" height="304" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Same house, two answers</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">An 1,800 sq ft home — the shortcut and the calculation disagree</text>

  <!-- Rule of thumb bar -->
  <text x="40" y="92" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Square-foot rule (600 sq ft/ton)</text>
  <rect x="40" y="104" width="540" height="40" rx="8" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="56" y="129" fill={C.orange} font-family={FONT} font-size="16" font-weight="800">3.0 tons</text>
  <text x="200" y="129" fill={C.muted} font-family={FONT} font-size="10.5">ignores insulation, glazing, climate, leakage</text>

  <!-- Load calc bar -->
  <text x="40" y="180" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Detailed load calculation</text>
  <rect x="40" y="192" width="450" height="40" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="56" y="217" fill={C.primary} font-family={FONT} font-size="16" font-weight="800">2.5 tons</text>
  <text x="200" y="217" fill={C.muted} font-family={FONT} font-size="10.5">reads the actual building, surface by surface</text>

  <!-- Caption -->
  <rect x="40" y="256" width="640" height="40" rx="8" fill={C.white} stroke={C.border} />
  <text x="56" y="281" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">Half a ton of oversizing is enough to cause short cycling and a cold, clammy home.</text>
</svg>
