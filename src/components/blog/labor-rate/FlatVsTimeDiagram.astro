---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>Flat-rate pricing vs time and materials</title>
  <desc>
    Flat-rate pricing charges a fixed price per task from a price book, rewarding efficient techs and
    giving customers certainty. Time and materials bills the hours actually worked plus parts, which
    suits open-ended diagnostic and install work.
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Flat-rate vs time &amp; materials</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Both rely on the same loaded labor rate underneath</text>

  <!-- Flat rate -->
  <rect x="24" y="76" width="320" height="200" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="40" y="100" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Flat rate</text>
  <text x="40" y="118" fill={C.muted} font-family={FONT} font-size="10">Fixed price per task from a price book</text>
  <text x="40" y="146" fill={C.green} font-family={FONT} font-size="11" font-weight="700">+ Price certainty for the customer</text>
  <text x="40" y="168" fill={C.green} font-family={FONT} font-size="11" font-weight="700">+ Rewards fast, skilled techs</text>
  <text x="40" y="190" fill={C.green} font-family={FONT} font-size="11" font-weight="700">+ Easier to sell, no clock-watching</text>
  <text x="40" y="218" fill={C.red} font-family={FONT} font-size="11" font-weight="700">− Needs an accurate price book</text>
  <text x="40" y="240" fill={C.red} font-family={FONT} font-size="11" font-weight="700">− Risk on jobs that run long</text>
  <text x="40" y="264" fill={C.muted} font-family={FONT} font-size="10">Best for: repairs, tune-ups, defined installs</text>

  <!-- T&M -->
  <rect x="376" y="76" width="320" height="200" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="392" y="100" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Time &amp; materials</text>
  <text x="392" y="118" fill={C.muted} font-family={FONT} font-size="10">Bill hours worked × labor rate + parts</text>
  <text x="392" y="146" fill={C.green} font-family={FONT} font-size="11" font-weight="700">+ Fair on unpredictable work</text>
  <text x="392" y="168" fill={C.green} font-family={FONT} font-size="11" font-weight="700">+ No risk of underpricing the job</text>
  <text x="392" y="190" fill={C.green} font-family={FONT} font-size="11" font-weight="700">+ Simple to calculate</text>
  <text x="392" y="218" fill={C.red} font-family={FONT} font-size="11" font-weight="700">− Customer fears an open meter</text>
  <text x="392" y="240" fill={C.red} font-family={FONT} font-size="11" font-weight="700">− Penalizes your fastest techs</text>
  <text x="392" y="264" fill={C.muted} font-family={FONT} font-size="10">Best for: diagnostics, retrofits, unknowns</text>
</svg>
