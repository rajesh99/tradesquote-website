---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>EER vs SEER vs SEER2 compared</title>
  <desc>Three side-by-side panels showing what EER, SEER, and SEER2 each measure and the test condition behind each rating.</desc>

  <text x="360" y="34" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Three efficiency ratings, three meanings</text>

  <!-- EER panel -->
  <rect x="32" y="58" width="206" height="214" rx="12" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="135" y="88" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="20" font-weight="800">EER</text>
  <text x="135" y="110" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">Energy Efficiency Ratio</text>
  <line x1="56" y1="124" x2="214" y2="124" stroke={C.orange} stroke-width="1" stroke-opacity="0.4" />
  <text x="135" y="148" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Single peak point</text>
  <text x="135" y="170" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11">BTU/hr &#247; watts</text>
  <text x="135" y="200" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">Test condition</text>
  <text x="135" y="220" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">95&#176;F outdoor</text>
  <text x="135" y="250" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Good: 11&#8211;13+</text>

  <!-- SEER panel -->
  <rect x="257" y="58" width="206" height="214" rx="12" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="360" y="88" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="20" font-weight="800">SEER</text>
  <text x="360" y="110" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">Seasonal EER</text>
  <line x1="281" y1="124" x2="439" y2="124" stroke={C.blue} stroke-width="1" stroke-opacity="0.4" />
  <text x="360" y="148" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Whole season avg</text>
  <text x="360" y="170" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11">BTU &#247; watt-hours</text>
  <text x="360" y="200" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">Test condition</text>
  <text x="360" y="220" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">M1, 0.1 in.w.c.</text>
  <text x="360" y="250" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Legacy standard</text>

  <!-- SEER2 panel -->
  <rect x="482" y="58" width="206" height="214" rx="12" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="585" y="88" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="20" font-weight="800">SEER2</text>
  <text x="585" y="110" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">2023 test standard</text>
  <line x1="506" y1="124" x2="664" y2="124" stroke={C.primary} stroke-width="1" stroke-opacity="0.4" />
  <text x="585" y="148" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Season avg, realistic</text>
  <text x="585" y="170" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11">SEER &#215; 0.95</text>
  <text x="585" y="200" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">Test condition</text>
  <text x="585" y="220" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">M2, 0.5 in.w.c.</text>
  <text x="585" y="250" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Today&#8217;s legal min</text>

  <text x="360" y="302" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">EER is one peak point; SEER and SEER2 average a season &#8212; SEER2 just uses a harder, more realistic test.</text>
</svg>
