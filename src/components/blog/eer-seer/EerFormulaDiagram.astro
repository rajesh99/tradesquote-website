---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>How to calculate EER</title>
  <desc>EER equals BTU per hour divided by watts at peak conditions, with a worked example of 24,000 BTU per hour divided by 2,000 watts equals 12 EER.</desc>

  <text x="360" y="34" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Calculating EER</text>

  <!-- Main formula -->
  <rect x="140" y="58" width="440" height="62" rx="10" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="360" y="98" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="22" font-weight="800">EER = BTU/hr &#247; watts</text>

  <!-- Condition note -->
  <rect x="180" y="138" width="360" height="48" rx="8" fill={C.panelBg} stroke={C.border} />
  <text x="360" y="159" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">Measured at a single peak condition</text>
  <text x="360" y="177" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">95&#176;F outdoor / 80&#176;F indoor, steady state</text>

  <!-- Worked plug-in -->
  <rect x="80" y="206" width="560" height="64" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1" />
  <text x="360" y="230" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="11" font-weight="700">Worked example: a 2-ton unit drawing 2,000 W at 95&#176;F</text>
  <text x="360" y="254" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="15" font-weight="800">24,000 BTU/hr &#247; 2,000 W = 12 EER</text>

  <text x="360" y="300" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">EER is a watt-for-watt snapshot at peak load &#8212; no seasonal averaging, no part-load credit.</text>
</svg>
