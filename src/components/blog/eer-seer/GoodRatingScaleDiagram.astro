---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>What is a good SEER2 rating</title>
  <desc>A horizontal scale from entry-level to premium SEER2 values, with the southern federal minimum of about 14 SEER2 marked and a practical sweet spot highlighted.</desc>

  <text x="360" y="34" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">What counts as a good SEER2 rating</text>

  <!-- Scale track segments -->
  <rect x="60" y="120" width="150" height="40" rx="6" fill={C.redLight} stroke={C.red} stroke-width="1" />
  <rect x="210" y="120" width="180" height="40" fill={C.orangeLight} stroke={C.orange} stroke-width="1" />
  <rect x="390" y="120" width="180" height="40" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <rect x="570" y="120" width="90" height="40" rx="6" fill={C.greenLight} stroke={C.green} stroke-width="1" />

  <!-- Segment labels -->
  <text x="135" y="145" text-anchor="middle" fill={C.red} font-family={FONT} font-size="12" font-weight="700">Below code</text>
  <text x="300" y="145" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="12" font-weight="700">Entry-level</text>
  <text x="480" y="145" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="12" font-weight="700">Sweet spot</text>
  <text x="615" y="145" text-anchor="middle" fill={C.green} font-family={FONT} font-size="12" font-weight="700">Premium</text>

  <!-- Scale value ticks -->
  <text x="60" y="186" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">&lt;13.4</text>
  <text x="210" y="186" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">14</text>
  <text x="390" y="186" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">16</text>
  <text x="570" y="186" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">18</text>
  <text x="660" y="186" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">20+</text>

  <!-- Federal minimum marker at 14 (x=210) -->
  <line x1="210" y1="96" x2="210" y2="120" stroke={C.dark} stroke-width="2" />
  <rect x="146" y="70" width="128" height="26" rx="6" fill={C.dark} />
  <text x="210" y="88" text-anchor="middle" fill={C.white} font-family={FONT} font-size="11" font-weight="700">South min: 14 SEER2</text>

  <!-- North minimum marker near 13.4 (x=180) -->
  <line x1="180" y1="160" x2="180" y2="214" stroke={C.muted} stroke-width="1.5" stroke-dasharray="4 3" />
  <text x="180" y="230" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">North min &#8776; 13.4 SEER2</text>

  <!-- Sweet spot callout -->
  <rect x="120" y="252" width="480" height="40" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="360" y="277" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Practical sweet spot for most homes: 15&#8211;18 SEER2</text>

  <text x="360" y="312" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Minimums are a floor, not a target &#8212; above ~20 SEER2, extra cost rarely pays back without rebates.</text>
</svg>
