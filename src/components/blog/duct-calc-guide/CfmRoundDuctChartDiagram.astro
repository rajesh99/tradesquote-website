---
import { C, FONT } from "../infographicTokens";

// Round metal duct at 0.10 in.wg/100 ft — from the post's Quick CFM-to-Duct Reference table
const rows: [string, string, number][] = [
  ["100 CFM",   '6 in',  78],
  ["225 CFM",   '8 in', 120],
  ["350 CFM",   '9 in', 160],
  ["450 CFM",  '10 in', 196],
  ["700 CFM",  '12 in', 264],
  ["1,100 CFM",'14 in', 350],
  ["1,700 CFM",'16 in', 468],
];
const BAR_MAX = 468;
const BAR_AVAIL = 380; // px width for the bar area
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 340" fill="none" aria-hidden="true">
  <title>Round duct size by CFM at 0.10 in.wg/100 ft</title>
  <desc>
    Quick reference table showing round metal duct diameter for residential supply runs at 0.10 in.wg/100 ft friction rate:
    100 CFM needs 6 in, 225 CFM needs 8 in, 350 CFM needs 9 in, 450 CFM needs 10 in,
    700 CFM needs 12 in, 1,100 CFM needs 14 in, and 1,700 CFM needs 16 in.
  </desc>

  <rect x="8" y="8" width="704" height="324" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Round duct size by CFM (0.10 in.wg/100 ft)</text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">Round metal supply duct — flex duct needs one size larger</text>

  {rows.map(([cfm, size, val], i) => {
    const y = 72 + i * 37;
    const barW = Math.round((val / BAR_MAX) * BAR_AVAIL);
    return (
      <g>
        <text x="28" y={y + 20} fill={C.dark} font-family={FONT} font-size="12" font-weight="700">{cfm}</text>
        <rect x="150" y={y + 6} width={barW} height="22" rx="6" fill={C.primaryLight} stroke={C.primary} stroke-width="1.2" />
        <text x={150 + barW + 8} y={y + 21} fill={C.dark} font-family={FONT} font-size="12.5" font-weight="800">{size}</text>
      </g>
    );
  })}
</svg>
