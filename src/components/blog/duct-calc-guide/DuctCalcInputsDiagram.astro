---
import { C, FONT } from "../infographicTokens";

// The three inputs every duct calculator needs — from "The Two Rules Every Duct Calculator Uses"
const inputs = [
  {
    num: "1",
    label: "CFM",
    desc: "Room airflow requirement",
    note: "From Manual J load calc or equipment specs",
    color: C.primary,
    bg: C.primaryLight,
  },
  {
    num: "2",
    label: "Friction Rate",
    desc: "Target: 0.08–0.10 in.wg/100 ft",
    note: "Residential branch runs; lower for longer runs",
    color: C.blue,
    bg: C.blueLight,
  },
  {
    num: "3",
    label: "Duct Shape",
    desc: "Round or rectangular",
    note: "Flex needs one size larger than rigid metal",
    color: C.orange,
    bg: C.orangeLight,
  },
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 200" fill="none" aria-hidden="true">
  <title>Three inputs every duct calculator needs</title>
  <desc>
    A duct calculator requires three inputs: CFM (room airflow), friction rate (target 0.08–0.10 in.wg/100 ft for residential branch runs), and duct shape (round or rectangular, with flex needing one size larger than rigid metal).
  </desc>

  <rect x="8" y="8" width="704" height="184" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">What a duct calculator needs</text>
  <text x="24" y="52" fill={C.muted} font-family={FONT} font-size="11">Three inputs → one duct size</text>

  {inputs.map(({ num, label, desc, note, color, bg }, i) => {
    const cardX = 24 + i * 228;
    const cardW = 212;
    return (
      <g>
        <rect x={cardX} y="64" width={cardW} height="116" rx="10" fill={bg} stroke={color} stroke-width="1.4" stroke-opacity="0.55" />
        <circle cx={cardX + 22} cy="86" r="14" fill={color} />
        <text x={cardX + 22} y="91" text-anchor="middle" fill={C.white} font-family={FONT} font-size="13" font-weight="700">{num}</text>
        <text x={cardX + 44} y="91" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">{label}</text>
        <text x={cardX + 12} y="118" fill={C.dark} font-family={FONT} font-size="11" font-weight="600">{desc}</text>
        <text x={cardX + 12} y="136" fill={C.muted} font-family={FONT} font-size="10">{note.slice(0, 36)}</text>
        {note.length > 36 && (
          <text x={cardX + 12} y="150" fill={C.muted} font-family={FONT} font-size="10">{note.slice(36)}</text>
        )}
      </g>
    );
  })}

  <defs>
    <marker id="duct-inputs-arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill={C.primary} />
    </marker>
  </defs>

  <!-- arrows between cards -->
  <path d="M244 122 H252" stroke={C.primary} stroke-width="2" marker-end="url(#duct-inputs-arr)" />
  <path d="M472 122 H480" stroke={C.primary} stroke-width="2" marker-end="url(#duct-inputs-arr)" />
</svg>
