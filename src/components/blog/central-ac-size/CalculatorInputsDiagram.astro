---
import { C, FONT } from "../infographicTokens";

const inputs = [
  "Conditioned floor area",
  "Climate zone",
  "Ceiling height",
  "Insulation quality",
  "Window area & orientation",
  "Duct location",
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 290" fill="none" aria-hidden="true">
  <title>Inputs a real central AC calculator needs</title>
  <desc>
    A legitimate central AC size calculator needs more than square footage: conditioned floor area, climate
    zone, ceiling height, insulation quality, window area and orientation, and duct location — all feeding a
    tonnage result.
  </desc>

  <rect x="8" y="8" width="704" height="274" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">What a real calculator needs</text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">More than square footage — six inputs drive an honest tonnage</text>

  {inputs.map((label, i) => {
    const y = 70 + i * 33;
    return (
      <g>
        <rect x="24" y={y} width="250" height="26" rx="6" fill={C.white} stroke={C.border} stroke-width="1.2" />
        <text x="36" y={y + 17} fill={C.dark} font-family={FONT} font-size="10" font-weight="600">{label}</text>
        <path d={`M274 ${y + 13} C 300 ${y + 13}, 318 145, 344 145`} stroke={C.border} stroke-width="1" fill="none" />
      </g>
    );
  })}

  <rect x="344" y="112" width="166" height="66" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="2" />
  <text x="427" y="140" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="800">Central AC</text>
  <text x="427" y="158" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="11" font-weight="700">calculator</text>

  <path d="M510 145 h 36 m -9 -5 l 9 5 l -9 5" stroke={C.primary} stroke-width="1.8" fill="none" />

  <rect x="554" y="110" width="142" height="70" rx="10" fill={C.dark} />
  <text x="625" y="140" text-anchor="middle" fill={C.white} font-family={FONT} font-size="13" font-weight="800">Tonnage</text>
  <text x="625" y="160" text-anchor="middle" fill={C.primaryLight} font-family={FONT} font-size="9.5">tons · BTU/hr</text>
</svg>
