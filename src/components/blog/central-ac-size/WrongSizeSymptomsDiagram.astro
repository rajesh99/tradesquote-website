---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 240" fill="none" aria-hidden="true">
  <title>Signs a central AC is the wrong size</title>
  <desc>
    Oversized systems short cycle every 5 to 10 minutes and leave the home cold but humid. Undersized
    systems run all day without reaching setpoint and can ice the evaporator coil.
  </desc>

  <rect x="8" y="8" width="704" height="224" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="34" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Signs your AC is the wrong size</text>
  <text x="24" y="54" fill={C.muted} font-family={FONT} font-size="11">Both extremes waste energy and comfort — symptoms point to the cause</text>

  <rect x="24" y="70" width="320" height="150" rx="10" fill={C.orangeLight} stroke={C.orange} stroke-width="1.4" />
  <text x="40" y="98" fill={C.orange} font-family={FONT} font-size="13" font-weight="800">Oversized</text>
  <text x="40" y="116" fill={C.muted} font-family={FONT} font-size="10">Too much capacity for the load</text>
  <circle cx="46" cy="142" r="3" fill={C.orange} />
  <text x="58" y="146" fill={C.dark} font-family={FONT} font-size="10.5">Cycles on/off every 5–10 min</text>
  <circle cx="46" cy="170" r="3" fill={C.orange} />
  <text x="58" y="174" fill={C.dark} font-family={FONT} font-size="10.5">Cold but humid indoors</text>
  <text x="40" y="206" fill={C.orange} font-family={FONT} font-size="9.5" font-weight="600">Short cycling = poor dehumidification</text>

  <rect x="376" y="70" width="320" height="150" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.4" />
  <text x="392" y="98" fill={C.blue} font-family={FONT} font-size="13" font-weight="800">Undersized</text>
  <text x="392" y="116" fill={C.muted} font-family={FONT} font-size="10">Not enough capacity for the load</text>
  <circle cx="398" cy="142" r="3" fill={C.blue} />
  <text x="410" y="146" fill={C.dark} font-family={FONT} font-size="10.5">Runs all day, never reaches setpoint</text>
  <circle cx="398" cy="170" r="3" fill={C.blue} />
  <text x="410" y="174" fill={C.dark} font-family={FONT} font-size="10.5">Ice on coil (or airflow problem)</text>
  <text x="392" y="206" fill={C.blue} font-family={FONT} font-size="9.5" font-weight="600">Constant runtime = high bills and wear</text>
</svg>
