---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 220" fill="none" aria-hidden="true">
  <title>Drafty vs tight home infiltration</title>
  <desc>Pre-1980 homes leak air naturally; tight modern homes need mechanical ventilation.</desc>

  <rect x="40" y="24" width="300" height="180" rx="12" fill={C.orangeLight} stroke={C.orange} stroke-width="1.5" />
  <text x="190" y="52" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Pre-1980 drafty home</text>
  <text x="190" y="100" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Envelope leaks provide</text>
  <text x="190" y="116" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">uncontrolled fresh air</text>
  <text x="190" y="160" text-anchor="middle" fill={C.orange} font-family={FONT} font-size="11" font-weight="600">Natural infiltration adequate</text>

  <rect x="380" y="24" width="300" height="180" rx="12" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="530" y="52" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Tight modern home (2–4 ACH50)</text>
  <text x="530" y="100" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">Pollutants, moisture, CO2</text>
  <text x="530" y="116" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="10">trapped without ventilation</text>
  <text x="530" y="160" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="11" font-weight="600">Mechanical ventilation required</text>
</svg>
