---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 240" fill="none" aria-hidden="true">
  <title>ASHRAE 62.2 ventilation formula</title>
  <desc>Q equals 0.03 times floor area plus 7.5 times bedrooms plus one.</desc>

  <rect x="8" y="8" width="704" height="224" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="360" y="40" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">ASHRAE 62.2-2022 formula</text>

  <rect x="40" y="60" width="640" height="44" rx="8" fill={C.white} stroke={C.primary} stroke-width="1.5" />
  <text x="360" y="88" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="600">Q = 0.03 × A_floor + 7.5 × (N_br + 1)</text>

  <rect x="80" y="128" width="240" height="88" rx="8" fill={C.primaryLight} stroke={C.primary} stroke-width="1" />
  <text x="200" y="156" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">0.03 × 2,000</text>
  <text x="200" y="180" text-anchor="middle" fill={C.primary} font-family={FONT} font-size="20" font-weight="700">= 60 CFM</text>
  <text x="200" y="204" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Floor area component</text>

  <text x="360" y="176" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="20" font-weight="700">+</text>

  <rect x="400" y="128" width="240" height="88" rx="8" fill={C.blueLight} stroke={C.blue} stroke-width="1" />
  <text x="520" y="156" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="11" font-weight="700">7.5 × (3 + 1)</text>
  <text x="520" y="180" text-anchor="middle" fill={C.blue} font-family={FONT} font-size="20" font-weight="700">= 30 CFM</text>
  <text x="520" y="204" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">Occupancy component</text>

  <rect x="240" y="220" width="240" height="4" rx="2" fill={C.primary} />
</svg>
