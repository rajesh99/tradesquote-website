---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Cost per hour by tonnage and SEER2</title>
  <desc>Grid of approximate running cost per hour for 2, 3, and 4 ton air conditioners at SEER2 ratings of 13, 16, and 20, at a sample rate of 16 cents per kilowatt-hour.</desc>

  <text x="360" y="30" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="16" font-weight="700">Approx. $/hour by size and SEER2</text>
  <text x="360" y="50" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11" font-weight="600">sample rate $0.16/kWh, unit running full-out</text>

  <!-- Column headers (SEER2) -->
  <text x="300" y="84" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="12" font-weight="700">SEER2 13</text>
  <text x="450" y="84" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="12" font-weight="700">SEER2 16</text>
  <text x="600" y="84" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="12" font-weight="700">SEER2 20</text>

  <!-- Row labels (tonnage) -->
  <text x="120" y="124" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">2 ton</text>
  <text x="120" y="184" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">3 ton</text>
  <text x="120" y="244" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="13" font-weight="800">4 ton</text>

  <!-- Row 1: 2 ton (24,000 BTU/hr) -->
  <rect x="225" y="100" width="150" height="40" rx="8" fill={C.greenLight} stroke={C.green} />
  <text x="300" y="125" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">$0.30/hr</text>
  <rect x="375" y="100" width="150" height="40" rx="8" fill={C.greenLight} stroke={C.green} />
  <text x="450" y="125" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">$0.24/hr</text>
  <rect x="525" y="100" width="150" height="40" rx="8" fill={C.greenLight} stroke={C.green} />
  <text x="600" y="125" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">$0.19/hr</text>

  <!-- Row 2: 3 ton (36,000 BTU/hr) -->
  <rect x="225" y="160" width="150" height="40" rx="8" fill={C.blueLight} stroke={C.blue} />
  <text x="300" y="185" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">$0.44/hr</text>
  <rect x="375" y="160" width="150" height="40" rx="8" fill={C.blueLight} stroke={C.blue} />
  <text x="450" y="185" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">$0.36/hr</text>
  <rect x="525" y="160" width="150" height="40" rx="8" fill={C.blueLight} stroke={C.blue} />
  <text x="600" y="185" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">$0.29/hr</text>

  <!-- Row 3: 4 ton (48,000 BTU/hr) -->
  <rect x="225" y="220" width="150" height="40" rx="8" fill={C.orangeLight} stroke={C.orange} />
  <text x="300" y="245" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">$0.59/hr</text>
  <rect x="375" y="220" width="150" height="40" rx="8" fill={C.orangeLight} stroke={C.orange} />
  <text x="450" y="245" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">$0.48/hr</text>
  <rect x="525" y="220" width="150" height="40" rx="8" fill={C.orangeLight} stroke={C.orange} />
  <text x="600" y="245" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">$0.38/hr</text>

  <text x="360" y="296" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="11">Higher SEER2 cuts the hourly cost for the same cooling. Real bills depend on runtime and your local rate.</text>
</svg>
