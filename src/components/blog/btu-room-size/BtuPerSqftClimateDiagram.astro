---
import { C, FONT } from "../infographicTokens";

const climates = [
  { label: "Hot / Humid", range: "22 – 25 BTU/sq ft", low: 22, high: 25, color: C.orange, bg: C.orangeLight, border: C.orange },
  { label: "Moderate",    range: "18 – 22 BTU/sq ft", low: 18, high: 22, color: C.primary, bg: C.primaryLight, border: C.primary },
  { label: "Cool",        range: "15 – 18 BTU/sq ft", low: 15, high: 18, color: C.blue, bg: C.blueLight, border: C.blue },
];

const scaleMin = 0;
const scaleMax = 28;
const barLeft = 190;
const barWidth = 480;
const toX = (v: number) => barLeft + (v / scaleMax) * barWidth;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 200" fill="none" aria-hidden="true">
  <title>BTU per square foot by climate zone</title>
  <desc>
    Hot and humid climates need 22–25 BTU per square foot. Moderate climates need 18–22 BTU per
    square foot. Cool climates need 15–18 BTU per square foot.
  </desc>

  <rect x="8" y="8" width="704" height="184" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">BTU per sq ft by climate</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Multiply your room's sq ft by the range midpoint for a quick estimate</text>

  <!-- Scale ticks -->
  {[0, 7, 14, 21, 28].map((v) => (
    <g>
      <line x1={toX(v)} y1="68" x2={toX(v)} y2="172" stroke={C.border} stroke-width="1" stroke-dasharray="3 3" />
      <text x={toX(v)} y="185" text-anchor="middle" fill={C.muted} font-family={FONT} font-size="9">{v}</text>
    </g>
  ))}

  {climates.map((cl, i) => {
    const y = 72 + i * 34;
    return (
      <g>
        <text x="24" y={y + 15} fill={C.dark} font-family={FONT} font-size="11.5" font-weight="700">{cl.label}</text>
        <rect
          x={toX(cl.low)}
          y={y}
          width={toX(cl.high) - toX(cl.low)}
          height="22"
          rx="5"
          fill={cl.bg}
          stroke={cl.border}
          stroke-width="1.4"
        />
        <text x={toX(cl.low) - 4} y={y + 15} text-anchor="end" fill={C.muted} font-family={FONT} font-size="9">{cl.low}</text>
        <text x={toX(cl.high) + 4} y={y + 15} fill={C.dark} font-family={FONT} font-size="11" font-weight="800">{cl.range}</text>
      </g>
    );
  })}
</svg>
