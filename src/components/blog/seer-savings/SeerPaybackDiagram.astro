---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>SEER upgrade payback period</title>
  <desc>
    Payback equals the price premium for the higher-SEER unit divided by the annual savings. The same
    14-to-18 SEER upgrade pays back in about 7 years in a hot, high-rate climate but over 20 years in a
    mild, low-rate one.
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">When the upgrade pays for itself</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">Payback = price premium ÷ annual savings</text>

  <rect x="40" y="76" width="640" height="40" rx="9" fill={C.white} stroke={C.primary} stroke-width="1.3" />
  <text x="360" y="101" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="14" font-weight="800">Payback (years) = upgrade premium ($) ÷ annual savings ($/yr)</text>

  <!-- Hot climate -->
  <rect x="40" y="132" width="312" height="132" rx="10" fill={C.greenLight} stroke={C.green} stroke-width="1.4" />
  <text x="56" y="156" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Hot climate, high rate</text>
  <text x="56" y="180" fill={C.muted} font-family={FONT} font-size="10.5">$1,800 premium ÷ ~$250/yr saved</text>
  <text x="56" y="214" fill={C.green} font-family={FONT} font-size="26" font-weight="800">~7 years</text>
  <text x="56" y="240" fill={C.muted} font-family={FONT} font-size="10">Pays back well within the unit's life</text>

  <!-- Mild climate -->
  <rect x="368" y="132" width="312" height="132" rx="10" fill={C.redLight} stroke={C.red} stroke-width="1.4" />
  <text x="384" y="156" fill={C.dark} font-family={FONT} font-size="12" font-weight="700">Mild climate, low rate</text>
  <text x="384" y="180" fill={C.muted} font-family={FONT} font-size="10.5">$1,800 premium ÷ ~$85/yr saved</text>
  <text x="384" y="214" fill={C.red} font-family={FONT} font-size="26" font-weight="800">~21 years</text>
  <text x="384" y="240" fill={C.muted} font-family={FONT} font-size="10">May outlast the equipment itself</text>
</svg>
