---
import { C, FONT } from "../infographicTokens";

const rows = [
  ["150–250 sq ft", "6,000–9,000 BTU", 150],
  ["250–350 sq ft", "9,000–12,000 BTU", 210],
  ["350–550 sq ft", "12,000–18,000 BTU", 300],
  ["550–800 sq ft", "18,000–24,000 BTU", 400],
  ["800–1,200 sq ft", "24,000–36,000 BTU", 520],
];
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 320" fill="none" aria-hidden="true">
  <title>Mini split size by room square footage</title>
  <desc>
    A starting-point mini split sizing chart: 150 to 250 square feet needs about 6,000 to 9,000 BTU,
    250 to 350 needs 9,000 to 12,000, 350 to 550 needs 12,000 to 18,000, 550 to 800 needs 18,000 to
    24,000, and 800 to 1,200 needs 24,000 to 36,000 BTU.
  </desc>

  <rect x="8" y="8" width="704" height="304" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Mini split size by room area</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">A starting point (~20–25 BTU/sq ft) — adjust for sun, ceilings, and climate</text>

  {rows.map((r, i) => {
    const y = 76 + i * 46;
    return (
      <g>
        <text x="28" y={y + 26} fill={C.dark} font-family={FONT} font-size="12" font-weight="700">{r[0]}</text>
        <rect x="180" y={y + 10} width={r[2]} height="24" rx="6" fill={C.primaryLight} stroke={C.primary} stroke-width="1.2" />
        <text x={188 + (r[2] as number) + 8} y={y + 27} fill={C.dark} font-family={FONT} font-size="11.5" font-weight="800">{r[1]}</text>
      </g>
    );
  })}
</svg>
