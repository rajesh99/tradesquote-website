---
import { C, FONT } from "../infographicTokens";
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 300" fill="none" aria-hidden="true">
  <title>Single-zone vs multi-zone mini split sizing</title>
  <desc>
    A single-zone mini split pairs one outdoor unit with one indoor head, sized to that room. A
    multi-zone system runs several heads off one condenser; size the condenser to the diversified peak,
    not the simple sum of every head, because rooms rarely peak at once.
  </desc>

  <rect x="8" y="8" width="704" height="284" rx="12" fill={C.panelBg} stroke={C.border} />
  <text x="24" y="36" fill={C.dark} font-family={FONT} font-size="14" font-weight="700">Single-zone vs multi-zone</text>
  <text x="24" y="56" fill={C.muted} font-family={FONT} font-size="11">One head per room, or several heads off one condenser</text>

  <!-- single zone -->
  <rect x="24" y="76" width="320" height="200" rx="10" fill={C.blueLight} stroke={C.blue} stroke-width="1.5" />
  <text x="40" y="100" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Single-zone</text>
  <text x="40" y="118" fill={C.muted} font-family={FONT} font-size="10">One condenser → one indoor head</text>
  <rect x="40" y="132" width="80" height="48" rx="7" fill={C.white} stroke={C.blue} stroke-width="1.2" />
  <text x="80" y="160" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10.5" font-weight="700">condenser</text>
  <line x1="120" y1="156" x2="180" y2="156" stroke={C.blue} stroke-width="2" />
  <rect x="180" y="132" width="64" height="48" rx="7" fill={C.white} stroke={C.blue} stroke-width="1.2" />
  <text x="212" y="160" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10.5" font-weight="700">head</text>
  <text x="40" y="212" fill={C.muted} font-family={FONT} font-size="10.5">Size the head to that one room's load.</text>
  <text x="40" y="232" fill={C.muted} font-family={FONT} font-size="10.5">Most efficient; best for a single space</text>
  <text x="40" y="252" fill={C.muted} font-family={FONT} font-size="10.5">or an add-on room.</text>

  <!-- multi zone -->
  <rect x="376" y="76" width="320" height="200" rx="10" fill={C.primaryLight} stroke={C.primary} stroke-width="1.5" />
  <text x="392" y="100" fill={C.dark} font-family={FONT} font-size="13" font-weight="700">Multi-zone</text>
  <text x="392" y="118" fill={C.muted} font-family={FONT} font-size="10">One condenser → multiple heads</text>
  <rect x="392" y="132" width="80" height="48" rx="7" fill={C.white} stroke={C.primary} stroke-width="1.2" />
  <text x="432" y="160" text-anchor="middle" fill={C.dark} font-family={FONT} font-size="10.5" font-weight="700">condenser</text>
  <line x1="472" y1="146" x2="528" y2="134" stroke={C.primary} stroke-width="2" />
  <line x1="472" y1="156" x2="528" y2="156" stroke={C.primary} stroke-width="2" />
  <line x1="472" y1="166" x2="528" y2="178" stroke={C.primary} stroke-width="2" />
  <rect x="528" y="120" width="56" height="28" rx="6" fill={C.white} stroke={C.primary} stroke-width="1.1" />
  <rect x="528" y="142" width="56" height="28" rx="6" fill={C.white} stroke={C.primary} stroke-width="1.1" />
  <rect x="528" y="164" width="56" height="28" rx="6" fill={C.white} stroke={C.primary} stroke-width="1.1" />
  <text x="392" y="222" fill={C.red} font-family={FONT} font-size="10.5" font-weight="700">Don't just add every head together —</text>
  <text x="392" y="242" fill={C.muted} font-family={FONT} font-size="10.5">size the condenser to the diversified</text>
  <text x="392" y="262" fill={C.muted} font-family={FONT} font-size="10.5">peak; rooms rarely peak at once.</text>
</svg>
