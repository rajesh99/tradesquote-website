---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 720 200"
  fill="none"
  aria-hidden="true"
>
  <title>Four steps to measure HVAC Delta T</title>
  <desc>
    Run the system, measure return and supply air with a probe thermometer, then subtract.
  </desc>

  <!-- Step 1 -->
  <rect x="16" y="8" width="160" height="184" rx="12" fill="#FAFAFA" stroke="#D5D5D5" />
  <circle cx="44" cy="36" r="16" fill="#01AD9F" />
  <text x="44" y="41" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="14" font-weight="700">1</text>
  <text x="96" y="88" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="12" font-weight="700">Run system 10–15 min</text>
  <text x="96" y="114" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="10">Set thermostat for</text>
  <text x="96" y="128" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="10">continuous run</text>
  <rect x="68" y="144" width="24" height="36" rx="4" fill="#E8F8F6" stroke="#01AD9F" stroke-width="1" />
  <circle cx="80" cy="172" r="5" fill="#01AD9F" opacity="0.3" />

  <path d="M184 100 H200" stroke="#01AD9F" stroke-width="2" marker-end="url(#stepArrow)" />

  <!-- Step 2 -->
  <rect x="192" y="8" width="160" height="184" rx="12" fill="#FAFAFA" stroke="#D5D5D5" />
  <circle cx="220" cy="36" r="16" fill="#01AD9F" />
  <text x="220" y="41" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="14" font-weight="700">2</text>
  <text x="272" y="88" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="12" font-weight="700">Probe at return grille</text>
  <text x="272" y="114" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="10">Large grille pulling</text>
  <text x="272" y="128" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="10">air back to unit</text>
  <rect x="244" y="148" width="36" height="28" rx="3" fill="#E8F8F6" stroke="#01AD9F" stroke-width="1" />
  <line x1="250" y1="156" x2="274" y2="156" stroke="#01AD9F" stroke-width="1" />
  <line x1="250" y1="162" x2="274" y2="162" stroke="#01AD9F" stroke-width="1" />
  <line x1="250" y1="168" x2="274" y2="168" stroke="#01AD9F" stroke-width="1" />

  <path d="M360 100 H376" stroke="#01AD9F" stroke-width="2" marker-end="url(#stepArrow)" />

  <!-- Step 3 -->
  <rect x="368" y="8" width="160" height="184" rx="12" fill="#FAFAFA" stroke="#D5D5D5" />
  <circle cx="396" cy="36" r="16" fill="#01AD9F" />
  <text x="396" y="41" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="14" font-weight="700">3</text>
  <text x="448" y="88" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="12" font-weight="700">Probe at supply register</text>
  <text x="448" y="114" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="10">Nearest register to</text>
  <text x="448" y="128" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="10">air handler</text>
  <rect x="420" y="148" width="36" height="28" rx="3" fill="#E8F8F6" stroke="#01AD9F" stroke-width="1" />
  <line x1="426" y1="154" x2="450" y2="170" stroke="#01AD9F" stroke-width="1.5" />
  <line x1="450" y1="154" x2="426" y2="170" stroke="#01AD9F" stroke-width="1.5" />

  <path d="M536 100 H552" stroke="#01AD9F" stroke-width="2" marker-end="url(#stepArrow)" />

  <!-- Step 4 -->
  <rect x="544" y="8" width="160" height="184" rx="12" fill="#FAFAFA" stroke="#D5D5D5" />
  <circle cx="572" cy="36" r="16" fill="#01AD9F" />
  <text x="572" y="41" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="14" font-weight="700">4</text>
  <text x="624" y="88" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="12" font-weight="700">Subtract temperatures</text>
  <text x="624" y="114" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="10">Cooling: return − supply</text>
  <text x="624" y="128" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="10">Heating: supply − return</text>
  <text x="624" y="164" text-anchor="middle" fill="#01AD9F" font-family="system-ui, sans-serif" font-size="22" font-weight="700">−</text>
  <text x="624" y="180" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="9">= ΔT</text>

  <defs>
    <marker id="stepArrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill="#01AD9F" />
    </marker>
  </defs>
</svg>
