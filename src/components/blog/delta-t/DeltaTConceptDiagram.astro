---
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 720 280"
  fill="none"
  aria-hidden="true"
>
  <title>Delta T concept: cooling and heating temperature split</title>
  <desc>
    Cooling mode subtracts supply from return air temperature. Heating mode subtracts return from
    supply air temperature.
  </desc>

  <!-- Cooling panel -->
  <rect x="8" y="8" width="344" height="264" rx="12" fill="#FAFAFA" stroke="#D5D5D5" />
  <text x="24" y="36" fill="#152035" font-family="system-ui, sans-serif" font-size="14" font-weight="700">
    Cooling mode
  </text>
  <text x="24" y="56" fill="#747577" font-family="system-ui, sans-serif" font-size="11">
    Return − Supply = ΔT
  </text>

  <!-- Return grille -->
  <rect x="32" y="80" width="72" height="48" rx="6" fill="#E8F8F6" stroke="#01AD9F" stroke-width="1.5" />
  <text x="68" y="100" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="10" font-weight="600">Return</text>
  <text x="68" y="116" text-anchor="middle" fill="#01AD9F" font-family="system-ui, sans-serif" font-size="12" font-weight="700">75°F</text>

  <!-- Arrow to coil -->
  <path d="M112 104 H148" stroke="#01AD9F" stroke-width="2" marker-end="url(#arrow)" />
  <rect x="152" y="88" width="56" height="32" rx="4" fill="#152035" />
  <text x="180" y="108" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="9" font-weight="600">Coil</text>

  <!-- Arrow to supply -->
  <path d="M216 104 H252" stroke="#01AD9F" stroke-width="2" marker-end="url(#arrow)" />
  <rect x="256" y="80" width="72" height="48" rx="6" fill="#E8F8F6" stroke="#01AD9F" stroke-width="1.5" />
  <text x="292" y="100" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="10" font-weight="600">Supply</text>
  <text x="292" y="116" text-anchor="middle" fill="#2563EB" font-family="system-ui, sans-serif" font-size="12" font-weight="700">55°F</text>

  <!-- Formula -->
  <rect x="32" y="160" width="296" height="44" rx="8" fill="#fff" stroke="#D5D5D5" />
  <text x="180" y="188" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="13" font-weight="600">
    ΔT = 75°F − 55°F = <tspan fill="#01AD9F" font-weight="700">20°F</tspan>
  </text>
  <text x="180" y="228" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="11">
    Normal range: 16–22°F
  </text>

  <!-- Heating panel -->
  <rect x="368" y="8" width="344" height="264" rx="12" fill="#FAFAFA" stroke="#D5D5D5" />
  <text x="384" y="36" fill="#152035" font-family="system-ui, sans-serif" font-size="14" font-weight="700">
    Heating mode
  </text>
  <text x="384" y="56" fill="#747577" font-family="system-ui, sans-serif" font-size="11">
    Supply − Return = ΔT
  </text>

  <!-- Return grille (cold) -->
  <rect x="392" y="80" width="72" height="48" rx="6" fill="#FFF7ED" stroke="#EA580C" stroke-width="1.5" />
  <text x="428" y="100" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="10" font-weight="600">Return</text>
  <text x="428" y="116" text-anchor="middle" fill="#2563EB" font-family="system-ui, sans-serif" font-size="12" font-weight="700">65°F</text>

  <!-- Arrow to heat exchanger -->
  <path d="M472 104 H508" stroke="#EA580C" stroke-width="2" marker-end="url(#arrowOrange)" />
  <rect x="512" y="88" width="56" height="32" rx="4" fill="#152035" />
  <text x="540" y="104" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="8" font-weight="600">Heat</text>
  <text x="540" y="114" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="8" font-weight="600">Exch.</text>

  <!-- Arrow to supply (warm) -->
  <path d="M576 104 H612" stroke="#EA580C" stroke-width="2" marker-end="url(#arrowOrange)" />
  <rect x="616" y="80" width="72" height="48" rx="6" fill="#FFF7ED" stroke="#EA580C" stroke-width="1.5" />
  <text x="652" y="100" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="10" font-weight="600">Supply</text>
  <text x="652" y="116" text-anchor="middle" fill="#EA580C" font-family="system-ui, sans-serif" font-size="12" font-weight="700">115°F</text>

  <!-- Formula -->
  <rect x="392" y="160" width="296" height="44" rx="8" fill="#fff" stroke="#D5D5D5" />
  <text x="540" y="188" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="13" font-weight="600">
    ΔT = 115°F − 65°F = <tspan fill="#EA580C" font-weight="700">50°F</tspan>
  </text>
  <text x="540" y="228" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="11">
    Normal range: 40–70°F (check nameplate)
  </text>

  <defs>
    <marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill="#01AD9F" />
    </marker>
    <marker id="arrowOrange" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill="#EA580C" />
    </marker>
  </defs>
</svg>
