---
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 720 360"
  fill="none"
  aria-hidden="true"
>
  <title>Delta T diagnostic decision tree for cooling mode</title>
  <desc>
    Low split below 16°F: check filter then refrigerant. High split above 22°F: check coil and blower.
    Furnace rise too high: check filter, ducts, then heat exchanger.
  </desc>

  <!-- Start -->
  <rect x="280" y="8" width="160" height="44" rx="8" fill="#152035" />
  <text x="360" y="28" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="11" font-weight="600">Measure ΔT</text>
  <text x="360" y="42" text-anchor="middle" fill="#a1a5ae" font-family="system-ui, sans-serif" font-size="9">(cooling mode)</text>

  <path d="M360 52 V72" stroke="#D5D5D5" stroke-width="2" />
  <path d="M360 72 H180 V100" stroke="#D5D5D5" stroke-width="2" />
  <path d="M360 72 H540 V100" stroke="#D5D5D5" stroke-width="2" />

  <!-- Low split branch -->
  <rect x="80" y="100" width="200" height="40" rx="8" fill="#EFF6FF" stroke="#2563EB" stroke-width="1.5" />
  <text x="180" y="118" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="11" font-weight="700">Low split (&lt; 16°F)</text>
  <text x="180" y="132" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="9">Not enough heat removed</text>

  <path d="M180 140 V168" stroke="#2563EB" stroke-width="2" marker-end="url(#blueArrow)" />

  <rect x="60" y="168" width="240" height="36" rx="6" fill="#FAFAFA" stroke="#D5D5D5" />
  <text x="180" y="190" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="10" font-weight="600">1. Check air filter</text>

  <path d="M180 204 V224" stroke="#D5D5D5" stroke-width="2" />
  <rect x="60" y="224" width="240" height="36" rx="6" fill="#FAFAFA" stroke="#D5D5D5" />
  <text x="180" y="246" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="10" font-weight="600">2. Check refrigerant charge</text>

  <path d="M180 260 V280" stroke="#D5D5D5" stroke-width="2" />
  <rect x="40" y="280" width="280" height="36" rx="6" fill="#FAFAFA" stroke="#D5D5D5" />
  <text x="180" y="302" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="9">Also: frozen coil, blocked registers, oversized unit</text>

  <!-- High split branch -->
  <rect x="440" y="100" width="200" height="40" rx="8" fill="#FFF7ED" stroke="#EA580C" stroke-width="1.5" />
  <text x="540" y="118" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="11" font-weight="700">High split (&gt; 22°F)</text>
  <text x="540" y="132" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="9">Air overcooled, low airflow</text>

  <path d="M540 140 V168" stroke="#EA580C" stroke-width="2" marker-end="url(#orangeArrow)" />

  <rect x="420" y="168" width="240" height="36" rx="6" fill="#FAFAFA" stroke="#D5D5D5" />
  <text x="540" y="190" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="10" font-weight="600">1. Check evaporator coil</text>

  <path d="M540 204 V224" stroke="#D5D5D5" stroke-width="2" />
  <rect x="420" y="224" width="240" height="36" rx="6" fill="#FAFAFA" stroke="#D5D5D5" />
  <text x="540" y="246" text-anchor="middle" fill="#152035" font-family="system-ui, sans-serif" font-size="10" font-weight="600">2. Check blower wheel</text>

  <path d="M540 260 V280" stroke="#D5D5D5" stroke-width="2" />
  <rect x="400" y="280" width="280" height="36" rx="6" fill="#FAFAFA" stroke="#D5D5D5" />
  <text x="540" y="302" text-anchor="middle" fill="#747577" font-family="system-ui, sans-serif" font-size="9">Also: dirty filter, blocked ducts, overcharge</text>

  <!-- Normal range note -->
  <rect x="240" y="328" width="240" height="28" rx="6" fill="#E8F8F6" stroke="#01AD9F" stroke-width="1" />
  <text x="360" y="346" text-anchor="middle" fill="#01AD9F" font-family="system-ui, sans-serif" font-size="10" font-weight="600">Normal: 16–22°F → verify with second test</text>

  <defs>
    <marker id="blueArrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill="#2563EB" />
    </marker>
    <marker id="orangeArrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill="#EA580C" />
    </marker>
  </defs>
</svg>
