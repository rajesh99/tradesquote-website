---
import type { HvacCalculator } from "@/config/hvacCalculators";
import { hvacAccentStyles } from "@/config/hvacCalculators";

interface Props {
  calculator: HvacCalculator;
}

const { calculator } = Astro.props;
const styles = hvacAccentStyles[calculator.accent];
---

<a
  href={`/calculators/hvac/${calculator.slug}`}
  class={`group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm ${styles.hoverBorder} hover:shadow-md transition`}
>
  <div class="flex items-center gap-3">
    <span
      class={`flex h-11 w-11 shrink-0 items-center justify-center rounded-xl ${styles.iconBg} ${styles.iconColor}`}
      set:html={calculator.icon}
    />
    <h2 class={`text-lg font-bold text-slate-900 ${styles.hoverTitle} transition`}>
      {calculator.title}
    </h2>
  </div>
  <p class="mt-3 text-sm text-slate-600 leading-relaxed">{calculator.description}</p>
  <p class="mt-3 text-xs text-slate-500">
    Answers: <span class="font-medium text-slate-700">"{calculator.question}"</span>
  </p>
  <span class={`mt-auto pt-4 inline-flex items-center gap-1 text-sm font-semibold ${styles.ctaColor}`}>
    Open calculator
    <svg
      class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      viewBox="0 0 24 24"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </span>
</a>
