---
const features = [
  {
    title: "AI-powered estimates",
    description:
      "Describe any job and get a detailed line-item estimate with quantities, unit prices, and totals instantly.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    iconBg: "bg-indigo-50",
    iconColor: "text-indigo-600",
    iconBorder: "border-indigo-100",
  },
  {
    title: "Knowledge base",
    description:
      "Upload PDFs, images, and documents to give the AI context about your past projects and pricing.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
    iconBg: "bg-violet-50",
    iconColor: "text-violet-600",
    iconBorder: "border-violet-100",
  },
  {
    title: "Quality control agent",
    description:
      "Every estimate is automatically validated by a QC agent that checks pricing consistency and line-item accuracy.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
    iconBg: "bg-emerald-50",
    iconColor: "text-emerald-600",
    iconBorder: "border-emerald-100",
  },
  {
    title: "Learns from you",
    description:
      "Correct any estimate and the AI learns from your feedback, improving accuracy over time.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20v-6M6 20V10M18 20V4"/></svg>`,
    iconBg: "bg-amber-50",
    iconColor: "text-amber-600",
    iconBorder: "border-amber-100",
  },
  {
    title: "Vision AI",
    description:
      "Attach photos or image links and TradesQuote analyzes them visually to inform the estimate.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>`,
    iconBg: "bg-sky-50",
    iconColor: "text-sky-600",
    iconBorder: "border-sky-100",
  },
  {
    title: "Secure & multi-tenant",
    description:
      "Your data is isolated per account. Prompt injection protection and enterprise-grade security built in.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    iconBg: "bg-slate-50",
    iconColor: "text-slate-600",
    iconBorder: "border-slate-200",
  },
];
---

<section id="platform" class="w-full py-24 px-6 bg-white border-t border-gray-100">
  <div class="max-w-6xl mx-auto flex flex-col items-center gap-16">
    <div class="flex flex-col items-center gap-3 text-center max-w-2xl">
      <span
        class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-600 text-sm font-semibold tracking-wide uppercase"
      >
        Platform
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight tracking-tight">
        All-in-one estimating
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed">
        AI, your knowledge base, and automated quality control — so every estimate is accurate and professional.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
      {features.map((item) => (
        <div class="flex flex-col gap-5 rounded-2xl bg-gray-50/80 border border-gray-100 p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          <div
            class={`w-10 h-10 rounded-xl border ${item.iconBg} ${item.iconBorder} ${item.iconColor} flex items-center justify-center shrink-0`}
          >
            <Fragment set:html={item.icon} />
          </div>
          <div class="flex flex-col gap-2">
            <h3 class="text-base font-bold text-gray-900 leading-snug">{item.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
