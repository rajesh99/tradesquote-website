---
import Header from './Header.astro';
import Part1 from './Part1.astro';
import InlineYouTubeEmbed from './InlineYouTubeEmbed.astro';
import PlatformFeatures from './PlatformFeatures.astro';
import EstimatorAccuracy from './EstimatorAccuracy.astro';
import EstimatorInputs from './EstimatorInputs.astro';
import Part10 from './Part10.astro';
import Part11 from './Part11.astro';
import Part12 from './Part12.astro';
import Footer from './Footer.astro';
---

<Header />
<Part1 />
<PlatformFeatures />
<section id="demo" class="w-full px-6 pb-20">
  <div class="mx-auto w-full max-w-5xl">
    <div class="text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight">
        See TradesQuote in action
      </h2>
      <p class="mt-4 text-base sm:text-lg text-gray-500">
        A quick walkthrough of how estimates come together — fast, consistent, and professional.
      </p>
    </div>

    <div class="mt-10 mx-auto w-full max-w-3xl">
      <InlineYouTubeEmbed
        videoId="BDyWl1jGdoo"
        posterSrc="/create-automation.png"
        posterAlt="TradesQuote demo preview"
        buttonAriaLabel="Play TradesQuote demo video"
      />
    </div>
  </div>
</section>
<EstimatorInputs />
<EstimatorAccuracy />
<Part10 />
<Part11 />
<Part12 />
<Footer />