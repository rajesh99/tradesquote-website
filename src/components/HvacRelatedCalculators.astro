---
import type { HvacCalculatorAccent } from "@/config/hvacCalculators";
import { hvacAccentStyles } from "@/config/hvacCalculators";

export type HvacRelatedCalculator = {
  href: string;
  title: string;
  description: string;
};

interface Props {
  calculators: HvacRelatedCalculator[];
  accent?: HvacCalculatorAccent;
  heading?: string;
}

const { calculators, accent = "blue", heading = "More HVAC calculators" } = Astro.props;
const styles = hvacAccentStyles[accent];
---

<section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-16">
  <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">{heading}</h2>
  <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {
      calculators.map((calc) => (
        <a
          href={calc.href}
          class={`group rounded-xl border border-slate-200 bg-white p-5 ${styles.hoverBorder} hover:shadow-md transition`}
        >
          <p class={`font-semibold text-slate-900 ${styles.hoverTitle}`}>{calc.title}</p>
          <p class="mt-1 text-sm text-slate-500">{calc.description}</p>
        </a>
      ))
    }
  </div>
</section>
