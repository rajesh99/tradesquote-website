---
const benefits = [
  {
    title: "Stop re-entering data",
    body:
      "When you generate an estimate in TradesQuote, every line item, quantity, and price is pushed straight into simPRO as a structured Quote in seconds — no copy-pasting or spreadsheets.",
    icon: "layers",
  },
  {
    title: "Save hours every week",
    body:
      "Estimators no longer need to manually recreate quotes in simPRO after building them in TradesQuote. What used to take 20–30 minutes of data entry is now a single click.",
    icon: "clock",
  },
  {
    title: "Eliminate costly errors",
    body:
      "Manual re-entry introduces typos, missed line items, and pricing mistakes. The exact data from your estimate lands in simPRO every time.",
    icon: "shield",
  },
  {
    title: "Keep your team in sync",
    body:
      "The moment an estimate is uploaded, your simPRO team can see the Quote, action it, and move it through your workflow — no lag waiting for data entry.",
    icon: "users",
  },
  {
    title: "Full traceability",
    body:
      "Every estimate uploaded to simPRO stores the Quote ID and a direct link back to the simPRO record. Your team always knows where each estimate lives.",
    icon: "link",
  },
  {
    title: "Stays connected automatically",
    body:
      "The integration silently refreshes its credentials in the background, so there is no need to reconnect every time a token expires.",
    icon: "refresh",
  },
];
---

<section class="w-full" aria-labelledby="why-connect-heading">
  <h2
    id="why-connect-heading"
    class="text-2xl sm:text-3xl font-bold text-gray-900 tracking-tight mb-8 sm:mb-10"
  >
    Why connect TradesQuote with simPRO?
  </h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-6">
    {benefits.map((b) => (
      <div
        class="flex flex-col gap-3 p-6 rounded-2xl border border-gray-100 bg-gray-50/80 hover:bg-white hover:shadow-sm hover:border-gray-200/80 transition-all duration-200"
      >
        <div class="flex items-start gap-4">
          <div
            class="shrink-0 w-10 h-10 rounded-xl bg-indigo-50 border border-indigo-100 flex items-center justify-center text-indigo-600"
            aria-hidden="true"
          >
            {b.icon === "layers" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 2 7 12 12 22 7 12 2" />
                <polyline points="2 17 12 22 22 17" />
                <polyline points="2 12 12 17 22 12" />
              </svg>
            )}
            {b.icon === "clock" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
            )}
            {b.icon === "shield" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              </svg>
            )}
            {b.icon === "users" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
            )}
            {b.icon === "link" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
              </svg>
            )}
            {b.icon === "refresh" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M23 4v6h-6" />
                <path d="M1 20v-6h6" />
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" />
              </svg>
            )}
          </div>
          <div class="min-w-0 flex flex-col gap-2">
            <h3 class="text-base font-semibold text-gray-900 leading-snug m-0">
              {b.title}
            </h3>
            <p class="text-sm text-gray-600 leading-relaxed m-0">{b.body}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
