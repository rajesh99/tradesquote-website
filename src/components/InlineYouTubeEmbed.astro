---
type Props = {
  videoId: string;
  posterSrc: string;
  posterAlt: string;
  badgeText?: string;
  buttonAriaLabel?: string;
  className?: string;
  aspectRatio?: string; // e.g. "16 / 9"
};

const {
  videoId,
  posterSrc,
  posterAlt,
  badgeText = 'Click to play demo video',
  buttonAriaLabel = 'Play video',
  className = '',
  aspectRatio = '16 / 9',
} = Astro.props;

const uid = `yt-inline-${Math.random().toString(36).slice(2)}`;
const buttonId = `${uid}-btn`;
const embedSrc = `https://www.youtube.com/embed/${encodeURIComponent(videoId)}?autoplay=1&rel=0&modestbranding=1&playsinline=1`;
---

<button
  id={buttonId}
  type="button"
  class={`group relative w-full rounded-2xl overflow-hidden border border-indigo-200 bg-black shadow-2xl shadow-indigo-200/50 ring-1 ring-indigo-100 focus:outline-none focus-visible:ring-4 focus-visible:ring-indigo-300/60 ${className}`}
  style={`aspect-ratio: ${aspectRatio}`}
  data-loaded="false"
  aria-label={buttonAriaLabel}
>
  <img
    src={posterSrc}
    alt={posterAlt}
    class="absolute inset-0 w-full h-full object-cover"
    width="1600"
    height="900"
    loading="lazy"
    decoding="async"
  />

  <span class="absolute inset-0 bg-black/35"></span>
  <span class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/25 to-transparent"></span>

  <span class="absolute left-4 top-4 inline-flex items-center gap-2 rounded-full bg-white/90 text-gray-900 px-3 py-1.5 text-xs font-semibold shadow-sm">
    <span class="w-2 h-2 rounded-full bg-red-500"></span>
    {badgeText}
  </span>

  <span class="absolute inset-0 flex items-center justify-center">
    <span class="flex flex-col items-center gap-3">
      <span class="w-16 h-16 rounded-full bg-red-600 shadow-2xl shadow-black/40 border border-white/30 flex items-center justify-center transition-transform duration-200 group-hover:scale-[1.1]">
        <svg class="w-8 h-8 sm:w-9 sm:h-9 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M8 5v14l11-7z" />
        </svg>
      </span>
      <span class="text-white font-extrabold text-lg drop-shadow-[0_2px_10px_rgba(0,0,0,0.6)]">Play</span>
    </span>
  </span>
</button>

<script define:vars={{ buttonId, embedSrc }}>
  const btn = document.getElementById(buttonId);
  if (btn) {
    btn.addEventListener('click', () => {
      if (btn.getAttribute('data-loaded') === 'true') return;
      btn.setAttribute('data-loaded', 'true');

      const iframe = document.createElement('iframe');
      iframe.width = '100%';
      iframe.height = '100%';
      iframe.loading = 'lazy';
      iframe.allowFullscreen = true;
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.title = 'TradesQuote demo';
      iframe.src = embedSrc;

      btn.innerHTML = '';
      btn.appendChild(iframe);
    });
  }
</script>
