---
import {
  DEFAULT_HVAC_EXTERNAL_RESOURCES,
  type ExternalResource,
} from "@/config/hvacExternalResources";

export type { ExternalResource };

interface Props {
  heading?: string;
  subheading?: string;
  resources?: ExternalResource[];
}

const {
  heading = "Trusted HVAC Standards & Resources",
  subheading = "The design rules and CFM targets on this page trace back to widely adopted industry standards. These organisations publish the specifications contractors, engineers, and code officials rely on.",
  resources = DEFAULT_HVAC_EXTERNAL_RESOURCES,
} = Astro.props;
---

<section class="bg-slate-50 border-y border-slate-200">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
    <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">{heading}</h2>
    <p class="mt-4 text-slate-600 leading-relaxed max-w-2xl">{subheading}</p>

    <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        resources.map((r) => (
          <a
            href={r.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm hover:border-cyan-300 hover:shadow-md transition-all"
          >
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-cyan-100">
                <svg
                  class="h-5 w-5 text-cyan-700"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d={r.iconPath} />
                </svg>
              </div>
              <span class="font-bold text-slate-900 group-hover:text-cyan-700 transition-colors">
                {r.name}
              </span>
              <svg
                class="ml-auto h-4 w-4 shrink-0 text-slate-400 group-hover:text-cyan-600 transition-colors"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                />
              </svg>
            </div>
            <p class="mt-3 text-sm text-slate-600">{r.description}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
