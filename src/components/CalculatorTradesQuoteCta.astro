---
interface Props {
  heading: string;
  description: string;
}

const { heading, description } = Astro.props;
---

<section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
  <div
    class="rounded-3xl bg-gradient-to-br from-slate-900 to-blue-900 px-6 py-12 sm:px-12 sm:py-16 text-center text-white relative overflow-hidden"
  >
    <div class="relative">
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight">{heading}</h2>
      <p class="mt-4 max-w-2xl mx-auto text-blue-100 leading-relaxed">{description}</p>

      <div class="mt-8 grid sm:grid-cols-3 gap-4 max-w-3xl mx-auto text-left">
        <div class="rounded-xl bg-white/10 p-4">
          <p class="font-semibold">AI line-item estimates</p>
          <p class="mt-1 text-sm text-blue-100">Quantities, unit prices, and totals generated instantly.</p>
        </div>
        <div class="rounded-xl bg-white/10 p-4">
          <p class="font-semibold">Knowledge base</p>
          <p class="mt-1 text-sm text-blue-100">Upload past jobs so estimates reflect your real pricing.</p>
        </div>
        <div class="rounded-xl bg-white/10 p-4">
          <p class="font-semibold">Shareable & signable</p>
          <p class="mt-1 text-sm text-blue-100">Clients review, accept, and sign from a public link.</p>
        </div>
      </div>

      <div class="mt-9 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="https://app.tradesquote.ai/auth/sign-up"
          class="rounded-lg bg-white px-6 py-3 text-sm font-semibold text-slate-900 shadow-sm hover:bg-blue-50 transition"
          >Get started — Free 14-day trial</a
        >
        <a
          href="/#pricing"
          class="rounded-lg border border-white/30 px-6 py-3 text-sm font-semibold text-white hover:bg-white/10 transition"
          >View pricing</a
        >
      </div>
      <p class="mt-4 text-xs text-blue-200">No credit card required · 14-day free trial · Cancel anytime</p>
    </div>
  </div>
</section>
