---
const benefits = [
  {
    title: "Hours Back Every Week",
    description: "Eliminate repetitive follow-ups so your team can focus on real, billable work.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    iconBg: "bg-amber-50",
    iconColor: "text-amber-500",
    iconBorder: "border-amber-100",
  },
  {
    title: "Faster Payments",
    description: "Automatic overdue reminders get you paid sooner — no awkward manual chasing required.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    iconBg: "bg-emerald-50",
    iconColor: "text-emerald-600",
    iconBorder: "border-emerald-100",
  },
  {
    title: "More Closed Estimates",
    description: "Consistent follow-ups revive cold quotes and increase your conversion rate significantly.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
    iconBg: "bg-indigo-50",
    iconColor: "text-indigo-600",
    iconBorder: "border-indigo-100",
  },
  {
    title: "Better Customer Experience",
    description: "Every customer gets the right message at the right time — automatically, every single time.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    iconBg: "bg-pink-50",
    iconColor: "text-pink-500",
    iconBorder: "border-pink-100",
  },
];
---

<section class="w-full py-24 px-6 bg-gray-50">
  <div class="max-w-6xl mx-auto flex flex-col items-center gap-16">

    <!-- Section header -->
    <div class="flex flex-col items-center gap-3 text-center max-w-2xl">
      <span class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-600 text-sm font-semibold tracking-wide uppercase">
        Benefits
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight tracking-tight">
        What you get back
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed">
        TradesQuote pays for itself many times over — here's exactly how.
      </p>
    </div>

    <!-- Benefit cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 w-full">
      {benefits.map((benefit) => (
        <div class="flex flex-col gap-5 rounded-2xl bg-white border border-gray-100 p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">

          <!-- Icon -->
          <div class={`w-10 h-10 rounded-xl border ${benefit.iconBg} ${benefit.iconBorder} ${benefit.iconColor} flex items-center justify-center shrink-0`}>
            <Fragment set:html={benefit.icon} />
          </div>

          <!-- Text -->
          <div class="flex flex-col gap-2">
            <h3 class="text-base font-bold text-gray-900 leading-snug">
              {benefit.title}
            </h3>
            <p class="text-sm text-gray-500 leading-relaxed">
              {benefit.description}
            </p>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>