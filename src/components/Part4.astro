---
const steps = [
  {
    number: "01",
    time: "2 mins",
    title: "Connect GetJobber",
    description:
      "Click one button to securely link your GetJobber account. TradesQuote instantly syncs your data — no technical setup, no configuration. Just authorize and you're ready.",
    image: "/multinudge.gif",
    alt: "TradesQuote dashboard animation",
  },
  {
    number: "02",
    time: "3 mins",
    title: "Create Your First Automation",
    description:
      "Choose a trigger — like a completed job, sent estimate, or overdue invoice. Add conditions if needed, pick a template, and insert real customer data automatically.",
    image: "/create-automation.png",
    alt: "Create automation screen",
  },
  {
    number: "03",
    time: "0 mins ongoing",
    title: "It Runs in the Background",
    description:
      "From that moment on, every time your event fires, the right email goes out automatically. No supervision, no reminders, no ongoing work from you — ever.",
    image: "/dashboard.png",
    alt: "Email automation dashboard",
  },
];
---

<section id="setup" class="w-full py-24 px-6 bg-gray-50">
  <div class="max-w-6xl mx-auto flex flex-col items-center gap-20">

    <!-- Section header -->
    <div class="flex flex-col items-center gap-3 text-center max-w-2xl">
      <span class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-600 text-sm font-semibold tracking-wide uppercase">
        Setup
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight tracking-tight">
        Setup in 5 minutes. Run forever.
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed">
        Three simple steps and your follow-ups are on autopilot.
      </p>
    </div>

    <!-- Steps -->
    <div class="flex flex-col gap-20 w-full">
      {steps.map((step, index) => (
        <div class={`flex flex-col ${index % 2 === 0 ? "lg:flex-row" : "lg:flex-row-reverse"} items-center gap-12 lg:gap-20`}>

          <!-- Text side -->
          <div class="flex flex-col gap-5 w-full max-w-lg">
            <!-- Step number + time badge -->
            <div class="flex items-center gap-3">
              <span class="flex items-center justify-center w-10 h-10 rounded-xl bg-indigo-600 text-white text-sm font-bold shrink-0">
                {step.number}
              </span>
              <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                </svg>
                {step.time}
              </span>
            </div>

            <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 leading-tight">
              {step.title}
            </h3>

            <p class="text-gray-500 text-base leading-relaxed">
              {step.description}
            </p>

            <!-- Connector line (not on last step) -->
            {index < steps.length - 1 && (
              <div class="hidden lg:flex items-center gap-2 mt-2">
                <div class="w-6 h-0.5 bg-indigo-200 rounded-full"></div>
                <span class="text-xs text-indigo-400 font-medium">next step</span>
              </div>
            )}
          </div>

          <!-- Image side -->
          <div class="w-full max-w-lg shrink-0">
            <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-xl shadow-gray-200/60 bg-white">
              <!-- Browser chrome -->
              <div class="flex items-center gap-1.5 px-4 py-3 bg-gray-50 border-b border-gray-100">
                <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
              </div>
              <div class="bg-white">
                <img
                  src={step.image}
                  alt={step.alt}
                  class="w-full object-cover"
                />
              </div>
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>