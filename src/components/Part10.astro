---
const plans = [
  {
    title: "Professional",
    price: "$49",
    period: "/month",
    description: "For growing businesses that need more power and flexibility.",
    badge: "Most Popular",
    features: [
      "Up to 20 active automations",
      "2,000 email sends per month",
      "GetJobber integration",
      "Priority email support",
      "Early access to new features",
    ],
    roi: "Save $38,000/yr · Gain $144,000/yr",
    cta: "Start free trial",
    ctaStyle: "primary",
  }
];
---

<section id="pricing" class="w-full py-24 px-6 bg-gray-50">
  <div class="max-w-6xl mx-auto flex flex-col items-center gap-16">

    <!-- Section header -->
    <div class="flex flex-col items-center gap-3 text-center max-w-2xl">
      <span class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-600 text-sm font-semibold tracking-wide uppercase">
        Pricing
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight tracking-tight">
        Simple, transparent pricing
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed">
        No hidden fees. No surprises. Just pick the plan that fits your business.
      </p>
    </div>

    <!-- Pricing cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full items-stretch justify-center md:justify-items-center">
      <div class="md:col-start-2 md:col-end-3 w-full max-w-md flex justify-center">
      {plans.map((plan) => (
        <div class={`relative flex flex-col rounded-2xl overflow-hidden transition-all duration-200 ${
        plan.badge
          ? "bg-gray-950 border border-indigo-500/40 shadow-2xl shadow-indigo-500/10 scale-[1.02]"
          : "bg-white border border-gray-100 shadow-sm hover:shadow-md"
        }`}>

        <!-- Popular badge -->
        {plan.badge && (
          <div class="absolute top-0 inset-x-0 flex justify-center">
          <span class="inline-flex items-center gap-1.5 px-4 py-1 bg-indigo-600 text-white text-xs font-bold uppercase tracking-wider rounded-b-xl">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            {plan.badge}
          </span>
          </div>
        )}

        <!-- Card body -->
        <div class={`flex flex-col flex-1 p-8 ${plan.badge ? "pt-10" : ""}`}>

          <!-- Plan name + description -->
          <div class="flex flex-col gap-2 mb-8">
          <h3 class={`text-lg font-bold ${plan.badge ? "text-white" : "text-gray-900"}`}>
            {plan.title}
          </h3>
          <p class={`text-sm leading-relaxed ${plan.badge ? "text-gray-400" : "text-gray-500"}`}>
            {plan.description}
          </p>
          </div>

          <!-- Price -->
          <div class="flex items-end gap-1 mb-8">
          <span class={`text-5xl font-extrabold leading-none tracking-tight ${plan.badge ? "text-white" : "text-gray-900"}`}>
            {plan.price}
          </span>
          <span class={`text-base font-medium mb-1 ${plan.badge ? "text-gray-400" : "text-gray-400"}`}>
            {plan.period}
          </span>
          </div>

          <!-- CTA button -->
          <a
          href="https://app.multinudge.com/auth/sign-up"
          class={`w-full inline-flex items-center justify-center gap-2 py-3 px-6 rounded-xl text-sm font-semibold transition-all duration-150 active:scale-[0.98] mb-8 ${
            plan.badge
            ? "bg-indigo-600 text-white hover:bg-indigo-500 shadow-lg shadow-indigo-500/20"
            : "bg-gray-900 text-white hover:bg-gray-800"
          }`}
          >
          {plan.cta}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
          </a>

          <!-- Divider -->
          <div class={`h-px mb-8 ${plan.badge ? "bg-white/10" : "bg-gray-100"}`}></div>

          <!-- Features -->
          <ul class="flex flex-col gap-4 flex-1">
          {plan.features.map((feature) => (
            <li class="flex items-start gap-3">
            <span class={`shrink-0 mt-0.5 w-4 h-4 rounded-full flex items-center justify-center ${plan.badge ? "bg-indigo-500/20" : "bg-indigo-50"}`}>
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke={plan.badge ? "#a5b4fc" : "#4f46e5"} stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            <span class={`text-sm leading-relaxed ${plan.badge ? "text-gray-300" : "text-gray-600"}`}>
              {feature}
            </span>
            </li>
          ))}
          </ul>

          <!-- ROI callout -->
          <div class={`mt-8 rounded-xl px-4 py-3 ${plan.badge ? "bg-indigo-500/10 border border-indigo-500/20" : "bg-emerald-50 border border-emerald-100"}`}>
          <p class={`text-xs font-semibold leading-relaxed ${plan.badge ? "text-indigo-300" : "text-emerald-700"}`}>
            <span class="opacity-70">ROI: </span>{plan.roi}
          </p>
          </div>

        </div>
        </div>
      ))}
      </div>
    </div>

    <!-- Bottom note -->
    <p class="text-sm text-gray-400 text-center">
      All plans include a 14-day free trial. No credit card required.
    </p>

  </div>
</section>