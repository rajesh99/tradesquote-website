---
import type { HvacCalculatorAccent } from "@/config/hvacCalculators";
import { hvacAccentStyles } from "@/config/hvacCalculators";
import type { CalculatorFaq } from "@/lib/calculatorFaq";

interface Props {
  faqs: CalculatorFaq[];
  accent?: HvacCalculatorAccent;
  subtitle: string;
  heading?: string;
}

const { faqs, accent = "blue", subtitle, heading = "Frequently asked questions" } = Astro.props;
const styles = hvacAccentStyles[accent];
---

<section id="faq" class="bg-slate-50 border-y border-slate-200">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-14">
    <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 text-center">{heading}</h2>
    <p class="mt-3 text-center text-slate-600">{subtitle}</p>

    <div class="mt-8 space-y-3">
      {
        faqs.map((faq) => (
          <details class="group rounded-xl border border-slate-200 bg-white p-5">
            <summary class="flex items-center justify-between cursor-pointer font-semibold text-slate-900">
              {faq.question}
              <svg
                class={`h-5 w-5 shrink-0 ${styles.iconColor} transition-transform group-open:rotate-45`}
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
            </summary>
            <p class="mt-3 text-slate-600 text-sm leading-relaxed" set:html={faq.answer} />
          </details>
        ))
      }
    </div>
  </div>
</section>
