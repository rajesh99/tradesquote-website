---
const inputs = [
  {
    label: "Job Description",
    sublabel: "Text",
    description:
      "Describe the job in plain language — \"install split AC in a 3-bedroom apartment\" — and TradesQuote generates a complete line-item estimate instantly.",
    formats: ["Plain text", "Special instructions", "Skill notes"],
    iconBg: "bg-indigo-50",
    iconBorder: "border-indigo-100",
    iconColor: "text-indigo-600",
    badgeBg: "bg-indigo-50",
    badgeText: "text-indigo-700",
    badgeBorder: "border-indigo-100",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    label: "Site Photos",
    sublabel: "Vision AI",
    description:
      "Attach photos taken on site — the switchboard, the HVAC unit, the room layout — and Vision AI analyses them visually to inform and improve the estimate.",
    formats: ["JPG", "PNG", "HEIC", "WebP", "GIF"],
    iconBg: "bg-sky-50",
    iconBorder: "border-sky-100",
    iconColor: "text-sky-600",
    badgeBg: "bg-sky-50",
    badgeText: "text-sky-700",
    badgeBorder: "border-sky-100",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>`,
  },
  {
    label: "Image Links",
    sublabel: "Vision AI",
    description:
      "Paste a URL to any hosted image — a photo from a client's email, a screenshot of a site plan, or a product image — and TradesQuote analyses it directly.",
    formats: ["Hosted image URLs", "Direct image links"],
    iconBg: "bg-cyan-50",
    iconBorder: "border-cyan-100",
    iconColor: "text-cyan-600",
    badgeBg: "bg-cyan-50",
    badgeText: "text-cyan-700",
    badgeBorder: "border-cyan-100",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
  },
  {
    label: "PDF Documents",
    sublabel: "Document AI",
    description:
      "Upload PDF floor plans, job specifications, or scanned quotes from competitors. TradesQuote reads the content and extracts relevant scope information to build the estimate.",
    formats: ["PDF"],
    iconBg: "bg-rose-50",
    iconBorder: "border-rose-100",
    iconColor: "text-rose-600",
    badgeBg: "bg-rose-50",
    badgeText: "text-rose-700",
    badgeBorder: "border-rose-100",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="15" x2="15" y2="15"/><line x1="9" y1="11" x2="15" y2="11"/></svg>`,
  },
  {
    label: "CAD Drawings",
    sublabel: "Auto-converted",
    description:
      "Upload CAD drawing files directly. TradesQuote automatically converts them in the background — no need to pre-process or label rooms and components manually.",
    formats: ["DXF", "DWG", "SVG", "And more via auto-convert"],
    iconBg: "bg-violet-50",
    iconBorder: "border-violet-100",
    iconColor: "text-violet-600",
    badgeBg: "bg-violet-50",
    badgeText: "text-violet-700",
    badgeBorder: "border-violet-100",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`,
  },
  {
    label: "Mixed Inputs",
    sublabel: "Combine anything",
    description:
      "Combine a text job description with photos, a PDF spec, and a CAD drawing in a single estimate request. TradesQuote merges all inputs into one accurate, line-item estimate.",
    formats: ["Any combination of the above"],
    iconBg: "bg-emerald-50",
    iconBorder: "border-emerald-100",
    iconColor: "text-emerald-600",
    badgeBg: "bg-emerald-50",
    badgeText: "text-emerald-700",
    badgeBorder: "border-emerald-100",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  },
];
---

<section
  id="estimator-inputs"
  class="w-full py-24 px-6 bg-white border-t border-gray-100"
  aria-labelledby="estimator-inputs-heading"
>
  <div class="max-w-6xl mx-auto flex flex-col gap-14">

    <!-- Header -->
    <div class="flex flex-col items-center gap-3 text-center max-w-2xl mx-auto">
      <span class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-600 text-sm font-semibold tracking-wide uppercase">
        Estimator Inputs
      </span>
      <h2
        id="estimator-inputs-heading"
        class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight tracking-tight"
      >
        Start with what you have — text, photos, PDFs, or drawings — TradesQuote estimates it
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed">
        Text, photos, PDFs, CAD drawings, or image links — TradesQuote accepts the files contractors
        actually have on hand, and turns them into a complete line-item estimate.
      </p>
    </div>

    <!-- Input cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {inputs.map((item) => (
        <div class="group flex flex-col gap-5 rounded-2xl border border-gray-100 bg-gray-50/60 p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">

          <!-- Icon + sublabel -->
          <div class="flex items-start justify-between gap-3">
            <div class={`w-11 h-11 rounded-xl border ${item.iconBg} ${item.iconBorder} ${item.iconColor} flex items-center justify-center shrink-0`}>
              <Fragment set:html={item.icon} />
            </div>
            <span class={`self-start inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold border ${item.badgeBg} ${item.badgeText} ${item.badgeBorder}`}>
              {item.sublabel}
            </span>
          </div>

          <!-- Label + description -->
          <div class="flex flex-col gap-2 flex-1">
            <h3 class="text-base font-bold text-gray-900 leading-snug">{item.label}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{item.description}</p>
          </div>

          <!-- Supported formats -->
          <div class="flex flex-wrap gap-1.5 pt-1 border-t border-gray-100">
            {item.formats.map((fmt) => (
              <span class="inline-flex items-center px-2.5 py-1 rounded-lg bg-white border border-gray-200 text-xs font-medium text-gray-600">
                {fmt}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Zero hassle callout -->
    <div class="rounded-2xl border border-indigo-100 bg-indigo-50/60 px-6 py-5 flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="shrink-0 w-10 h-10 rounded-xl bg-indigo-100 border border-indigo-200 text-indigo-600 flex items-center justify-center">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
        </svg>
      </div>
      <div class="flex-1">
        <p class="text-sm font-semibold text-indigo-900">No pre-processing needed for CAD files</p>
        <p class="text-sm text-indigo-800/80 mt-0.5 leading-relaxed">
          Upload your drawing file as-is. TradesQuote converts it automatically in the background — no need to specify rooms, label components, or clean up the file beforehand.
        </p>
      </div>
    </div>

  </div>
</section>
