---
const faqItems = [
  {
    id: 1,
    question: "Do I need to leave GetJobber?",
    answer:
      "Absolutely not. TradesQuote works alongside GetJobber. You keep using GetJobber for scheduling, invoicing, and customer management. TradesQuote just watches for events and sends emails automatically.",
    defaultOpen: true,
  },
  {
    id: 2,
    question: "How hard is this to set up?",
    answer:
      "Incredibly easy. Connect your GetJobber account with one click, pick a template, choose your trigger, and you're live. Most users have their first automation running in under 5 minutes.",
    defaultOpen: false,
  },
  {
    id: 3,
    question: "What if I don't know what emails to send?",
    answer:
      "We provide proven templates for every common scenario — thank-you emails, estimate follow-ups, overdue invoice reminders, welcome emails, and more. Just pick one, personalise the message, and activate it.",
    defaultOpen: false,
  },
  {
    id: 4,
    question: "What if I send too many emails?",
    answer:
      "You're in full control. You set the triggers and conditions, so emails only go out when the exact rules you defined are met. You can also add time delays, frequency caps, or turn any automation off at any time.",
    defaultOpen: false,
  },
  {
    id: 5,
    question: "Can I turn automations on and off?",
    answer:
      "Yes — toggle any automation on or off with a single click, any time. You can pause, edit, or delete automations without affecting anything else.",
    defaultOpen: false,
  },
  {
    id: 6,
    question: "Can I cancel anytime?",
    answer:
      "Yes, absolutely. No long-term contracts, no cancellation fees. You can cancel your subscription at any time from your account settings and your card won't be charged again.",
    defaultOpen: false,
  },
];
---

<section id="faq" class="w-full py-24 px-6 bg-white">
  <div class="max-w-3xl mx-auto flex flex-col items-center gap-16">

    <!-- Section header -->
    <div class="flex flex-col items-center gap-3 text-center max-w-2xl">
      <span class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-600 text-sm font-semibold tracking-wide uppercase">
        FAQ
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight tracking-tight">
        Frequently asked questions
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed">
        Everything you need to know about TradesQuote. Can't find the answer? <a href="#contact" class="text-indigo-600 font-medium hover:underline">Chat to our team.</a>
      </p>
    </div>

    <!-- Accordion -->
    <div class="w-full flex flex-col divide-y divide-gray-100">
      {faqItems.map((item) => (
        <div class="faq-item w-full">
          <button
            type="button"
            class="faq-trigger w-full flex items-center justify-between gap-6 py-6 text-left cursor-pointer"
            aria-expanded={item.defaultOpen ? "true" : "false"}
            data-faq-id={item.id}
          >
            <span class={`text-base font-semibold leading-snug ${item.defaultOpen ? "text-indigo-600" : "text-gray-900"} faq-question`}>
              {item.question}
            </span>
            <span class="faq-icon shrink-0 w-8 h-8 rounded-full border border-gray-200 bg-gray-50 flex items-center justify-center transition-transform duration-200">
              {item.defaultOpen ? (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-indigo-600">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              ) : (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400">
                  <line x1="12" y1="5" x2="12" y2="19"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              )}
            </span>
          </button>

          <div
            id={`faq-answer-${item.id}`}
            class="faq-answer overflow-hidden"
            style={item.defaultOpen ? "max-height: 500px; opacity: 1;" : "max-height: 0; opacity: 0;"}
          >
            <p class="text-gray-500 text-base leading-relaxed pb-6 pr-14">
              {item.answer}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  document.querySelectorAll('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      if (!item) return;

      const answerEl = item.querySelector('.faq-answer') as HTMLElement | null;
      const iconEl = item.querySelector('.faq-icon');
      const questionEl = item.querySelector('.faq-question');
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';

      btn.setAttribute('aria-expanded', String(!isExpanded));

      if (answerEl) {
        if (isExpanded) {
          answerEl.style.maxHeight = '0';
          answerEl.style.opacity = '0';
        } else {
          answerEl.style.maxHeight = '500px';
          answerEl.style.opacity = '1';
        }
        answerEl.style.transition = 'max-height 0.3s ease, opacity 0.25s ease';
      }

      if (iconEl) {
        iconEl.innerHTML = isExpanded
          ? `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`
          : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2.5" stroke-linecap="round" class="text-indigo-600"><line x1="5" y1="12" x2="19" y2="12"/></svg>`;
      }

      if (questionEl) {
        if (isExpanded) {
          questionEl.classList.remove('text-indigo-600');
          questionEl.classList.add('text-gray-900');
        } else {
          questionEl.classList.remove('text-gray-900');
          questionEl.classList.add('text-indigo-600');
        }
      }
    });
  });
</script>