---
const productLinks = [
  { label: "Home", href: "/#home" },
  { label: "Pricing", href: "/#pricing" },
];

const legalLinks = [
  { label: "FAQ", href: "/#faq" },
  { label: "Contact us", href: "/contact" },
  { label: "Privacy Policy", href: "/privacy-policy" },
  { label: "Terms of Service", href: "/terms-of-service" },
];

const contactItems = [
  {
    type: "email",
    text: "sales@veersoftsolutions.com",
    href: "mailto:sales@veersoftsolutions.com",
  },
  {
    type: "phone",
    text: "+91 9611101279",
    href: "tel:+919611101279",
  },
  {
    type: "address",
    lines: [
      "4/g1, ganga chelston, Marathahalli",
      "Bengaluru - 560037, India"
    ],
    href: null,
  },
];


interface SocialLink {
  label: string;
  href: string;
  icon: string;
}
const socialLinks: SocialLink[] = [
  // { label: "X (Twitter)", href: "#", icon: "x" },
  // { label: "LinkedIn", href: "#", icon: "linkedin" },
  // { label: "Facebook", href: "#", icon: "facebook" },
  // { label: "GitHub", href: "#", icon: "github" },
];
---

<footer
  class="part13 flex flex-col items-center w-full bg-[#f7f7fb]"
  role="contentinfo"
>
  <!-- Upper section: four columns -->
  <div
    class="w-full max-w-[1216px] px-6 sm:px-8 lg:px-12 pt-12 sm:pt-16 pb-12 sm:pb-16"
  >
    <div
      class="flex flex-col justify-between sm:flex-row flex-wrap items-start gap-10 sm:gap-12 lg:gap-16"
    >
      <!-- Company: logo + description -->
      <div class="flex flex-col gap-6 min-w-0 max-w-[280px]">
        <a href="#home" class="inline-flex items-center shrink-0" aria-label="Multi Nudge home">
          <img
            src="/logo.svg"
            alt="Multi Nudge"
            width="199"
            height="42"
            class="h-8 sm:h-[42px] w-auto"
          />
        </a>
        <p
          class="text-[#4b5563] font-normal text-base leading-6 tracking-normal"
        >
          TradesQuote uses artificial intelligence to generate accurate, professional project estimates in seconds.
        </p>
      </div>

      <!-- Product links -->
      <nav
        class="flex flex-col gap-5 min-w-[122px]"
        aria-label="Product navigation"
      >
        <h3
          class="font-semibold text-[#1f2937] text-xl leading-5 tracking-normal"
        >
          Product
        </h3>
        <ul class="flex flex-col gap-4 list-none p-0 m-0">
          {productLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-[#4b5563] font-medium text-base leading-6 no-underline hover:text-[#4b44d4] transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Legal links -->
      <nav
        class="flex flex-col gap-5 min-w-[108px]"
        aria-label="Legal navigation"
      >
        <h3
          class="font-semibold text-[#1f2937] text-xl leading-5 tracking-normal"
        >
          Legal
        </h3>
        <ul class="flex flex-col gap-4 list-none p-0 m-0">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-[#4b5563] font-medium text-base leading-6 no-underline hover:text-[#4b44d4] transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact us -->
      <div class="flex flex-col gap-5 min-w-0 max-w-[260px]">
        <h3
          class="font-semibold text-[#1f2937] text-xl leading-5 tracking-normal"
        >
          Contact us
        </h3>
        <div class="flex flex-col gap-4 not-italic">
          {contactItems.map((item) => (
            <div class="flex items-start gap-2">
              <span class="shrink-0 w-4 h-4 mt-0.5 text-[#4b5563]" aria-hidden="true">
                {item.type === "email" && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2" />
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                  </svg>
                )}
                {item.type === "phone" && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                  </svg>
                )}
                {item.type === "address" && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                )}
              </span>
              {item.href ? (
                <a
                  href={item.href}
                  class="text-[#4b5563] font-medium text-base leading-[22px] no-underline hover:text-[#4b44d4] transition-colors wrap-break-word"
                >
                  {item.text}
                </a>
              ) : item.lines ? (
                <p class="text-[#4b5563] font-medium text-base leading-[22px] m-0 wrap-break-word">
                  {item.lines[0]}
                  <br />
                  {item.lines[1]}
                </p>
              ) : null}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Lower section: copyright + social -->
  <div
    class="w-full max-w-[1216px] px-6 sm:px-8 lg:px-12 py-8 sm:py-10 border-t border-[#e5e7eb]"
  >
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-6"
    >
      <p
        class="text-[#374151] font-normal text-base leading-6 tracking-normal order-2 sm:order-1"
      >
        &copy; {new Date().getFullYear()} TradesQuote. All rights reserved.
      </p>
      <nav
        class="flex items-center gap-8 order-1 sm:order-2"
        aria-label="Social media links"
      >
        {socialLinks.map((social) => (
          <a
            href={social.href}
            aria-label={social.label}
            class="text-[#4b5563] hover:text-[#4b44d4] transition-colors p-1"
          >
            {social.icon === "x" && (
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            )}
            {social.icon === "linkedin" && (
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            )}
            {social.icon === "facebook" && (
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
            )}
            {social.icon === "github" && (
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
              </svg>
            )}
          </a>
        ))}
      </nav>
    </div>
  </div>
</footer>
