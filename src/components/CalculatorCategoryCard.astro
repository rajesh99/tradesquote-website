---
import type { CalculatorCategory } from "@/config/calculatorCategories";
import { accentStyles } from "@/config/calculatorCategories";

interface Props {
  category: CalculatorCategory;
}

const { category } = Astro.props;
const styles = accentStyles[category.accent];
const isLive = category.status === "live";
---

{
  isLive ? (
    <a
      href={`/calculators/${category.slug}`}
      class={`group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm ${styles.hoverBorder} hover:shadow-md transition`}
    >
      <div class="flex items-center gap-3">
        <span
          class={`flex h-11 w-11 shrink-0 items-center justify-center rounded-xl ${styles.iconBg} ${styles.iconColor}`}
          set:html={category.icon}
        />
        <div class="min-w-0">
          <h2 class={`text-lg font-bold text-slate-900 ${styles.hoverTitle} transition`}>
            {category.name}
          </h2>
          {category.toolCount && (
            <span class="mt-0.5 inline-block text-xs font-semibold text-slate-500">
              {category.toolCount} calculators
            </span>
          )}
        </div>
      </div>
      <p class="mt-3 text-sm text-slate-600 leading-relaxed">{category.description}</p>
      <span
        class={`mt-auto pt-4 inline-flex items-center gap-1 text-sm font-semibold ${styles.ctaColor}`}
      >
        Browse calculators
        <svg
          class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17 8l4 4m0 0l-4 4m4-4H3"
          />
        </svg>
      </span>
    </a>
  ) : (
    <div class="flex flex-col rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6">
      <div class="flex items-center gap-3">
        <span
          class={`flex h-11 w-11 shrink-0 items-center justify-center rounded-xl ${styles.iconBg} ${styles.iconColor} opacity-70`}
          set:html={category.icon}
        />
        <div class="min-w-0">
          <h2 class="text-lg font-bold text-slate-700">{category.name}</h2>
          <span class="mt-0.5 inline-block rounded-full bg-slate-200 px-2 py-0.5 text-xs font-semibold text-slate-600">
            Coming soon
          </span>
        </div>
      </div>
      <p class="mt-3 text-sm text-slate-600 leading-relaxed">{category.description}</p>
      <p class="mt-auto pt-4 text-xs text-slate-500">Planned for a future release</p>
    </div>
  )
}
