---
---

<!-- Still have questions? -->
<section id="contact" class="w-full py-24 px-6 bg-gray-50">
  <div class="max-w-2xl mx-auto flex flex-col items-center gap-8 text-center">

    <!-- Avatar stack -->
    <div class="flex items-center justify-center -space-x-3">
      <div class="w-10 h-10 rounded-full bg-indigo-100 border-2 border-white flex items-center justify-center text-indigo-600 font-bold text-sm z-30">A</div>
      <div class="w-12 h-12 rounded-full bg-violet-100 border-2 border-white flex items-center justify-center text-violet-600 font-bold text-base z-20">S</div>
      <div class="w-10 h-10 rounded-full bg-blue-100 border-2 border-white flex items-center justify-center text-blue-600 font-bold text-sm z-10">M</div>
    </div>

    <!-- Copy -->
    <div class="flex flex-col gap-3">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 leading-tight tracking-tight">
        Still have questions?
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed">
        Can't find the answer you're looking for? Our friendly team is happy to help.
      </p>
    </div>

    <!-- CTA -->
    <a
      href="mailto:sales@veersoftsolutions.com"
      class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-gray-900 text-white text-sm font-semibold rounded-xl hover:bg-gray-800 active:scale-[0.98] transition-all duration-150"
    >
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22,6 12,13 2,6"/>
      </svg>
      Get in touch
    </a>

  </div>
</section>

<!-- Final CTA banner -->
<section class="w-full py-24 px-6 bg-gray-950 relative overflow-hidden">

  <!-- Background glow -->
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_60%_at_50%_50%,rgba(99,102,241,0.15),transparent)] -z-10"></div>

  <div class="max-w-3xl mx-auto flex flex-col items-center gap-8 text-center">

    <!-- Badge -->
    <span class="inline-flex items-center px-3 py-1 rounded-full bg-white/10 text-white/60 text-sm font-semibold tracking-wide uppercase border border-white/10">
      Get started today
    </span>

    <!-- Headline -->
    <div class="flex flex-col gap-4">
      <h2 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight tracking-tight">
        Everything you need to estimate with confidence
      </h2>
      <p class="text-gray-400 text-lg leading-relaxed max-w-xl mx-auto">
        TradesQuote brings together AI, your knowledge base, and automated quality control — so every estimate is accurate and professional.
      </p>
    </div>

    <!-- CTAs -->
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="https://tradesquote.ai/auth/sign-up"
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-indigo-600 text-white text-base font-semibold rounded-xl hover:bg-indigo-500 active:scale-[0.98] transition-all duration-150 shadow-lg shadow-indigo-500/25"
      >
        Start free trial
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a
        href="#pricing"
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-white/5 text-white text-base font-semibold rounded-xl border border-white/10 hover:bg-white/10 active:scale-[0.98] transition-all duration-150"
      >
        View pricing
      </a>
    </div>

    <!-- Trust note -->
    <p class="text-gray-600 text-sm font-medium">
      No credit card required &middot; 14-day free trial &middot; Cancel anytime
    </p>

  </div>
</section>