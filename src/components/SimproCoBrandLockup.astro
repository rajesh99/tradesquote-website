---
/**
 * Partnership lockup per Simpro External Brand Manual (Logo lockup — partnerships):
 * logo mark without tagline; minimum 0.5pt blue stroke between partner marks.
 */
---

<div
  class="flex flex-col sm:flex-row flex-wrap items-center justify-center gap-4 sm:gap-10 rounded-2xl border border-[#abacaa]/60 bg-[#ececec] px-6 py-5 sm:px-10 sm:py-6"
>
  <a href="/" class="inline-flex shrink-0 items-center self-center py-1" aria-label="TradesQuote home">
    <img
      src="/logo.svg"
      alt="TradesQuote"
      width="200"
      height="44"
      class="h-8 sm:h-10 w-auto max-w-[200px] object-contain object-left"
      loading="eager"
    />
  </a>

  <div
    class="sm:hidden h-px w-16 shrink-0 bg-[#002f87]"
    style="min-height: 0.5px"
    aria-hidden="true"
  >
  </div>
  <div
    class="hidden sm:block h-10 sm:h-12 w-px shrink-0 bg-[#002f87]"
    style="min-width: 0.5px"
    aria-hidden="true"
  >
  </div>

  <div class="flex shrink-0 items-center justify-center py-1">
    <img
      src="/brands/simpro/simpro-logo-fullcolor.png"
      alt="Simpro"
      width="280"
      height="84"
      class="h-9 sm:h-11 w-auto max-w-[min(280px,100%)] object-contain"
      loading="eager"
    />
  </div>
</div>
