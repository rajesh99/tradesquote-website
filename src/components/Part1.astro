---
const rotatingTexts = [
  "Manual Follow-ups",
  "Missed Follow-ups",
  "Poor Follow-through",
];
---

<section
  id="home"
  class="relative w-full flex flex-col items-center text-center px-6 pt-24 pb-20 overflow-hidden"
>
  <!-- Subtle radial gradient bg -->
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-10%,rgba(99,102,241,0.08),transparent)] -z-10"></div>

  <!-- Badge -->
  <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-indigo-100 bg-indigo-50 text-indigo-600 text-sm font-medium mb-8">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
    </svg>
    Smart Email Automation for GetJobber Field Service Businesses
  </div>

  <!-- Headline -->
  <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-gray-900 leading-[1.1] tracking-tight max-w-4xl">
    Stop Losing Money On
    <span class="relative block overflow-hidden h-[1.2em] mt-1">
      <span
        id="rotating-wrapper"
        class="flex flex-col transition-transform duration-500 ease-in-out"
        style="will-change: transform;"
      >
        {rotatingTexts.map((text) => (
          <span class="block bg-gradient-to-r from-indigo-600 to-violet-500 bg-clip-text text-transparent leading-[1.2em]">
            {text}
          </span>
        ))}
      </span>
    </span>
  </h1>

  <!-- Subtext -->
  <p class="mt-8 max-w-xl text-lg text-gray-500 leading-relaxed">
    MultiNudge automatically sends follow-ups, reminders, and review requests
    based on real business activity — so you get paid faster and never miss a lead.
  </p>

  <!-- CTAs -->
  <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
    <a
      href="https://app.multinudge.com/auth/sign-up"
      class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-indigo-600 text-white text-base font-semibold rounded-xl hover:bg-indigo-700 active:scale-[0.98] transition-all duration-150 shadow-lg shadow-indigo-500/20"
    >
      Start free trial
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </a>
    <a
      href="#setup"
      class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-gray-700 text-base font-semibold rounded-xl border border-gray-200 hover:bg-gray-50 active:scale-[0.98] transition-all duration-150"
    >
      See how it works
    </a>
  </div>

  <!-- Social proof -->
  <p class="mt-6 text-sm text-gray-400 font-medium">
    No credit card required · Setup in 5 minutes
  </p>

  <!-- Hero image card -->
  <div class="mt-16 w-full max-w-4xl rounded-2xl overflow-hidden border border-gray-200 shadow-2xl shadow-gray-200/60">
    <!-- Fake browser chrome -->
    <div class="flex items-center gap-1.5 px-4 py-3 bg-gray-50 border-b border-gray-200">
      <span class="w-3 h-3 rounded-full bg-red-400"></span>
      <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
      <span class="w-3 h-3 rounded-full bg-green-400"></span>
      <span class="mx-auto flex items-center gap-2 px-4 py-1 bg-white rounded-md border border-gray-200 text-xs text-gray-400 font-mono w-56">
        app.multinudge.com
      </span>
    </div>
    <div class="bg-white">
      <img
        src="/multinudge.gif"
        alt="MultiNudge dashboard showing automated email workflows"
        class="w-full object-cover"
      />
    </div>
  </div>
</section>

<script>
  const wrapper = document.getElementById('rotating-wrapper');
  if (wrapper) {
    const lines = wrapper.querySelectorAll('span');
    const total = lines.length;
    let index = 0;
    const lineHeight = wrapper.parentElement?.clientHeight ?? 84;

    setInterval(() => {
      index = (index + 1) % total;
      (wrapper as HTMLElement).style.transform = `translateY(-${index * lineHeight}px)`;
    }, 3000);
  }
</script>